@using Microsoft.AspNetCore.Identity
@inject UserManager<NipponQuest.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = "KanaBlitz Arena";
    var currentUser = await UserManager.GetUserAsync(User);
}

<style>
    /* BASE */
    .reveal-up { opacity: 0; transform: translateY(30px); transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
    .reveal-up.active { opacity: 1; transform: translateY(0); }

    /* HERO META */
    .hero-meta {
        display: inline-flex; align-items: center; gap: 18px;
        flex-wrap: wrap; justify-content: center;
        font-size: 0.78rem; font-weight: 800; color: #64748b;
        letter-spacing: 0.5px; text-transform: uppercase;
    }
    .hero-meta .meta-chip { display: inline-flex; align-items: center; gap: 6px; }
    .hero-meta .meta-chip i { color: #f59e0b; font-size: 0.95rem; }
    .hero-meta .meta-dot { color: #cbd5e1; font-weight: 900; }

    /* STEP PROGRESS */
    .step-progress { display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 1.75rem; flex-wrap: wrap; }
    .step-pill {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 8px 16px; border-radius: 50px;
        background: #f1f5f9; color: #94a3b8;
        font-weight: 900; font-size: 0.72rem; letter-spacing: 1.5px; text-transform: uppercase;
        transition: all 250ms ease; border: 2px solid transparent;
    }
    .step-pill .step-icon {
        width: 18px; height: 18px; border-radius: 50%;
        background: #cbd5e1; color: #fff;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 0.65rem; transition: all 250ms ease;
    }
    .step-pill.active { background: #eff6ff; color: #1d4ed8; border-color: #bfdbfe; }
    .step-pill.active .step-icon { background: #3b82f6; }
    .step-pill.done { background: #f0fdf4; color: #15803d; border-color: #bbf7d0; }
    .step-pill.done .step-icon { background: #22c55e; }
    .step-connector { width: 32px; height: 2px; background: #e2e8f0; border-radius: 2px; transition: all 250ms ease; }
    .step-connector.done { background: #22c55e; }

    /* LOBBY CARDS */
    .setup-card {
        background: #ffffff;
        border: 2px solid #f1f5f9;
        border-radius: 24px;
        transition: transform 250ms ease, box-shadow 250ms ease, border-color 250ms ease, background 250ms ease;
        cursor: pointer;
        height: 100%;
        display: flex; flex-direction: column;
        justify-content: center; align-items: center;
        position: relative; overflow: hidden;
    }
    .setup-card:hover { transform: translateY(-4px); box-shadow: 0 14px 30px rgba(0,0,0,0.08); border-color: #e2e8f0; }
    .setup-card.selected { border-width: 3px; transform: translateY(-4px) scale(1.03); box-shadow: 0 0 0 5px rgba(14, 165, 233, 0.1), 0 16px 32px rgba(14, 165, 233, 0.12); }

    .alpha-select[data-alpha="hiragana"].selected { border-color: #0ea5e9; background: #f0f9ff; }
    .alpha-select[data-alpha="katakana"].selected { border-color: #ef4444; background: #fef2f2; }
    .alpha-select[data-alpha="mixed"].selected    { border-color: #f59e0b; background: #fffbeb; }
    .alpha-select[data-alpha="dakuten"].selected  { border-color: #8b5cf6; background: #f5f3ff; }

    .diff-select[data-diff="easy"]     { background: #f8fdfa; }
    .diff-select[data-diff="normal"]   { background: #ffffff; }
    .diff-select[data-diff="hard"]     { background: #fbfaff; }
    .diff-select[data-diff="insanity"] { background: #fffafa; }

    .diff-select[data-diff="easy"].selected     { border-color: #22c55e; background: #f0fdf4; }
    .diff-select[data-diff="normal"].selected   { border-color: #3b82f6; background: #eff6ff; }
    .diff-select[data-diff="hard"].selected     { border-color: #a855f7; background: #faf5ff; box-shadow: 0 0 0 5px rgba(168, 85, 247, 0.12), 0 0 30px rgba(168, 85, 247, 0.25); }
    .diff-select[data-diff="insanity"].selected { border-color: #ef4444; background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%); box-shadow: 0 0 0 5px rgba(239, 68, 68, 0.12), 0 0 30px rgba(239, 68, 68, 0.3); }

    @@keyframes insanity-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.15); }
        50%      { box-shadow: 0 0 0 8px rgba(239, 68, 68, 0); }
    }
    .diff-select[data-diff="insanity"]:not(.selected):not(.locked) { animation: insanity-pulse 2.5s ease-in-out infinite; }
    .diff-select[data-diff="hard"]:not(.selected):not(.locked):hover { box-shadow: 0 14px 30px rgba(168, 85, 247, 0.18); }

    /* LOCKED STATE */
    .setup-card.locked {
        cursor: not-allowed;
        background: #f8fafc;
        border-color: #e2e8f0;
        opacity: 0.92;
    }
    .setup-card.locked:hover { transform: none; box-shadow: none; border-color: #e2e8f0; }
    .setup-card.locked .alpha-label,
    .setup-card.locked .diff-icon-wrap i,
    .setup-card.locked .time-row,
    .setup-card.locked .reward-mult-row { opacity: 0.45; filter: grayscale(0.6); }
    .lock-overlay {
        position: absolute; top: 10px; right: 10px;
        width: 32px; height: 32px; border-radius: 50%;
        background: #0f172a; color: #fde68a;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 0.95rem; box-shadow: 0 4px 10px rgba(15, 23, 42, 0.25);
        z-index: 2;
    }
    .lock-req {
        position: absolute; bottom: 10px; left: 10px; right: 10px;
        font-size: 0.6rem; font-weight: 900; letter-spacing: 1px;
        text-transform: uppercase; color: #64748b;
        background: #ffffff; border: 1px solid #e2e8f0;
        padding: 4px 8px; border-radius: 8px;
        text-align: center; line-height: 1.3;
    }

    .even-row { display: flex; flex-wrap: wrap; }
    .even-row > [class*="col-"] { display: flex; }

    /* HUD */
    .hud-panel { background: #0f172a; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 20px 40px rgba(0,0,0,0.2); }
    .heart-icon { color: #ef4444; filter: drop-shadow(0 0 5px rgba(239, 68, 68, 0.4)); transition: all 0.3s ease; }
    .heart-lost { color: #334155; filter: none; transform: scale(0.8); opacity: 0.5; }

    /* ARENA */
    .arena-card { background: #ffffff; border-radius: 32px; border: 1px solid #e2e8f0; box-shadow: 0 25px 60px -12px rgba(0,0,0,0.08); }
    .combo-badge {
        background: #fffbeb; color: #b45309; border: 1px solid #fde68a;
        font-weight: 900; padding: 6px 15px; border-radius: 50px; font-size: 0.8rem;
        opacity: 0; transform: scale(0.8); transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .combo-badge.active { opacity: 1; transform: scale(1); }
    .blitz-option-btn {
        border-radius: 18px; padding: 20px;
        font-weight: 900; font-size: 1.4rem;
        border: 2px solid #f1f5f9; background: #ffffff; transition: all 0.2s;
    }
    .blitz-option-btn:hover:not(:disabled) { border-color: #0ea5e9; color: #0ea5e9; background: #f0f9ff; transform: translateY(-3px); }

    .step-label { display: inline-block; background: #0f172a; color: #fff; font-size: 0.7rem; font-weight: 900; padding: 6px 14px; border-radius: 10px; letter-spacing: 1.5px; margin-right: 10px; vertical-align: middle; }

    .perfect-flag { background: #fef3c7; color: #b45309; border: 1px solid #fde68a; font-weight: 900; font-size: 0.75rem; padding: 6px 14px; border-radius: 50px; letter-spacing: 1px; }

    .missing-placeholder { display: inline-block; color: transparent; border-bottom: 2px solid #ef4444; padding: 0 4px; margin: 0 2px; font-weight: 900; user-select: none; line-height: 1.1; }

    .kanji-stack { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.4rem; line-height: 1; }
    .kanji-stack .kanji-top { font-size: 5rem; font-weight: 900; color: #0f172a; letter-spacing: -2px; line-height: 1; }
    .kanji-stack .kana-bottom { font-size: 2.4rem; font-weight: 700; color: #475569; letter-spacing: 0; line-height: 1.1; }
    .kanji-stack .kana-bottom .missing-placeholder { font-size: 2.4rem; }

    /* HEADER + INFO BUBBLE */
    .blitz-header-row { display: inline-flex; align-items: center; gap: 1rem; flex-wrap: wrap; justify-content: center; }
    .blitz-info-btn { width: 44px; height: 44px; border-radius: 50%; background: #ffffff; border: 2px solid #e2e8f0; color: #64748b; display: flex; align-items: center; justify-content: center; transition: all 0.2s; flex-shrink: 0; }
    .blitz-info-btn:hover { border-color: #0ea5e9; color: #0ea5e9; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(14, 165, 233, 0.15); }

    .back-to-lobby { background: #ffffff; border: 2px solid #e2e8f0; color: #475569; font-weight: 800; font-size: 0.75rem; letter-spacing: 1px; padding: 8px 16px; border-radius: 50px; transition: all 0.2s; }
    .back-to-lobby:hover { border-color: #ef4444; color: #ef4444; background: #fef2f2; }

    /* LOBBY CARD SIZES */
    .lobby-card-lg { min-height: 200px; height: 200px; padding: 1.5rem 1rem !important; width: 100%; }
    .lobby-card-lg .alpha-kana-display { font-size: 3.4rem; line-height: 1; height: 70px; display: flex; align-items: center; justify-content: center; margin-bottom: 0.6rem; font-weight: 900; white-space: nowrap; }
    .lobby-card-lg .alpha-label { font-size: 0.95rem; font-weight: 900; letter-spacing: 1px; margin-bottom: 0; text-align: center; }
    .lobby-card-lg .alpha-sublabel { font-size: 0.72rem; font-weight: 700; opacity: 0.5; margin-top: 6px; text-align: center; }

    .script-hint { display: inline-block; margin-top: 8px; padding: 3px 10px; font-size: 0.62rem; font-weight: 900; letter-spacing: 1px; text-transform: uppercase; border-radius: 50px; background: #f1f5f9; color: #64748b; }
    .script-hint.beginner { background: #f0fdf4; color: #15803d; }
    .script-hint.intermediate { background: #eff6ff; color: #1d4ed8; }
    .script-hint.advanced { background: #fef2f2; color: #b91c1c; }

    .lobby-card-xl { min-height: 240px; height: 240px; padding: 1.25rem 1rem !important; width: 100%; }
    .lobby-card-xl .diff-icon-wrap { height: 60px; display: flex; align-items: center; justify-content: center; margin-bottom: 0.4rem; }
    .lobby-card-xl .diff-icon-wrap i { font-size: 2.4rem; line-height: 1; }
    .lobby-card-xl .alpha-label { font-size: 0.95rem; font-weight: 900; letter-spacing: 1px; margin-bottom: 0; text-align: center; }

    .time-row { display: flex; align-items: center; justify-content: center; gap: 6px; margin-top: 6px; font-size: 0.72rem; font-weight: 800; color: #64748b; letter-spacing: 0.5px; }
    .time-row .time-bullet { color: #cbd5e1; font-weight: 900; }

    .reward-mult-row { display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 8px; font-weight: 900; font-size: 0.85rem; color: #0f172a; letter-spacing: 0; }
    .reward-mult-row .mini-xp { width: 26px; height: 26px; border-radius: 7px; background: #38bdf8; color: #ffffff; display: inline-flex; align-items: center; justify-content: center; font-size: 0.62rem; font-weight: 900; box-shadow: 0 2px 0 #0284c7; letter-spacing: 0; }
    .reward-mult-row .mini-gold { width: 26px; height: 26px; border-radius: 50%; background: #fbbf24; border: 2px solid #d97706; color: #92400e; display: inline-flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 900; box-shadow: 0 2px 0 #b45309; letter-spacing: 0; }
    .reward-mult-row .reward-amt { font-weight: 900; color: #0f172a; font-size: 0.9rem; }
    .reward-mult-row .reward-sep { color: #cbd5e1; font-weight: 900; }

    .estimate-note { font-size: 0.7rem; font-weight: 800; color: #94a3b8; letter-spacing: 0.5px; text-align: center; margin: 0 0 1rem 0; }
    .estimate-note i { color: #f59e0b; margin-right: 4px; }

    /* CTA */
    .btn-blitz-cta { position: relative; overflow: hidden; background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%); border: none; color: #ffffff; transition: all 250ms ease; background-size: 200% 200%; background-position: 0% 50%; }
    .btn-blitz-cta:hover:not(:disabled) { background-position: 100% 50%; transform: translateY(-2px); box-shadow: 0 14px 30px rgba(37, 99, 235, 0.35); color: #ffffff; }
    .btn-blitz-cta:disabled { background: #e2e8f0; color: #94a3b8; cursor: not-allowed; opacity: 1; }
    .btn-blitz-cta .cta-arrow { display: inline-block; transition: transform 250ms ease; margin-left: 6px; }
    .btn-blitz-cta:hover:not(:disabled) .cta-arrow { transform: translateX(6px); }

    /* INFO MODAL PILLARS */
    .info-pillar { border: 1px solid #e2e8f0; border-radius: 16px; padding: 16px; height: 100%; background: #ffffff; transition: all 0.2s; }
    .info-pillar:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.05); }
    .info-pillar .info-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 10px; }
    .info-divider { height: 1px; background: #e2e8f0; margin: 18px 0; }
    .info-row-list { list-style: none; padding-left: 0; margin: 0; }
    .info-row-list li { display: flex; align-items: flex-start; gap: 10px; padding: 8px 0; font-size: 0.85rem; color: #475569; font-weight: 600; }
    .info-row-list li i { color: #f59e0b; font-size: 1rem; flex-shrink: 0; margin-top: 2px; }

    /* EXIT MODAL */
    .exit-confirm-icon { width: 80px; height: 80px; border-radius: 50%; background: #fef2f2; color: #ef4444; display: flex; align-items: center; justify-content: center; font-size: 2.4rem; margin: 0 auto; }

    /* LOCK MODAL */
    .lock-modal-icon { width: 80px; height: 80px; border-radius: 50%; background: #fef3c7; color: #b45309; display: flex; align-items: center; justify-content: center; font-size: 2.2rem; margin: 0 auto; }
    .lock-req-list { list-style: none; padding: 0; margin: 0; text-align: left; }
    .lock-req-list li { display: flex; align-items: center; gap: 10px; padding: 10px 14px; margin-bottom: 8px; border-radius: 12px; background: #f8fafc; border: 1px solid #e2e8f0; font-size: 0.85rem; font-weight: 700; color: #475569; }
    .lock-req-list li.met { background: #f0fdf4; border-color: #bbf7d0; color: #15803d; }
    .lock-req-list li .req-icon { width: 22px; height: 22px; border-radius: 50%; background: #cbd5e1; color: #fff; display: inline-flex; align-items: center; justify-content: center; font-size: 0.7rem; flex-shrink: 0; }
    .lock-req-list li.met .req-icon { background: #22c55e; }
    .lock-req-list li .req-progress { margin-left: auto; font-weight: 900; font-size: 0.78rem; color: #64748b; letter-spacing: 0.5px; }
    .lock-req-list li.met .req-progress { color: #15803d; }

    /* RESULTS PAGE — balanced */
    .results-hero {
        max-width: 640px;
        margin: 0 auto 2rem auto;
    }
    .results-status-icon {
        width: 96px; height: 96px;
        border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 2.6rem; margin-bottom: 1rem;
    }
    .results-status-icon.win  { background: #ecfdf5; color: #16a34a; box-shadow: 0 8px 24px rgba(34, 197, 94, 0.18); }
    .results-status-icon.loss { background: #fef2f2; color: #ef4444; box-shadow: 0 8px 24px rgba(239, 68, 68, 0.18); }
    .results-status-icon.time { background: #fff7ed; color: #f59e0b; box-shadow: 0 8px 24px rgba(245, 158, 11, 0.18); }

    .results-title { font-size: clamp(1.8rem, 3.5vw, 2.4rem); font-weight: 900; letter-spacing: -1px; color: #0f172a; margin-bottom: 0.5rem; }
    .results-subtitle { font-size: 0.95rem; font-weight: 700; color: #64748b; }

    .results-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        max-width: 640px;
        margin: 0 auto 1.75rem auto;
    }
    @@media (max-width: 540px) { .results-grid { grid-template-columns: repeat(3, 1fr); gap: 8px; } }
    .result-stat-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 18px 12px;
        text-align: center;
        transition: all 250ms ease;
    }
    .result-stat-card .stat-key {
        font-size: 0.62rem; font-weight: 900;
        letter-spacing: 1.5px; color: #94a3b8;
        text-transform: uppercase; margin-bottom: 6px;
    }
    .result-stat-card .stat-val {
        font-size: 1.6rem; font-weight: 900;
        color: #0f172a; line-height: 1;
    }
    .result-stat-card .stat-val .stat-suffix { font-size: 0.85rem; color: #64748b; margin-left: 2px; }

    .results-rewards-card {
        max-width: 640px; margin: 0 auto 1.75rem auto;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        padding: 1.75rem 1.5rem;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
    }
    .results-rewards-title {
        font-size: 0.7rem; font-weight: 900;
        letter-spacing: 2px; color: #0f172a;
        text-transform: uppercase;
        text-align: center; margin-bottom: 1.25rem;
    }
    .results-rewards-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
    }
    .reward-tile {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 1.25rem 1rem;
        text-align: center;
    }
    .reward-tile .reward-icon-wrap {
        width: 48px; height: 48px;
        margin: 0 auto 8px auto;
        display: flex; align-items: center; justify-content: center;
    }
    .reward-tile .reward-icon-xp {
        width: 48px; height: 48px; border-radius: 12px;
        background: #38bdf8; color: #ffffff;
        font-weight: 900; font-size: 1.1rem; letter-spacing: 0;
        display: inline-flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 0 #0284c7;
    }
    .reward-tile .reward-icon-gold {
        width: 48px; height: 48px; border-radius: 50%;
        background: #fbbf24; border: 3px solid #d97706; color: #92400e;
        font-weight: 900; font-size: 1.3rem;
        display: inline-flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 0 #b45309;
    }
    .reward-tile .reward-amount {
        font-size: 1.8rem; font-weight: 900;
        color: #0f172a; line-height: 1;
    }
    .reward-tile .reward-label {
        font-size: 0.62rem; font-weight: 900;
        letter-spacing: 1.5px; color: #94a3b8;
        text-transform: uppercase; margin-top: 6px;
    }

    .results-cta-row {
        display: flex; gap: 12px; flex-wrap: wrap;
        justify-content: center; max-width: 640px; margin: 0 auto;
    }
    .results-cta-row .btn { min-width: 180px; }
</style>

<div class="container py-5">
    <div id="ui-lobby">

        <div class="text-center mb-4 reveal-up">
            <div class="mb-3">
                <span class="badge rounded-pill bg-warning bg-opacity-10 text-warning border border-warning-subtle px-3 py-2 fw-black shadow-sm" style="letter-spacing: 1px;">
                    <i class="bi bi-lightning-charge-fill me-1"></i> HIGH INTENSITY TRAINING
                </span>
            </div>

            <div class="blitz-header-row">
                <h1 class="display-3 fw-black text-dark m-0" style="letter-spacing: -3px;">
                    Kana<span class="text-warning">Blitz</span>
                </h1>
                <button type="button" class="blitz-info-btn shadow-sm"
                        data-bs-toggle="modal" data-bs-target="#blitzGuideModal"
                        title="How KanaBlitz works">
                    <i class="bi bi-info-lg fs-5 fw-black"></i>
                </button>
            </div>

            <p class="lead fw-bold text-muted mx-auto mt-3 mb-3" style="max-width: 560px;">
                Lock in kana fluency through rapid pattern recognition.
            </p>

            <div class="hero-meta">
                <span class="meta-chip"><i class="bi bi-lightning-charge-fill"></i> Avg session: 1&ndash;2 mins</span>
                <span class="meta-dot">&bull;</span>
                <span class="meta-chip"><i class="bi bi-bullseye"></i> Build streaks</span>
                <span class="meta-dot">&bull;</span>
                <span class="meta-chip"><i class="bi bi-lightbulb-fill"></i> Train recall speed</span>
            </div>
        </div>

        <div class="row justify-content-center reveal-up">
            <div class="col-lg-10">
                <div class="step-progress" id="step-progress">
                    <span class="step-pill active" id="step-pill-script">
                        <span class="step-icon"><i class="bi bi-1-circle-fill"></i></span>
                        <span>Script</span>
                    </span>
                    <span class="step-connector" id="step-conn-1"></span>
                    <span class="step-pill" id="step-pill-intensity">
                        <span class="step-icon"><i class="bi bi-2-circle-fill"></i></span>
                        <span>Intensity</span>
                    </span>
                    <span class="step-connector" id="step-conn-2"></span>
                    <span class="step-pill" id="step-pill-start">
                        <span class="step-icon"><i class="bi bi-play-fill"></i></span>
                        <span>Start</span>
                    </span>
                </div>
            </div>
        </div>

        <div class="row justify-content-center reveal-up delay-100">
            <div class="col-lg-10">

                <div class="d-flex align-items-center mb-3">
                    <span class="step-label">STEP 01</span>
                    <h6 class="fw-black text-muted text-uppercase mb-0" style="letter-spacing: 2px; font-size: 0.75rem;">Choose Your Script</h6>
                </div>

                <div class="row g-3 mb-5 even-row">
                    <div class="col-md-3 col-6">
                        <div class="setup-card lobby-card-lg text-center alpha-select" data-alpha="hiragana" onclick="selectAlpha(this)">
                            <div class="alpha-kana-display text-primary">あ</div>
                            <div class="alpha-label">HIRAGANA</div>
                            <div class="alpha-sublabel">Basic syllabary</div>
