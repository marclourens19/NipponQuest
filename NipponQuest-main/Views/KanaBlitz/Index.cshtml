@section Scripts {
<script>
    // ── CONFIG ──
    const TIME_LIMITS    = { easy: 120, normal: 90, hard: 60, insanity: 45 };
    const TIME_BONUS     = { easy: 0,   normal: 0,  hard: 1.0, insanity: 0.5 };
    const TIME_PENALTY   = { easy: 0,   normal: 0,  hard: 2.0, insanity: 3.0 };
    const SPEED_WINDOW   = { easy: 10,  normal: 7,  hard: 5,  insanity: 3 };
    const SCORE_DIFFMULT = { easy: 1.0, normal: 1.5, hard: 2.75, insanity: 4.5 };
    const TICK_MS        = 100;

    // ── STATE ──
    let cfgAlpha = null, cfgDiff = null;
    let pool = [];
    let arenaDistractors = [];
    let game = {
        timer: null, timeLeft: 0,
        score: 0, mistakes: 0,
        hp: 3, streak: 0, maxCombo: 0,
        points: 0,
        current: null,
        qStartedAt: 0,
        runStartedAt: 0
    };

    let unlocks = {
        level: 1,
        hard:     { unlocked: false, threshold: 0.90, correctFloor: 30, progress: { hiragana: 0, katakana: 0, dakuten: 0, mixed: 0 }, progressMax: { hiragana: 0, katakana: 0, dakuten: 0, mixed: 0 } },
        insanity: { unlocked: false, threshold: 0.95, correctFloor: 25, requiredLevel: 15, levelMet: false, hardCleared: false, progress: { hiragana: 0, katakana: 0, dakuten: 0, mixed: 0 }, progressMax: { hiragana: 0, katakana: 0, dakuten: 0, mixed: 0 } }
    };

    const ALPHA_LABELS = { hiragana: 'HIRAGANA', katakana: 'KATAKANA', dakuten: 'DAKUTEN', mixed: 'MIXED BLITZ' };
    const DIFF_LABELS  = { easy: 'EASY', normal: 'NORMAL', hard: 'HARD', insanity: 'INSANITY' };

    // Alphabet-scoped fallback kana so multiple-choice options never leak
    // kana from other scripts (mixed = all kana).
    const KANA_BY_ALPHA = {
        hiragana: ['あ','い','う','え','お','か','き','く','け','こ','さ','し','す','せ','そ','た','ち','つ','て','と','な','に','ぬ','ね','の','は','ひ','ふ','へ','ほ','ま','み','む','め','も','や','ゆ','よ','ら','り','る','れ','ろ','わ','を','ん','きょ','しゃ','じゅ','ちょ','りゅ','ぴょ','ひゃ','みょ','にゅ','しゅ','じょ','ちゅ'],
        katakana: ['ア','イ','ウ','エ','オ','カ','キ','ク','ケ','コ','サ','シ','ス','セ','ソ','タ','チ','ツ','テ','ト','ナ','ニ','ヌ','ネ','ノ','ハ','ヒ','フ','ヘ','ホ','マ','ミ','ム','メ','モ','ヤ','ユ','ヨ','ラ','リ','ル','レ','ロ','ワ','ヲ','ン','ニュ','チョ','ジャ','ファ','ピュ','ショ','シャ','ジュ','チュ','キャ','フォ','ティ'],
        dakuten:  ['が','ぎ','ぐ','げ','ご','ざ','じ','ず','ぜ','ぞ','だ','ぢ','づ','で','ど','ば','び','ぶ','べ','ぼ','ぱ','ぴ','ぷ','ぺ','ぽ','ガ','ギ','グ','ゲ','ゴ','ザ','ジ','ズ','ダ','ド','バ','ビ','ブ','ベ','ボ','パ','ピ','プ','ペ','ポ','ぎゅ','じゅ','びょ','ぎょ','ぴょ']
    };
    KANA_BY_ALPHA.mixed = [...KANA_BY_ALPHA.hiragana, ...KANA_BY_ALPHA.katakana, ...KANA_BY_ALPHA.dakuten];

    // ── UNLOCKS ──
    async function loadUnlocks() {
        try {
            const res = await fetch('/KanaBlitz/GetUnlocks');
            if (!res.ok) return;
            const data = await res.json();
            unlocks.level    = data.level ?? 1;
            unlocks.hard     = data.hard     ?? unlocks.hard;
            unlocks.insanity = data.insanity ?? unlocks.insanity;
            applyUnlocksToCards();
        } catch (e) { console.warn('Unlock fetch failed', e); }
    }

    function applyUnlocksToCards() {
        const hardCard = document.querySelector('.diff-select[data-diff="hard"]');
        const insanityCard = document.querySelector('.diff-select[data-diff="insanity"]');

        if (hardCard) {
            if (unlocks.hard.unlocked) {
                hardCard.classList.remove('locked');
                hardCard.dataset.locked = 'false';
                const ov = hardCard.querySelector('.lock-overlay'); if (ov) ov.remove();
                const rq = hardCard.querySelector('.lock-req'); if (rq) rq.remove();
            } else {
                hardCard.classList.add('locked');
                hardCard.dataset.locked = 'true';
            }
        }

        if (insanityCard) {
            if (unlocks.insanity.unlocked) {
                insanityCard.classList.remove('locked');
                insanityCard.dataset.locked = 'false';
                const ov = insanityCard.querySelector('.lock-overlay'); if (ov) ov.remove();
                const rq = insanityCard.querySelector('.lock-req'); if (rq) rq.remove();
            } else {
                insanityCard.classList.add('locked');
                insanityCard.dataset.locked = 'true';
            }
        }
    }

    function showLockModal(diff) {
        const titleEl    = document.getElementById('lock-modal-title');
        const subtitleEl = document.getElementById('lock-modal-subtitle');
        const listEl     = document.getElementById('lock-modal-list');
        listEl.innerHTML = '';

        if (diff === 'hard') {
            const floor   = unlocks.hard.correctFloor ?? 30;
            const accPct  = Math.round((unlocks.hard.threshold ?? 0.90) * 100);
            titleEl.textContent = 'Hard Mode Locked';
            subtitleEl.textContent = `Reach ${accPct}% accuracy AND ${floor}+ correct words in a single Normal run on every script.`;

            const order = ['hiragana', 'katakana', 'dakuten', 'mixed'];
            order.forEach(a => {
                const pct = Math.round((unlocks.hard.progress[a] ?? 0) * 100);
                const max = unlocks.hard.progressMax[a] ?? 0;
                const accMet = pct >= accPct;
                const cntMet = max >= floor;
                const met = accMet && cntMet;
                const li = document.createElement('li');
                if (met) li.classList.add('met');
                li.innerHTML = `
                    <span class="req-icon"><i class="bi ${met ? 'bi-check-lg' : 'bi-lock-fill'}"></i></span>
                    <span>Normal &middot; ${ALPHA_LABELS[a]}</span>
                    <span class="req-progress">${pct}% &middot; ${max}/${floor}</span>`;
                listEl.appendChild(li);
            });
        } else if (diff === 'insanity') {
            const floor   = unlocks.insanity.correctFloor ?? 25;
            const accPct  = Math.round((unlocks.insanity.threshold ?? 0.95) * 100);
            const reqLvl  = unlocks.insanity.requiredLevel ?? 15;

            titleEl.textContent = 'Insanity Mode Locked';
            subtitleEl.textContent = `Reach ${accPct}% accuracy AND ${floor}+ correct words in a single Hard run on every script, and reach Account Level ${reqLvl}.`;

            const order = ['hiragana', 'katakana', 'dakuten', 'mixed'];
            order.forEach(a => {
                const pct = Math.round((unlocks.insanity.progress[a] ?? 0) * 100);
                const max = unlocks.insanity.progressMax[a] ?? 0;
                const accMet = pct >= accPct;
                const cntMet = max >= floor;
                const met = accMet && cntMet;
                const li = document.createElement('li');
                if (met) li.classList.add('met');
                li.innerHTML = `
                    <span class="req-icon"><i class="bi ${met ? 'bi-check-lg' : 'bi-lock-fill'}"></i></span>
                    <span>Hard &middot; ${ALPHA_LABELS[a]}</span>
                    <span class="req-progress">${pct}% &middot; ${max}/${floor}</span>`;
                listEl.appendChild(li);
            });

            const li = document.createElement('li');
            const met = unlocks.insanity.levelMet;
            if (met) li.classList.add('met');
            li.innerHTML = `
                <span class="req-icon"><i class="bi ${met ? 'bi-check-lg' : 'bi-lock-fill'}"></i></span>
                <span>Account Level</span>
                <span class="req-progress">Lv ${unlocks.level} / Lv ${reqLvl}</span>`;
            listEl.appendChild(li);
        }

        const modalEl = document.getElementById('lockedModeModal');
        bootstrap.Modal.getOrCreateInstance(modalEl).show();
    }

    function generateOptions(correct) {
        const alpha    = cfgAlpha || 'hiragana';
        const shuffle  = arr => arr.sort(() => Math.random() - 0.5);

        // 1) prefer real distractors from the server (already alphabet-filtered)
        const serverPool = (arenaDistractors || []).filter(d => d && d !== correct);
        // 2) fall back to alphabet-scoped kana if we don't have enough
        const fallback   = (KANA_BY_ALPHA[alpha] || KANA_BY_ALPHA.hiragana).filter(d => d !== correct);

        const choices = [correct];
        shuffle(serverPool);
        while (choices.length < 4 && serverPool.length) {
            const c = serverPool.shift();
            if (!choices.includes(c)) choices.push(c);
        }
        shuffle(fallback);
        while (choices.length < 4 && fallback.length) {
            const c = fallback.shift();
            if (!choices.includes(c)) choices.push(c);
        }
        return shuffle(choices);
    }

    // ── LOBBY ──
    function selectAlpha(el) {
        document.querySelectorAll('.alpha-select').forEach(x => x.classList.remove('selected'));
        el.classList.add('selected');
        cfgAlpha = el.dataset.alpha;
        checkReady();
    }

    function selectDiff(el) {
        const diff = el.dataset.diff;
        const isLocked = el.dataset.locked === 'true';

        if (isLocked) { showLockModal(diff); return; }

        document.querySelectorAll('.diff-select').forEach(x => x.classList.remove('selected'));
        el.classList.add('selected');
        cfgDiff = diff;
        checkReady();
    }

    function checkReady() {
        const btn = document.getElementById('btn-start-blitz');
        const ready = !!(cfgAlpha && cfgDiff);
        btn.disabled = !ready;

        const pillScript    = document.getElementById('step-pill-script');
        const pillIntensity = document.getElementById('step-pill-intensity');
        const pillStart     = document.getElementById('step-pill-start');
        const conn1 = document.getElementById('step-conn-1');
        const conn2 = document.getElementById('step-conn-2');

        [pillScript, pillIntensity, pillStart].forEach(p => p.classList.remove('active', 'done'));
        conn1.classList.remove('done'); conn2.classList.remove('done');

        if (cfgAlpha) { pillScript.classList.add('done'); conn1.classList.add('done'); }
        else { pillScript.classList.add('active'); }

        if (cfgDiff) { pillIntensity.classList.add('done'); conn2.classList.add('done'); }
        else if (cfgAlpha) { pillIntensity.classList.add('active'); }

        if (ready) { pillStart.classList.add('active'); }

        const ctaText = document.getElementById('cta-text');
        if (ready) {
            ctaText.textContent = `ENTER ARENA \u2022 ${ALPHA_LABELS[cfgAlpha]} \u2022 ${DIFF_LABELS[cfgDiff]}`;
            btn.setAttribute('title', 'Begin your run');
        } else {
            ctaText.textContent = 'ENTER ARENA';
            btn.setAttribute('title', 'Select script and intensity');
        }

        if (window.bootstrap && bootstrap.Tooltip) {
            const inst = bootstrap.Tooltip.getInstance(btn);
            if (inst) { inst.dispose(); }
            new bootstrap.Tooltip(btn);
        }
    }

    // ── EXIT ──
    function exitToLobby() {
        const modalEl = document.getElementById('exitConfirmModal');
        bootstrap.Modal.getOrCreateInstance(modalEl).show();
    }

    function confirmExitToLobby() {
        const exitModal = bootstrap.Modal.getInstance(document.getElementById('exitConfirmModal'));
        if (exitModal) exitModal.hide();

        clearInterval(game.timer);
        game = { timer: null, timeLeft: 0, score: 0, mistakes: 0, hp: 3, streak: 0, maxCombo: 0, points: 0, current: null, qStartedAt: 0, runStartedAt: 0 };
        pool = [];
        document.getElementById('ui-game').classList.add('d-none');
        document.getElementById('ui-results').classList.add('d-none');
        document.getElementById('ui-lobby').classList.remove('d-none');

        document.querySelectorAll('.heart-icon').forEach(h => h.classList.remove('heart-lost'));
        document.getElementById('hud-score').innerText = '0';
        document.getElementById('hud-combo-badge').classList.remove('active');
        const timerEl = document.getElementById('hud-timer');
        timerEl.classList.remove('text-danger');
        timerEl.classList.add('text-warning');

        document.getElementById('reward-loading').classList.remove('d-none');
        document.getElementById('reward-display').classList.add('d-none');
        document.getElementById('result-perfect-flag').classList.add('d-none');
        document.getElementById('result-pb-flag').classList.add('d-none');
        document.getElementById('result-leaderboard-card').classList.add('d-none');

        const btn = document.getElementById('btn-start-blitz');
        const inner = `<i class="bi bi-play-fill fs-4 me-2"></i><span id="cta-text">ENTER ARENA</span><span class="cta-arrow"><i class="bi bi-arrow-right"></i></span>`;
        btn.innerHTML = inner;
        btn.disabled = !(cfgAlpha && cfgDiff);

        loadUnlocks();
        checkReady();
    }

    // ── ENGINE ──
    async function startArena() {
        const btn = document.getElementById('btn-start-blitz');
        btn.disabled = true;
        btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>SYNCING ARENA...`;

        try {
            const res = await fetch(`/KanaBlitz/GetArenaPayload?alphabet=${cfgAlpha}&difficulty=${cfgDiff}`);
            if (res.status === 403) {
                const err = await res.json().catch(() => ({}));
                alert(err.error || 'This mode is locked.');
                location.reload();
                return;
            }
            const data = await res.json();

            pool = Array.isArray(data) ? data : (data.words || []);
            arenaDistractors = data.distractors || [];

            if (!pool || pool.length === 0) {
                alert("No words found for this configuration.");
                location.reload();
                return;
            }

            document.getElementById('ui-lobby').classList.add('d-none');
            document.getElementById('ui-game').classList.remove('d-none');

            game.score    = 0;
            game.mistakes = 0;
            game.hp       = 3;
            game.streak   = 0;
            game.maxCombo = 0;
            game.points   = 0;
            game.timeLeft = TIME_LIMITS[cfgDiff] ?? 90;
            game.runStartedAt = performance.now();

            updateTimerUI();
            game.timer = setInterval(tick, TICK_MS);

            nextTarget();
        } catch (e) {
            console.error("Fetch failed:", e);
            location.reload();
        }
    }

    function tick() {
        game.timeLeft -= (TICK_MS / 1000);
        if (game.timeLeft <= 0) {
            game.timeLeft = 0;
            updateTimerUI();
            finish("Time Expired");
            return;
        }
        updateTimerUI();
    }

    function updateTimerUI() {
        const t = Math.max(0, Math.ceil(game.timeLeft));
        const m = Math.floor(t / 60).toString().padStart(2, '0');
        const s = (t % 60).toString().padStart(2, '0');
        const el = document.getElementById('hud-timer');
        el.innerText = `${m}:${s}`;
        if (game.timeLeft <= 10) {
            el.classList.remove('text-warning'); el.classList.add('text-danger');
        } else {
            el.classList.remove('text-danger'); el.classList.add('text-warning');
        }
    }

    function nextTarget() {
        if (pool.length === 0) return finish("Victory!");

        const q = pool.shift();
        game.current = q;
        game.qStartedAt = performance.now();

        document.getElementById('game-meaning').innerText = cfgDiff === 'easy' ? 'PICK THE KANA' : (q.meaning || '');
        document.getElementById('game-display').innerHTML = q.display;
        document.getElementById('game-category').innerText = q.category ? `Category: ${q.category}` : '';

        const correct = q.missing;
        const options = generateOptions(correct);

        const container = document.getElementById('game-options');
        container.innerHTML = '';
        options.forEach(opt => {
            const div = document.createElement('div');
            div.className = 'col-6 col-md-3';
            div.innerHTML = `<button class="btn blitz-option-btn w-100 shadow-sm" onclick="handleInput('${opt}', this)">${opt}</button>`;
            container.appendChild(div);
        });

        playCurrentAudio();
    }

    function handleInput(val, btn) {
        const correct = game.current.missing;
        const elapsed = (performance.now() - game.qStartedAt) / 1000;

        if (val === correct) {
            const window = SPEED_WINDOW[cfgDiff] ?? 7;
            const speedFactor = Math.max(0, (window - elapsed) / window);
            const base       = 100;
            const speedBonus = Math.round(speedFactor * 80);
            const comboBonus = Math.min(game.streak, 30) * 8;
            const diffMult   = SCORE_DIFFMULT[cfgDiff] ?? 1.5;
            const earned     = Math.round((base + speedBonus + comboBonus) * diffMult);

            game.points += earned;
            game.score++;
            game.streak++;
            if (game.streak > game.maxCombo) game.maxCombo = game.streak;

            const bonus = TIME_BONUS[cfgDiff] ?? 0;
            if (bonus > 0) game.timeLeft = Math.min(TIME_LIMITS[cfgDiff] + 30, game.timeLeft + bonus);

            btn.classList.add('bg-success', 'text-white', 'border-success');
            updateHUD();
            setTimeout(nextTarget, 150);
        } else {
            game.mistakes++;
            game.streak = 0;
            game.hp--;

            const penalty = TIME_PENALTY[cfgDiff] ?? 0;
            if (penalty > 0) {
                game.timeLeft = Math.max(0, game.timeLeft - penalty);
                if (game.timeLeft <= 0) {
                    btn.classList.add('bg-danger', 'text-white', 'border-danger');
                    updateHUD();
                    return finish("Time Expired");
                }
            }

            btn.classList.add('bg-danger', 'text-white', 'border-danger');
            updateHUD();

            if (game.hp <= 0) finish("Arena Defeat");
            else setTimeout(nextTarget, 600);
        }
    }

    function updateHUD() {
        document.getElementById('hud-score').innerText = game.points.toLocaleString();

        const hearts = document.querySelectorAll('.heart-icon');
        hearts.forEach((h, i) => {
            if (i >= game.hp) h.classList.add('heart-lost');
            else h.classList.remove('heart-lost');
        });

        const combo = document.getElementById('hud-combo-badge');
        if (game.streak >= 3) {
            const multiplier = (1.0 + (game.streak * 0.05)).toFixed(2);
            combo.innerText = `COMBO \u00d7${multiplier}`;
            combo.classList.add('active');
        } else {
            combo.classList.remove('active');
        }
    }

    function playCurrentAudio() {
        if (!game.current) return;
        const msg = new SpeechSynthesisUtterance();
        msg.text = (game.current.kana || '').split('(')[0].trim();
        msg.lang = 'ja-JP';
        window.speechSynthesis.speak(msg);
    }

    // ── FINISH ──
    async function finish(status) {
        clearInterval(game.timer);
        document.getElementById('ui-game').classList.add('d-none');
        document.getElementById('ui-results').classList.remove('d-none');

        const iconWrap  = document.getElementById('result-status-icon');
        iconWrap.classList.remove('win', 'loss', 'time');
        const titleEl   = document.getElementById('result-status');
        const summaryEl = document.getElementById('result-summary-line');

        if (status === 'Arena Defeat') {
            iconWrap.classList.add('loss');
            iconWrap.innerHTML = '<i class="bi bi-shield-slash-fill"></i>';
            titleEl.textContent = 'Arena Defeat';
            summaryEl.textContent = 'You ran out of lives. Reload, refocus, regroup.';
        } else if (status === 'Time Expired') {
            iconWrap.classList.add('time');
            iconWrap.innerHTML = '<i class="bi bi-stopwatch-fill"></i>';
            titleEl.textContent = 'Time Expired';
            summaryEl.textContent = 'The clock won this round. Push the tempo next run.';
        } else {
            iconWrap.classList.add('win');
            iconWrap.innerHTML = '<i class="bi bi-trophy-fill"></i>';
            titleEl.textContent = 'Arena Cleared';
            summaryEl.textContent = 'Clean run. Bank the rewards and queue the next set.';
        }

        document.getElementById('result-count').innerText = game.score;
        document.getElementById('result-combo').innerText = game.maxCombo || 0;

        const durationSec = Math.max(1, Math.round((performance.now() - game.runStartedAt) / 1000));
        const kpm = Math.round((game.score / durationSec) * 60);

        try {
            const res = await fetch('/KanaBlitz/SubmitScore', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    Alphabet: cfgAlpha,
                    Difficulty: cfgDiff,
                    CorrectAnswers: game.score,
                    Mistakes: game.mistakes,
                    MaxCombo: game.maxCombo,
                    Points: game.points,
                    DurationSeconds: durationSec
                })
            });
            const data = await res.json();

            document.getElementById('reward-loading').classList.add('d-none');
            document.getElementById('reward-display').classList.remove('d-none');

            document.getElementById('final-exp').innerText    = data.exp ?? 0;
            document.getElementById('final-gold').innerText   = data.gold ?? 0;
            document.getElementById('final-points').innerText = (data.points ?? game.points).toLocaleString();
            document.getElementById('final-kpm').innerText    = kpm;
            document.getElementById('result-accuracy').innerText = data.accuracy ?? 0;

            if (data.perfectBonus) document.getElementById('result-perfect-flag').classList.remove('d-none');
            else document.getElementById('result-perfect-flag').classList.add('d-none');

            if (data.isNewPB) document.getElementById('result-pb-flag').classList.remove('d-none');
            else document.getElementById('result-pb-flag').classList.add('d-none');

            const lbCard = document.getElementById('result-leaderboard-card');
            if (cfgDiff === 'normal' && (data.rankAfter ?? 0) > 0) {
                lbCard.classList.remove('d-none');
                document.getElementById('lb-mode-label').textContent =
                    `Normal \u00b7 ${ALPHA_LABELS[cfgAlpha] || cfgAlpha.toUpperCase()}`;
                document.getElementById('lb-rank-before').innerText = data.rankBefore ?? '—';
                document.getElementById('lb-rank-after').innerText  = data.rankAfter ?? '—';

                const delta = data.rankDelta ?? 0;
                const icon  = document.getElementById('lb-delta-icon');
                const lbl   = document.getElementById('lb-delta-label');
                if (delta > 0) {
                    icon.className = 'bi bi-arrow-up-circle-fill';
                    icon.style.color = '#16a34a';
                    lbl.textContent  = `Up ${delta} place${delta === 1 ? '' : 's'}`;
                } else if (delta < 0) {
                    icon.className = 'bi bi-arrow-down-circle-fill';
                    icon.style.color = '#ef4444';
                    lbl.textContent  = `Down ${Math.abs(delta)} place${Math.abs(delta) === 1 ? '' : 's'}`;
                } else {
                    icon.className = 'bi bi-dash-circle-fill';
                    icon.style.color = '#94a3b8';
                    lbl.textContent  = 'Holding rank';
                }
            } else {
                lbCard.classList.add('d-none');
            }
        } catch (e) {
            document.getElementById('reward-loading').innerText = "Failed to sync rewards.";
        }
    }

    // ── BOOT ──
    document.addEventListener('DOMContentLoaded', () => {
        const obs = new IntersectionObserver((entries) => {
            entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('active'); });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal-up').forEach(el => obs.observe(el));

        if (window.bootstrap && bootstrap.Tooltip) {
            const ctaBtn = document.getElementById('btn-start-blitz');
            new bootstrap.Tooltip(ctaBtn);
        }

        loadUnlocks();
        checkReady();
    });
</script>
}