// FINISH
// ════════════════════════════════════════════════════════════════
async function finishGame(status){
  if(game.finished)return;game.finished=true;if(game.timer)clearInterval(game.timer);
  const dur=Math.max(1,Math.round((performance.now()-game.runStartedAt)/1000));
  const tot=game.score+game.mistakes,acc=tot>0?Math.round((game.score/tot)*100):0,kpm=Math.round((game.score/dur)*60);
  let sData={};
  try{const r=await fetch('/KanaBlitz/SubmitScore',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({Alphabet:cfgAlpha,Difficulty:cfgDiff,CorrectAnswers:game.score,Mistakes:game.mistakes,MaxCombo:game.maxCombo,Points:game.points,DurationSeconds:dur})});if(r.ok)sData=await r.json()}catch{}
  document.getElementById('ui-arena').style.display='none';document.getElementById('ui-results').style.display='block';
  const isWin=status==='victory',isTO=status==='timeout',isPerfect=game.mistakes===0&&game.score>=5;
  if(isWin){playVictorySound();spawnConfetti()}else playDefeatSound();
  const icon=document.getElementById('result-icon'),iconS=document.getElementById('result-icon-span'),title=document.getElementById('result-title'),sub=document.getElementById('result-subtitle');
  icon.className=isWin?'results-icon win':isTO?'results-icon time':'results-icon loss';
  iconS.innerHTML=isWin?`<span style="color:#10b981">${SVG.trophy}</span>`:isTO?`<span style="color:#f59e0b">${SVG.clock}</span>`:`<span style="color:#ef4444">${SVG.skull}</span>`;
  title.style.color=isWin?'#34d399':isTO?'#fbbf24':'#f87171';
  title.textContent=isWin?'Arena Cleared!':isTO?'Time Expired':'Arena Defeat';
  sub.textContent=isWin?'Clean run. Bank the rewards.':isTO?'The clock won this round.':'You ran out of lives. Regroup.';
  document.getElementById('result-mode-tag').textContent=`${ALPHA_LABELS[cfgAlpha]} · ${DIFF_LABELS[cfgDiff]}`;
  document.getElementById('result-perfect-tag').style.display=isPerfect?'inline-block':'none';
  document.getElementById('result-pb-tag').style.display=sData.isNewPB?'inline-block':'none';
  document.getElementById('result-correct').textContent=game.score;
  document.getElementById('result-accuracy').textContent=`${sData.accuracy??acc}%`;
  document.getElementById('result-combo').innerHTML=`${game.maxCombo}<span style="font-size:0.7rem;color:#64748b">x</span>`;
  const fXP=sData.exp??calcLocalXP(),fG=sData.gold??calcLocalGold();
  document.getElementById('reward-spinner').style.display='none';document.getElementById('reward-grid').style.display='grid';
  document.getElementById('final-xp').textContent=`+${fXP}`;document.getElementById('final-gold').textContent=`+${fG}`;
  document.getElementById('final-points').textContent=game.points.toLocaleString();document.getElementById('final-kpm').textContent=kpm;
  const ac=ALPHA_COLORS[cfgAlpha],dc=DIFF_COLORS[cfgDiff];
  const pa=document.getElementById('btn-play-again');pa.style.background=`linear-gradient(135deg,${ac},${dc})`;pa.style.boxShadow=`0 4px 16px ${dc}44`;
}
function calcLocalXP(){const dm={easy:1,normal:2,hard:4,insanity:8}[cfgDiff],cm=1+Math.min(game.maxCombo,30)*0.04,t=game.score+game.mistakes,a=t>0?game.score/t:0,am=a>=0.95?1.3:a>=0.85?1.1:a>=0.7?1:0.9,raw=game.score*3*dm*cm*am,mp=Math.min(game.mistakes*2,Math.round(raw*0.3)),pb=(game.mistakes===0&&game.score>=5)?Math.round(20*dm):0;return Math.max(0,Math.round(raw)-mp+pb)}
function calcLocalGold(){const dm={easy:1,normal:2,hard:4,insanity:8}[cfgDiff],cm=1+Math.min(game.maxCombo,30)*0.04,t=game.score+game.mistakes,a=t>0?game.score/t:0,am=a>=0.95?1.3:a>=0.85?1.1:a>=0.7?1:0.9,raw=game.score*0.8*dm*cm*am,pb=(game.mistakes===0&&game.score>=5)?Math.round(8*dm):0;return Math.max(0,Math.round(raw)+pb)}
function spawnConfetti(){const c=document.getElementById('confetti-container'),cols=['#f43f5e','#0ea5e9','#f59e0b','#10b981','#8b5cf6','#ec4899'];for(let i=0;i<35;i++){const d=document.createElement('div');d.className='confetti-piece';d.style.left=Math.random()*100+'%';d.style.top='-10px';const s=5+Math.random()*7;d.style.width=s+'px';d.style.height=s+'px';d.style.background=cols[Math.floor(Math.random()*cols.length)];d.style.borderRadius=Math.random()>0.5?'50%':'0';const dur=2+Math.random()*3,del=Math.random()*2;d.style.animation=`confetti-fall ${dur}s ease-out ${del}s both`;c.appendChild(d)}setTimeout(()=>{c.innerHTML=''},5000)}

