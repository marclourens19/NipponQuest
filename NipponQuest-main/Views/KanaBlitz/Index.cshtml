  el.innerHTML=`<div class="modal-overlay" onclick="closeGuide()"><div class="modal-box" style="border:1px solid #334155" onclick="event.stopPropagation()"><div class="modal-head" style="background:linear-gradient(135deg,#d97706,#ea580c)"><h2>KANABLITZ FIELD MANUAL</h2><p style="color:#fed7aa">Everything you need to dominate the arena</p><button class="close-btn" onclick="closeGuide()">✕</button></div><div class="modal-body"><h4 style="font-weight:900;font-size:0.65rem;text-transform:uppercase;letter-spacing:1px;color:#fff;margin-bottom:0.3rem">What is KanaBlitz?</h4><p>A high-intensity Japanese reading drill. See a word with a missing kana, pick the right one from four options before time runs out. Build streaks for bigger rewards.</p><div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.5rem;margin-bottom:0.75rem"><div style="border:1px solid #334155;border-radius:0.6rem;padding:0.5rem;background:rgba(30,41,59,0.3)"><h5 style="font-weight:900;font-size:0.5rem;text-transform:uppercase;letter-spacing:1px;color:#fff;margin-bottom:0.2rem">Tier & Time</h5><p style="font-size:0.55rem;color:#64748b;margin:0">Easy 120s · Normal 90s · Hard 60s · Insanity 45s</p></div><div style="border:1px solid #334155;border-radius:0.6rem;padding:0.5rem;background:rgba(30,41,59,0.3)"><h5 style="font-weight:900;font-size:0.5rem;text-transform:uppercase;letter-spacing:1px;color:#fff;margin-bottom:0.2rem">Time Banking</h5><p style="font-size:0.55rem;color:#64748b;margin:0">Hard & Insanity: correct adds time, mistakes burn it</p></div><div style="border:1px solid #334155;border-radius:0.6rem;padding:0.5rem;background:rgba(30,41,59,0.3)"><h5 style="font-weight:900;font-size:0.5rem;text-transform:uppercase;letter-spacing:1px;color:#fff;margin-bottom:0.2rem">Score & Combo</h5><p style="font-size:0.55rem;color:#64748b;margin:0">Score = speed + streak + difficulty multiplier</p></div></div><h4 style="font-weight:900;font-size:0.65rem;text-transform:uppercase;letter-spacing:1px;color:#fff;margin-bottom:0.3rem">Pro Tips</h4><div style="display:flex;gap:0.4rem;margin-bottom:0.3rem;font-size:0.65rem;color:#94a3b8"><span style="width:4px;height:4px;border-radius:50%;background:#fbbf24;margin-top:0.4rem;flex-shrink:0"></span>Play Normal to climb the leaderboard — fixed 90s clock.</div><div style="display:flex;gap:0.4rem;margin-bottom:0.3rem;font-size:0.65rem;color:#94a3b8"><span style="width:4px;height:4px;border-radius:50%;background:#fbbf24;margin-top:0.4rem;flex-shrink:0"></span>On Hard & Insanity, protect the streak. One miss costs time AND combo.</div><div style="display:flex;gap:0.4rem;margin-bottom:0.3rem;font-size:0.65rem;color:#94a3b8"><span style="width:4px;height:4px;border-radius:50%;background:#fbbf24;margin-top:0.4rem;flex-shrink:0"></span>Cycle scripts daily. Mixed Blitz exposes weak spots fast.</div><button style="width:100%;padding:0.6rem;border-radius:0.6rem;background:linear-gradient(135deg,#0ea5e9,#2563eb);color:#fff;font-weight:900;border:none;cursor:pointer;margin-top:0.5rem;font-family:'Nunito',sans-serif;font-size:0.7rem" onclick="closeGuide()">Got it</button></div></div></div>`;
}
function closeGuide(){document.getElementById('guide-modal').style.display='none'}

document.addEventListener('keydown',e=>{
  const key=e.key.toLowerCase();let idx=['1','2','3','4'].indexOf(key);
  if(idx===-1)idx=['a','b','c','d'].indexOf(key);
  if(idx>=0&&!game.isProcessing&&!game.finished&&document.getElementById('ui-arena').style.display==='block'){const b=document.getElementById(`opt-${idx}`);if(b)b.click()}
  if(key==='escape'){if(document.getElementById('guide-modal').style.display==='flex')closeGuide();else if(document.getElementById('exit-modal').style.display==='flex')closeExitModal();else if(document.getElementById('insanity-warning').style.display==='flex')closeInsanityWarning();else if(document.getElementById('rules-modal').style.display==='flex')closeRulesModal()}
});
</script>
</body>
</html>