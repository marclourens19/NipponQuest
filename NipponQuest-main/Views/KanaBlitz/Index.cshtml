// ════════════════════════════════════════════════════════════════
// SOUND EFFECTS
// ════════════════════════════════════════════════════════════════
const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
function playTone(freq,dur,type,vol,delay){
  const t=type||'sine',v=vol||0.12,d=delay||0,now=audioCtx.currentTime+d;
  const o=audioCtx.createOscillator(),g=audioCtx.createGain();
  o.type=t;o.frequency.value=freq;
  g.gain.setValueAtTime(0,now);g.gain.linearRampToValueAtTime(v,now+0.03);
  g.gain.exponentialRampToValueAtTime(0.001,now+dur);
  o.connect(g).connect(audioCtx.destination);o.start(now);o.stop(now+dur+0.05);
}
function playCorrectSound(){playTone(523.25,0.25,'sine',0.15);playTone(783.99,0.25,'sine',0.12,0.08)}
function playWrongSound(){const n=audioCtx.currentTime,o=audioCtx.createOscillator(),g=audioCtx.createGain();o.type='sawtooth';o.frequency.setValueAtTime(150,n);o.frequency.linearRampToValueAtTime(80,n+0.3);g.gain.setValueAtTime(0.2,n);g.gain.exponentialRampToValueAtTime(0.001,n+0.35);o.connect(g).connect(audioCtx.destination);o.start(n);o.stop(n+0.4)}
function playComboSound(s){const b=600+Math.min(s,20)*30;playTone(b,0.2);playTone(b*1.5,0.15,'sine',0.1,0.06)}
function playTickSound(){playTone(880,0.08,'sine',0.08)}
function playVictorySound(){[523.25,659.25,783.99,1046.50].forEach((f,i)=>playTone(f,0.4,'sine',0.12,i*0.12))}
function playDefeatSound(){[392,349.23,293.66,220].forEach((f,i)=>playTone(f,0.5,'triangle',0.12,i*0.2))}

// ════════════════════════════════════════════════════════════════
// CONFIG
// ════════════════════════════════════════════════════════════════
const TIME_LIMITS={easy:120,normal:90,hard:60,insanity:45};
const TIME_BONUS={easy:0,normal:0,hard:1.0,insanity:0.5};
const TIME_PENALTY={easy:0,normal:0,hard:2.0,insanity:3.0};
const SPEED_WINDOW={easy:10,normal:7,hard:5,insanity:3};
const SCORE_DIFFMULT={easy:1.0,normal:1.5,hard:2.75,insanity:4.5};
const ALPHA_LABELS={hiragana:'Hiragana',katakana:'Katakana',dakuten:'Dakuten',mixed:'Mixed Blitz'};
const DIFF_LABELS={easy:'Easy',normal:'Normal',hard:'Hard',insanity:'Insanity'};
const ALPHA_COLORS={hiragana:'#0ea5e9',katakana:'#f43f5e',dakuten:'#8b5cf6',mixed:'#f59e0b'};
const DIFF_COLORS={easy:'#10b981',normal:'#3b82f6',hard:'#8b5cf6',insanity:'#ef4444'};
const OPTION_LETTERS=['A','B','C','D'];
const KANA_POOLS={
  hiragana:['あ','い','う','え','お','か','き','く','け','こ','さ','し','す','せ','そ','た','ち','つ','て','と','な','に','ぬ','ね','の','は','ひ','ふ','へ','ほ','ま','み','む','め','も','や','ゆ','よ','ら','り','る','れ','ろ','わ','を','ん'],
  katakana:['ア','イ','ウ','エ','オ','カ','キ','ク','ケ','コ','サ','シ','ス','セ','ソ','タ','チ','ツ','テ','ト','ナ','ニ','ヌ','ネ','ノ','ハ','ヒ','フ','ヘ','ホ','マ','ミ','ム','メ','モ','ヤ','ユ','ヨ','ラ','リ','ル','レ','ロ','ワ','ヲ','ン'],
  dakuten:['が','ぎ','ぐ','げ','ご','ざ','じ','ず','ぜ','ぞ','だ','ぢ','づ','で','ど','ば','び','ぶ','べ','ぼ','ぱ','ぴ','ぷ','ぺ','ぽ','ガ','ギ','グ','ゲ','ゴ','ザ','ジ','ズ','ゼ','ゾ','ダ','デ','ド','バ','ビ','ブ','ベ','ボ','パ','ピ','プ','ペ','ポ'],
};
KANA_POOLS.mixed=[...KANA_POOLS.hiragana,...KANA_POOLS.katakana,...KANA_POOLS.dakuten];
const MULTI_POOLS={
  hiragana:['きょ','しゃ','じゅ','ちょ','ちゅ','ちゃ','りょ','きゅ','しゅ','にゅ','ひょ','みょ','じょ','ひゃ','けっ','きっ','ざっ','しゅっ','ぴょ','りゅ','ぎょ','びゃ','にゃ','ひゅ'],
  katakana:['キョ','シャ','ジュ','チョ','チュ','チャ','リョ','キュ','シュ','ニュ','ヒョ','ミョ','ジョ','ヒャ','ケッ','キッ','ザッ','リュ','ギョ','ビャ','ニャ','ファ','フォ','ティ','ディ'],
  dakuten:['ぎょ','じゅ','びゃ','ぎゅ','びょ','じょ','じゃ','ぎゃ','ジュ','ビョ','ギョ','ザッ','ダッ','バッ','パッ','ジャ','ビャ','ギャ'],
};
