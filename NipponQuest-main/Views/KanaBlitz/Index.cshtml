// ════════════════════════════════════════════════════════════════
// STATE
// ════════════════════════════════════════════════════════════════
let cfgAlpha=null,cfgDiff=null;
let game={timer:null,timeLeft:0,score:0,points:0,mistakes:0,hp:3,streak:0,maxCombo:0,current:null,qStartedAt:0,runStartedAt:0,pool:[],isProcessing:false,finished:false,kanjiDistractors:[],furiganaDistractors:[]};
let devUnlocked=false;
let rulesAcknowledged=localStorage.getItem('kanablitz-rules-acknowledged')==='true';
let insanityAcknowledged=localStorage.getItem('insanity-acknowledged')==='true';

// Init
document.addEventListener("DOMContentLoaded",async()=>{
  renderHearts(3);
  try{const r=await fetch('/KanaBlitz/GetAcknowledgements');if(r.ok){const a=await r.json();rulesAcknowledged=!!a.rules;insanityAcknowledged=!!a.insanity;if(rulesAcknowledged)localStorage.setItem('kanablitz-rules-acknowledged','true');if(insanityAcknowledged)localStorage.setItem('insanity-acknowledged','true')}}catch{}
  try{const r=await fetch('/KanaBlitz/GetUnlocks');if(r.ok){const d=await r.json();if(d.hard?.unlocked)unlockDifficulty('hard');if(d.insanity?.unlocked)unlockDifficulty('insanity')}}catch{}
  updateSteps();
  if(!rulesAcknowledged)showRulesWarning();
});

function unlockDifficulty(id){const e=document.querySelector(`.choice-card[data-diff="${id}"]`);if(!e)return;e.dataset.locked="false";e.classList.remove('locked');const l=e.querySelector('.lock-badge');if(l)l.style.display='none';const r=e.querySelector('.req-badge');if(r)r.style.display='none'}
function renderHearts(hp){let h='';for(let i=0;i<3;i++)h+=SVG.heart(i<hp);document.getElementById('hud-hearts').innerHTML=h}

// ════════════════════════════════════════════════════════════════
// LOBBY
// ════════════════════════════════════════════════════════════════
function selectAlpha(el){
  document.querySelectorAll('.choice-card[data-alpha]').forEach(c=>{c.classList.remove('selected');c.style.borderColor='';c.style.boxShadow='';c.style.background='';const ck=c.querySelector('.check');if(ck)ck.remove()});
  el.classList.add('selected');cfgAlpha=el.dataset.alpha;
  const col=ALPHA_COLORS[cfgAlpha]||'#0ea5e9';
  el.style.borderColor=col;el.style.boxShadow=`0 0 25px ${col}33,0 8px 32px ${col}15`;el.style.background=`linear-gradient(135deg,${col}15,rgba(30,41,59,0.8))`;
  const ck=document.createElement('div');ck.className='check';ck.style.color=col;ck.textContent='✓';el.appendChild(ck);
  updateSteps();
}
function selectDiff(el){
  const d=el.dataset.diff,locked=el.dataset.locked==='true';
  if(locked){showLockAlert(el.dataset.req);return}
  document.getElementById('lock-alert-area').innerHTML='';
  document.querySelectorAll('.choice-card[data-diff]').forEach(c=>{c.classList.remove('selected');c.style.borderColor='';c.style.boxShadow='';c.style.background='';const ck=c.querySelector('.check');if(ck)ck.remove()});
  el.classList.add('selected');cfgDiff=d;
  const col=DIFF_COLORS[cfgDiff]||'#3b82f6';
  el.style.borderColor=col;el.style.boxShadow=`0 0 25px ${col}33,0 8px 32px ${col}15`;el.style.background=`linear-gradient(135deg,${col}15,rgba(30,41,59,0.8))`;
  const ck=document.createElement('div');ck.className='check';ck.style.color=col;ck.textContent='✓';el.appendChild(ck);
  updateSteps();
}
function showLockAlert(msg){document.getElementById('lock-alert-area').innerHTML=`<div style="background:rgba(120,53,15,0.3);border:1px solid rgba(245,158,11,0.2);color:#fcd34d;padding:0.5rem;border-radius:0.6rem;font-size:0.65rem;font-weight:700;display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem"><span><span style="font-size:0.5rem;font-weight:900;letter-spacing:1px;background:#f59e0b;color:#fff;padding:0.15rem 0.4rem;border-radius:0.25rem;margin-right:0.4rem">LOCKED</span>${msg}</span><button onclick="this.parentElement.remove()" style="background:none;border:none;font-weight:900;color:#fcd34d;cursor:pointer;padding:0 0.4rem;font-family:'Nunito',sans-serif">✕</button></div>`}
function updateSteps(){
  const s1=document.getElementById('step-script'),s2=document.getElementById('step-intensity'),s3=document.getElementById('step-start');
  const l1=document.getElementById('step-line-1'),l2=document.getElementById('step-line-2');
  s1.className='step-pill done';s1.querySelector('.num').textContent='✓';
  s2.className='step-pill inactive';s2.querySelector('.num').textContent='2';
  s3.className='step-pill inactive';s3.querySelector('.num').textContent='3';
  l1.className='step-line inactive';l2.className='step-line inactive';
  if(cfgAlpha){s2.className='step-pill active';l1.className='step-line done'}
  if(cfgDiff){s2.className='step-pill done';s2.querySelector('.num').textContent='✓';s3.className='step-pill active';l2.className='step-line done'}
  const btn=document.getElementById('btn-start'),ready=!!(cfgAlpha&&cfgDiff);
  btn.disabled=!ready;
  if(ready){
    const ac=ALPHA_COLORS[cfgAlpha],dc=DIFF_COLORS[cfgDiff];
    btn.className='cta-btn ready';
    btn.style.background=`linear-gradient(135deg,${ac},${dc})`;
    btn.style.boxShadow=`0 4px 24px ${dc}44`;
    btn.innerHTML=`<span class="icon">${SVG.bolt}</span> ENTER ARENA · ${ALPHA_LABELS[cfgAlpha]} · ${DIFF_LABELS[cfgDiff]}`;
  }else{
    btn.className='cta-btn disabled';btn.style.background='';btn.style.boxShadow='';
    btn.innerHTML='ENTER ARENA';
  }
}
function toggleDev(){
  devUnlocked=!devUnlocked;const btn=document.getElementById('dev-toggle');
  if(devUnlocked){btn.className='dev-toggle unlocked-toggle';btn.innerHTML='<svg style="width:10px;height:10px;margin-right:2px;display:inline" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 019.9-1"/></svg> Dev: Restrictions Unlocked'}
  else{btn.className='dev-toggle locked-toggle';btn.innerHTML='<svg style="width:10px;height:10px;margin-right:2px;display:inline" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg> Dev: Restrictions Enforced'}
  document.querySelectorAll('.choice-card[data-locked]').forEach(c=>{
    if(devUnlocked){c.dataset.locked='false';c.classList.remove('locked');const r=c.querySelector('.req-badge');if(r)r.style.display='none';const l=c.querySelector('.lock-badge');if(l)l.style.display='none'}
    else{c.dataset.locked='true';c.classList.add('locked');const r=c.querySelector('.req-badge');if(r)r.style.display='block';const l=c.querySelector('.lock-badge');if(l)l.style.display='block'}
  });
}

// ════════════════════════════════════════════════════════════════
// ARENA
// ════════════════════════════════════════════════════════════════
async function startArena(){
  if(!cfgAlpha||!cfgDiff)return;
  if(!rulesAcknowledged){showRulesWarning();return}
  if(cfgDiff==='insanity'&&!insanityAcknowledged){showInsanityWarning();return}
  beginArena();
}
function showRulesWarning(){
  const el=document.getElementById('rules-modal');el.style.display='flex';
  el.innerHTML=`<div class="modal-overlay"><div class="modal-box" style="border:1px solid rgba(14,165,233,0.2)" onclick="event.stopPropagation()"><div class="modal-head" style="background:linear-gradient(135deg,#0284c7,#1d4ed8)"><h2>KANABLITZ RULES</h2><p style="color:#bae6fd">Please read and acknowledge before your first run</p></div><div class="modal-body"><p>KanaBlitz is a fast reaction training mode. It uses timers, quick visual feedback, animated UI effects, and sound cues.</p><div class="modal-list-item"><span class="dot" style="background:#38bdf8"></span><div><strong>Choose One Answer</strong><br><span>Select the missing kana or kanji from four options. Keyboard shortcuts A-D and 1-4 are supported.</span></div></div><div class="modal-list-item"><span class="dot" style="background:#38bdf8"></span><div><strong>Lives and Time</strong><br><span>You have limited lives. Hard and Insanity can add time on correct answers and remove time on mistakes.</span></div></div><div class="modal-list-item"><span class="dot" style="background:#38bdf8"></span><div><strong>Scoring</strong><br><span>Score rewards speed, accuracy, streaks, and difficulty.</span></div></div><div class="modal-list-item"><span class="dot" style="background:#f59e0b"></span><div><strong>Photosensitivity Warning</strong><br><span>This mode includes motion, shake effects, flashes, pulsing timers, and bright color feedback. Stop playing if you feel discomfort.</span></div></div><div class="modal-list-item"><span class="dot" style="background:#38bdf8"></span><div><strong>Sound Notice</strong><br><span>Audio cues play during the session. Adjust your volume before starting.</span></div></div><button class="ack-btn" id="rules-ack" onclick="toggleRulesAck(this)"><span class="box"></span> I understand the rules and the photosensitivity warning.</button><div class="modal-actions"><button class="back-btn" onclick="closeRulesModal()">Close</button><button class="enter-btn" id="rules-enter" disabled style="background:linear-gradient(135deg,#0ea5e9,#2563eb)" onclick="confirmRules()">Accept Rules</button></div></div></div></div>`;
}
function toggleRulesAck(b){b.classList.toggle('checked');b.querySelector('.box').innerHTML=b.classList.contains('checked')?'✓':'';document.getElementById('rules-enter').disabled=!b.classList.contains('checked')}
function closeRulesModal(){document.getElementById('rules-modal').style.display='none'}
async function confirmRules(){rulesAcknowledged=true;localStorage.setItem('kanablitz-rules-acknowledged','true');try{await fetch('/KanaBlitz/AcceptAcknowledgement',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({key:'rules'})})}catch{}closeRulesModal()}

function showInsanityWarning(){
  const el=document.getElementById('insanity-warning');el.style.display='flex';
  el.innerHTML=`<div class="modal-overlay"><div class="modal-box" style="border:1px solid rgba(239,68,68,0.2)" onclick="event.stopPropagation()"><div class="modal-head" style="background:linear-gradient(135deg,#dc2626,#be123c)"><h2>INSANITY MODE</h2><p style="color:#fecaca">${ALPHA_LABELS[cfgAlpha]} · 45s · Kanji + Advanced Kana</p></div><div class="modal-body"><p>This mode requires solid knowledge of <strong style="color:#fff">written Japanese</strong>.</p><div class="modal-list-item"><span class="dot" style="background:#f87171"></span><div><strong>Kanji + Furigana</strong><br><span>Questions use full kanji with partial furigana.</span></div></div><div class="modal-list-item"><span class="dot" style="background:#f87171"></span><div><strong>Kanji Recognition</strong><br><span>Some questions ask you to select the correct kanji.</span></div></div><div class="modal-list-item"><span class="dot" style="background:#f87171"></span><div><strong>45 second clock</strong><br><span>Correct adds +0.5s. Every mistake costs -3s.</span></div></div><div class="modal-list-item"><span class="dot" style="background:#f87171"></span><div><strong>Compound sounds</strong><br><span>Yoon, sokuon appear frequently.</span></div></div><div class="modal-list-item"><span class="dot" style="background:#f87171"></span><div><strong>Idioms & classical vocab</strong><br><span>Four-character idioms and cultural terms.</span></div></div><button class="ack-btn" id="insanity-ack" onclick="toggleInsanityAck(this)"><span class="box"></span> I understand this mode — I am ready.</button><div class="modal-actions"><button class="back-btn" onclick="closeInsanityWarning()">Go Back</button><button class="enter-btn" id="insanity-enter" disabled style="background:linear-gradient(135deg,#dc2626,#be123c)" onclick="confirmInsanity()">Enter Insanity</button></div></div></div></div>`;
}
function toggleInsanityAck(b){b.classList.toggle('checked');b.querySelector('.box').innerHTML=b.classList.contains('checked')?'✓':'';document.getElementById('insanity-enter').disabled=!b.classList.contains('checked')}
function closeInsanityWarning(){document.getElementById('insanity-warning').style.display='none'}
async function confirmInsanity(){insanityAcknowledged=true;localStorage.setItem('insanity-acknowledged','true');try{await fetch('/KanaBlitz/AcceptAcknowledgement',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({key:'insanity'})})}catch{}closeInsanityWarning();beginArena()}

async function beginArena(){
  if(audioCtx.state==='suspended')audioCtx.resume();
  let pool=[];game.kanjiDistractors=[];game.furiganaDistractors=[];
  try{const r=await fetch(`/KanaBlitz/GetArenaPayload?alphabet=${cfgAlpha}&difficulty=${cfgDiff}`);if(r.ok){const d=await r.json();pool=d.words||[];game.kanjiDistractors=d.kanjiDistractors||[];game.furiganaDistractors=d.furiganaDistractors||[]}}catch{}
  if(pool.length===0){const k=['あ','い','う','え','お','か','き','く','け','こ'];pool=k.map(k=>({kana:k,romaji:k,meaning:'Local Fallback',category:'Local',missing:k,display:`<span class="blank">?</span>`}))}
  game.pool=pool.sort(()=>Math.random()-0.5);
  game.score=0;game.points=0;game.mistakes=0;game.hp=3;game.streak=0;game.maxCombo=0;game.isProcessing=false;game.finished=false;
  game.timeLeft=TIME_LIMITS[cfgDiff];game.runStartedAt=performance.now();

  document.getElementById('ui-lobby').style.display='none';
  document.getElementById('ui-results').style.display='none';
  document.getElementById('ui-arena').style.display='block';
  document.getElementById('guide-btn').style.display='none';
  const ac=ALPHA_COLORS[cfgAlpha],dc=DIFF_COLORS[cfgDiff];
  document.getElementById('arena-alpha-tag').textContent=ALPHA_LABELS[cfgAlpha];document.getElementById('arena-alpha-tag').style.borderColor=ac+'44';document.getElementById('arena-alpha-tag').style.color=ac;
  document.getElementById('arena-diff-tag').textContent=DIFF_LABELS[cfgDiff];document.getElementById('arena-diff-tag').style.borderColor=dc+'44';document.getElementById('arena-diff-tag').style.color=dc;
  document.getElementById('arena-divider').style.background=`linear-gradient(90deg,${ac},${dc})`;
  renderHearts(3);document.getElementById('hud-score').textContent='0';
  document.getElementById('hud-combo').className='hud-combo';

  // Countdown
  const displayEl=document.getElementById('arena-display'),optGrid=document.getElementById('arena-options'),catEl=document.getElementById('arena-category'),meanEl=document.getElementById('arena-meaning');
  optGrid.style.display='none';catEl.style.display='none';meanEl.textContent='Get Ready';
  let cd=3;displayEl.innerHTML=`<div class="countdown-num anim-countdown" style="color:${dc}">${cd}</div>`;
  const cdI=setInterval(()=>{cd--;if(cd<=0){clearInterval(cdI);optGrid.style.display='grid';catEl.style.display='inline-flex';game.runStartedAt=performance.now();nextTarget();startGameTimer()}else{displayEl.innerHTML=`<div class="countdown-num anim-countdown" style="color:${dc}">${cd}</div>`}},700);
}

function startGameTimer(){
  updateTimerDisplay();
  game.timer=setInterval(()=>{game.timeLeft-=0.1;if(game.timeLeft<=0){game.timeLeft=0;clearInterval(game.timer);updateTimerDisplay();finishGame('timeout');return}updateTimerDisplay()},100);
}

let lastTickSec=-1;
function updateTimerDisplay(){
  const t=Math.max(0,Math.ceil(game.timeLeft)),m=Math.floor(t/60).toString().padStart(2,'0'),s=(t%60).toString().padStart(2,'0');
  const el=document.getElementById('hud-timer'),fill=document.getElementById('timer-bar-fill');
  const pct=(game.timeLeft/TIME_LIMITS[cfgDiff])*100;fill.style.width=pct+'%';
  if(game.timeLeft<=10){el.style.color='#ef4444';fill.style.background='linear-gradient(90deg,#ef4444,#dc2626)';fill.style.boxShadow='0 0 12px rgba(239,68,68,0.6)';if(t!==lastTickSec&&t>0){playTickSound();lastTickSec=t}el.className='time anim-timer-pulse'}
  else if(game.timeLeft<=30){el.style.color='#f59e0b';fill.style.background='linear-gradient(90deg,#f59e0b,#d97706)';fill.style.boxShadow='none';el.className='time';lastTickSec=-1}
  else{el.style.color='#22c55e';fill.style.background='linear-gradient(90deg,#22c55e,#16a34a)';fill.style.boxShadow='none';el.className='time';lastTickSec=-1}
  el.textContent=`${m}:${s}`;
}

function nextTarget(){
  if(game.pool.length===0||game.finished){finishGame('victory');return}
  const q=game.pool.shift();game.current=q;game.qStartedAt=performance.now();game.isProcessing=false;
  const meaning=document.getElementById('arena-meaning');meaning.textContent=cfgDiff==='easy'?'':(q.meaning||'');
  const catEl=document.getElementById('arena-category');
  if(q.category){catEl.style.display='inline-flex';catEl.innerHTML=`<span class="icon">${SVG.tag}</span> ${q.category}`}else catEl.style.display='none';
  const displayEl=document.getElementById('arena-display');
  if(cfgDiff==='easy')displayEl.innerHTML=`<span style="font-size:3.5rem">${(q.romaji||q.kana||'').toUpperCase()}</span>`;
  else if(q.display&&q.display.length>0)displayEl.innerHTML=q.display;
  else displayEl.innerHTML=`<span class="blank">?</span>`;
  const correct=q.missing,qType=q.questionType||'kana',wAlpha=q.alphabet||cfgAlpha;
  const badge=document.getElementById('arena-badge');
  const bLabels={easy:'ROMAJI → KANA',kana:'MISSING KANA',furigana_blank:'FURIGANA READING',kanji_from_furigana:'KANJI RECOGNITION'};
  badge.innerHTML=`<span class="dot"></span> <span>${bLabels[qType]||'TARGET RECOGNITION'}</span>`;
  const options=generateOptions(correct,qType,wAlpha);renderOptions(options,correct,qType);updateScoreDisplay();
}

function generateOptions(correct,qType,wAlpha){
  const ch=[correct];
  if(qType==='kanji_from_furigana'){const p=(game.kanjiDistractors||[]).filter(k=>k!==correct).sort(()=>Math.random()-0.5);while(ch.length<4&&p.length){const c=p.shift();if(!ch.includes(c))ch.push(c)}const fb=['学校','先生','天気','電車','家族','友達','時間','病院','電話','銀行','大学','元気','猫','犬','山','川','花','月','海','心','夢','力','道','映画','音楽'].filter(k=>k!==correct&&!ch.includes(k)).sort(()=>Math.random()-0.5);while(ch.length<4&&fb.length)ch.push(fb.shift())}
  else if(qType==='furigana_blank'||[...correct].length>1){const a=wAlpha||cfgAlpha;const mp=(MULTI_POOLS[a]||MULTI_POOLS.mixed).filter(k=>k!==correct).sort(()=>Math.random()-0.5);while(ch.length<4&&mp.length){const c=mp.shift();if(!ch.includes(c))ch.push(c)}}
  else{const a=wAlpha||cfgAlpha;const p=(KANA_POOLS[a]||KANA_POOLS.hiragana).filter(k=>k!==correct).sort(()=>Math.random()-0.5);while(ch.length<4&&p.length){const c=p.shift();if(!ch.includes(c))ch.push(c)}}
  if(ch.length<4){const fb=KANA_POOLS.hiragana.filter(k=>!ch.includes(k));while(ch.length<4&&fb.length)ch.push(fb.shift())}
  return ch.sort(()=>Math.random()-0.5);
}

function renderOptions(options,correct,qType){
  const c=document.getElementById('arena-options');c.innerHTML='';
  const isK=qType==='kanji_from_furigana',ts=isK?'1.3rem':'2rem';
  options.forEach((opt,idx)=>{
    const d=document.createElement('div');d.className='option-btn default';d.id=`opt-${idx}`;
    d.innerHTML=`<div class="opt-badge">${OPTION_LETTERS[idx]}</div><span class="opt-text" style="font-size:${ts}">${opt}</span><div class="opt-key">${OPTION_LETTERS[idx]}</div>`;
    d.onclick=()=>handleAnswer(opt,idx,correct);c.appendChild(d);
  });
}

function flashScreen(type){const f=document.getElementById(`${type}-flash`);f.className=`screen-flash ${type} show`;setTimeout(()=>{f.className='screen-flash'},300)}
function showScorePopup(val){const el=document.getElementById('score-popup');el.textContent=`+${val}`;el.style.display='block';el.className='score-popup anim-float-up';setTimeout(()=>{el.style.display='none';el.className='score-popup'},800)}
function showComboPopup(streak){const el=document.getElementById('combo-popup');el.innerHTML=`<span class="icon" style="color:#ef4444;margin-right:4px">${SVG.flame}</span> ${streak}x COMBO!`;el.style.display='block';el.className='combo-popup anim-scale-pop';setTimeout(()=>{el.style.display='none';el.className='combo-popup'},1200)}

function handleAnswer(val,idx,correct){
  if(game.isProcessing||game.finished)return;game.isProcessing=true;
  const elapsed=(performance.now()-game.qStartedAt)/1000,btn=document.getElementById(`opt-${idx}`);
  if(val===correct){
    const sw=SPEED_WINDOW[cfgDiff],sf=Math.max(0,(sw-elapsed)/sw),base=100,sb=Math.round(sf*80),cb=Math.min(game.streak,30)*8,dm=SCORE_DIFFMULT[cfgDiff],earned=Math.round((base+sb+cb)*dm);
    game.score++;game.points+=earned;game.streak++;if(game.streak>game.maxCombo)game.maxCombo=game.streak;
    const bonus=TIME_BONUS[cfgDiff];if(bonus>0){game.timeLeft=Math.min(TIME_LIMITS[cfgDiff]+30,game.timeLeft+bonus);showTimeDelta(`+${bonus}s`,'#10b981')}
    btn.className='option-btn correct';btn.innerHTML=`<div class="opt-badge">${OPTION_LETTERS[idx]}</div><span class="opt-text">${val}</span><div class="opt-status"><span class="opt-status-icon">✓</span></div>`;
    flashScreen('green');playCorrectSound();showScorePopup(earned);
    if(game.streak>=3)setTimeout(()=>playComboSound(game.streak),100);
    if(game.streak>=5)setTimeout(()=>showComboPopup(game.streak),200);
    if(game.streak>=5)document.getElementById('arena-card').classList.add('correct-glow');else document.getElementById('arena-card').classList.remove('correct-glow');
    updateScoreDisplay();setTimeout(()=>nextTarget(),250);
  }else{
    game.mistakes++;game.streak=0;game.hp--;
    document.getElementById('arena-card').classList.remove('correct-glow');
    const pen=TIME_PENALTY[cfgDiff];if(pen>0){game.timeLeft=Math.max(0,game.timeLeft-pen);showTimeDelta(`-${pen}s`,'#ef4444')}
    btn.className='option-btn wrong';btn.innerHTML=`<div class="opt-badge">${OPTION_LETTERS[idx]}</div><span class="opt-text">${val}</span><div class="opt-status"><span class="opt-status-icon">✕</span></div>`;
    document.querySelectorAll('.option-btn').forEach((el,i)=>{if(el.textContent.includes(correct)&&!el.classList.contains('wrong')){el.className='option-btn reveal';el.innerHTML=`<div class="opt-badge">${OPTION_LETTERS[i]}</div><span class="opt-text">${correct}</span><div class="opt-status"><span class="opt-status-icon">✓</span></div>`}});
    flashScreen('red');playWrongSound();renderHearts(game.hp);updateScoreDisplay();
    if(game.hp<=0||game.timeLeft<=0)setTimeout(()=>finishGame(game.timeLeft<=0?'timeout':'defeat'),700);
    else setTimeout(()=>nextTarget(),700);
  }
}

function showTimeDelta(text,color){const el=document.getElementById('time-delta');el.textContent=text;el.style.color=color;el.style.opacity='1';setTimeout(()=>{el.style.opacity='0'},800)}
function updateScoreDisplay(){
  document.getElementById('hud-score').textContent=game.points.toLocaleString();
  document.getElementById('score-count').textContent=`${game.score} correct`;
  const combo=document.getElementById('hud-combo');
  if(game.streak>=3){combo.className=`hud-combo show ${game.streak>=15?'streak-15':game.streak>=10?'streak-10':'streak-3'} anim-combo-flash`;combo.innerHTML=`<span class="icon" style="color:#ef4444;margin-right:3px">${SVG.flame}</span> COMBO x${(1+game.streak*0.05).toFixed(1)}`}else combo.className='hud-combo';
  const fh=document.getElementById('footer-hint');fh.innerHTML=game.streak>=3?`<span class="icon" style="color:#ef4444;margin-right:3px">${SVG.flame}</span> ${game.streak} streak`:'Press keys A, B, C, D (or 1-4)';
  const sf=document.getElementById('streak-fill'),pct=Math.min(game.streak*5,100);sf.style.width=`${pct}%`;
  sf.style.background=game.streak>=15?'linear-gradient(90deg,#ef4444,#f59e0b)':game.streak>=10?'linear-gradient(90deg,#f59e0b,#ea580c)':game.streak>=5?'#f59e0b':'#38bdf8';
}

