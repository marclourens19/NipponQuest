@using Microsoft.AspNetCore.Identity
@inject UserManager<NipponQuest.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = "KanaBlitz Arena";
    var currentUser = await UserManager.GetUserAsync(User);
    var isDev = currentUser?.GamerTag == "NQDev" ? "true" : "false";
    Layout = null;
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>KanaBlitz Arena</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <script>window.isDev = @Html.Raw(isDev);</script>
<style>
/* ══════════════════════════════════════════════════════════════ */
/* BASE                                                           */
/* ══════════════════════════════════════════════════════════════ */
*{box-sizing:border-box;margin:0;padding:0}
body{
  font-family:'Nunito',sans-serif;
  background:#020617;
  color:#e2e8f0;
  min-height:100vh;
  overflow-x:hidden;
}
.container{max-width:768px;margin:0 auto;padding:1.5rem 1rem;position:relative;z-index:10}

/* ══════════════════════════════════════════════════════════════ */
/* NIPPONQUEST BACK ARROW                                         */
/* ══════════════════════════════════════════════════════════════ */
.nq-back-btn {
  position: fixed;
  top: 1.5rem;
  left: 1.5rem;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.4rem 0.8rem;
  border-radius: 999px;
  background: rgba(30,41,59,0.8);
  border: 1px solid #334155;
  color: #94a3b8;
  font-size: 0.65rem;
  font-weight: 900;
  letter-spacing: 1px;
  text-transform: uppercase;
  text-decoration: none;
  backdrop-filter: blur(8px);
  transition: all 0.2s;
  font-family: 'Nunito', sans-serif;
}
.nq-back-btn:hover {
  background: rgba(51,65,85,0.8);
  color: #e2e8f0;
  transform: translateX(-3px);
}
@@media(max-width: 640px) {
  .nq-back-btn {
    top: 1rem;
    left: 1rem;
    padding: 0.3rem 0.6rem;
    font-size: 0.55rem;
  }
}

/* ══════════════════════════════════════════════════════════════ */
/* SVG ICON HELPERS                                               */
/* ══════════════════════════════════════════════════════════════ */
.icon{display:inline-flex;align-items:center;justify-content:center;vertical-align:middle}
.icon svg{display:block}

/* ══════════════════════════════════════════════════════════════ */
/* ANIMATED BACKGROUND                                            */
/* ══════════════════════════════════════════════════════════════ */
.bg-layer{position:fixed;inset:0;z-index:0;pointer-events:none}
.bg-aurora{
  position:absolute;inset:0;
  background:linear-gradient(135deg,#020617,#1e1b4b22,#020617);
  background-size:200% 200%;
  animation:aurora 8s ease infinite;
}
.bg-radial-top{position:absolute;inset:0;background:radial-gradient(ellipse at top,rgba(14,165,233,0.06),transparent 70%)}
.bg-radial-br{position:absolute;inset:0;background:radial-gradient(ellipse at bottom right,rgba(139,92,246,0.05),transparent 70%)}
.bg-vignette{position:fixed;inset:0;pointer-events:none;z-index:1;box-shadow:inset 0 0 150px rgba(0,0,0,0.6),inset 0 0 50px rgba(0,0,0,0.3)}
.bg-particle{
  position:absolute;border-radius:50%;
  animation:particle-float linear infinite;
  opacity:0;
}

/* ══════════════════════════════════════════════════════════════ */
/* KEYFRAMES                                                    */
/* ══════════════════════════════════════════════════════════════ */
@@keyframes aurora{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
@@keyframes particle-float{0%{transform:translateY(0);opacity:0}10%{opacity:1}90%{opacity:1}100%{transform:translateY(-400px);opacity:0}}
@@keyframes slide-up{0%{opacity:0;transform:translateY(24px)}100%{opacity:1;transform:translateY(0)}}
@@keyframes float-up{0%{opacity:1;transform:translateY(0) scale(1)}100%{opacity:0;transform:translateY(-80px) scale(1.3)}}
@@keyframes scale-pop{0%{transform:scale(0.5);opacity:0}50%{transform:scale(1.15)}100%{transform:scale(1);opacity:1}}
@@keyframes shake{0%,100%{transform:translateX(0)}10%{transform:translateX(-6px)}20%{transform:translateX(6px)}30%{transform:translateX(-4px)}40%{transform:translateX(4px)}50%{transform:translateX(-2px)}60%{transform:translateX(2px)}}
@@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}
@@keyframes timer-pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.06)}}
@@keyframes combo-flash{0%{transform:scale(1);filter:brightness(1)}50%{transform:scale(1.15);filter:brightness(1.4)}100%{transform:scale(1);filter:brightness(1)}}
@@keyframes countdown-pop{0%{transform:scale(0.5);opacity:0}50%{transform:scale(1.2)}100%{transform:scale(1);opacity:1}}
@@keyframes confetti-fall{0%{transform:translateY(-100vh) rotate(0deg);opacity:1}100%{transform:translateY(100vh) rotate(720deg);opacity:0}}
@@keyframes spin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}

.anim-slide-up{animation:slide-up 0.5s ease both}
.anim-shake{animation:shake 0.5s ease}
.anim-float-up{animation:float-up 0.8s ease-out forwards}
.anim-scale-pop{animation:scale-pop 0.4s ease-out both}
.anim-countdown{animation:countdown-pop 0.5s ease-out both}
.anim-combo-flash{animation:combo-flash 0.3s ease-out}
.anim-timer-pulse{animation:timer-pulse 0.8s ease-in-out infinite}

/* ══════════════════════════════════════════════════════════════ */
/* SCREEN FLASHES                                                 */
/* ══════════════════════════════════════════════════════════════ */
.screen-flash{position:fixed;inset:0;z-index:50;pointer-events:none;transition:opacity 0.3s;opacity:0}
.screen-flash.show{opacity:1}
.screen-flash.green{background:radial-gradient(circle,rgba(16,185,129,0.2),transparent 70%)}
.screen-flash.red{background:radial-gradient(circle,rgba(239,68,68,0.2),transparent 70%)}

/* ══════════════════════════════════════════════════════════════ */
/* TOP BAR                                                        */
/* ══════════════════════════════════════════════════════════════ */
.top-bar{text-align:center;margin-bottom:1.25rem}
.top-bar-inner{display:inline-flex;align-items:center;gap:0.5rem;font-size:0.5rem;font-weight:900;letter-spacing:0.3em;text-transform:uppercase;color:#475569}
.top-bar-line{width:48px;height:1px;background:linear-gradient(90deg,transparent,rgba(56,189,248,0.3),transparent)}

/* ══════════════════════════════════════════════════════════════ */
/* LOBBY                                                          */
/* ══════════════════════════════════════════════════════════════ */
.lobby-header{text-align:center;margin-bottom:2rem}
.lobby-badge{
  display:inline-flex;align-items:center;gap:0.4rem;
  padding:0.35rem 0.75rem;border-radius:999px;
  background:rgba(120,53,15,0.3);border:1px solid rgba(245,158,11,0.2);
  color:#fcd34d;font-size:0.6rem;font-weight:900;
  letter-spacing:1.5px;text-transform:uppercase;margin-bottom:1rem;
}
.lobby-badge .dot{width:6px;height:6px;border-radius:50%;background:#fbbf24;animation:pulse 1.5s infinite}
.lobby-header h1{font-size:3.2rem;font-weight:900;letter-spacing:-2px;color:#fff}
.lobby-header h1 span{color:#fbbf24}
.lobby-header .sub{color:#64748b;font-weight:700;font-size:0.85rem;margin-bottom:0.75rem}
.lobby-meta{
  display:flex;align-items:center;justify-content:center;
  gap:0.75rem;font-size:0.65rem;font-weight:700;color:#475569;
  text-transform:uppercase;letter-spacing:0.5px;flex-wrap:wrap;
}
.lobby-meta .dot{width:4px;height:4px;border-radius:50%;background:#fbbf24}

/* Steps */
.steps{display:flex;align-items:center;justify-content:center;gap:0.5rem;margin-bottom:1.5rem;flex-wrap:wrap}
.step-pill{
  display:flex;align-items:center;gap:0.35rem;
  padding:0.35rem 0.75rem;border-radius:999px;
  font-size:0.6rem;font-weight:900;letter-spacing:1.5px;
  text-transform:uppercase;border:2px solid;transition:all 0.3s;
}
.step-pill.done{background:rgba(16,185,129,0.15);color:#6ee7b7;border-color:rgba(16,185,129,0.3)}
.step-pill.active{background:rgba(59,130,246,0.15);color:#93c5fd;border-color:rgba(59,130,246,0.3)}
.step-pill.inactive{background:rgba(30,41,59,0.5);color:#475569;border-color:#334155}
.step-pill .num{
  width:16px;height:16px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:0.5rem;font-weight:900;
}
.step-pill.done .num{background:#10b981;color:#fff}
.step-pill.active .num{background:#3b82f6;color:#fff}
.step-pill.inactive .num{background:#334155;color:#64748b}
.step-line{width:24px;height:2px;border-radius:2px;transition:all 0.3s}
.step-line.done{background:rgba(16,185,129,0.5)}
.step-line.inactive{background:#334155}

/* Section headers */
.section-header{display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem}
.section-header .num{
  padding:0.3rem 0.6rem;border-radius:0.5rem;
  background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.8);
  font-size:0.5rem;font-weight:900;letter-spacing:1px;
}
.section-header h3{font-size:0.6rem;font-weight:900;color:#475569;text-transform:uppercase;letter-spacing:2px}
.section-sub{font-size:0.6rem;font-weight:700;color:#475569;display:flex;align-items:center;gap:0.4rem;margin-bottom:0.5rem}
.section-sub .dot{width:4px;height:4px;border-radius:50%;background:#fbbf24}

/* Choice cards grid */
.choice-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem;margin-bottom:1.5rem}
@@media(max-width:640px){.choice-grid{grid-template-columns:repeat(2,1fr)}}
.choice-card{
  padding:1rem 0.5rem;border-radius:1rem;
  border:2px solid #334155;background:rgba(30,41,59,0.5);
  text-align:center;cursor:pointer;transition:all 0.2s;
  position:relative;overflow:hidden;
}
.choice-card:hover:not(.locked):not(.selected){border-color:#475569;transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,0.3)}
.choice-card.selected{transform:translateY(-3px) scale(1.02)}
.choice-card.locked{cursor:not-allowed;opacity:0.4}
.choice-card.locked:hover{transform:none;box-shadow:none}
.choice-card .kana-display{font-size:1.8rem;font-weight:900;margin-bottom:0.25rem;line-height:1.2}
.choice-card .label{font-size:0.7rem;font-weight:900;letter-spacing:1px;text-transform:uppercase;margin-bottom:0.15rem;color:#fff}
.choice-card .sub{font-size:0.55rem;font-weight:700;color:#64748b;margin-bottom:0.4rem}
.choice-card .hint{
  display:inline-block;padding:0.15rem 0.5rem;
  border-radius:999px;font-size:0.45rem;font-weight:900;
  letter-spacing:1px;text-transform:uppercase;border:1px solid;
}
.choice-card .check{
  position:absolute;top:0.3rem;right:0.3rem;
  width:18px;height:18px;border-radius:50%;
  background:rgba(255,255,255,0.9);
  display:flex;align-items:center;justify-content:center;
  font-size:0.55rem;font-weight:900;
}
.choice-card .lock-badge{
  position:absolute;top:0.3rem;right:0.3rem;
  font-size:0.45rem;font-weight:900;letter-spacing:1px;
  padding:0.15rem 0.4rem;border-radius:0.4rem;
  background:#0f172a;color:#fbbf24;border:1px solid rgba(251,191,36,0.3);
}
.choice-card .req-badge{
  position:absolute;bottom:0.3rem;left:0.4rem;right:0.4rem;
  font-size:0.4rem;font-weight:700;
  background:rgba(120,53,15,0.4);border:1px solid rgba(245,158,11,0.2);
  color:#fcd34d;padding:0.2rem 0.3rem;border-radius:0.5rem;text-align:center;
}
.choice-card .time-row{
  display:flex;align-items:center;justify-content:center;
  gap:0.3rem;font-size:0.55rem;font-weight:700;color:#64748b;margin-bottom:0.4rem;
}
.choice-card .reward-row{display:flex;align-items:center;justify-content:center;gap:0.4rem}
.choice-card .xp-badge{
  width:16px;height:16px;border-radius:3px;background:#0ea5e9;color:#fff;
  display:flex;align-items:center;justify-content:center;font-size:0.4rem;font-weight:900;
}
.choice-card .gold-badge{
  width:16px;height:16px;border-radius:50%;background:#fbbf24;
  border:2px solid #d97706;color:#92400e;
  display:flex;align-items:center;justify-content:center;font-size:0.4rem;font-weight:900;
}
.choice-card .xp-val,.choice-card .gold-val{font-size:0.55rem;font-weight:900;color:#fff}

/* CTA button */
.cta-btn{
  width:100%;padding:0.85rem;border-radius:1rem;
  font-weight:900;font-size:0.85rem;letter-spacing:1px;
  border:none;cursor:pointer;transition:all 0.3s;
  display:flex;align-items:center;justify-content:center;gap:0.5rem;
  font-family:'Nunito',sans-serif;
}
.cta-btn.ready{color:#fff}
.cta-btn.ready:hover{transform:translateY(-2px)}
.cta-btn.disabled{background:rgba(30,41,59,0.5);color:#475569;cursor:not-allowed;border:1px solid #334155}
.cta-hint{text-align:center;color:#475569;font-size:0.6rem;font-weight:700;margin-top:0.5rem}

/* Dev toggle */
.dev-toggle{font-size:0.55rem;font-weight:700;padding:0.25rem 0.6rem;border-radius:999px;border:1px solid;cursor:pointer;transition:all 0.2s;font-family:'Nunito',sans-serif;background:transparent}
.dev-toggle.locked-toggle{color:#fcd34d;border-color:rgba(245,158,11,0.3);background:rgba(120,53,15,0.3)}
.dev-toggle.unlocked-toggle{color:#6ee7b7;border-color:rgba(16,185,129,0.3);background:rgba(6,78,59,0.3)}

/* ══════════════════════════════════════════════════════════════ */
/* ARENA                                                          */
/* ══════════════════════════════════════════════════════════════ */
.arena{display:none}
.arena-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem}
.exit-btn{
  display:flex;align-items:center;gap:0.3rem;padding:0.35rem 0.6rem;
  border-radius:999px;background:rgba(30,41,59,0.5);border:1px solid #334155;
  color:#94a3b8;font-size:0.55rem;font-weight:900;letter-spacing:1px;
  text-transform:uppercase;cursor:pointer;transition:all 0.2s;font-family:'Nunito',sans-serif;
}
.exit-btn:hover{background:rgba(127,29,29,0.3);border-color:rgba(239,68,68,0.3);color:#fca5a5}
.arena-tags{display:flex;gap:0.3rem}
.arena-tags span{
  padding:0.25rem 0.5rem;border-radius:0.4rem;
  background:rgba(30,41,59,0.5);border:1px solid #334155;
  font-size:0.5rem;font-weight:700;
}

/* HUD */
.hud{
  background:rgba(30,41,59,0.6);backdrop-filter:blur(12px);
  border:1px solid rgba(51,65,85,0.5);border-radius:1rem;
  padding:0.75rem 1rem;margin-bottom:0.75rem;
  box-shadow:0 4px 16px rgba(0,0,0,0.2);
}
.timer-bar{height:6px;background:rgba(51,65,85,0.5);border-radius:3px;overflow:hidden;margin-bottom:0.6rem}
.timer-bar-fill{height:100%;border-radius:3px;transition:width 0.3s linear,background 0.3s}
.hud-row{display:flex;align-items:center;justify-content:space-between}
.hud-timer{display:flex;align-items:center;gap:0.4rem}
.hud-timer .clock-icon{color:#94a3b8}
.hud-timer .time{font-size:1.4rem;font-weight:900;font-family:'Nunito',monospace}
.hud-center{text-align:center}
.hud-combo{
  display:none;font-size:0.5rem;font-weight:900;letter-spacing:1px;
  padding:0.2rem 0.5rem;border-radius:999px;margin-bottom:0.2rem;
}
.hud-combo.show{display:inline-block}
.hud-combo.streak-3{background:rgba(120,53,15,0.4);color:#fcd34d;border:1px solid rgba(245,158,11,0.3)}
.hud-combo.streak-10{background:linear-gradient(135deg,#f59e0b,#ea580c);color:#fff}
.hud-combo.streak-15{background:linear-gradient(135deg,#ef4444,#f59e0b);color:#fff}
.hud-score{font-size:0.55rem;font-weight:900;color:#64748b;text-transform:uppercase;letter-spacing:1px}
.hud-score span{color:#fff}

/* Flat hearts — NO animation, NO emoji */
.hud-hearts{display:flex;gap:0.3rem;align-items:center}
.heart-icon{width:18px;height:18px;display:flex;align-items:center;justify-content:center}
.heart-icon svg{width:16px;height:16px}
.heart-icon.alive svg{fill:#ef4444;stroke:none}
.heart-icon.dead svg{fill:#334155;stroke:none}

/* Arena card */
.arena-card{
  border-radius:1.5rem;border:2px solid rgba(51,65,85,0.5);
  padding:0.35rem;transition:border-color 0.3s,box-shadow 0.3s;
}
.arena-card.correct-glow{border-color:#22c55e;box-shadow:0 0 30px rgba(34,197,94,0.15)}
.arena-card-inner{
  background:rgba(30,41,59,0.4);backdrop-filter:blur(8px);
  border-radius:1.25rem;overflow:hidden;border:1px solid rgba(51,65,85,0.3);
}
.streak-bar{height:5px;background:rgba(51,65,85,0.5)}
.streak-fill{height:100%;transition:width 0.3s}
.arena-body{padding:2rem 1rem;text-align:center;position:relative}
.arena-badge{
  position:absolute;top:0.75rem;right:0.75rem;
  display:flex;align-items:center;gap:0.35rem;
  padding:0.25rem 0.6rem;background:rgba(51,65,85,0.5);border:1px solid rgba(71,85,105,0.5);
  border-radius:999px;font-size:0.45rem;font-weight:900;color:#64748b;
}
.arena-badge .dot{width:5px;height:5px;border-radius:50%;background:#22c55e;animation:pulse 1.5s infinite}
.arena-meaning{font-weight:900;font-size:0.8rem;color:#fff;text-transform:uppercase;letter-spacing:2px;margin-bottom:0.2rem}
.arena-divider{width:40px;height:3px;border-radius:999px;margin:0.5rem auto}
.arena-category{
  display:inline-flex;align-items:center;gap:0.3rem;
  padding:0.25rem 0.5rem;background:rgba(51,65,85,0.5);border-radius:0.5rem;
  font-size:0.5rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:2px;margin-bottom:0.75rem;
}
.arena-display{font-size:3.5rem;font-weight:900;color:#fff;padding:1.5rem 0}
.arena-display .blank,.arena-display .missing-placeholder{
  display:inline-block;min-width:50px;height:60px;border-bottom:3px solid #ef4444;
  background:rgba(239,68,68,0.08);border-radius:0.5rem;
  color:#fca5a5;font-size:2.5rem;margin:0 0.3rem;padding:0 0.4rem;
  animation:pulse 1.2s infinite;vertical-align:bottom;line-height:1;
}

/* 2x2 Options */
.options-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-top:1rem}
.option-btn{
  padding:1.25rem 0.75rem;border-radius:0.75rem;border:2px solid;transition:all 0.2s;
  cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;
  position:relative;overflow:hidden;min-height:100px;font-family:'Nunito',sans-serif;
}
.option-btn:not(.disabled):hover{transform:translateY(-2px)}
.option-btn .opt-badge{
  position:absolute;top:0.4rem;left:0.4rem;
  width:20px;height:20px;border-radius:0.3rem;
  display:flex;align-items:center;justify-content:center;
  font-size:0.5rem;font-weight:900;
}
.option-btn .opt-status{position:absolute;top:0.4rem;right:0.4rem}
.option-btn .opt-status-icon{
  width:20px;height:20px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:0.5rem;font-weight:900;
}
.option-btn .opt-key{
  position:absolute;bottom:0.4rem;right:0.4rem;
  font-size:0.4rem;font-weight:900;letter-spacing:1px;
  padding:0.15rem 0.3rem;border-radius:0.25rem;border:1px solid;
}
.option-btn .opt-text{font-size:2rem;font-weight:900;margin-top:0.3rem;transition:transform 0.2s}

/* Option states */
.option-btn.default{background:rgba(51,65,85,0.5);border-color:#475569;color:#e2e8f0}
.option-btn.default:hover{background:rgba(51,65,85,0.7);border-color:rgba(56,189,248,0.5);box-shadow:0 4px 12px rgba(56,189,248,0.1)}
.option-btn.default .opt-badge{background:#475569;color:#94a3b8}
.option-btn.default:hover .opt-badge{background:#38bdf8;color:#fff}
.option-btn.default .opt-key{border-color:rgba(71,85,105,0.5);color:#64748b}

.option-btn.correct{background:linear-gradient(135deg,#059669,#047857);border-color:#10b981;color:#fff;box-shadow:0 4px 16px rgba(16,185,129,0.3);transform:scale(1.02);z-index:10}
.option-btn.correct .opt-badge{background:rgba(255,255,255,0.2);color:#fff}
.option-btn.correct .opt-status-icon{background:rgba(255,255,255,0.9);color:#10b981}
.option-btn.correct .opt-key{border-color:rgba(255,255,255,0.3);color:rgba(255,255,255,0.7)}

.option-btn.wrong{background:linear-gradient(135deg,#dc2626,#b91c1c);border-color:#ef4444;color:#fff;animation:shake 0.4s}
.option-btn.wrong .opt-badge{background:rgba(255,255,255,0.2);color:#fff}
.option-btn.wrong .opt-status-icon{background:rgba(255,255,255,0.9);color:#ef4444}
.option-btn.wrong .opt-key{border-color:rgba(255,255,255,0.3);color:rgba(255,255,255,0.7)}

.option-btn.reveal{background:rgba(16,185,129,0.15);border-color:rgba(16,185,129,0.5);color:#6ee7b7}
.option-btn.reveal .opt-badge{background:#10b981;color:#fff}
.option-btn.reveal .opt-status-icon{background:#10b981;color:#fff}
.option-btn.reveal .opt-key{border-color:rgba(16,185,129,0.4);color:#6ee7b7}

.option-btn.disabled{opacity:0.6;cursor:default}
.option-btn.disabled:hover{transform:none;box-shadow:none}

.arena-footer{margin-top:1rem;display:flex;align-items:center;justify-content:center;gap:0.75rem;font-size:0.6rem;font-weight:700;color:#64748b}

/* Floating popups */
.score-popup{
  position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);
  pointer-events:none;z-index:40;
  font-size:3rem;font-weight:900;color:#34d399;
  text-shadow:0 0 20px rgba(16,185,129,0.6);
}
.combo-popup{
  position:fixed;top:33%;left:50%;transform:translateX(-50%);
  pointer-events:none;z-index:40;
  font-size:2rem;font-weight:900;color:#fbbf24;
  text-shadow:0 0 30px rgba(245,158,11,0.8);
}

/* Countdown */
.countdown-display{
  display:flex;align-items:center;justify-content:center;padding:6rem 0;
}
.countdown-num{font-size:8rem;font-weight:900}

/* ══════════════════════════════════════════════════════════════ */
/* MODALS                                                         */
/* ══════════════════════════════════════════════════════════════ */
.modal-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);
  z-index:100;display:flex;align-items:center;justify-content:center;padding:1rem;
}
.modal-box{
  background:#0f172a;border-radius:1.5rem;max-width:520px;width:100%;
  max-height:85vh;overflow-y:auto;box-shadow:0 24px 60px rgba(0,0,0,0.4);
}
.modal-head{padding:1.25rem;text-align:center;border-radius:1.5rem 1.5rem 0 0;position:relative}
.modal-head h2{font-size:1rem;font-weight:900;color:#fff;text-transform:uppercase;letter-spacing:1px}
.modal-head p{font-size:0.65rem;margin-top:0.2rem}
.modal-head .close-btn{position:absolute;top:0.75rem;right:0.75rem;background:rgba(255,255,255,0.2);color:#fff;border:none;width:24px;height:24px;border-radius:50%;cursor:pointer;font-size:0.65rem;font-family:'Nunito',sans-serif}
.modal-body{padding:1.25rem}
.modal-body p{font-size:0.75rem;color:#94a3b8;line-height:1.6;margin-bottom:0.75rem}
.modal-list-item{
  display:flex;gap:0.6rem;padding:0.6rem;
  background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06);
  border-radius:0.6rem;margin-bottom:0.4rem;
}
.modal-list-item .dot{width:5px;height:5px;border-radius:50%;margin-top:0.3rem;flex-shrink:0}
.modal-list-item strong{color:#fff;font-size:0.65rem}
.modal-list-item span{color:#94a3b8;font-size:0.6rem}
.ack-btn{
  width:100%;display:flex;align-items:center;gap:0.6rem;
  padding:0.6rem;border-radius:0.6rem;border:2px solid #334155;
  background:transparent;color:#94a3b8;font-size:0.7rem;font-weight:700;
  cursor:pointer;transition:all 0.2s;margin-bottom:0.6rem;text-align:left;
  font-family:'Nunito',sans-serif;
}
.ack-btn.checked{background:rgba(34,197,94,0.1);border-color:rgba(34,197,94,0.4);color:#6ee7b7}
.ack-btn .box{
  width:16px;height:16px;border-radius:3px;border:2px solid #475569;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
  transition:all 0.2s;font-size:0.5rem;
}
.ack-btn.checked .box{background:#22c55e;border-color:#22c55e;color:#fff}
.modal-actions{display:flex;gap:0.4rem}
.modal-actions button{
  flex:1;padding:0.6rem;border-radius:0.6rem;font-weight:900;font-size:0.7rem;
  border:none;cursor:pointer;transition:all 0.2s;font-family:'Nunito',sans-serif;
}
.modal-actions .back-btn{background:#1e293b;color:#cbd5e1}
.modal-actions .back-btn:hover{background:#334155}
.modal-actions .enter-btn{color:#fff}
.modal-actions .enter-btn:disabled{opacity:0.4;cursor:not-allowed}

/* Exit modal */
.exit-modal{
  background:#0f172a;border:1px solid #334155;border-radius:1.5rem;
  max-width:340px;width:100%;padding:1.5rem;text-align:center;
  box-shadow:0 24px 60px rgba(0,0,0,0.4);
}
.exit-modal .exit-icon{
  width:50px;height:50px;border-radius:50%;
  background:rgba(127,29,29,0.4);
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 0.75rem;
}
.exit-modal h3{font-weight:900;font-size:1rem;color:#fff;margin-bottom:0.3rem}
.exit-modal p{color:#64748b;font-weight:700;font-size:0.75rem;margin-bottom:1rem}
.exit-actions{display:flex;gap:0.4rem;justify-content:center}
.exit-actions button{padding:0.5rem 1.25rem;border-radius:999px;font-weight:900;font-size:0.7rem;border:none;cursor:pointer;transition:all 0.2s;font-family:'Nunito',sans-serif}
.exit-actions .cancel{background:#1e293b;color:#94a3b8;border:1px solid #334155}
.exit-actions .cancel:hover{background:#334155}
.exit-actions .confirm{background:#ef4444;color:#fff}
.exit-actions .confirm:hover{background:#dc2626}

/* ══════════════════════════════════════════════════════════════ */
/* RESULTS                                                        */
/* ══════════════════════════════════════════════════════════════ */
.results{display:none}
.results-container{max-width:520px;margin:0 auto}
.results-header{text-align:center;margin-bottom:1.5rem}
.results-icon{
  width:64px;height:64px;border-radius:50%;display:flex;align-items:center;justify-content:center;
  margin:0 auto 0.75rem;
}
.results-icon.win{background:rgba(16,185,129,0.2);box-shadow:0 8px 24px rgba(16,185,129,0.15)}
.results-icon.time{background:rgba(245,158,11,0.2);box-shadow:0 8px 24px rgba(245,158,11,0.15)}
.results-icon.loss{background:rgba(239,68,68,0.2);box-shadow:0 8px 24px rgba(239,68,68,0.15)}
.results-title{font-size:1.8rem;font-weight:900;letter-spacing:-1px;margin-bottom:0.3rem}
.results-subtitle{font-size:0.75rem;color:#64748b;font-weight:700}
.results-badges{display:flex;gap:0.4rem;justify-content:center;margin-top:0.5rem;flex-wrap:wrap}
.results-badges span{padding:0.25rem 0.5rem;border-radius:999px;font-size:0.5rem;font-weight:900;letter-spacing:1px;text-transform:uppercase;border:1px solid}
.results-badges .mode-tag{background:rgba(30,41,59,0.5);border-color:#475569;color:#94a3b8}
.results-badges .perfect-tag{background:rgba(120,53,15,0.3);border-color:rgba(245,158,11,0.3);color:#fcd34d}
.results-badges .pb-tag{background:rgba(30,64,175,0.3);border-color:rgba(59,130,246,0.3);color:#93c5fd}

.results-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0.6rem;margin-bottom:0.75rem}
.results-stat{
  background:rgba(30,41,59,0.6);border:1px solid rgba(51,65,85,0.5);border-radius:1rem;
  padding:1rem 0.5rem;text-align:center;backdrop-filter:blur(8px);
}
.results-stat .stat-label{font-size:0.45rem;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:#475569;margin-bottom:0.3rem}
.results-stat .stat-value{font-size:1.4rem;font-weight:900;color:#fff;line-height:1}

.results-rewards{
  background:rgba(30,41,59,0.6);border:1px solid rgba(51,65,85,0.5);border-radius:1.25rem;
  padding:1.25rem;margin-bottom:1.25rem;backdrop-filter:blur(8px);
}
.results-rewards h3{font-size:0.45rem;font-weight:900;letter-spacing:3px;text-transform:uppercase;color:#475569;text-align:center;margin-bottom:0.75rem}
.rewards-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0.5rem}
.reward-tile{background:rgba(51,65,85,0.3);border:1px solid rgba(71,85,105,0.3);border-radius:0.6rem;padding:0.5rem;text-align:center}
.reward-tile .reward-icon{width:28px;height:28px;margin:0 auto 0.3rem;display:flex;align-items:center;justify-content:center;font-size:0.9rem}
.reward-tile .reward-icon.xp{background:#0ea5e9;color:#fff;border-radius:0.3rem;font-weight:900;font-size:0.45rem}
.reward-tile .reward-icon.gold{background:#fbbf24;color:#92400e;border-radius:50%;border:2px solid #d97706;font-weight:900;font-size:0.45rem}
.reward-tile .reward-value{font-size:1rem;font-weight:900;color:#fff}
.reward-tile .reward-label{font-size:0.4rem;font-weight:900;letter-spacing:1px;text-transform:uppercase;color:#475569;margin-top:0.15rem}

.results-actions{display:flex;gap:0.5rem;justify-content:center;flex-wrap:wrap}
.results-actions button{
  padding:0.6rem 1.25rem;border-radius:999px;font-weight:900;font-size:0.75rem;
  border:none;cursor:pointer;transition:all 0.2s;font-family:'Nunito',sans-serif;
}
.results-actions .primary{color:#fff}
.results-actions .primary:hover{transform:translateY(-2px)}
.results-actions .secondary{background:rgba(51,65,85,0.5);color:#94a3b8;border:1px solid #475569}
.results-actions .secondary:hover{background:rgba(51,65,85,0.7)}

/* ══════════════════════════════════════════════════════════════ */
/* RESPONSIVE                                                     */
/* ══════════════════════════════════════════════════════════════ */
@@media(max-width:640px){
  .lobby-header h1{font-size:2.5rem}
  .arena-display{font-size:2.5rem}
  .arena-display .blank{min-width:35px;height:45px;font-size:2rem}
  .option-btn .opt-text{font-size:1.6rem}
  .rewards-grid{grid-template-columns:repeat(2,1fr)}
}

/* Guide button */
.guide-btn{
  position:fixed;bottom:1.5rem;right:1.5rem;z-index:20;
  width:36px;height:36px;border-radius:50%;
  background:rgba(30,41,59,0.8);border:1px solid #334155;
  color:#64748b;display:flex;align-items:center;justify-content:center;
  font-size:0.8rem;font-weight:900;cursor:pointer;transition:all 0.2s;
  backdrop-filter:blur(8px);font-family:'Nunito',sans-serif;
}
.guide-btn:hover{background:rgba(51,65,85,0.8);color:#e2e8f0}

/* Confetti piece */
.confetti-piece{position:fixed;pointer-events:none;z-index:50}
</style>
</head>
<body>

<!-- NIPPONQUEST BACK ARROW -->
<a href="@Url.Action("Index", "Home")" class="nq-back-btn">
    <span style="font-size: 1rem; line-height: 0; padding-bottom: 2px;">&#8592;</span> Back
</a>

<!-- Background layers -->
<div class="bg-layer">
  <div class="bg-aurora"></div>
  <div class="bg-radial-top"></div>
  <div class="bg-radial-br"></div>
  <div id="particles"></div>
</div>
<div class="bg-vignette"></div>

<!-- Screen flashes -->
<div class="screen-flash" id="green-flash"></div>
<div class="screen-flash" id="red-flash"></div>

<!-- Score popup -->
<div id="score-popup" class="score-popup" style="display:none"></div>
<div id="combo-popup" class="combo-popup" style="display:none"></div>

<!-- Confetti container -->
<div id="confetti-container"></div>

<div class="container">
  <!-- Top bar -->
  <div class="top-bar">
    <div class="top-bar-inner">
      <span class="top-bar-line"></span>
      <span>KANABLITZ</span>
      <span class="top-bar-line"></span>
    </div>
  </div>

  <!-- ═══ LOBBY ═══ -->
  <div id="ui-lobby" class="anim-slide-up">
    <div class="lobby-header">
      <div class="lobby-badge"><span class="dot"></span> High Intensity Training</div>
      <h1>Kana<span>Blitz</span></h1>
      <p class="sub">Lock in kana fluency through rapid pattern recognition.</p>
      <div class="lobby-meta">
        <span><span class="dot"></span> 1–2 min sessions</span><span style="color:#334155">·</span>
        <span><span class="dot"></span> Build streaks</span><span style="color:#334155">·</span>
        <span><span class="dot"></span> Train recall</span>
      </div>
    </div>

    <!-- Steps -->
    <div class="steps">
      <div class="step-pill active" id="step-script"><span class="num">1</span> Script</div>
      <div class="step-line inactive" id="step-line-1"></div>
      <div class="step-pill inactive" id="step-intensity"><span class="num">2</span> Intensity</div>
      <div class="step-line inactive" id="step-line-2"></div>
      <div class="step-pill inactive" id="step-start"><span class="num">3</span> Start</div>
    </div>

    <!-- Script grid -->
    <div class="section-header"><span class="num">01</span><h3>Choose Your Script</h3></div>
    <div class="choice-grid" id="script-grid">
      <div class="choice-card" data-alpha="hiragana" onclick="selectAlpha(this)">
        <div class="kana-display" style="color:#0ea5e9">あ</div>
        <div class="label">Hiragana</div>
        <div class="sub">Basic syllabary</div>
        <span class="hint" style="background:#064e3b;color:#6ee7b7;border-color:#065f46">Beginner</span>
      </div>
      <div class="choice-card" data-alpha="katakana" onclick="selectAlpha(this)">
        <div class="kana-display" style="color:#f43f5e">ア</div>
        <div class="label">Katakana</div>
        <div class="sub">Loanwords &amp; foreign</div>
        <span class="hint" style="background:#4c0519;color:#fda4af;border-color:#881337">Beginner</span>
      </div>
      <div class="choice-card" data-alpha="dakuten" onclick="selectAlpha(this)">
        <div class="kana-display"><span style="color:#8b5cf6">が</span></div>
        <div class="label">Dakuten</div>
        <div class="sub">が, ぱ, ゃ, っ, ー</div>
        <span class="hint" style="background:#1e1b4b;color:#a5b4fc;border-color:#3730a3">Intermediate</span>
      </div>
      <div class="choice-card" data-alpha="mixed" onclick="selectAlpha(this)">
        <div class="kana-display" style="color:#f59e0b">混</div>
        <div class="label">Mixed Blitz</div>
        <div class="sub">Leaderboard run</div>
        <span class="hint" style="background:#451a03;color:#fcd34d;border-color:#92400e">Advanced</span>
      </div>
    </div>

    <!-- Difficulty grid -->
    <div class="section-header" style="justify-content:space-between;display:flex">
      <div style="display:flex;align-items:center;gap:0.5rem">
        <span class="num">02</span>
        <h3>Choose Your Intensity</h3>
      </div>
      @if(isDev == "true")
      {
        <button id="dev-toggle" class="dev-toggle locked-toggle" onclick="toggleDev()">
          <svg class="icon" style="width:10px;height:10px;margin-right:2px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          Dev: Restrictions Enforced
        </button>
      }
    </div>
    <p class="section-sub"><span class="dot"></span> Higher tiers run on shorter clocks but bank far bigger rewards.</p>

    <div id="lock-alert-area"></div>

    <div class="choice-grid" id="diff-grid">
      <div class="choice-card" data-diff="easy" onclick="selectDiff(this)">
        <div class="kana-display" style="font-size:1.4rem;color:#10b981">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="label">Easy</div>
        <div class="time-row"><span>120s</span><span>·</span><span>Romaji → Kana</span></div>
        <div class="reward-row">
          <span class="xp-badge">XP</span><span class="xp-val">+5</span><span style="color:#475569">|</span>
          <span class="gold-badge">G</span><span class="gold-val">+2</span>
        </div>
      </div>
      <div class="choice-card" data-diff="normal" onclick="selectDiff(this)">
        <div class="kana-display" style="font-size:1.4rem;color:#3b82f6">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="4"/><path d="M8 12l3 3 5-5"/></svg>
        </div>
        <div class="label">Normal</div>
        <div class="time-row"><span>90s</span><span>·</span><span>Basic Words</span></div>
        <div class="reward-row">
          <span class="xp-badge">XP</span><span class="xp-val">+10</span><span style="color:#475569">|</span>
          <span class="gold-badge">G</span><span class="gold-val">+4</span>
        </div>
      </div>
      <div class="choice-card locked" data-diff="hard" data-locked="true" data-req="Requires: 90% accuracy & 30 correct in one Normal run on all scripts" onclick="selectDiff(this)">
        <div class="lock-badge">REQ</div>
        <div class="kana-display" style="font-size:1.4rem;color:#8b5cf6">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 22 20 2 20"/><circle cx="12" cy="14" r="2" fill="currentColor"/></svg>
        </div>
        <div class="label">Hard</div>
        <div class="time-row"><span>60s</span><span>·</span><span>+1s / -2s</span></div>
        <div class="reward-row">
          <span class="xp-badge">XP</span><span class="xp-val">+22</span><span style="color:#475569">|</span>
          <span class="gold-badge">G</span><span class="gold-val">+9</span>
        </div>
        <div class="req-badge">Requires: 90% accuracy & 30 correct in one Normal run on all scripts</div>
      </div>
      <div class="choice-card locked" data-diff="insanity" data-locked="true" data-req="Requires: 95% accuracy & 25 correct in one Hard run on all scripts + Account Level 15" onclick="selectDiff(this)">
        <div class="lock-badge">REQ</div>
        <div class="kana-display" style="font-size:1.4rem;color:#ef4444">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" fill="currentColor"/></svg>
        </div>
        <div class="label">Insanity</div>
        <div class="time-row"><span>45s</span><span>·</span><span>+0.5s / -3s</span></div>
        <div class="reward-row">
          <span class="xp-badge">XP</span><span class="xp-val">+45</span><span style="color:#475569">|</span>
          <span class="gold-badge">G</span><span class="gold-val">+18</span>
        </div>
        <div class="req-badge">Requires: 95% accuracy & 25 correct in one Hard run on all scripts + Account Level 15</div>
      </div>
    </div>

    <!-- CTA -->
    <div style="max-width:420px;margin:0 auto">
      <button id="btn-start" class="cta-btn disabled" onclick="startArena()" disabled>
        ENTER ARENA
      </button>
      <p class="cta-hint">Select both a script and an intensity to begin your run.</p>
    </div>
  </div>

  <!-- ═══ ARENA ═══ -->
  <div id="ui-arena" class="arena">
    <div class="arena-header">
      <button class="exit-btn" onclick="exitArena()">&#8592; Exit</button>
      <div class="arena-tags"><span id="arena-alpha-tag"></span><span id="arena-diff-tag"></span></div>
    </div>

    <!-- HUD -->
    <div class="hud">
      <div class="timer-bar"><div class="timer-bar-fill" id="timer-bar-fill" style="width:100%;background:linear-gradient(90deg,#22c55e,#16a34a)"></div></div>
      <div class="hud-row">
        <div class="hud-timer">
          <span class="clock-icon icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
          <span class="time" id="hud-timer" style="color:#22c55e">01:30</span>
          <span id="time-delta" style="font-size:0.65rem;font-weight:900;transition:opacity 0.3s"></span>
        </div>
        <div class="hud-center">
          <div class="hud-combo" id="hud-combo"></div>
          <div class="hud-score">Score: <span id="hud-score">0</span></div>
        </div>
        <div class="hud-hearts" id="hud-hearts"></div>
      </div>
    </div>

    <!-- Arena card -->
    <div class="arena-card" id="arena-card">
      <div class="arena-card-inner">
        <div class="streak-bar"><div class="streak-fill" id="streak-fill" style="width:0%;background:#38bdf8"></div></div>
        <div class="arena-body">
          <div class="arena-badge" id="arena-badge">
            <span class="dot"></span> <span>TARGET RECOGNITION</span>
          </div>
          <div id="arena-category" class="arena-category"></div>
          <div id="arena-meaning" class="arena-meaning"></div>
          <div class="arena-divider" id="arena-divider"></div>
          <div id="arena-display" class="arena-display"></div>
          <div id="arena-options" class="options-grid"></div>
          <div class="arena-footer" id="arena-footer">
            <span id="score-count">0 correct</span>
            <span style="color:#334155">·</span>
            <span id="footer-hint">Press keys A, B, C, D (or 1-4)</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ RESULTS ═══ -->
  <div id="ui-results" class="results">
    <div class="results-container">
