@using Microsoft.AspNetCore.Identity
@using NipponQuest.Models
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager

<style>
    /* ══════════════════════════════════════════
       HUD — Nunito · Clean White Navbar Edition
       ══════════════════════════════════════════ */

    .hud-pill {
        display: flex;
        align-items: center;
        gap: 0;
        background: #ffffff;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 7px 14px;
        box-shadow: 0 2px 12px rgba(15, 23, 42, 0.06);
        position: relative;
        overflow: hidden;
        font-family: 'Nunito', sans-serif;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .hud-pill:hover {
        border-color: #cbd5e1;
        box-shadow: 0 4px 20px rgba(15, 23, 42, 0.08);
    }

    .hud-sep {
        width: 1px;
        height: 22px;
        background: #e2e8f0;
        margin: 0 10px;
        flex-shrink: 0;
    }

    /* ── Streak ───────────────────────────────── */
    .hud-streak { display: flex; align-items: center; gap: 5px; }
    .streak-flame-active {
        color: #f97316;
        filter: drop-shadow(0 0 4px rgba(249, 115, 22, 0.4));
        font-size: 1rem;
    }
    .streak-frozen {
        color: #94a3b8;
        font-size: 1rem;
    }
    .hud-streak-val {
        font-weight: 900;
        font-size: 0.85rem;
        color: #0f172a;
        line-height: 1;
    }

    /* ── League — uses existing rank-text classes unchanged ── */
    .hud-rank-link {
        text-decoration: none;
        transition: opacity 150ms ease, transform 150ms ease;
    }
    .hud-rank-link:hover { opacity: 0.85; transform: translateY(-1px); }

    /* ── Level ────────────────────────────────── */
    .hud-lv { display: flex; flex-direction: column; align-items: center; }
    .hud-lv-tag {
        font-size: 0.46rem;
        font-weight: 900;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #94a3b8;
        line-height: 1;
    }
    .hud-lv-num {
        font-size: 0.9rem;
        font-weight: 900;
        color: #0ea5e9;
        line-height: 1;
        margin-top: 2px;
    }

    /* ── Gold value ───────────────────────────── */
    .hud-gold { display: flex; align-items: center; gap: 5px; }
    .hud-gold-val {
        font-weight: 900;
        font-size: 0.85rem;
        color: #0f172a;
        line-height: 1;
    }

    /* ── XP bar (desktop only) ────────────────── */
    .hud-xp { display: flex; flex-direction: column; gap: 3px; min-width: 108px; }
    .hud-xp-top { display: flex; justify-content: space-between; align-items: center; }
    .hud-xp-label {
        font-size: 0.46rem;
        font-weight: 900;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #94a3b8;
    }
    .hud-xp-pct { font-size: 0.46rem; font-weight: 900; color: #0ea5e9; }
    .hud-xp-track {
        height: 6px;
        background: #f1f5f9;
        border-radius: 50px;
        overflow: hidden;
    }
    .hud-xp-fill {
        height: 100%;
        background: linear-gradient(90deg, #0ea5e9, #38bdf8);
        border-radius: 50px;
        box-shadow: 0 0 6px rgba(14, 165, 233, 0.35);
        transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* ── Logout ───────────────────────────────── */
    .hud-logout {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        background: #ffffff;
        border: 2px solid #e2e8f0 !important;
        border-radius: 14px;
        padding: 8px 18px;
        font-family: 'Nunito', sans-serif;
        font-size: 0.65rem;
        font-weight: 900;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #64748b;
        cursor: pointer;
        transition: all 200ms ease;
        white-space: nowrap;
        box-shadow: 0 2px 10px rgba(15, 23, 42, 0.05);
    }
    .hud-logout:hover {
        background: #fef2f2;
        border-color: #fca5a5 !important;
        color: #dc2626;
        box-shadow: 0 4px 16px rgba(220, 53, 69, 0.12);
        transform: translateY(-2px);
    }

    /* ── Auth buttons ─────────────────────────── */
    .hud-auth-login {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 38px;
        padding: 6px 18px;
        background: #ffffff;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        font-family: 'Nunito', sans-serif;
        font-size: 0.62rem;
        font-weight: 900;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #0f172a;
        text-decoration: none;
        box-shadow: 0 2px 8px rgba(15, 23, 42, 0.04);
        transition: all 200ms ease;
    }
    .hud-auth-login:hover {
        border-color: #0ea5e9;
        color: #0ea5e9;
        box-shadow: 0 4px 14px rgba(14, 165, 233, 0.12);
        transform: translateY(-1px);
    }

    .hud-auth-register {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 38px;
        padding: 6px 18px;
        background: linear-gradient(135deg, #0ea5e9, #2563eb);
        border: none;
        border-radius: 12px;
        font-family: 'Nunito', sans-serif;
        font-size: 0.62rem;
        font-weight: 900;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #ffffff;
        text-decoration: none;
        box-shadow: 0 4px 16px rgba(14, 165, 233, 0.3);
        transition: all 200ms ease;
        position: relative;
        overflow: hidden;
    }
    .hud-auth-register:hover {
        box-shadow: 0 6px 22px rgba(14, 165, 233, 0.4);
        transform: translateY(-2px);
        color: #ffffff;
    }

    /* ── Responsive ───────────────────────────── */
    @@media (max-width: 767px) {
        .hud-pill           { padding: 5px 10px; border-radius: 13px; }
        .hud-sep            { margin: 0 7px; height: 18px; }
        .hud-lv-num         { font-size: 0.8rem; }
        .hud-streak-val     { font-size: 0.78rem; }
        .hud-gold-val       { font-size: 0.78rem; }
        .hud-logout         { padding: 6px 12px; border-radius: 12px; min-height: 40px; }
        .hud-auth-login,
        .hud-auth-register  { padding: 5px 12px; border-radius: 10px; min-height: 34px; }
    }
</style>

<ul class="navbar-nav d-flex flex-row align-items-center gap-2 mb-0 p-0">

    @if (SignInManager.IsSignedIn(User))
    {
        var player = await UserManager.GetUserAsync(User);
        var leagueKey = player?.CurrentLeague.ToString().ToLower() ?? "sprout";
        bool hasStreak = player?.LoginStreak > 0;
        var xpPct = player?.XPPercentage ?? 0;

        <li class="nav-item">
            <div class="d-flex align-items-center gap-2">

                <!-- ── Stats pill ────────────────────────── -->
                <div class="hud-pill">

                    <!-- Streak -->
                    <div class="hud-streak">
                        <i class="bi bi-fire @(hasStreak ? "streak-flame-active" : "streak-frozen")"></i>
                        <span class="hud-streak-val">@player?.LoginStreak</span>
                    </div>

                    <div class="hud-sep"></div>

                    <!-- League — uses your existing rank-text CSS, hidden on xs -->
                    <a asp-controller="Leagues" asp-action="Index"
                       class="hud-rank-link d-none d-sm-inline-flex">
                        <span class="rank-text @leagueKey">@player?.CurrentLeague</span>
                    </a>
                    <div class="hud-sep d-none d-sm-block"></div>

                    <!-- Gold -->
                    <div class="hud-gold">
                        <span class="hud-gold-val">@player?.Gold</span>
                        <div class="gold-coin"></div>
                    </div>

                    <div class="hud-sep"></div>

                    <!-- Level -->
                    <div class="hud-lv">
                        <span class="hud-lv-tag">LVL</span>
                        <span class="hud-lv-num">@player?.Level</span>
                    </div>

                    <!-- XP bar — desktop only -->
                    <div class="hud-sep d-none d-md-block"></div>
                    <div class="hud-xp d-none d-md-flex">
                        <div class="hud-xp-top">
                            <span class="hud-xp-label">EXP</span>
                            <span class="hud-xp-pct">@xpPct%</span>
                        </div>
                        <div class="hud-xp-track">
                            <div class="hud-xp-fill" style="width: @xpPct%;"></div>
                        </div>
                    </div>

                </div><!-- /hud-pill -->

                <!-- ── Logout ─────────────────────────────── -->
                <form class="m-0" asp-area="Identity"
                      asp-page="/Account/Logout"
                      asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                    <button type="submit" class="hud-logout">
                        <span class="d-none d-md-inline">Logout</span>
                        <i class="bi bi-box-arrow-right d-md-none" style="font-size: 1rem;"></i>
                    </button>
                </form>

            </div>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="hud-auth-login" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
        <li class="nav-item">
            <a class="hud-auth-register" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
    }

</ul>
