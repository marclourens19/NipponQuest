<script>
    document.addEventListener("DOMContentLoaded", function () {
        const obs = new IntersectionObserver(
            es => es.forEach(e => { if (e.isIntersecting) e.target.classList.add('active'); }),
            { threshold: 0.05 }
        );
        document.querySelectorAll('.lg-reveal').forEach(el => obs.observe(el));

        const publishSwitch = document.getElementById('publishSwitch');
        if (publishSwitch) {
            publishSwitch.addEventListener('change', function () {
                const priceField = new bootstrap.Collapse(document.getElementById('priceField'), { toggle: false });
                this.checked ? priceField.show() : priceField.hide();
            });
        }
    });

    function selectColor(hex, element, isLocked) {
        if (isLocked) {
            document.getElementById('purchaseColorHex').value = hex;
            document.getElementById('modalColorPreview').style.backgroundColor = hex;
            new bootstrap.Modal(document.getElementById('buyColorModal')).show();
            return;
        }
        document.getElementById('ThemeColorInput').value = hex;
        document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('selected'));
        element.classList.add('selected');
        document.getElementById('MainEditCard').style.setProperty('background-color', hex, 'important');
    }

    let activeCardId = null;
    function confirmDeleteCard(id) {
        activeCardId = id;
        new bootstrap.Modal(document.getElementById('deleteConfirmModal')).show();
    }
    function executeDelete() {
        if (activeCardId) {
            document.getElementById('deleteCardId').value = activeCardId;
            document.getElementById('deleteCardForm').submit();
        }
    }
</script>
