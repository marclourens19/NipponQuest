@model NipponQuest.Models.Deck

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">

<style>
    /* ──────────────────────────────────────────────────────
       EDIT DECK — Nunito · Site CSS Aligned
       ────────────────────────────────────────────────────── */

    body { font-family: 'Nunito', sans-serif !important; background: #ffffff; }

    .lg-reveal { opacity: 0; transform: translateY(24px); transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
    .lg-reveal.active { opacity: 1; transform: translateY(0); }

    /* ── HERO ── */
    .lg-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 55%, #0ea5e9 160%);
        border-radius: 28px;
        color: #ffffff;
        padding: 2.5rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 25px 60px -15px rgba(15, 23, 42, 0.4);
        font-family: 'Nunito', sans-serif;
    }
    .lg-hero::before {
        content: "";
        position: absolute;
        inset: -50% -10% auto auto;
        width: 420px; height: 420px;
        background: radial-gradient(circle, rgba(245, 158, 11, 0.18) 0%, transparent 70%);
        pointer-events: none;
    }
    .lg-hero::after {
        content: "編集";
        position: absolute;
        right: 20px; bottom: -20px;
        font-size: 8rem; font-weight: 900;
        color: rgba(255,255,255,0.04);
        line-height: 1; letter-spacing: -4px;
        pointer-events: none;
    }
    .lg-hero-meta {
        font-size: 0.65rem; font-weight: 900;
        letter-spacing: 2px;
        color: rgba(255,255,255,0.6);
        text-transform: uppercase;
    }
    .lg-title {
        font-size: clamp(2.4rem, 5vw, 3.8rem);
        font-weight: 900; letter-spacing: -2px; line-height: 1;
        margin: 6px 0 2px;
        font-family: 'Nunito', sans-serif;
    }
    .lg-info-btn {
        width: 40px; height: 40px; border-radius: 50%;
        background: rgba(255,255,255,0.12);
        border: 2px solid rgba(255,255,255,0.25);
        color: #ffffff;
        display: inline-flex; align-items: center; justify-content: center;
        transition: all 200ms ease;
        cursor: pointer;
    }
    .lg-info-btn:hover { background: #fbbf24; color: #422006; border-color: #fbbf24; transform: translateY(-2px); }

    /* ── PANELS ── */
    .lg-panel {
        background: #ffffff;
        border: 2px solid #e2e8f0;
        border-radius: 24px;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.04);
        transition: all 250ms ease;
        font-family: 'Nunito', sans-serif;
    }
    .lg-panel:hover { box-shadow: 0 12px 32px rgba(15, 23, 42, 0.08); }

    /* ── EDIT CARD (the coloured deck preview card) ── */
    .edit-card {
        border-radius: 24px;
        border: 2px solid #e2e8f0;
        padding: 2rem;
        transition: all 300ms ease;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.04);
    }

    /* ── INFO PILLARS ── */
    .info-pillar { border: 2px solid #e2e8f0; border-radius: 16px; padding: 16px; height: 100%; background: #ffffff; transition: all 0.2s; }
    .info-pillar:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.05); border-color: #cbd5e1; }
    .info-pillar .info-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 10px; }

    /* ── FORMS ── */
    .btn { font-family: 'Nunito', sans-serif !important; }
    .auth-input {
        font-family: 'Nunito', sans-serif !important;
        font-weight: 700;
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 12px !important;
        padding: 0.85rem 1rem;
        color: #0f172a;
        transition: all 0.25s;
    }
    .auth-input:focus {
        background: #ffffff;
        border-color: #0ea5e9;
        box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.1);
        outline: none;
    }
    .auth-input::placeholder { color: #94a3b8; font-weight: 600; }

    .table-input {
        font-family: 'Nunito', sans-serif !important;
        border: 2px solid transparent;
        background: transparent;
        padding: 0.5rem 0.75rem;
        border-radius: 8px;
        transition: all 0.25s;
        font-weight: 700;
        color: #0f172a;
    }
    .table-input:focus {
        border-color: #0ea5e9 !important;
        background: #fff !important;
        box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1);
        outline: none;
    }
    .card-row:hover .table-input { border-color: #e2e8f0; background: #fff; }
    .card-row { transition: background-color 0.2s ease; }
    .card-row:hover { background-color: #f8fafc; }

    /* ── COLOUR SWATCHES ── */
    .color-swatch {
        width: 34px; height: 34px; border-radius: 50%;
        cursor: pointer;
        display: inline-flex; align-items: center; justify-content: center;
        border: 2px solid rgba(0,0,0,0.08);
        transition: transform 0.2s, box-shadow 0.2s;
        flex-shrink: 0;
    }
    .color-swatch.selected {
        box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.55);
        transform: scale(1.18);
    }
    .color-swatch:not(.locked):hover { transform: scale(1.15); }
    .color-swatch.locked { opacity: 0.6; cursor: pointer; border-style: dashed; }
    .color-swatch.locked:hover { opacity: 1; transform: scale(1.1); }

    /* ── GOLD COIN ── */
    .gold-coin {
        background: linear-gradient(135deg, #FFD700 0%, #FFB900 100%);
        border-radius: 50%; border: 1.5px solid #B45309;
        display: inline-flex; align-items: center; justify-content: center;
        font-weight: 900; color: #451a03 !important;
        font-family: 'Nunito', sans-serif; flex-shrink: 0;
    }
    .gold-coin::after { content: "G"; }

    /* ── CTA BUTTONS ── */
    .btn-blitz-dark {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: #ffffff !important;
        border: none;
        border-radius: 14px;
        font-family: 'Nunito', sans-serif;
        font-weight: 900;
        font-size: 0.78rem;
        letter-spacing: 1px;
        padding: 10px 20px;
        transition: all 200ms ease;
        display: inline-flex; align-items: center; gap: 6px;
        cursor: pointer;
    }
    .btn-blitz-dark:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(15,23,42,0.3); color: #fff !important; }

    .btn-blitz-primary {
        background: linear-gradient(135deg, #0ea5e9, #2563eb);
        color: #ffffff !important;
        border: none;
        border-radius: 14px;
        font-family: 'Nunito', sans-serif;
        font-weight: 900;
        font-size: 0.78rem;
        letter-spacing: 1px;
        padding: 10px 20px;
        transition: all 200ms ease;
        display: inline-flex; align-items: center; gap: 6px;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(14,165,233,0.3);
    }
    .btn-blitz-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(14,165,233,0.4); color: #fff !important; }

    .btn-blitz-gold {
        background: linear-gradient(135deg, #fbbf24, #f59e0b);
        color: #422006 !important;
        border: none;
        border-radius: 14px;
        font-family: 'Nunito', sans-serif;
        font-weight: 900;
        font-size: 0.78rem;
        letter-spacing: 1px;
        padding: 10px 20px;
        transition: all 200ms ease;
        display: inline-flex; align-items: center; gap: 6px;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(245,158,11,0.3);
    }
    .btn-blitz-gold:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(245,158,11,0.4); }

    .btn-blitz-ghost {
        background: #ffffff;
        color: #0f172a;
        border: 2px solid #e2e8f0;
        border-radius: 14px;
        font-family: 'Nunito', sans-serif;
        font-weight: 900;
        font-size: 0.78rem;
        letter-spacing: 1px;
        padding: 10px 20px;
        transition: all 200ms ease;
        display: inline-flex; align-items: center; gap: 6px;
        cursor: pointer;
        text-decoration: none;
    }
    .btn-blitz-ghost:hover { border-color: #0ea5e9; color: #0ea5e9; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(14,165,233,0.1); }

    .btn-blitz-danger {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: #ffffff !important;
        border: none;
        border-radius: 14px;
        font-family: 'Nunito', sans-serif;
        font-weight: 900;
        font-size: 0.78rem;
        letter-spacing: 1px;
        padding: 10px 20px;
        transition: all 200ms ease;
        display: inline-flex; align-items: center; gap: 6px;
        cursor: pointer;
    }
    .btn-blitz-danger:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(239,68,68,0.3); color: #fff !important; }

    /* ── TABLE MEDIA BUBBLE BUTTONS ── */
    .bubble-btn-sm {
        width: 36px; height: 36px;
        display: inline-flex; align-items: center; justify-content: center;
        border-radius: 50%;
        border: 2px solid #e2e8f0;
        cursor: pointer;
        transition: all 0.2s;
        background: #fff;
    }
    .bubble-btn-sm:hover { border-color: #0ea5e9; background: #f0f9ff; }
    .border-info { border-color: #0ea5e9 !important; border-width: 2px !important; background-color: #f0f9ff; }
    .border-indigo { border-color: #6366f1 !important; border-width: 2px !important; background-color: #f5f3ff; }

    /* ── TABLE INLINE ACTION BUTTONS ── */
    .tbl-save {
        background: none; border: none; cursor: pointer;
        color: #0ea5e9; padding: 6px 10px; border-radius: 8px;
        transition: all 0.2s;
    }
    .tbl-save:hover { background: #e0f2fe; }
    .tbl-delete {
        background: none; border: none; cursor: pointer;
        color: #64748b; padding: 6px 10px; border-radius: 8px;
        transition: all 0.2s;
    }
    .tbl-delete:hover { background: #fef2f2; color: #dc2626; }

    /* ── COMMUNITY TOGGLE ── */
    .community-box {
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 1.25rem;
        transition: all 0.2s;
    }
    .form-switch .form-check-input {
        width: 2.4em; height: 1.2em;
        cursor: pointer;
        background-color: #e2e8f0;
        border-color: #e2e8f0;
    }
    .form-switch .form-check-input:checked { background-color: #0ea5e9; border-color: #0ea5e9; }
    .form-switch .form-check-label { font-family: 'Nunito', sans-serif; }

    /* ── UNLOCK ALL BUTTON ── */
    .unlock-all-btn {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 6px 14px;
        border-radius: 12px;
        border: 2px solid #fde68a;
        background: #fffbeb;
        color: #92400e;
        font-family: 'Nunito', sans-serif;
        font-weight: 900;
        font-size: 0.65rem;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.2s;
        height: 34px;
    }
    .unlock-all-btn:hover { background: #fef3c7; border-color: #fbbf24; transform: translateY(-1px); }

    /* ── TIP BAR ── */
    .tip-bar {
        background: #f0f9ff;
        border: 2px solid #bae6fd;
        border-radius: 16px;
        padding: 12px 20px;
        font-size: 0.78rem;
        font-weight: 700;
        color: #0369a1;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* ── MODAL ── */
    .modal-content { border-radius: 24px !important; font-family: 'Nunito', sans-serif; }

    /* ── RESPONSIVE ── */
    @@media (max-width: 575.98px) {
        .container.py-5.mt-4 { padding-top: 1.25rem !important; margin-top: 0 !important; }
        .mobile-header-container { padding: 1.5rem !important; border-radius: 24px !important; }
        .lg-hero::after { font-size: 5rem; right: 10px; bottom: -10px; }
        .mobile-header-btns { flex-wrap: wrap !important; width: 100%; }
        .edit-card { padding: 1.25rem; }
    }
</style>

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-11">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger fw-bold border-0 d-flex align-items-center mb-4 px-4 py-3 alert-dismissible fade show lg-reveal active" style="border-radius: 14px;">
                    <i class="bi bi-exclamation-octagon-fill fs-5 me-2 text-danger"></i>
                    <div>@TempData["Error"]</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success fw-bold border-0 d-flex align-items-center mb-4 px-4 py-3 alert-dismissible fade show lg-reveal active" style="border-radius: 14px;">
                    <i class="bi bi-check-circle-fill fs-5 me-2 text-success"></i>
                    <div>@TempData["Message"]</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- ── HERO ── -->
            <div class="lg-hero mb-4 lg-reveal active mobile-header-container">
                <div class="row g-4 align-items-center position-relative" style="z-index: 2;">
                    <div class="col-lg-8">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <div class="lg-hero-meta"><i class="bi bi-pencil-square me-1 text-warning"></i> WORKSPACE &middot; 編集</div>
                        </div>
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <h1 class="lg-title m-0 text-uppercase">EDIT <span style="color: #fbbf24;">DECK</span></h1>
                            <button type="button" class="lg-info-btn" data-bs-toggle="modal" data-bs-target="#editGuideModal" title="How to use the Editor">
                                <i class="bi bi-info-lg fs-5 fw-black"></i>
                            </button>
                        </div>
                        <div class="lg-hero-meta mt-2 opacity-75" style="letter-spacing: 1px; font-size: 0.8rem;">Update deck details and manage your flashcards</div>

                        <div class="d-flex gap-2 mt-4 mobile-header-btns flex-wrap">
                            <a asp-action="Index" class="btn-blitz-ghost">
                                <i class="bi bi-arrow-left"></i> BACK TO MY DECKS
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── EDIT FORM (coloured preview card) ── -->
            <div class="edit-card mb-4 lg-reveal active" id="MainEditCard"
                 style="background-color: @(string.IsNullOrEmpty(Model.ThemeColor) ? "#ffffff" : Model.ThemeColor) !important;">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ApplicationUserId" />

                    <div class="row g-4 align-items-end mb-4">
                        <div class="col-md-6">
                            <label asp-for="Title" class="form-label fw-black text-dark small text-uppercase mb-1" style="letter-spacing: 1px; font-size: 0.65rem;">Deck Title</label>
                            <input asp-for="Title" class="form-control auth-input" placeholder="Enter deck title..." required />
                            <span asp-validation-for="Title" class="text-danger small fw-bold mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Description" class="form-label fw-black text-dark small text-uppercase mb-1" style="letter-spacing: 1px; font-size: 0.65rem;">Description</label>
                            <input asp-for="Description" class="form-control auth-input" placeholder="What is this deck about?" />
                        </div>

                        <!-- Colour swatches -->
                        <div class="col-12">
                            <label class="form-label fw-black text-dark small text-uppercase mb-2" style="letter-spacing: 1px; font-size: 0.65rem;">Deck Theme Colour</label>
                            <div class="d-flex flex-wrap align-items-center gap-2">
                                <input type="hidden" asp-for="ThemeColor" id="ThemeColorInput" value="@Model.ThemeColor" />

                                @foreach (var color in (List<string>)ViewBag.FreeColors)
                                {
                                    <div class="color-swatch @(Model.ThemeColor == color ? "selected" : "")"
                                         style="background-color: @color;"
                                         onclick="selectColor('@color', this, false)"
                                         title="Free theme"></div>
                                }

                                <div class="vr mx-1 opacity-25" style="height: 34px;"></div>

                                @foreach (var color in (List<string>)ViewBag.PremiumColors)
                                {
                                    bool isOwned = ((List<string>)ViewBag.PurchasedColors).Contains(color);
                                    <div class="color-swatch @(Model.ThemeColor == color ? "selected" : "") @(isOwned ? "" : "locked")"
                                         style="background-color: @color;"
                                         onclick="selectColor('@color', this, @(isOwned ? "false" : "true"))"
                                         title="@(isOwned ? "Equip theme" : "Unlock for 50G")">
                                        @if (!isOwned)
                                        {
                                            <i class="bi bi-lock-fill" style="font-size: 0.7rem; color: rgba(0,0,0,0.4);"></i>
                                        }
                                    </div>
                                }

                                @if (((List<string>)ViewBag.PremiumColors).Except((List<string>)ViewBag.PurchasedColors).Any())
                                {
                                    <div class="vr mx-1 opacity-25" style="height: 34px;"></div>
                                    <button type="button" class="unlock-all-btn" data-bs-toggle="modal" data-bs-target="#buyAllColorsModal">
                                        <i class="bi bi-unlock-fill"></i>
                                        UNLOCK ALL (500 <div class="gold-coin" style="width: 14px; height: 14px; font-size: 0.48rem; border-width: 1px; display: inline-flex;"></div>)
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Community Hub toggle -->
                    <div class="community-box mb-4">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-2">
                            <div>
                                <div class="fw-black text-dark small text-uppercase mb-1" style="letter-spacing: 1px; font-size: 0.7rem;">
                                    <i class="bi bi-globe-americas me-1" style="color: #0ea5e9;"></i> Community Hub
                                </div>
                                <span class="small fw-bold" style="color: #64748b;">Sell your deck to the community and earn Gold.</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                @if (ViewBag.UserLevel < 5)
                                {
                                    <div class="badge fw-black small" style="background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; border-radius: 10px; padding: 6px 12px;">
                                        <i class="bi bi-lock-fill me-1"></i> REACH LVL 5 TO UNLOCK
                                    </div>
                                    <div class="form-check form-switch m-0 fs-5 opacity-50">
                                        <input class="form-check-input" type="checkbox" role="switch" disabled>
                                    </div>
                                }
                                else
                                {
                                    <div class="form-check form-switch m-0 fs-5">
                                        <input class="form-check-input" type="checkbox" role="switch" asp-for="IsPublic" id="publishSwitch">
                                        <label class="form-check-label fw-black ms-2 text-dark" style="font-size: 0.75rem; letter-spacing: 1px; text-transform: uppercase; cursor: pointer;" for="publishSwitch">MAKE PUBLIC</label>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="collapse @(Model.IsPublic && ViewBag.UserLevel >= 5 ? "show" : "")" id="priceField">
                            <div class="pt-3 border-top mt-2" style="border-color: #e2e8f0 !important;">
                                <label asp-for="Price" class="form-label fw-black text-dark small text-uppercase mb-1" style="letter-spacing: 1px; font-size: 0.65rem;">Market Price (Gold)</label>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="gold-coin" style="width: 28px; height: 28px; font-size: 0.8rem; border-width: 1.5px;"></div>
                                    <input asp-for="Price" type="number" min="0" max="10000" class="form-control auth-input" placeholder="0 for Free" style="max-width: 200px;" />
                                </div>
                                <span class="small fw-bold mt-2 d-block" style="color: #64748b;">
                                    <i class="bi bi-info-circle-fill" style="color: #0ea5e9;"></i> Tax rates: 5% (0–50G) · 10% (51–250G) · 20% (251G+)
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn-blitz-dark">
                            <i class="bi bi-save"></i> SAVE DECK INFO
                        </button>
                    </div>
                </form>
            </div>

            <!-- ── TIP BAR ── -->
            <div class="tip-bar mb-4 lg-reveal active">
                <i class="bi bi-info-circle-fill" style="color: #0ea5e9; font-size: 1rem; flex-shrink: 0;"></i>
                <span>
                    <strong style="color: #0f172a;">Quick Tip:</strong>
                    Edit text directly in the table below. Use <i class="bi bi-save mx-1" style="color: #0ea5e9;"></i> to save a card, or the <i class="bi bi-image mx-1" style="color: #0ea5e9;"></i> / <i class="bi bi-volume-up-fill mx-1" style="color: #6366f1;"></i> icons to update media.
                </span>
            </div>

            <!-- ── CARDS TABLE ── -->
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-3 lg-reveal active">
                <h4 class="fw-black text-dark text-uppercase m-0" style="letter-spacing: -0.5px; font-family: 'Nunito', sans-serif;">MANAGE CARDS (@Model.Flashcards.Count)</h4>
                <a asp-action="AddCard" asp-route-deckId="@Model.Id" class="btn-blitz-primary">
                    <i class="bi bi-plus-lg"></i> ADD NEW CARD
                </a>
            </div>

            <div class="lg-panel p-0 overflow-hidden mb-5 lg-reveal active" style="border-top: 4px solid #0ea5e9 !important;">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                            <tr>
                                <th class="ps-4 py-3 fw-black text-uppercase border-0" style="font-size: 0.6rem; letter-spacing: 1.5px; color: #94a3b8;">FRONT (JAPANESE)</th>
                                <th class="py-3 fw-black text-uppercase border-0" style="font-size: 0.6rem; letter-spacing: 1.5px; color: #94a3b8;">BACK (MEANING)</th>
                                <th class="py-3 fw-black text-uppercase text-center border-0" style="font-size: 0.6rem; letter-spacing: 1.5px; color: #94a3b8;">MEDIA</th>
                                <th class="pe-4 py-3 fw-black text-uppercase text-end border-0" style="font-size: 0.6rem; letter-spacing: 1.5px; color: #94a3b8;">ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var card in Model.Flashcards.OrderBy(c => c.Id))
                            {
                                <tr class="card-row" style="border-bottom: 1px solid #f1f5f9;">
                                    <form asp-action="UpdateCard" method="post" enctype="multipart/form-data">
                                        <input type="hidden" name="Id" value="@card.Id" />
                                        <input type="hidden" name="DeckId" value="@card.DeckId" />

                                        <td class="ps-4 py-3" style="width: 30%;">
                                            <input type="text" name="FrontText" value="@card.FrontText" class="form-control form-control-sm table-input fw-black" style="font-size: 0.92rem;" />
                                        </td>
                                        <td class="py-3" style="width: 35%;">
                                            <input type="text" name="BackText" value="@card.BackText" class="form-control form-control-sm table-input fw-bold" style="font-size: 0.85rem;" />
                                        </td>
                                        <td class="py-3 text-center" style="width: 15%;">
                                            <div class="d-flex justify-content-center gap-2">
                                                <label class="bubble-btn-sm @(string.IsNullOrEmpty(card.ImageFilePath) ? "" : "border-info")" title="Update Image">
                                                    <i class="bi bi-image" style="font-size: 0.95rem; color: @(string.IsNullOrEmpty(card.ImageFilePath) ? "#94a3b8" : "#0ea5e9");"></i>
                                                    <input type="file" name="imageFile" class="d-none" onchange="this.form.submit()" />
                                                </label>
                                                <label class="bubble-btn-sm @(string.IsNullOrEmpty(card.AudioFilePath) ? "" : "border-indigo")" title="Update Audio">
                                                    <i class="bi bi-volume-up-fill" style="font-size: 0.95rem; color: @(string.IsNullOrEmpty(card.AudioFilePath) ? "#94a3b8" : "#6366f1");"></i>
                                                    <input type="file" name="audioFile" class="d-none" onchange="this.form.submit()" />
                                                </label>
                                            </div>
                                        </td>
                                        <td class="pe-4 py-3 text-end" style="width: 20%;">
                                            <div class="d-inline-flex gap-1 bg-white rounded-pill" style="border: 2px solid #e2e8f0; padding: 2px;">
                                                <button type="submit" class="tbl-save" title="Save Card Changes">
                                                    <i class="bi bi-save"></i>
                                                </button>
                                                <button type="button" class="tbl-delete" onclick="confirmDeleteCard(@card.Id)" title="Delete Card">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </form>
                                </tr>
                            }
                            @if (!Model.Flashcards.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5">
                                        <i class="bi bi-inboxes display-4 mb-3 d-block" style="color: #cbd5e1;"></i>
                                        <h5 class="fw-black text-dark text-uppercase" style="font-family: 'Nunito', sans-serif;">Deck is Empty</h5>
                                        <p class="fw-bold small" style="color: #94a3b8;">Add your first flashcard to start building this deck.</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- ── HIDDEN DELETE FORM ── -->
<form id="deleteCardForm" asp-action="DeleteCard" method="post" style="display:none;">
    <input type="hidden" name="cardId" id="deleteCardId" />
    <input type="hidden" name="deckId" value="@Model.Id" />
</form>

<!-- ── DELETE CONFIRM MODAL ── -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 text-center bg-white">
            <div class="bg-danger p-4 text-center position-relative" style="border-radius: 24px 24px 0 0;">
                <h5 class="fw-black text-white m-0 text-uppercase" style="letter-spacing: 1px;">
                    <i class="bi bi-exclamation-triangle-fill me-2 opacity-50"></i> Delete Card
                </h5>
                <button type="button" class="btn-close btn-close-white position-absolute top-50 end-0 translate-middle-y me-4" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 p-md-5">
                <p class="fw-bold mb-4" style="color: #64748b; font-size: 0.85rem;">This action is permanent and cannot be reversed. Are you sure you want to remove this card?</p>
                <div class="d-grid gap-3">
                    <button type="button" class="btn-blitz-danger w-100 justify-content-center" onclick="executeDelete()">
                        CONFIRM DELETE
                    </button>
                    <button type="button" class="btn-blitz-ghost w-100 justify-content-center" data-bs-dismiss="modal">
                        CANCEL
