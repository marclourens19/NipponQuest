@model NipponQuest.Models.Flashcard

@{
    int current = ViewBag.CurrentIndex ?? 1;
    int total = ViewBag.TotalInSession ?? 10;
    double progress = ((double)(current - 1) / total) * 100;
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
            
            <!-- 1. TOP NAVIGATION ROW -->
            <div class="d-flex justify-content-between align-items-center mb-5">
                <a asp-action="Index" class="btn btn-white rounded-pill px-4 fw-bold shadow-sm text-muted d-inline-flex align-items-center transition-all hover-lift">
                    <i class="bi bi-arrow-left me-2 fs-5"></i> ABORT QUEST
                </a>
                <div class="badge bg-soft-blue text-primary border border-primary-subtle rounded-pill px-3 py-2 fw-black text-uppercase tracking-wider shadow-sm">
                    <i class="bi bi-lightning-charge-fill me-1 text-warning"></i> ACTIVE SESSION
                </div>
            </div>

            <!-- 2. STUDY QUEST HEADER CARD -->
            <div class="static-card border-0 rounded-4 overflow-hidden bg-white mb-5 p-4 shadow-sm">
                <div class="text-center">
                    <div class="d-flex justify-content-center align-items-center gap-3 mb-3">
                        <h1 class="fw-black text-dark m-0 text-uppercase tracking-tight" style="font-size: 2.5rem;">
                            STUDY <span class="text-primary hero-glow-text">QUEST</span>
                        </h1>
                        <button type="button" class="btn btn-white rounded-circle shadow-sm p-0 d-flex align-items-center justify-content-center text-muted hover-blue" 
                                style="width: 38px; height: 38px;" data-bs-toggle="modal" data-bs-target="#studyGuideModal">
                            <i class="bi bi-info-lg fs-5 fw-black"></i>
                        </button>
                    </div>
                    
                    <div class="mt-4 px-md-5">
                        <div class="d-flex justify-content-between align-items-end mb-2">
                            <span class="text-muted small fw-bold text-uppercase tracking-wider" style="font-size: 0.75rem;">Arena Progress</span>
                            <span class="fw-black text-muted small text-uppercase tracking-wider" style="font-size: 0.75rem;">
                                <span class="text-primary">@current</span> / <span class="text-dark">@total</span> CARDS
                            </span>
                        </div>
                        <div class="progress rounded-pill shadow-none" style="height: 12px; background: #f1f5f9; border: none;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" 
                                 role="progressbar" style="width: @progress.ToString("0")%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 3. THE ARENA FLASHCARD -->
            <div class="flashcard-scene mb-4" id="flashcard-engine" onclick="toggleFlip()">
                <div class="flashcard-inner">
                    
                    <!-- Front Face -->
                    <div class="card-face card-front">
                        <span class="card-label fw-black text-uppercase tracking-widest opacity-25">Front Side</span>
                        <div class="card-main-body">
                            <!-- Dead Zone Padding Fix -->
                            <div class="text-scroll-container">
                                <div class="text-auto-scale fw-black text-white px-3" id="front-text">@Html.Raw(Model.FrontText)</div>
                            </div>
                            
                            @if (!string.IsNullOrEmpty(Model.ImageFilePath))
                            {
                                <div class="card-image-wrapper mt-3">
                                    <img src="/uploads/media/@Model.ImageFilePath" class="img-fluid rounded-4 shadow" alt="Quest Image" />
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(Model.AudioFilePath))
                            {
                                <audio id="frontCardAudio" src="/uploads/media/@Model.AudioFilePath"></audio>
                                <button type="button" class="btn btn-outline-light border-opacity-25 rounded-pill px-4 fw-black mt-4 transition-all hover-lift" 
                                        onclick="event.stopPropagation(); document.getElementById('frontCardAudio').play();">
                                    <i class="bi bi-volume-up-fill me-2 fs-5"></i> LISTEN
                                </button>
                            }
                            
                            <div class="mt-auto pt-3">
                                <span class="badge bg-white bg-opacity-10 rounded-pill px-3 py-2 fw-black text-uppercase tracking-wider small opacity-75">
                                    <i class="bi bi-hand-index-thumb me-2"></i> Tap to Reveal
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Back Face -->
                    <div class="card-face card-back">
                        <span class="card-label fw-black text-uppercase tracking-widest text-primary opacity-50">Revealed Meaning</span>
                        <div class="card-main-body">
                            <div class="text-scroll-container">
                                <div class="text-auto-scale fw-black text-primary px-3 hero-glow-text" id="back-text">@Html.Raw(Model.BackText)</div>
                            </div>
                            
                            @if (!string.IsNullOrEmpty(Model.AudioFilePath))
                            {
                                <audio id="backCardAudio" src="/uploads/media/@Model.AudioFilePath"></audio>
                                <button type="button" class="btn btn-outline-primary rounded-pill px-4 fw-black mt-4 transition-all hover-lift" 
                                        onclick="event.stopPropagation(); document.getElementById('backCardAudio').play();">
                                    <i class="bi bi-volume-up-fill me-2 fs-5"></i> REPLAY AUDIO
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- 4. RATE YOUR RECALL HUB -->
            <div id="recall-hub" class="recall-hub-container">
                <div class="static-card border-0 rounded-4 bg-white p-4 shadow-sm text-center">
                    <p class="text-muted small fw-bold text-uppercase tracking-wider mb-4">Rate your recall</p>
                    <form asp-action="SubmitResult" method="post">
                        <input type="hidden" name="cardId" value="@Model.Id" />
                        <div class="d-flex justify-content-center gap-3 gap-md-4">
                            <button type="submit" name="quality" value="0" class="recall-btn again shadow-sm">
                                <i class="bi bi-x-lg"></i> <span class="fw-black">1M</span>
                            </button>
                            <button type="submit" name="quality" value="3" class="recall-btn hard shadow-sm">
                                <i class="bi bi-dash-lg"></i> <span class="fw-black">10M</span>
                            </button>
                            <button type="submit" name="quality" value="4" class="recall-btn good shadow-sm">
                                <i class="bi bi-check-lg"></i> <span class="fw-black">1D</span>
                            </button>
                            <button type="submit" name="quality" value="5" class="recall-btn easy shadow-sm">
                                <i class="bi bi-star-fill"></i> <span class="fw-black">4D</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- 5. REVAMPED INFO MODAL (QUEST LOG STYLE) -->
<div class="modal fade" id="studyGuideModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-5 shadow-lg overflow-hidden">
            <!-- Header Banner -->
            <div class="bg-primary p-4 text-center position-relative">
                <div class="position-absolute top-50 start-0 translate-middle-y ps-4 text-white opacity-25">
                    <i class="bi bi-journal-text display-4"></i>
                </div>
                <h4 class="fw-black text-white m-0 text-uppercase tracking-widest">Quest Log: Arena Rules</h4>
                <button type="button" class="btn-close btn-close-white position-absolute top-50 end-0 translate-middle-y me-4" data-bs-dismiss="modal"></button>
            </div>
            
            <div class="modal-body p-4 p-md-5 bg-white">
                <div class="row g-4">
                    <!-- Rule 1 -->
                    <div class="col-md-6">
                        <div class="d-flex align-items-start gap-3 p-3 rounded-4 bg-light transition-all hover-lift h-100">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2">
                                <i class="bi bi-eye-fill fs-4"></i>
                            </div>
                            <div>
                                <h6 class="fw-black text-dark text-uppercase tracking-tight mb-1">The Reveal</h6>
                                <p class="text-muted small fw-bold mb-0">Tap the card to reveal the hidden meaning. High-fidelity audio will play automatically on reveal.</p>
                            </div>
                        </div>
                    </div>
                    <!-- Rule 2 -->
                    <div class="col-md-6">
                        <div class="d-flex align-items-start gap-3 p-3 rounded-4 bg-light transition-all hover-lift h-100">
                            <div class="bg-warning bg-opacity-10 text-warning rounded-3 p-2">
                                <i class="bi bi-bar-chart-fill fs-4"></i>
                            </div>
                            <div>
                                <h6 class="fw-black text-dark text-uppercase tracking-tight mb-1">Recall Grading</h6>
                                <p class="text-muted small fw-bold mb-0">Grade yourself honestly. Correct answers push the card further into the future (SRS Spaced Repetition).</p>
                            </div>
                        </div>
                    </div>
                    <!-- Stats / Legend -->
                    <div class="col-12 mt-4">
                        <div class="border border-light-subtle rounded-4 p-4">
                            <h6 class="fw-black text-muted text-uppercase tracking-widest small mb-4 text-center">Recall Legend</h6>
                            <div class="row text-center g-3">
                                <div class="col-3">
                                    <div class="fw-black text-danger mb-1">1M</div>
                                    <div class="text-muted" style="font-size: 0.65rem; font-weight: 800;">AGAIN</div>
                                </div>
                                <div class="col-3">
                                    <div class="fw-black text-secondary mb-1">10M</div>
                                    <div class="text-muted" style="font-size: 0.65rem; font-weight: 800;">HARD</div>
                                </div>
                                <div class="col-3">
                                    <div class="fw-black text-success mb-1">1D</div>
                                    <div class="text-muted" style="font-size: 0.65rem; font-weight: 800;">GOOD</div>
                                </div>
                                <div class="col-3">
                                    <div class="fw-black text-warning mb-1">4D</div>
                                    <div class="text-muted" style="font-size: 0.65rem; font-weight: 800;">EASY</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="mt-5">
                    <button type="button" class="btn btn-primary rounded-pill px-5 py-3 fw-black shadow-sm text-uppercase tracking-wider w-100 btn-cta-premium" data-bs-dismiss="modal">
                        Resume Study Quest
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f8fafc; }

    /* FLASHCARD ENGINE */
    .flashcard-scene { width: 100%; height: 500px; perspective: 1500px; cursor: pointer; }
    .flashcard-inner { position: relative; width: 100%; height: 100%; transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1); transform-style: preserve-3d; }
    .flashcard-scene.flipped .flashcard-inner { transform: rotateY(180deg); }

    .card-face {
        position: absolute; width: 100%; height: 100%; backface-visibility: hidden;
        border-radius: 40px; 
        background: linear-gradient(145deg, #111827, #1f2937); 
        display: flex; flex-direction: column;
        padding: 30px; border: 1px solid rgba(255,255,255,0.05); overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
    }
    .card-back { transform: rotateY(180deg); }

    /* CARD CONTENT LAYOUT */
    .card-label { font-size: 0.7rem; margin-bottom: 0px; text-align: center; height: 30px; display: block; }
    
    .card-main-body { 
        flex-grow: 1; 
        display: flex; 
        flex-direction: column; 
        align-items: center; 
        justify-content: center; 
        width: 100%;
        padding-top: 20px; /* Crucial: Dead space below the label */
    }

    .text-scroll-container {
        width: 100%;
        max-height: 200px;
        overflow-y: auto;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 10px 0;
    }

    .text-auto-scale { 
        text-align: center; 
        line-height: 1.25; /* Loosened for Kanji clarity */
        width: 100%; 
        word-break: break-word; 
    }

    .card-image-wrapper img { max-height: 160px; object-fit: contain; }

    /* RECALL HUB */
    .recall-hub-container { 
        opacity: 0; transform: translateY(20px); pointer-events: none; 
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); 
    }
    .flashcard-scene.flipped + .recall-hub-container { opacity: 1; transform: translateY(0); pointer-events: all; }

    .recall-btn {
        width: 70px; height: 70px; border-radius: 50%; border: 1px solid #e2e8f0;
        background: white; display: flex; flex-direction: column; align-items: center; justify-content: center;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); color: #64748b; font-size: 0.75rem;
    }
    .recall-btn i { font-size: 1.2rem; margin-bottom: 2px; }
    
    .recall-btn:hover { transform: translateY(-5px); color: white !important; }
    .recall-btn.again:hover { background: #ef4444; border-color: #ef4444; }
    .recall-btn.hard:hover { background: #94a3b8; border-color: #94a3b8; }
    .recall-btn.good:hover { background: #10b981; border-color: #10b981; }
    .recall-btn.easy:hover { background: #eab308; border-color: #eab308; }

    .btn-white { background: #fff; border: 1px solid #e2e8f0; }
    .btn-white:hover { background: #f8fafc; border-color: #cbd5e1; }
    .hover-lift:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important; }
    .hero-glow-text { text-shadow: 0 0 20px rgba(14, 165, 233, 0.2); }
</style>

@section Scripts {
    <script>
        function toggleFlip() {
            const engine = document.getElementById('flashcard-engine');
            engine.classList.toggle('flipped');
            if (engine.classList.contains('flipped')) {
                const audio = document.getElementById('backCardAudio');
                if (audio) { setTimeout(() => audio.play(), 300); }
            }
        }

        function scaleText() {
            const elements = document.querySelectorAll('.text-auto-scale');
            elements.forEach(el => {
                const text = el.innerText.trim();
                const length = text.length;
                let fontSize;

                if (length > 150) fontSize = "1.2rem";
                else if (length > 100) fontSize = "1.4rem";
                else if (length > 60) fontSize = "1.7rem";
                else if (length > 30) fontSize = "2.2rem";
                else if (length > 15) fontSize = "3.0rem";
                else fontSize = "4.0rem";

                el.style.fontSize = fontSize;
            });
        }

        document.addEventListener('DOMContentLoaded', scaleText);
    </script>
}