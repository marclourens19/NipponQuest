@model NipponQuest.Models.Flashcard

@{
    int current = ViewBag.CurrentIndex ?? 1;
    int total = ViewBag.TotalInSession ?? 10;
    double progress = ((double)(current - 1) / total) * 100;
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">

<style>
    /* ──────────────────────────────────────────────────────
       STUDY SESSION — Nunito · Site CSS Aligned
       ────────────────────────────────────────────────────── */

    body { font-family: 'Nunito', sans-serif !important; background: #ffffff; }

    .lg-reveal { opacity: 0; transform: translateY(24px); transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
    .lg-reveal.active { opacity: 1; transform: translateY(0); }

    /* ── HERO ── */
    .lg-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 55%, #0ea5e9 160%);
        border-radius: 24px;
        color: #ffffff;
        padding: 1.4rem 1.5rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 18px 42px -15px rgba(15, 23, 42, 0.32);
        font-family: 'Nunito', sans-serif;
    }
    .lg-hero::before {
        content: "";
        position: absolute;
        inset: -50% -10% auto auto;
        width: 240px; height: 240px;
        background: radial-gradient(circle, rgba(245, 158, 11, 0.16) 0%, transparent 70%);
        pointer-events: none;
    }
    .lg-hero::after {
        content: "クエスト"; /* Quest */
        position: absolute;
        right: 12px; bottom: -14px;
        font-size: 4.5rem;
        font-weight: 900;
        color: rgba(255,255,255,0.04);
        line-height: 1;
        letter-spacing: -3px;
        pointer-events: none;
    }
    .lg-hero-meta {
        font-size: 0.58rem; font-weight: 900;
        letter-spacing: 1.8px;
        color: rgba(255,255,255,0.6);
        text-transform: uppercase;
    }
    .lg-title {
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        font-weight: 900; letter-spacing: -1.5px; line-height: 1;
        margin: 4px 0 0;
        font-family: 'Nunito', sans-serif;
    }
    
    .lg-info-btn {
        width: 40px; height: 40px; border-radius: 50%;
        background: rgba(255,255,255,0.12);
        border: 2px solid rgba(255,255,255,0.25);
        color: #ffffff;
        display: inline-flex; align-items: center; justify-content: center;
        transition: all 200ms ease;
        cursor: pointer;
    }
    .lg-info-btn:hover { background: #fbbf24; color: #422006; border-color: #fbbf24; transform: translateY(-2px); }

    .progress-thin { height: 8px; background: rgba(255,255,255,0.15); border-radius: 50px; overflow: hidden; }
    .progress-thin > div { height: 100%; background: linear-gradient(90deg, #fbbf24, #f59e0b); border-radius: 50px; transition: width 0.4s ease; box-shadow: 0 0 10px rgba(251,191,36,0.3); }

    /* ── INFO PILLARS (MODAL) ── */
    .info-pillar { border: 2px solid #e2e8f0; border-radius: 16px; padding: 16px; height: 100%; background: #ffffff; transition: all 0.2s; font-family: 'Nunito', sans-serif; }
    .info-pillar:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.05); border-color: #cbd5e1; }
    .info-pillar .info-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 10px; }

    /* ── BUTTONS ── */
    .btn { font-family: 'Nunito', sans-serif !important; }
    .btn-white { background: #ffffff; border: 2px solid #e2e8f0; color: #64748b; font-weight: 900; letter-spacing: 1px; }
    .btn-white:hover { background: #f8fafc; border-color: #cbd5e1; color: #0f172a; }
    
    .hover-lift { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .hover-lift:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important; }

    /* ── FLASHCARD 3D CORE ── */
    .flashcard-container.flipped .flashcard-inner { transform: rotateY(180deg); }
    .card-face { font-family: 'Nunito', sans-serif; }
    
    /* SCROLL CUT-OFF BUG FIX */
    .card-scroll-area {
        flex-grow: 1;
        min-height: 0;
        overflow-y: auto;
        overflow-x: hidden;
        display: flex;
        flex-direction: column;
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.2) transparent;
    }
    .card-scroll-area::before,
    .card-scroll-area::after {
        content: "";
        margin: auto;
    }
    .card-scroll-area::-webkit-scrollbar { width: 6px; }
    .card-scroll-area::-webkit-scrollbar-thumb { background-color: rgba(255,255,255,0.2); border-radius: 10px; }

    .text-auto-scale { 
        text-align: center; 
        line-height: 1.3; 
        width: 100%; 
        word-break: break-word; 
    }

    /* ── ANKI EVALUATION BUTTONS ── */
    .anki-new-btn { border-radius: 12px !important; transition: all 0.2s ease; padding: 10px 4px !important; font-family: 'Nunito', sans-serif !important; }
    .anki-new-btn:hover { transform: translateY(-2px); }
    .btn-again:hover { background-color: #f43f5e !important; color: white !important; }
    .btn-hard:hover { background-color: #f59e0b !important; color: white !important; }
    .btn-good:hover { background-color: #0ea5e9 !important; color: white !important; }
    .btn-easy:hover { background-color: #10b981 !important; color: white !important; }

    /* ── MODALS ── */
    .modal-content { border-radius: 24px !important; font-family: 'Nunito', sans-serif; }

    @@media (max-width: 575.98px) {
        .container.py-5.mt-4 { padding-top: 1.25rem !important; margin-top: 0 !important; }
        .lg-hero { padding: 1.5rem; border-radius: 20px; }
        .lg-hero::after { font-size: 5rem; right: 10px; bottom: -10px; }
    }
</style>

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
            
            <div class="d-flex justify-content-start align-items-center mb-4 lg-reveal active">
                <a asp-action="Index" class="btn btn-white rounded-pill px-4 shadow-sm d-inline-flex align-items-center transition-all hover-lift" style="font-size: 0.75rem;">
                    <i class="bi bi-arrow-left me-2 fs-5"></i> ABORT QUEST
                </a>
            </div>

            <div class="lg-hero mb-4 lg-reveal active">
                <div class="d-flex justify-content-between align-items-start mb-2 position-relative" style="z-index: 2;">
                    <div class="lg-hero-meta"><i class="bi bi-lightning-charge-fill me-1 text-warning"></i> ACTIVE SESSION</div>
                    <button type="button" class="lg-info-btn" data-bs-toggle="modal" data-bs-target="#studyGuideModal" title="Arena Rules">
                        <i class="bi bi-info-lg fs-5 fw-black"></i>
                    </button>
                </div>
                
                <div class="text-center mb-4 mt-2 position-relative" style="z-index: 2;">
                    <h1 class="lg-title">
                        STUDY <span style="color: #fbbf24;">QUEST</span>
                    </h1>
                    <p class="lg-hero-meta opacity-75 mt-2" style="letter-spacing: 2px;">Expand your mastery</p>
                </div>
                
                <div class="px-md-2 mt-4 position-relative" style="z-index: 2;">
                    <div class="d-flex justify-content-between align-items-end mb-2">
                        <span class="lg-hero-meta" style="font-size: 0.65rem;">Arena Progress</span>
                        <span class="fw-black text-uppercase tracking-wider" style="font-size: 0.75rem;">
                            <span style="color: #fbbf24;">@current</span> / <span class="opacity-75">@total</span> CARDS
                        </span>
                    </div>
                    <div class="progress-thin">
                        <div style="width: @progress.ToString("0")%;"></div>
                    </div>
                </div>
            </div>

            <div class="flashcard-container group mx-auto w-100 mb-4 lg-reveal active" 
                 style="max-width: 500px; height: 520px; perspective: 1000px; cursor: pointer;" 
                 id="flashcard-engine" onclick="toggleFlip()">
                
                <div class="flashcard-inner h-100 w-100 position-relative" style="transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1); transform-style: preserve-3d;">
                    
                    <div class="card-face card-front position-absolute w-100 h-100 p-4 d-flex flex-column text-start" 
                         style="background: linear-gradient(to bottom right, #1e293b, #0f172a); border: 2px solid #334155; border-radius: 24px; backface-visibility: hidden; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);">
                        
                        <div class="d-flex justify-content-between align-items-center border-bottom pb-2 flex-shrink-0" style="border-color: #334155 !important;">
                            <span class="text-white opacity-50 fw-black" style="font-size: 0.65rem; letter-spacing: 1.5px;">ACTIVE QUEST</span>
                            <span class="rounded px-2 py-1 font-monospace fw-bold" style="background: rgba(14,165,233,0.2); color: #38bdf8; font-size: 0.65rem;">FRONT</span>
                        </div>
                        
                        <div class="card-scroll-area text-center w-100 py-3">
                            <div class="w-100">
                                <div class="text-auto-scale fw-black text-white px-2 mx-auto" style="text-shadow: 0 4px 6px rgba(0,0,0,0.3);" id="front-text">@Html.Raw(Model.FrontText)</div>
                                
                                @if (!string.IsNullOrEmpty(Model.ImageFilePath))
                                {
                                    <div class="card-image-wrapper mt-4">
                                        <img src="/uploads/media/@Model.ImageFilePath" class="img-fluid rounded-4 shadow-lg border border-secondary border-opacity-25" style="max-height: 160px; object-fit: contain;" alt="Quest Image" />
                                    </div>
                                }
                            </div>
                        </div>

                        <p class="mt-2 mb-0 fw-bold text-uppercase flex-shrink-0 text-center" style="color: #38bdf8; font-size: 0.7rem; letter-spacing: 1.5px;">
                            💡 Click anywhere to reveal
                        </p>
                    </div>

                    <div class="card-face card-back position-absolute w-100 h-100 p-4 d-flex flex-column text-start" 
                         style="background: linear-gradient(to bottom right, #020617, #0f172a, #082f49); border: 2px solid #38bdf8; border-radius: 24px; backface-visibility: hidden; transform: rotateY(180deg); box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);">
                        
                        <div class="d-flex justify-content-between align-items-center border-bottom pb-2 flex-shrink-0" style="border-color: #1e293b !important;">
                            <span class="fw-black" style="color: #38bdf8; font-size: 0.65rem; letter-spacing: 1.5px;">MEANING & RECALL</span>
                            <span class="rounded px-2 py-1 font-monospace fw-bold" style="background: rgba(16,185,129,0.2); color: #34d399; font-size: 0.65rem;">REVEALED</span>
                        </div>
                        
                        <div class="card-scroll-area text-center w-100 py-3">
                            <div class="w-100">
                                <div class="text-auto-scale fw-black tracking-tight mx-auto" style="color: #fbbf24;" id="back-text">@Html.Raw(Model.BackText)</div>

                                @if (!string.IsNullOrEmpty(Model.AudioFilePath))
                                {
                                    <audio id="backCardAudio" src="/uploads/media/@Model.AudioFilePath"></audio>
                                    <button type="button" class="btn btn-outline-info btn-sm rounded-pill px-4 py-2 fw-black mt-4 transition-all hover-lift" 
                                            style="border-width: 2px; background: rgba(14,165,233,0.1);" 
                                            onclick="event.stopPropagation(); document.getElementById('backCardAudio').play();">
                                        <i class="bi bi-volume-up-fill me-2 fs-6"></i> REPLAY AUDIO
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="mt-2 border-top pt-3 flex-shrink-0" style="border-color: #1e293b !important;" onclick="event.stopPropagation()">
                            <p class="fw-bold text-white opacity-50 mb-2 text-start" style="font-size: 0.65rem; letter-spacing: 1.5px;">HOW WELL DID YOU RECALL THIS?</p>
                            
                            <form asp-action="SubmitResult" method="post" class="m-0">
                                <input type="hidden" name="cardId" value="@Model.Id" />
                                <div class="d-flex gap-2 w-100 text-center">
                                    <button type="submit" name="quality" value="0" class="btn flex-fill anki-new-btn btn-again" style="background: rgba(244,63,94,0.2); color: #fda4af; border: 1px solid rgba(244,63,94,0.3) !important;">
                                        <i class="bi bi-x-circle d-block mb-1 opacity-75"></i>
                                        <span class="d-block fw-black" style="font-size: 0.6rem;">AGAIN</span>
                                        <span class="d-block opacity-75" style="font-size: 0.5rem;">1m</span>
                                    </button>
                                    <button type="submit" name="quality" value="3" class="btn flex-fill anki-new-btn btn-hard" style="background: rgba(245,158,11,0.2); color: #fcd34d; border: 1px solid rgba(245,158,11,0.3) !important;">
                                        <i class="bi bi-dash-circle d-block mb-1 opacity-75"></i>
                                        <span class="d-block fw-black" style="font-size: 0.6rem;">HARD</span>
                                        <span class="d-block opacity-75" style="font-size: 0.5rem;">10m</span>
                                    </button>
                                    <button type="submit" name="quality" value="4" class="btn flex-fill anki-new-btn btn-good" style="background: rgba(14,165,233,0.2); color: #7dd3fc; border: 1px solid rgba(14,165,233,0.3) !important;">
                                        <i class="bi bi-check-circle d-block mb-1 opacity-75"></i>
                                        <span class="d-block fw-black" style="font-size: 0.6rem;">GOOD</span>
                                        <span class="d-block opacity-75" style="font-size: 0.5rem;">1d</span>
                                    </button>
                                    <button type="submit" name="quality" value="5" class="btn flex-fill anki-new-btn btn-easy" style="background: rgba(16,185,129,0.2); color: #6ee7b7; border: 1px solid rgba(16,185,129,0.3) !important;">
                                        <i class="bi bi-star d-block mb-1 opacity-75"></i>
                                        <span class="d-block fw-black" style="font-size: 0.6rem;">EASY</span>
                                        <span class="d-block opacity-75" style="font-size: 0.5rem;">4d</span>
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<!-- GUIDE MODAL -->
<div class="modal fade" id="studyGuideModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 bg-white overflow-hidden">
            
            <div class="p-4 text-center position-relative" style="background: linear-gradient(135deg, #fbbf24, #f59e0b);">
                <div class="position-absolute top-50 start-0 translate-middle-y ps-4 text-dark opacity-25">
                    <i class="bi bi-journal-text display-4"></i>
                </div>
                <h4 class="fw-black text-dark m-0 text-uppercase" style="letter-spacing: 2px;">Quest Log</h4>
                <p class="text-dark fw-bold small mb-0 mt-1 opacity-75">Arena Study Rules</p>
                <button type="button" class="btn-close position-absolute top-50 end-0 translate-middle-y me-4" data-bs-dismiss="modal"></button>
            </div>
            
            <div class="modal-body p-4 p-md-5">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="info-pillar">
                            <div class="info-icon" style="background: #e0f2fe; color: #0369a1;"><i class="bi bi-eye-fill"></i></div>
                            <h6 class="fw-black text-dark text-uppercase mb-1" style="font-size: 0.75rem; letter-spacing: 1px;">The Reveal</h6>
                            <p class="text-muted small fw-bold mb-0">Tap the card at any time to reveal the hidden meaning. If the card has associated native audio, it will play automatically.</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-pillar">
                            <div class="info-icon" style="background: #fee2e2; color: #b91c1c;"><i class="bi bi-bar-chart-fill"></i></div>
                            <h6 class="fw-black text-dark text-uppercase mb-1" style="font-size: 0.75rem; letter-spacing: 1px;">Recall Grading</h6>
                            <p class="text-muted small fw-bold mb-0">Grade yourself honestly. Correct answers push the card further into the future via the SRS Spaced Repetition algorithm.</p>
                        </div>
                    </div>
                    <div class="col-12 mt-4">
                        <div class="border rounded-4 p-4 bg-white shadow-sm" style="border-color: #e2e8f0 !important;">
                            <h6 class="fw-black text-muted text-uppercase tracking-widest small mb-4 text-center">Recall Legend</h6>
                            <div class="row text-center g-3">
                                <div class="col-3">
                                    <div class="fw-black text-danger fs-5 mb-1">1M</div>
                                    <div class="text-muted" style="font-size: 0.65rem; font-weight: 800; letter-spacing: 1px;">AGAIN</div>
                                </div>
                                <div class="col-3">
                                    <div class="fw-black text-secondary fs-5 mb-1" style="color: #f59e0b !important;">10M</div>
                                    <div class="text-muted" style="font-size: 0.65rem; font-weight: 800; letter-spacing: 1px;">HARD</div>
                                </div>
                                <div class="col-3">
                                    <div class="fw-black text-success fs-5 mb-1" style="color: #0ea5e9 !important;">1D</div>
                                    <div class="text-muted" style="font-size: 0.65rem; font-weight: 800; letter-spacing: 1px;">GOOD</div>
                                </div>
                                <div class="col-3">
                                    <div class="fw-black text-warning fs-5 mb-1" style="color: #10b981 !important;">4D</div>
                                    <div class="text-muted" style="font-size: 0.65rem; font-weight: 800; letter-spacing: 1px;">EASY</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="mt-5 text-center">
                    <button type="button" class="btn w-100 fw-black text-white" style="background: linear-gradient(135deg, #0f172a, #1e293b); border: none; border-radius: 14px; padding: 12px; letter-spacing: 1px; transition: transform 0.2s; box-shadow: 0 4px 16px rgba(15,23,42,0.3);" data-bs-dismiss="modal">
                        RESUME STUDY QUEST
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleFlip() {
            const engine = document.getElementById('flashcard-engine');
            engine.classList.toggle('flipped');
            
            if (engine.classList.contains('flipped')) {
                const audio = document.getElementById('backCardAudio');
                if (audio) { 
                    setTimeout(() => audio.play().catch(e => console.log('Audio autoplay prevented:', e)), 300); 
                }
            }
        }

        function scaleText() {
            const elements = document.querySelectorAll('.text-auto-scale');
            elements.forEach(el => {
                const text = el.innerText.trim();
                const length = text.length;
                let fontSize;

                if (length > 250) fontSize = "1.0rem";
                else if (length > 150) fontSize = "1.2rem";
                else if (length > 100) fontSize = "1.5rem";
                else if (length > 60) fontSize = "1.8rem";
                else if (length > 30) fontSize = "2.2rem";
                else if (length > 15) fontSize = "3.0rem";
                else fontSize = "4.0rem";

                el.style.fontSize = fontSize;
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            scaleText();
            const obs = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) e.target.classList.add('active'); }), { threshold: 0.05 });
            document.querySelectorAll('.lg-reveal').forEach(el => obs.observe(el));
        });
    </script>
}
