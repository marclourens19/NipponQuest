@model NipponQuest.Models.Deck

<div class="container py-5 mt-4">
    <!-- 1. TOP HEADER SECTION -->
    <div class="row justify-content-center mb-4">
        <div class="col-lg-11">
            <div class="d-flex justify-content-between align-items-end flex-wrap gap-3">
                <div>
                    <h1 class="fw-black text-dark m-0 text-uppercase tracking-tight d-flex align-items-center flex-wrap gap-3" style="font-size: 2.8rem; letter-spacing: -1px;">
                        <span>CREATE <span class="text-primary hero-glow-text">DECK</span></span>
                        
                        <!-- HELP BUTTON -->
                        <button class="btn btn-white rounded-circle shadow-sm p-0 d-flex align-items-center justify-content-center text-muted hover-blue transition-all hover-lift" 
                                style="width: 38px; height: 38px; margin-bottom: 8px;" 
                                data-bs-toggle="modal" data-bs-target="#createGuideModal" 
                                title="Deck Creation Guide">
                            <i class="bi bi-info-lg fs-5 fw-black"></i>
                        </button>
                    </h1>
                    <p class="text-muted fw-bold m-0 mt-1 text-uppercase tracking-wider" style="font-size: 0.85rem;">Forge a new quest and build your flashcard collection</p>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-white rounded-pill px-4 fw-bold shadow-sm text-muted d-flex align-items-center transition-all hover-lift">
                        <i class="bi bi-arrow-left me-2 fs-5"></i> BACK TO MY DECKS
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. FORM CARD -->
    <div class="row justify-content-center">
        <div class="col-lg-7 col-xl-6">
            <div class="static-card border-0 rounded-4 shadow-sm bg-white mb-5 p-4 p-md-5 transition-all" style="border-top: 5px solid #0ea5e9 !important;">
                <form asp-action="Create" method="post">
                    
                    <!-- Deck Title -->
                    <div class="mb-4">
                        <label asp-for="Title" class="form-label fw-black text-dark small text-uppercase tracking-wider ms-1">
                            Deck Title <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title" class="form-control form-control-lg fw-black text-dark bg-light border-0 shadow-sm rounded-4 py-3" 
                               placeholder="e.g., JLPT N4 KANJI" required />
                        <span asp-validation-for="Title" class="text-danger small fw-bold mt-1 d-block ms-1"></span>
                    </div>
                    
                    <!-- Description -->
                    <div class="mb-5">
                        <label asp-for="Description" class="form-label fw-black text-dark small text-uppercase tracking-wider ms-1">
                            Description <span class="text-muted opacity-50 text-lowercase fw-bold">(Optional)</span>
                        </label>
                        <textarea asp-for="Description" class="form-control form-control-lg fw-bold text-dark bg-light border-0 shadow-sm rounded-4 py-3" 
                                  rows="3" placeholder="What will you conquer in this quest?"></textarea>
                        <span asp-validation-for="Description" class="text-danger small fw-bold mt-1 d-block ms-1"></span>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-black shadow-sm py-3 text-uppercase tracking-wider btn-cta-premium transition-all hover-lift">
                            <i class="bi bi-hammer me-2"></i> FORGE NEW DECK
                        </button>
                        <a asp-action="Index" class="btn btn-light btn-lg rounded-pill fw-black text-muted text-uppercase tracking-wider shadow-sm py-3 text-center transition-all hover-lift">
                            CANCEL
                        </a>
                    </div>
                    
                </form>
            </div>
        </div>
    </div>
</div>

<!-- 3. REVAMPED CREATE GUIDE MODAL (QUEST LOG STYLE) -->
<div class="modal fade" id="createGuideModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-5 shadow-lg overflow-hidden">
            <!-- Header Banner -->
            <div class="bg-primary p-4 text-center position-relative">
                <div class="position-absolute top-50 start-0 translate-middle-y ps-4 text-white opacity-25">
                    <i class="bi bi-journal-plus display-4"></i>
                </div>
                <h4 class="fw-black text-white m-0 text-uppercase tracking-widest">Quest Log: Creation Guide</h4>
                <button type="button" class="btn-close btn-close-white position-absolute top-50 end-0 translate-middle-y me-4" data-bs-dismiss="modal"></button>
            </div>
            
            <div class="modal-body p-4 p-md-5 bg-white">
                <div class="row g-4">
                    <!-- Rule 1 -->
                    <div class="col-md-6">
                        <div class="d-flex align-items-start gap-3 p-3 rounded-4 bg-light transition-all hover-lift h-100">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2">
                                <i class="bi bi-type fs-4"></i>
                            </div>
                            <div>
                                <h6 class="fw-black text-dark text-uppercase tracking-tight mb-1">1. Deck Title</h6>
                                <p class="text-muted small fw-bold mb-0">Give your deck a clear, recognizable name. This is how it will appear on your dashboard. Good examples include "JLPT N5 Vocab" or "Restaurant Phrases".</p>
                            </div>
                        </div>
                    </div>
                    <!-- Rule 2 -->
                    <div class="col-md-6">
                        <div class="d-flex align-items-start gap-3 p-3 rounded-4 bg-light transition-all hover-lift h-100">
                            <div class="bg-info bg-opacity-10 text-info rounded-3 p-2">
                                <i class="bi bi-card-text fs-4"></i>
                            </div>
                            <div>
                                <h6 class="fw-black text-dark text-uppercase tracking-tight mb-1">2. Description (Optional)</h6>
                                <p class="text-muted small fw-bold mb-0">Add a few details about what's inside. If you ever choose to share this deck in the <strong>Community Hub</strong>, this description helps other warriors know exactly what they are downloading!</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="mt-5 text-center">
                    <button type="button" class="btn btn-primary rounded-pill px-5 py-3 fw-black shadow-sm text-uppercase tracking-wider btn-cta-premium w-100" data-bs-dismiss="modal">
                        Understood!
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f8fafc; }

    /* Specific Overrides */
    .tracking-tight { letter-spacing: -1px; }
    .tracking-wider { letter-spacing: 1px; }
    
    .hero-glow-text { text-shadow: 0 0 20px rgba(14, 165, 233, 0.2); }
    
    /* Buttons */
    .btn-white { background: #fff; border: 1px solid #e2e8f0; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .btn-white:hover { background: #f8fafc; border-color: #cbd5e1; }

    /* Hover Utilities */
    .hover-lift { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .hover-lift:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.1) !important; }
    
    .hover-blue:hover { color: #0ea5e9 !important; border-color: #0ea5e9 !important; }
    .transition-all { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    
    /* Input Focus */
    .form-control:focus {
        border-color: #0ea5e9 !important;
        box-shadow: 0 0 0 0.25rem rgba(14, 165, 233, 0.15) !important;
    }
</style>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}