@model NipponQuest.Models.Deck

@{
    // SAFE FALLBACKS: Prevents crashes during Create GET if ViewBags are missing.
    var freeColors = ViewBag.FreeColors as List<string> ?? new List<string> { "#ffffff" };

    // LIGHTER PASTEL COLORS — matches updated FlashcardsController.cs
    var premiumColors = ViewBag.PremiumColors as List<string> ?? new List<string> {
        "#fecaca", // rose-200
        "#fed7aa", // orange-200
        "#fef08a", // yellow-200
        "#d9f99d", // lime-200
        "#bbf7d0", // green-200
        "#a7f3d0", // emerald-200
        "#99f6e4", // teal-200
        "#a5f3fc", // cyan-200
        "#bae6fd", // sky-200
        "#bfdbfe", // blue-200
        "#c7d2fe", // indigo-200
        "#ddd6fe", // violet-200
        "#e9d5ff", // purple-200
        "#f5d0fe", // fuchsia-200
        "#fbcfe8", // pink-200
        "#fecdd3", // rose-100 warm
        "#e2e8f0", // slate-200
        "#e7e5e4", // stone-200
        "#fef9c3"  // yellow-100 cream
    };

    var purchasedColors = ViewBag.PurchasedColors as List<string> ?? new List<string>();
    var userLevel = ViewBag.UserLevel as int? ?? 1;
    var deckId = Model?.Id ?? 0;
    var defaultColor = Model?.ThemeColor ?? "#ffffff";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">

<style>
    /* ──────────────────────────────────────────────────────
       CREATE DECK — Nunito · Site CSS Aligned
       ────────────────────────────────────────────────────── */

    body { font-family: 'Nunito', sans-serif !important; background: #ffffff; }

    .lg-reveal { opacity: 0; transform: translateY(24px); transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
    .lg-reveal.active { opacity: 1; transform: translateY(0); }

    /* ── HERO ── */
    .lg-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 55%, #0ea5e9 160%);
        border-radius: 28px;
        color: #ffffff;
        padding: 2.5rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 25px 60px -15px rgba(15, 23, 42, 0.4);
        font-family: 'Nunito', sans-serif;
    }
    .lg-hero::before {
        content: "";
        position: absolute;
        inset: -50% -10% auto auto;
        width: 420px; height: 420px;
        background: radial-gradient(circle, rgba(245, 158, 11, 0.18) 0%, transparent 70%);
        pointer-events: none;
    }
    .lg-hero::after {
        content: "鍛造";
        position: absolute;
        right: 20px; bottom: -20px;
        font-size: 8rem; font-weight: 900;
        color: rgba(255,255,255,0.04);
        line-height: 1; letter-spacing: -4px;
        pointer-events: none;
    }
    .lg-hero-meta {
        font-size: 0.65rem; font-weight: 900;
        letter-spacing: 2px;
        color: rgba(255,255,255,0.6);
        text-transform: uppercase;
    }
    .lg-title {
        font-size: clamp(2.4rem, 5vw, 3.8rem);
        font-weight: 900; letter-spacing: -2px; line-height: 1;
        margin: 6px 0 2px;
        font-family: 'Nunito', sans-serif;
    }
    .lg-info-btn {
        width: 40px; height: 40px; border-radius: 50%;
        background: rgba(255,255,255,0.12);
        border: 2px solid rgba(255,255,255,0.25);
        color: #ffffff;
        display: inline-flex; align-items: center; justify-content: center;
        transition: all 200ms ease;
        cursor: pointer;
    }
    .lg-info-btn:hover { background: #fbbf24; color: #422006; border-color: #fbbf24; transform: translateY(-2px); }

    /* ── MAIN PREVIEW CARD ── */
    .create-card {
        background: #ffffff;
        border: 2px solid #e2e8f0;
        border-radius: 24px;
        padding: 2rem;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.04);
        transition: all 250ms ease;
    }
    .create-card:hover { box-shadow: 0 12px 32px rgba(15, 23, 42, 0.08); }

    /* ── INFO PILLARS ── */
    .info-pillar {
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 16px;
        height: 100%;
        background: #ffffff;
        transition: all 0.2s;
        font-family: 'Nunito', sans-serif;
    }
    .info-pillar:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.05); border-color: #cbd5e1; }
    .info-pillar .info-icon {
        width: 44px; height: 44px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; margin-bottom: 10px;
    }

    /* ── FORMS ── */
    .btn { font-family: 'Nunito', sans-serif !important; }
    .auth-input {
        font-family: 'Nunito', sans-serif !important;
        font-weight: 700;
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 12px !important;
        padding: 0.85rem 1rem;
        color: #0f172a;
        transition: all 0.25s;
    }
    .auth-input:focus {
        background: #ffffff;
        border-color: #0ea5e9;
        box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.1);
        outline: none;
    }
    .auth-input::placeholder { color: #94a3b8; font-weight: 600; }

    /* ── BUTTON SYSTEM ── */
    .btn-blitz-dark {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: #ffffff !important;
        border: none;
        border-radius: 14px;
        font-family: 'Nunito', sans-serif;
        font-weight: 900;
        font-size: 0.78rem;
        letter-spacing: 1px;
        padding: 10px 20px;
        transition: all 200ms ease;
        display: inline-flex; align-items: center; gap: 6px;
        cursor: pointer;
        text-decoration: none;
    }
    .btn-blitz-dark:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(15,23,42,0.3); color: #fff !important; }

    .btn-blitz-primary {
        background: linear-gradient(135deg, #0ea5e9, #2563eb);
        color: #ffffff !important;
        border: none;
        border-radius: 14px;
        font-family: 'Nunito', sans-serif;
        font-weight: 900;
        font-size: 0.78rem;
        letter-spacing: 1px;
        padding: 10px 20px;
        transition: all 200ms ease;
        display: inline-flex; align-items: center; gap: 6px;
        cursor: pointer;
        text-decoration: none;
        box-shadow: 0 4px 16px rgba(14,165,233,0.3);
    }
    .btn-blitz-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(14,165,233,0.4); color: #fff !important; }

    .btn-blitz-gold {
        background: linear-gradient(135deg, #fbbf24, #f59e0b);
        color: #422006 !important;
        border: none;
        border-radius: 14px;
        font-family: 'Nunito', sans-serif;
        font-weight: 900;
        font-size: 0.78rem;
        letter-spacing: 1px;
        padding: 10px 20px;
        transition: all 200ms ease;
        display: inline-flex; align-items: center; gap: 6px;
        cursor: pointer;
        text-decoration: none;
        box-shadow: 0 4px 16px rgba(245,158,11,0.3);
    }
    .btn-blitz-gold:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(245,158,11,0.4); }

    .btn-blitz-ghost {
        background: #ffffff;
        color: #0f172a;
        border: 2px solid #e2e8f0;
        border-radius: 14px;
        font-family: 'Nunito', sans-serif;
        font-weight: 900;
        font-size: 0.78rem;
        letter-spacing: 1px;
        padding: 10px 20px;
        transition: all 200ms ease;
        display: inline-flex; align-items: center; gap: 6px;
        cursor: pointer;
        text-decoration: none;
    }
    .btn-blitz-ghost:hover { border-color: #0ea5e9; color: #0ea5e9; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(14,165,233,0.1); }

    /* ── COLOUR SWATCHES ── */
    .color-swatch {
        width: 34px; height: 34px;
        border-radius: 50%;
        cursor: pointer;
        display: inline-flex; align-items: center; justify-content: center;
        border: 2px solid rgba(0,0,0,0.08);
        transition: transform 0.2s, box-shadow 0.2s;
        flex-shrink: 0;
    }
    .color-swatch[style*="#ffffff"] { border-color: #e2e8f0; }
    .color-swatch.selected {
        box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.55);
        transform: scale(1.18);
    }
    .color-swatch:not(.locked):hover { transform: scale(1.15); }
    .color-swatch.locked {
        opacity: 0.65;
        cursor: pointer;
        border-style: dashed;
    }
    .color-swatch.locked:hover { opacity: 1; transform: scale(1.1); }

    /* ── COMMUNITY HUB BOX ── */
    .community-box {
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 1.25rem;
        transition: all 0.2s;
    }
    .form-switch .form-check-input {
        width: 2.4em; height: 1.2em;
        cursor: pointer;
        background-color: #e2e8f0;
        border-color: #e2e8f0;
    }
    .form-switch .form-check-input:checked { background-color: #0ea5e9; border-color: #0ea5e9; }

    /* ── UNLOCK ALL ── */
    .unlock-all-btn {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 6px 14px;
        border-radius: 12px;
        border: 2px solid #fde68a;
        background: #fffbeb;
        color: #92400e;
        font-family: 'Nunito', sans-serif;
        font-weight: 900;
        font-size: 0.65rem;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.2s;
        height: 34px;
    }
    .unlock-all-btn:hover { background: #fef3c7; border-color: #fbbf24; transform: translateY(-1px); }

    /* ── TIP BAR ── */
    .tip-bar {
        background: #f0f9ff;
        border: 2px solid #bae6fd;
        border-radius: 16px;
        padding: 12px 20px;
        font-size: 0.78rem;
        font-weight: 700;
        color: #0369a1;
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'Nunito', sans-serif;
    }

    /* ── GOLD COIN ── */
    .gold-coin {
        background: linear-gradient(135deg, #FFD700 0%, #FFB900 100%);
        border-radius: 50%; border: 1.5px solid #B45309;
        display: inline-flex; align-items: center; justify-content: center;
        font-weight: 900; color: #451a03 !important;
        font-family: 'Nunito', sans-serif; flex-shrink: 0;
    }
    .gold-coin::after { content: "G"; }

    /* ── MODAL ── */
    .modal-content { border-radius: 24px !important; font-family: 'Nunito', sans-serif; }

    /* ── RESPONSIVE ── */
    @@media (max-width: 575.98px) {
        .container.py-5.mt-4 { padding-top: 1.25rem !important; margin-top: 0 !important; }
        .mobile-header-container { padding: 1.5rem !important; border-radius: 24px !important; }
        .lg-hero::after { font-size: 5rem; right: 10px; bottom: -10px; }
        .mobile-header-btns { flex-wrap: wrap !important; width: 100%; }
        .create-card { padding: 1.25rem; }
    }
</style>

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-11">
            
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger fw-bold border-0 d-flex align-items-center mb-4 px-4 py-3 alert-dismissible fade show lg-reveal active" style="border-radius: 14px; font-family: 'Nunito', sans-serif;">
                    <i class="bi bi-exclamation-octagon-fill fs-5 me-2 text-danger"></i>
                    <div>@TempData["Error"]</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success fw-bold border-0 d-flex align-items-center mb-4 px-4 py-3 alert-dismissible fade show lg-reveal active" style="border-radius: 14px; font-family: 'Nunito', sans-serif;">
                    <i class="bi bi-check-circle-fill fs-5 me-2 text-success"></i>
                    <div>@TempData["Message"]</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- ── HERO ── -->
            <div class="lg-hero mb-4 lg-reveal active mobile-header-container">
                <div class="row g-4 align-items-center position-relative" style="z-index: 2;">
                    <div class="col-lg-8">
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <div class="lg-hero-meta"><i class="bi bi-hammer me-1 text-warning"></i> FORGE &middot; 鍛造</div>
                        </div>
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <h1 class="lg-title m-0 text-uppercase">CREATE <span style="color: #fbbf24;">DECK</span></h1>
                            <button type="button" class="lg-info-btn" data-bs-toggle="modal" data-bs-target="#createGuideModal" title="Creation Guide">
                                <i class="bi bi-info-lg fs-5 fw-black"></i>
                            </button>
                        </div>
                        <div class="lg-hero-meta mt-2 opacity-75" style="letter-spacing: 1px; font-size: 0.8rem;">Forge a new quest and build your flashcard collection</div>

                        <div class="d-flex gap-2 mt-4 mobile-header-btns flex-wrap">
                            <a asp-action="Index" class="btn-blitz-ghost">
                                <i class="bi bi-arrow-left"></i> BACK TO MY DECKS
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── CREATE FORM ── -->
            <div class="create-card mb-4 lg-reveal active" id="MainCreateCard" style="background-color: @defaultColor !important;">
                <form asp-action="Create" method="post">
                    
                    <div class="row g-4 align-items-end mb-4">
                        <div class="col-md-6">
                            <label asp-for="Title" class="form-label fw-black text-dark small text-uppercase mb-1" style="letter-spacing: 1px; font-size: 0.65rem;">Deck Title <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control auth-input" placeholder="e.g., JLPT N4 KANJI" required />
                            <span asp-validation-for="Title" class="text-danger small fw-bold mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Description" class="form-label fw-black text-dark small text-uppercase mb-1" style="letter-spacing: 1px; font-size: 0.65rem;">Description <span class="text-muted opacity-50 text-lowercase fw-bold">(Optional)</span></label>
                            <input asp-for="Description" class="form-control auth-input" placeholder="What will you conquer?" />
                            <span asp-validation-for="Description" class="text-danger small fw-bold mt-1 d-block"></span>
                        </div>

                        <div class="col-12 mt-4">
                            <div class="mb-2">
                                <label class="form-label fw-black text-dark small text-uppercase m-0" style="letter-spacing: 1px; font-size: 0.65rem;">Equip Deck Theme Color</label>
                            </div>
                            
                            <div class="d-flex flex-wrap align-items-center gap-2 ps-1 py-1">
                                <input type="hidden" asp-for="ThemeColor" id="ThemeColorInput" value="@defaultColor" />
                                
                                @foreach (var color in freeColors)
                                {
                                    <div class="color-swatch @(defaultColor == color ? "selected" : "")"
                                         style="background-color: @color;"
                                         onclick="selectColor('@color', this, false)" title="Equip @color">
                                    </div>
                                }

                                <div class="vr mx-1 opacity-25" style="height: 34px;"></div>

                                @foreach (var color in premiumColors)
                                {
                                    bool isOwned = purchasedColors.Contains(color);
                                    
                                    <div class="color-swatch @(defaultColor == color ? "selected" : "") @(isOwned ? "" : "locked")"
                                         style="background-color: @color;"
                                         onclick="selectColor('@color', this, @(isOwned ? "false" : "true"))" 
                                         title="@(isOwned ? "Equip theme" : "Unlock theme for 50G")">
                                         @if (!isOwned)
                                         {
                                             <i class="bi bi-lock-fill" style="font-size: 0.7rem; color: rgba(0,0,0,0.4);"></i>
                                         }
                                    </div>
                                }

                                @if (premiumColors.Except(purchasedColors).Any())
                                {
                                    <div class="vr mx-1 opacity-25" style="height: 34px;"></div>
                                    <button type="button" class="unlock-all-btn" data-bs-toggle="modal" data-bs-target="#buyAllColorsModal">
                                        <i class="bi bi-unlock-fill"></i> UNLOCK ALL (500 <div class="gold-coin" style="width: 14px; height: 14px; font-size: 0.5rem; border-width: 1px; vertical-align: middle; display: inline-flex;"></div>)
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Community Hub -->
                    <div class="community-box mb-4 mt-4">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
                            <div>
                                <h6 class="fw-black text-dark m-0 text-uppercase d-flex align-items-center" style="letter-spacing: 1px; font-size: 0.72rem;">
                                    <i class="bi bi-globe-americas me-2" style="color: #6366f1;"></i> Community Hub
                                </h6>
                                <span class="small text-dark fw-bold opacity-75">Sell this new deck to the community and earn Gold.</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                @if (userLevel < 5)
                                {
                                    <div class="badge rounded-pill px-3 py-2 fw-black small" style="background: #fef2f2; color: #dc2626; border: 1px solid #fecaca;">
                                        <i class="bi bi-lock-fill me-1"></i> REACH LVL 5 TO UNLOCK
                                    </div>
                                    <div class="form-check form-switch m-0 fs-5 opacity-50">
                                        <input class="form-check-input" type="checkbox" role="switch" disabled>
                                    </div>
                                }
                                else
                                {
                                    <div class="form-check form-switch m-0 fs-5">
                                        <input class="form-check-input cursor-pointer" type="checkbox" role="switch" asp-for="IsPublic" id="publishSwitch">
                                        <label class="form-check-label fw-black ms-2 text-dark fs-6 cursor-pointer text-uppercase pt-1" style="letter-spacing: 1px;" for="publishSwitch">MAKE PUBLIC</label>
                                    </div>
                                }
                            </div>
                        </div>
                        
                        <div class="collapse" id="priceField">
                            <div class="pt-3 border-top mt-2" style="border-color: #e2e8f0 !important;">
                                <label asp-for="Price" class="form-label fw-black text-dark small text-uppercase mb-1" style="letter-spacing: 1px; font-size: 0.65rem;">Market Price (Gold)</label>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="gold-coin" style="width: 24px; height: 24px; font-size: 0.8rem; border-width: 1.5px;"></div>
                                    <input asp-for="Price" type="number" min="0" max="10000" class="form-control auth-input" style="max-width: 220px;" placeholder="0 for Free" />
                                </div>
                                <span class="text-dark small fw-bold mt-2 d-block opacity-75"><i class="bi bi-info-circle-fill text-primary"></i> Tax rates apply: 5% (0-50G), 10% (51-250G), 20% (251G+).</span>
                            </div>
                        </div>
                    </div>

                    <div class="tip-bar mb-4">
                        <i class="bi bi-info-circle-fill text-primary me-1"></i>
                        <span><strong style="color:#0f172a;">Next Steps:</strong> After forging your deck, you will be taken to the Master Editor where you can add unlimited cards, upload images, and attach voice notes.</span>
                    </div>

                    <div class="d-flex justify-content-end gap-3 flex-wrap">
                        <a asp-action="Index" class="btn-blitz-ghost">
                            CANCEL
                        </a>
                        <button type="submit" class="btn-blitz-dark">
                            <i class="bi bi-hammer"></i> FORGE & CONTINUE
                        </button>
                    </div>
                </form>
            </div>
            
        </div>
    </div>
</div>

<!-- GUIDE MODAL -->
<div class="modal fade" id="createGuideModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 bg-white overflow-hidden">
            <div class="p-4 text-center position-relative" style="background: linear-gradient(135deg, #0ea5e9, #2563eb); border-radius: 24px 24px 0 0;">
                <div class="position-absolute top-50 start-0 translate-middle-y ps-4 text-white opacity-25">
                    <i class="bi bi-journal-plus display-4"></i>
                </div>
                <h4 class="fw-black text-white m-0 text-uppercase tracking-widest" style="letter-spacing: 2px;">Quest Log</h4>
                <p class="text-white fw-bold small mb-0 mt-1 opacity-75">Creation Guide</p>
                <button type="button" class="btn-close btn-close-white position-absolute top-50 end-0 translate-middle-y me-4" data-bs-dismiss="modal"></button>
            </div>
            
            <div class="modal-body p-4 p-md-5 bg-white">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="info-pillar w-100">
                            <div class="info-icon" style="background: #e0f2fe; color: #0369a1;"><i class="bi bi-palette-fill"></i></div>
                            <h6 class="fw-black text-dark text-uppercase mb-1" style="font-size: 0.75rem; letter-spacing: 1px;">1. Customize Deck</h6>
                            <p class="text-muted small fw-bold mb-0">Give your deck a Title, an optional Description, and equip a Theme Color. Premium colors can be permanently unlocked with Gold!</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-pillar w-100">
                            <div class="info-icon" style="background: #e0f2fe; color: #2563eb;"><i class="bi bi-arrow-right-circle-fill"></i></div>
                            <h6 class="fw-black text-dark text-uppercase mb-1" style="font-size: 0.75rem; letter-spacing: 1px;">2. Forge & Continue</h6>
                            <p class="text-muted small fw-bold mb-0">Clicking <strong>Forge</strong> will save your deck and drop you straight into the Master Editor, where you can bulk-add cards and attach media.</p>
                        </div>
                    </div>
                </div>
                
                <div class="mt-5 text-center">
                    <button type="button" class="btn-blitz-dark w-100 justify-content-center" data-bs-dismiss="modal">
                        Understood!
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- BUY SINGLE COLOUR MODAL -->
<div class="modal fade" id="buyColorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 bg-white text-center overflow-hidden">
            <div class="modal-body p-4 p-md-5">
                <div class="mb-3 d-flex justify-content-center">
                    <div id="modalColorPreview" style="width: 60px; height: 60px; border-radius: 50%; border: 3px solid #e2e8f0; box-shadow: 0 4px 10px rgba(0,0,0,0.06);"></div>
                </div>
                <h5 class="fw-black text-dark mb-1 text-uppercase">Unlock Theme?</h5>
                <p class="text-muted small fw-bold mb-4">Permanently unlock this premium color for all your decks.</p>
                
                <form asp-action="PurchaseColor" method="post">
                    <input type="hidden" name="deckId" value="@deckId" />
                    <input type="hidden" name="colorHex" id="purchaseColorHex" value="" />
                    
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn-blitz-primary w-100 justify-content-center">
                            UNLOCK FOR 50 <div class="gold-coin" style="width: 18px; height: 18px; font-size: 0.6rem; border-width: 1px;"></div>
                        </button>
                        <button type="button" class="btn-blitz-ghost w-100 justify-content-center" data-bs-dismiss="modal">
                            CANCEL
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- BUY ALL COLOURS MODAL -->
<div class="modal fade" id="buyAllColorsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 bg-white text-center overflow-hidden">
            <div class="modal-body p-4 p-md-5">
                <div class="mb-3">
                    <i class="bi bi-palette-fill display-4" style="color: #fbbf24;"></i>
                </div>
                <h5 class="fw-black text-dark mb-1 text-uppercase">Master Painter Bundle</h5>
                <p class="text-muted small fw-bold mb-4">Instantly unlock all remaining premium colors at a major discount.</p>
                
                <form asp-action="PurchaseAllColors" method="post">
                    <input type="hidden" name="deckId" value="@deckId" />
                    
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn-blitz-gold w-100 justify-content-center">
                            UNLOCK ALL FOR 500 <div class="gold-coin" style="width: 18px; height: 18px; font-size: 0.6rem; border-width: 1px;"></div>
                        </button>
                        <button type="button" class="btn-blitz-ghost w-100 justify-content-center" data-bs-dismiss="modal">
                            CANCEL
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const obs = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) e.target.classList.add('active'); }), { threshold: 0.05 });
            document.querySelectorAll('.lg-reveal').forEach(el => obs.observe(el));

            const publishSwitch = document.getElementById('publishSwitch');
            if (publishSwitch) {
                publishSwitch.addEventListener('change', function() {
                    const priceField = new bootstrap.Collapse(document.getElementById('priceField'), { toggle: false });
                    if (this.checked) priceField.show();
                    else priceField.hide();
                });
            }
        });

        function selectColor(hex, element, isLocked) {
            if (isLocked) {
                document.getElementById('purchaseColorHex').value = hex;
                document.getElementById('modalColorPreview').style.backgroundColor = hex;
                const buyModal = new bootstrap.Modal(document.getElementById('buyColorModal'));
                buyModal.show();
                return;
            }

            document.getElementById('ThemeColorInput').value = hex;
            document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('selected'));
            element.classList.add('selected');

            const mainCard = document.getElementById('MainCreateCard');
            mainCard.style.setProperty('background-color', hex === '#ffffff' ? '#ffffff' : hex, 'important');
        }
    </script>
}
