@model NipponQuest.Models.Deck

<div class="container py-5 mt-4">
    <!-- 1. TOP HEADER SECTION -->
    <div class="row justify-content-center mb-4">
        <div class="col-lg-11">
            <div class="d-flex justify-content-between align-items-end flex-wrap gap-3">
                <div>
                    <h1 class="fw-black text-dark m-0 text-uppercase tracking-tight d-flex align-items-center flex-wrap gap-3" style="font-size: 2.8rem; letter-spacing: -1px;">
                        <span>DELETE <span class="text-danger hero-glow-text-danger">DECK</span></span>
                    </h1>
                    <p class="text-muted fw-bold m-0 mt-1 text-uppercase tracking-wider" style="font-size: 0.85rem;">Permanently remove this quest from your collection</p>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-white rounded-pill px-4 fw-bold shadow-sm text-muted d-flex align-items-center transition-all hover-lift">
                        <i class="bi bi-arrow-left me-2 fs-5"></i> BACK TO MY DECKS
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. DELETE CONFIRMATION CARD -->
    <div class="row justify-content-center">
        <div class="col-lg-6 col-xl-5">
            
            <div class="static-card border-0 rounded-4 shadow-lg overflow-hidden bg-white mb-5 p-0 transition-all">
                
                <!-- Premium Danger Header Banner -->
                <div class="p-4 p-md-5 text-center text-white position-relative" style="background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);">
                    <div class="mb-3">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-white bg-opacity-25 shadow-sm transition-all hover-scale" style="width: 80px; height: 80px;">
                            <i class="bi bi-exclamation-octagon-fill text-white display-5"></i>
                        </div>
                    </div>
                    <h3 class="fw-black m-0 text-uppercase tracking-tight">Confirm Deletion</h3>
                </div>
                
                <div class="card-body p-4 p-md-5 text-center">
                    <h4 class="fw-black text-dark mb-4 text-uppercase tracking-wider">@Model.Title</h4>
                    
                    <div class="p-4 border border-danger border-opacity-25 rounded-4 bg-danger bg-opacity-10 text-danger fw-bold mb-5 transition-all hover-lift">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i> 
                        THIS ACTION IS PERMANENT. 
                        <span class="d-block mt-2 opacity-75 small">All flashcards within this deck will be destroyed.</span>
                    </div>

                    <form asp-action="DeleteConfirmed" method="post">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-black shadow-sm py-3 text-uppercase tracking-wider btn-cta-danger transition-all hover-lift" style="border: none;">
                                <i class="bi bi-trash3-fill me-2"></i> CONFIRM DELETE
                            </button>
                            <a asp-action="Index" class="btn btn-light btn-lg rounded-pill fw-black text-muted text-uppercase tracking-wider shadow-sm py-3 text-center transition-all hover-lift">
                                CANCEL
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    body { background-color: #f8fafc; }

    /* Specific Overrides */
    .tracking-tight { letter-spacing: -1px; }
    .tracking-wider { letter-spacing: 1px; }
    
    .hero-glow-text-danger { text-shadow: 0 0 20px rgba(239, 68, 68, 0.3); }

    /* Buttons */
    .btn-white { background: #fff; border: 1px solid #e2e8f0; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .btn-white:hover { background: #f8fafc; border-color: #cbd5e1; }
    
    .btn-cta-danger {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        box-shadow: 0 4px 6px -1px rgba(239, 68, 68, 0.2), 0 2px 4px -1px rgba(239, 68, 68, 0.1);
    }

    /* Hovers & Micro-interactions */
    .hover-lift { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .hover-lift:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.1) !important; }
    
    .hover-scale:hover { transform: scale(1.1); }
    
    .btn-cta-danger:hover { 
        box-shadow: 0 12px 24px rgba(239, 68, 68, 0.3) !important; 
        filter: brightness(1.1);
    }
    
    .transition-all { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
</style>