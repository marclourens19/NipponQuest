@model IEnumerable<NipponQuest.Models.DeckViewModel>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">

<style>
    /* ──────────────────────────────────────────────────────
       FLASHCARDS VAULT — Nunito · Site CSS Aligned
       ────────────────────────────────────────────────────── */

    body { font-family: 'Nunito', sans-serif !important; background: #ffffff; }

    .lg-reveal { opacity: 0; transform: translateY(24px); transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
    .lg-reveal.active { opacity: 1; transform: translateY(0); }

    /* ── HERO ── */
    .lg-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 55%, #0ea5e9 160%);
        border-radius: 28px;
        color: #ffffff;
        padding: 2.5rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 25px 60px -15px rgba(15, 23, 42, 0.4);
        font-family: 'Nunito', sans-serif;
    }
    .lg-hero::before {
        content: "";
        position: absolute;
        inset: -50% -10% auto auto;
        width: 420px; height: 420px;
        background: radial-gradient(circle, rgba(245, 158, 11, 0.18) 0%, transparent 70%);
        pointer-events: none;
    }
    .lg-hero::after {
        content: "カード"; /* Cards */
        position: absolute;
        right: 20px; bottom: -20px;
        font-size: 8rem;
        font-weight: 900;
        color: rgba(255,255,255,0.04);
        line-height: 1;
        letter-spacing: -4px;
        pointer-events: none;
        font-family: 'Nunito', sans-serif;
    }
    .lg-hero-meta {
        font-size: 0.65rem; font-weight: 900;
        letter-spacing: 2px;
        color: rgba(255,255,255,0.6);
        text-transform: uppercase;
    }
    .lg-title {
        font-size: clamp(2.4rem, 5vw, 3.8rem);
        font-weight: 900; letter-spacing: -2px; line-height: 1;
        margin: 6px 0 2px;
        font-family: 'Nunito', sans-serif;
    }
    
    .lg-info-btn {
        width: 40px; height: 40px; border-radius: 50%;
        background: rgba(255,255,255,0.12);
        border: 2px solid rgba(255,255,255,0.25);
        color: #ffffff;
        display: inline-flex; align-items: center; justify-content: center;
        transition: all 200ms ease;
        cursor: pointer;
    }
    .lg-info-btn:hover {
        background: #fbbf24;
        color: #422006;
        border-color: #fbbf24;
        transform: translateY(-2px);
    }

    /* ── PANELS ── */
    .lg-panel {
        background: #ffffff;
        border: 2px solid #e2e8f0;
        border-radius: 24px;
        padding: 1.75rem;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.04);
        transition: all 250ms ease;
        font-family: 'Nunito', sans-serif;
    }
    .lg-panel:hover { box-shadow: 0 12px 32px rgba(15, 23, 42, 0.08); }
    .lg-panel-sub { font-size: 0.65rem; color: #94a3b8; font-weight: 800; letter-spacing: 1px; }

    .info-pillar { border: 2px solid #e2e8f0; border-radius: 16px; padding: 16px; height: 100%; background: #ffffff; transition: all 0.2s; font-family: 'Nunito', sans-serif; }
    .info-pillar:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.05); border-color: #cbd5e1; }
    .info-pillar .info-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 10px; }

    /* ── BUTTONS & UTILITIES ── */
    .btn { font-family: 'Nunito', sans-serif !important; }
    .btn-white { background: #ffffff; border: 2px solid #e2e8f0; }
    .btn-white:hover { background: #f8fafc; border-color: #cbd5e1; }
    
    .hover-lift { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .hover-lift:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.1) !important; }
    
    .hover-bg-light:hover { background-color: #f8fafc !important; }
    .hover-blue:hover { color: #0ea5e9 !important; border-color: #0ea5e9 !important; }
    .hover-danger:hover { background-color: #fef2f2 !important; color: #dc2626 !important; border-color: #fca5a5 !important; }
    
    .transition-all { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    
    .dropdown-menu { z-index: 1050; border: 2px solid #e2e8f0 !important; font-family: 'Nunito', sans-serif !important; }
    .dropdown-item { font-family: 'Nunito', sans-serif !important; }
    .dropdown-item:hover { background-color: #f0f9ff !important; transform: translateX(4px); }

    .gold-coin {
        background: linear-gradient(135deg, #FFD700 0%, #FFB900 100%);
        border-radius: 50%;
        border: 1.5px solid #B45309;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        color: #451a03 !important; 
        font-family: 'Nunito', sans-serif;
    }
    .gold-coin::after { content: "G"; }

    /* ── MOBILE RESPONSIVENESS ── */
    @@media (max-width: 575.98px) {
        .container.py-5.mt-4 { padding-top: 1.25rem !important; margin-top: 0 !important; }
        .mobile-header-container { padding: 1.5rem !important; border-radius: 24px !important; }
        .lg-hero::after { font-size: 5rem; right: 10px; bottom: -10px; }
        .mobile-header-btns { flex-wrap: wrap !important; width: 100%; }
        .mobile-header-btns .btn { flex: 1 1 auto; justify-content: center; font-size: 0.75rem !important; padding-left: 0.75rem !important; padding-right: 0.75rem !important; }
        
        .stat-number { font-size: 1.55rem !important; }
        .stat-cell { padding: 0.85rem 0.5rem !important; }
        .stat-cell i.fs-3 { font-size: 1.35rem !important; margin-bottom: 0.25rem !important; }
        .stat-cell .lg-panel-sub { font-size: 0.55rem !important; }
        
        .col-6.col-md-3:nth-child(-n+2) .stat-cell { border-bottom: 2px solid #e2e8f0 !important; }
        .col-6.col-md-3:nth-child(2) .stat-cell, .col-6.col-md-3:nth-child(4) .stat-cell { border-right: none !important; border-left: none !important; }
        
        .mobile-due-banner { flex-direction: column !important; align-items: flex-start !important; gap: 0.75rem !important; padding: 0.85rem 1rem !important; }
        .mobile-due-btn { width: 100% !important; text-align: center !important; justify-content: center !important; }
        
        .col-md-6.col-xl-4 { width: 100% !important; }
        .lg-panel .p-4 { padding: 1rem !important; }
        .lg-panel .px-4.pb-4 { padding: 0 1rem 1rem !important; }
        .dropdown-menu { min-width: 100% !important; font-size: 0.85rem !important; left: 0 !important; transform: none !important; }
        .d-flex.gap-1.flex-shrink-0 .btn { width: 36px !important; height: 36px !important; }
        .modal-body.p-4.p-md-5 { padding: 1.25rem !important; }
    }
    
    @@media (min-width: 576px) and (max-width: 767.98px) {
        .mobile-header-btns { flex-wrap: wrap !important; }
        .mobile-header-btns .btn { flex: 1 1 auto; justify-content: center; }
        .stat-number { font-size: 1.8rem !important; }
        .stat-cell { padding: 1rem 0.6rem !important; }
        .col-6.col-md-3:nth-child(-n+2) .stat-cell { border-bottom: 2px solid #e2e8f0 !important; }
        .col-6.col-md-3:nth-child(2) .stat-cell, .col-6.col-md-3:nth-child(4) .stat-cell { border-right: none !important; }
        .mobile-due-banner { flex-direction: column !important; align-items: flex-start !important; gap: 0.6rem !important; }
        .mobile-due-btn { width: 100% !important; }
        .col-md-6.col-xl-4 { width: 50% !important; }
    }
</style>

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-11">
            
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success shadow-sm rounded-pill fw-bold border-0 d-flex align-items-center mb-4 px-4 py-3 alert-dismissible fade show lg-reveal active" style="font-family: 'Nunito', sans-serif;">
                    <i class="bi bi-check-circle-fill fs-5 me-2 text-success"></i>
                    <div>@TempData["Message"]</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="lg-hero mb-4 lg-reveal active mobile-header-container">
                <div class="row g-4 align-items-center position-relative" style="z-index: 2;">
                    <div class="col-lg-7">
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <div class="lg-hero-meta"><i class="bi bi-stack me-1 text-warning"></i> LIBRARY &middot; 図書館</div>
                        </div>
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <h1 class="lg-title m-0 text-uppercase">MY <span style="color: #fbbf24;">FLASHCARDS</span></h1>
                            <button type="button" class="lg-info-btn" data-bs-toggle="modal" data-bs-target="#guideModal" title="How to use Flashcards">
                                <i class="bi bi-info-lg fs-5 fw-black"></i>
                            </button>
                        </div>
                        <div class="lg-hero-meta mt-2 opacity-75" style="letter-spacing: 1px; font-size: 0.8rem;">Organize and master your progress</div>

                        <div class="d-flex gap-2 mt-4 mobile-header-btns flex-wrap">
                            <a asp-action="Discover" class="btn btn-light rounded-pill px-4 fw-black shadow-sm d-flex align-items-center transition-all hover-lift" style="color: #0ea5e9;">
                                <i class="bi bi-globe-americas me-2 fs-5"></i> DISCOVER
                            </a>
                            <button class="btn btn-outline-light rounded-pill px-4 fw-black shadow-sm d-flex align-items-center transition-all hover-lift" style="border-width: 2px;" onclick="document.getElementById('ankiUpload').click()">
                                <i class="bi bi-file-earmark-arrow-up me-2 fs-5"></i> IMPORT
                            </button>
                            <a asp-action="Create" class="btn rounded-pill px-4 fw-black shadow-sm d-flex align-items-center transition-all hover-lift" style="background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #422006; border: none;">
                                <i class="bi bi-plus-lg me-2 fs-5"></i> CREATE NEW
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <form id="ankiForm" asp-action="ImportAnki" method="post" enctype="multipart/form-data" style="display:none;">
                <input type="file" id="ankiUpload" name="ankiFile" onchange="this.form.submit()" accept=".apkg" />
            </form>

            <div class="lg-panel p-0 mb-5 lg-reveal overflow-hidden">
                <div class="row g-0 text-center">
                    <div class="col-6 col-md-3 p-4 border-end transition-all hover-bg-light stat-cell" style="border-color: #e2e8f0 !important;">
                        <i class="bi bi-stack fs-3 text-primary mb-2 d-block" style="color: #0ea5e9 !important;"></i>
                        <div class="stat-number fw-black" style="font-size: 2.2rem; color: #0f172a; font-family: 'Nunito', sans-serif;">@Model.Count()</div>
                        <span class="lg-panel-sub text-uppercase tracking-wider">Total Decks</span>
                    </div>
                    <div class="col-6 col-md-3 p-4 border-end transition-all hover-bg-light stat-cell" style="border-color: #e2e8f0 !important;">
                        <i class="bi bi-files fs-3 text-primary mb-2 d-block" style="color: #0ea5e9 !important;"></i>
                        <div class="stat-number fw-black" style="font-size: 2.2rem; color: #0f172a; font-family: 'Nunito', sans-serif;">@Model.Sum(x => x.CardCount).ToString("N0")</div>
                        <span class="lg-panel-sub text-uppercase tracking-wider">Total Cards</span>
                    </div>
                    <div class="col-6 col-md-3 p-4 border-end transition-all hover-bg-light stat-cell" style="border-color: #e2e8f0 !important;">
                        <i class="bi bi-alarm fs-3 mb-2 d-block" style="color: #ef4444;"></i>
                        <div class="stat-number fw-black @(Model.Sum(x => x.DueCount) > 0 ? "text-danger" : "text-dark")" style="font-size: 2.2rem; font-family: 'Nunito', sans-serif;">
                            @Model.Sum(x => x.DueCount).ToString("N0")
                        </div>
                        <span class="lg-panel-sub text-uppercase tracking-wider">Due Today</span>
                    </div>
                    <div class="col-6 col-md-3 p-4 transition-all stat-cell" style="background: #f0fdf4;">
                        <i class="bi bi-check-circle-fill fs-3 text-success mb-2 d-block"></i>
                        <div class="stat-number fw-black text-dark" style="font-size: 2.2rem; font-family: 'Nunito', sans-serif;">@(ViewBag.ReviewedToday ?? 0)</div>
                        <span class="lg-panel-sub text-uppercase tracking-wider">Reviewed Today</span>
                    </div>
                </div>
                
                @if (Model.Sum(x => x.DueCount) > 0)
                {
                    <div class="bg-warning bg-opacity-10 border-top border-warning p-3 d-flex justify-content-between align-items-center px-4 mobile-due-banner">
                        <span class="fw-bold text-dark" style="font-size: 0.9rem; font-family: 'Nunito', sans-serif;">
                            <i class="bi bi-lightning-charge-fill text-warning me-1 fs-5 align-middle"></i> 
                            <strong>@Model.Sum(x => x.DueCount).ToString("N0") cards</strong> are due today. Keep your streak going!
                        </span>
                        <a asp-action="StudyAllDue" class="btn fw-black rounded-pill px-4 shadow-sm text-dark btn-sm transition-all hover-lift mobile-due-btn" style="background: linear-gradient(135deg, #fbbf24, #f59e0b); border: none;">
                            STUDY ALL NOW <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                }
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 lg-reveal">
                <h4 class="fw-black text-dark text-uppercase m-0 tracking-tight" style="letter-spacing: -0.5px; font-family: 'Nunito', sans-serif;">ACTIVE DECKS</h4>
                <a href="https://ankiweb.net/shared/decks/japanese" target="_blank" class="text-muted fw-bold text-decoration-none hover-blue small text-uppercase transition-all d-flex align-items-center" style="font-family: 'Nunito', sans-serif;">
                    <i class="bi bi-box-arrow-up-right me-2"></i> Browse AnkiWeb
                </a>
            </div>

            <div class="row g-4 mb-5 pb-5">
                @foreach (var item in Model)
                {
                    var pct = item.CardCount > 0 ? (100 - (item.DueCount * 100 / item.CardCount)) : 0;
                    var hexColor = !string.IsNullOrEmpty(item.ThemeColor) && item.ThemeColor != "#ffffff" ? item.ThemeColor : (item.IsCommunityDeck ? "#f0f9ff" : "#ffffff"); 

                    <div class="col-md-6 col-xl-4 lg-reveal">
                        <div class="lg-panel h-100 p-0 d-flex flex-column position-relative transition-all hover-lift" style="background-color: @hexColor !important; box-shadow: 0 4px 16px rgba(15, 23, 42, 0.04);">
                            
                            <div class="p-4 flex-grow-1 d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <h4 class="fw-black text-dark m-0 tracking-tight text-truncate pe-2" style="max-width: 75%; font-family: 'Nunito', sans-serif;" title="@item.Title">
                                        @item.Title
                                    </h4>
                                    <span class="badge bg-white text-primary shadow-sm rounded-pill fw-bold flex-shrink-0" style="font-size: 0.75rem; color: #0ea5e9 !important; border: 1px solid #bae6fd;">@item.CardCount Cards</span>
                                </div>

                                <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
                                    <div class="small fw-bold d-flex align-items-center opacity-75 text-dark" style="font-family: 'Nunito', sans-serif;">
                                        <i class="bi bi-person-circle me-1"></i>
                                        <span>By @(item.IsCommunityDeck ? (item.AuthorName ?? "Community") : "You")</span>
                                    </div>
                                    
                                    @if (item.IsPublic && !item.IsCommunityDeck)
                                    {
                                        <span class="badge bg-slate-100 text-slate-600 small fw-bold px-2 rounded-1 d-flex align-items-center" style="font-size: 0.65rem; background: rgba(15,23,42,0.05); color: #475569;">
                                            <i class="bi bi-globe-americas me-1"></i> Published
                                        </span>
                                    }
                                    @if (item.IsCommunityDeck)
                                    {
                                        <span class="badge text-white small fw-bold text-uppercase px-2 rounded-1 shadow-sm" style="font-size: 0.65rem; letter-spacing: 0.5px; background: #0f172a;">
                                            Community Deck
                                        </span>
                                    }
                                </div>

                                <div class="flex-grow-1 mb-4">
                                    <p class="text-dark small fw-bold m-0 opacity-75" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4rem; font-family: 'Nunito', sans-serif;">
                                        @(string.IsNullOrWhiteSpace(item.Description) ? "No description provided." : item.Description.Replace("(Community Deck)", "").Trim())
                                    </p>
                                </div>

                                <div class="mt-auto">
                                    <div class="d-flex justify-content-between mb-1" style="font-family: 'Nunito', sans-serif;">
                                        <span class="text-dark text-uppercase tracking-wider opacity-75" style="font-size: 0.65rem; font-weight: 900;">MASTERY</span>
                                        <span class="text-dark" style="font-size: 0.65rem; font-weight: 900;">@pct%</span>
                                    </div>
                                    <div class="progress rounded-pill shadow-none" style="height: 6px; background: rgba(15,23,42,0.1);">
                                        <div class="progress-bar" style="width: @pct%; background: #0f172a;"></div>
                                    </div>
                                </div>
                            </div>

                            <div class="px-4 pb-4 bg-transparent d-flex justify-content-between align-items-center gap-2 mt-2">
                                
                                <div class="dropdown flex-grow-1">
                                    <button class="btn w-100 rounded-pill fw-black shadow-sm dropdown-toggle py-2 transition-all hover-lift" type="button" data-bs-toggle="dropdown" style="background: #0f172a; color: #fff;">
                                        START STUDY (@(item.DueCount > 0 ? item.DueCount : 0))
                                    </button>
                                    <ul class="dropdown-menu shadow-lg rounded-4 p-2 mt-2" style="min-width: 240px;">
                                        <li><h6 class="dropdown-header fw-bold text-uppercase small tracking-wider" style="color: #0ea5e9;">Select Quest Length</h6></li>
                                        <li>
                                            <a class="dropdown-item rounded-3 py-2 d-flex align-items-center justify-content-between transition-all" href="@Url.Action("StartSession", new { id = item.Id, length = 10 })">
                                                <span class="fw-bold text-dark">10 Cards</span>
                                                <span class="text-muted small fw-bold ms-3">+10 EXP / +5 <span class="gold-coin"></span></span>
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item rounded-3 py-2 d-flex align-items-center justify-content-between transition-all" href="@Url.Action("StartSession", new { id = item.Id, length = 15 })">
                                                <span class="fw-bold text-dark">15 Cards</span>
                                                <span class="text-muted small fw-bold ms-3">+15 EXP / +5 <span class="gold-coin"></span></span>
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item rounded-3 py-2 d-flex align-items-center justify-content-between transition-all" href="@Url.Action("StartSession", new { id = item.Id, length = 20 })">
                                                <span class="fw-bold text-dark">20 Cards</span>
                                                <span class="text-muted small fw-bold ms-3">+20 EXP / +5 <span class="gold-coin"></span></span>
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item rounded-3 py-2 d-flex align-items-center justify-content-between custom-quest-btn transition-all" href="#" data-bs-toggle="modal" data-bs-target="#customQuestModal" data-deck-id="@item.Id">
                                                <span class="fw-bold text-dark"><i class="bi bi-gear-fill text-muted me-1"></i> Custom</span>
                                                <span class="text-muted small fw-bold ms-3">1:1 EXP / +5 <span class="gold-coin"></span></span>
                                            </a>
                                        </li>
                                        @if (item.DueCount > 0)
                                        {
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <a class="dropdown-item rounded-3 py-2 fw-black d-flex justify-content-between align-items-center transition-all" style="background: #fffbeb; color: #b45309;" href="@Url.Action("StartSession", new { id = item.Id, length = item.DueCount })">
                                                    <span><i class="bi bi-lightning-charge-fill text-warning me-1"></i> Study All Due (@item.DueCount)</span>
                                                    <span class="small fw-black opacity-75 ms-2">+@item.DueCount EXP / +5 <span class="gold-coin"></span></span>
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                </div>

                                <div class="d-flex gap-1 flex-shrink-0">
                                    @if (!item.IsCommunityClone)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-white rounded-circle text-secondary d-flex align-items-center justify-content-center shadow-sm transition-all hover-lift" style="width: 40px; height: 40px; color: #64748b !important;" title="Edit">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="AddCard" asp-route-deckId="@item.Id" class="btn btn-white rounded-circle text-secondary d-flex align-items-center justify-content-center shadow-sm transition-all hover-lift" style="width: 40px; height: 40px; color: #64748b !important;" title="Add Card">
                                            <i class="bi bi-plus-lg"></i>
                                        </a>
                                    }
                                    <button type="button" class="btn btn-white rounded-circle d-flex align-items-center justify-content-center shadow-sm transition-all hover-danger hover-lift delete-deck-btn" style="width: 40px; height: 40px; color: #ef4444 !important;" title="Delete" data-bs-toggle="modal" data-bs-target="#deleteDeckModal" data-deck-id="@item.Id">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5 lg-reveal">
                    <i class="bi bi-inboxes text-muted opacity-25 display-1 mb-3 d-block"></i>
                    <h4 class="fw-black text-dark text-uppercase" style="font-family: 'Nunito', sans-serif;">No Decks Found</h4>
                    <p class="text-muted fw-bold" style="font-family: 'Nunito', sans-serif;">Import an Anki file or create a new deck to begin your quest.</p>
                </div>
            }

        </div>
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteDeckModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 rounded-4 shadow-lg overflow-hidden" style="font-family: 'Nunito', sans-serif;">
            <div class="bg-danger p-4 text-center position-relative">
                <h5 class="fw-black text-white m-0 text-uppercase tracking-widest"><i class="bi bi-exclamation-triangle-fill me-2 opacity-50"></i> Delete Deck</h5>
                <button type="button" class="btn-close btn-close-white position-absolute top-50 end-0 translate-middle-y me-4" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4 p-md-5 bg-white text-center">
                <p class="text-muted fw-bold mb-4" style="font-size: 0.9rem;">Are you sure you want to permanently delete this deck and all its associated cards? This action cannot be undone.</p>
                
                <form id="deleteDeckForm" asp-action="DeleteConfirmed" method="post">
                    <input type="hidden" name="id" id="deleteDeckId" value="" />
                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-danger rounded-pill fw-black py-3 shadow-sm text-uppercase tracking-wider transition-all hover-lift">
                            YES, DELETE
                        </button>
                        <button type="button" class="btn btn-light rounded-pill fw-bold text-muted text-uppercase tracking-wider py-2 transition-all hover-lift" data-bs-dismiss="modal">
                            CANCEL
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

