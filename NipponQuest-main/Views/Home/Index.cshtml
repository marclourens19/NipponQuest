@section Scripts {
<script>
// ── SCROLL REVEAL ──
document.addEventListener('DOMContentLoaded',()=>{
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('active')});
  },{threshold:0.08,rootMargin:'0px 0px -50px 0px'});
  document.querySelectorAll('.reveal-up').forEach(el=>obs.observe(el));
});

// ── QUIZ — 2×2 GRID KANABLITZ STYLE ──
const quizData=[
  {q:'あ',a:'A',options:['A','KA','SA','TA']},
  {q:'い',a:'I',options:['U','I','E','O']},
  {q:'う',a:'U',options:['O','N','U','RA']},
  {q:'え',a:'E',options:['E','RU','RE','RO']},
  {q:'お',a:'O',options:['WA','WO','A','O']}
];
let currentQuest=0,streak=0,maxStreak=0,score=0;

function initQuiz(){
  const quest=quizData[currentQuest];
  document.getElementById('quiz-progress').innerText=`QUEST ${currentQuest+1} / 5`;
  document.getElementById('hiragana-display').innerText=quest.q;
  document.getElementById('quiz-meaning').innerText=currentQuest===0?'HIRAGANA · BASIC READING':'';
  document.getElementById('quiz-category').style.display='inline-flex';
  
  const container=document.getElementById('answer-buttons');
  container.innerHTML='';
  quest.options.forEach((opt,i)=>{
    const d=document.createElement('div');
    d.className='quiz-option';
    d.id=`opt-${i}`;
    d.innerHTML=`
      <div class="opt-badge">${['A','B','C','D'][i]}</div>
      <span class="opt-text">${opt}</span>
      <div class="opt-key">${['A','B','C','D'][i]}</div>
    `;
    d.onclick=()=>checkAnswer(opt,i);
    container.appendChild(d);
  });
  
  document.getElementById('score-count').innerText=`${score} correct`;
  updateComboUI();
}

function checkAnswer(choice,idx){
  const correct=quizData[currentQuest].a;
  document.querySelectorAll('.quiz-option').forEach(b=>b.style.pointerEvents='none');
  
  if(choice===correct){
    score++;streak++;
    if(streak>maxStreak)maxStreak=streak;
    const btn=document.getElementById(`opt-${idx}`);
    btn.className='quiz-option correct';
    btn.innerHTML=`<div class="opt-badge" style="background:rgba(255,255,255,0.2);color:#fff">${['A','B','C','D'][idx]}</div><span class="opt-text">${choice}</span><div class="opt-status"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>`;
    
    document.getElementById('quiz-streak-fill').style.width='100%';
    document.getElementById('quiz-streak-fill').style.background='#22c55e';
    document.getElementById('quiz-card').style.borderColor='#22c55e';
    
    setTimeout(()=>{nextQuestion()},600);
    
  }else{
    streak=0;
    const btn=document.getElementById(`opt-${idx}`);
    btn.className='quiz-option wrong';
    btn.innerHTML=`<div class="opt-badge" style="background:rgba(255,255,255,0.2);color:#fff">${['A','B','C','D'][idx]}</div><span class="opt-text">${choice}</span><div class="opt-status"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></div>`;
    
    // Reveal correct
    document.querySelectorAll('.quiz-option').forEach((el,i)=>{
      const optText=el.querySelector('.opt-text')?.textContent;
      if(optText===correct&&!el.classList.contains('wrong')){
        el.className='quiz-option reveal';
        el.innerHTML=`<div class="opt-badge">${['A','B','C','D'][i]}</div><span class="opt-text">${correct}</span><div class="opt-status"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>`;
      }
    });
    
    document.getElementById('quiz-streak-fill').style.width='0%';
    document.getElementById('quiz-streak-fill').style.background='#ef4444';
    document.getElementById('quiz-card').style.borderColor='#ef4444';
    setTimeout(()=>{document.getElementById('quiz-card').style.borderColor='';nextQuestion()},800);
  }
  updateComboUI();
  document.getElementById('score-count').innerText=`${score} correct`;
}

function updateComboUI(){
  const combo=document.getElementById('quiz-combo');
  const footer=document.getElementById('footer-hint');
  if(streak>=2){
    combo.className='quiz-hud-combo show anim-combo-flash';
    combo.innerHTML=`<svg style="width:10px;height:10px;vertical-align:-1px;margin-right:2px" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 23c-3.5 0-7-2.5-7-7 0-3 1.5-5 3-7 .5-.7 1-1.3 1.5-2C10 6 10 5 9 3c3 1 5 3.5 6 6 .5-1 1-2 1-3 2 2 3.5 4.5 3.5 7.5 0 4.5-3.5 9.5-7.5 9.5z"/></svg> ${streak} STREAK`;
    footer.innerHTML=`<svg style="width:10px;height:10px;vertical-align:-1px;margin-right:2px" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 23c-3.5 0-7-2.5-7-7 0-3 1.5-5 3-7 .5-.7 1-1.3 1.5-2C10 6 10 5 9 3c3 1 5 3.5 6 6 .5-1 1-2 1-3 2 2 3.5 4.5 3.5 7.5 0 4.5-3.5 9.5-7.5 9.5z"/></svg> ${streak} streak`;
  }else{
    combo.className='quiz-hud-combo';
    footer.innerText='Select the correct romaji reading';
  }
  document.getElementById('quiz-score-val').textContent=score;
  if(score>0)document.getElementById('quiz-score-display').style.display='inline';
}

function nextQuestion(){
  currentQuest++;
  currentQuest<quizData.length?initQuiz():showResults();
}

function showResults(){
  document.getElementById('quiz-game').style.display='none';
  document.getElementById('quiz-result').style.display='block';
  document.getElementById('final-score').innerText=`${score} / 5`;
}

function resetQuiz(){
  currentQuest=0;streak=0;maxStreak=0;score=0;
  document.getElementById('quiz-game').style.display='block';
  document.getElementById('quiz-result').style.display='none';
  document.getElementById('quiz-streak-fill').style.width='0%';
  document.getElementById('quiz-streak-fill').style.background='#38bdf8';
  document.getElementById('quiz-card').style.borderColor='';
  document.getElementById('quiz-score-display').style.display='none';
  document.getElementById('quiz-score-val').textContent='0';
  updateComboUI();
  initQuiz();
}

