@using Microsoft.AspNetCore.Identity
@model IReadOnlyList<Octokit.GitHubCommit>
@inject UserManager<NipponQuest.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = "Master Japanese - NipponQuest";
    var currentUser = await UserManager.GetUserAsync(User);

    string FormatNumber(long num)
    {
        if (num >= 1000000000) return (num / 1000000000D).ToString("0.#") + "B+";
        if (num >= 1000000)    return (num / 1000000D).ToString("0.#") + "M+";
        if (num >= 1000)       return (num / 1000D).ToString("0.#") + "k+";
        return num.ToString();
    }

    long rawXp        = ViewBag.TotalXP      != null ? (long)ViewBag.TotalXP      : 0;
    long rawGold      = ViewBag.TotalGold    != null ? (long)ViewBag.TotalGold    : 0;
    int  rawStreaks   = ViewBag.ActiveStreaks != null ? (int)ViewBag.ActiveStreaks  : 0;
    
    string totalXpDisplay      = FormatNumber(rawXp);
    string totalGoldDisplay    = FormatNumber(rawGold);
    string activeStreaksDisplay = FormatNumber(rawStreaks);
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">

<style>
/* ══════════════════════════════════════════════════════════════ */
/* BASE                                                         */
/* ══════════════════════════════════════════════════════════════ */
*{box-sizing:border-box}
body{
  font-family:'Nunito',sans-serif !important;
  background:#ffffff !important;
  color:#0f172a;
}

/* ── SCROLL REVEAL ── */
.reveal-up{
  opacity:0;transform:translateY(30px);
  transition:all 0.6s cubic-bezier(0.16,1,0.3,1);
  will-change:opacity,transform;
}
.reveal-up.active{opacity:1;transform:translateY(0)}
.delay-100{transition-delay:100ms}
.delay-200{transition-delay:200ms}
.delay-300{transition-delay:300ms}

/* ── KEYFRAMES ── */
@@keyframes slide-up{0%{opacity:0;transform:translateY(24px)}100%{opacity:1;transform:translateY(0)}}
@@keyframes scale-pop{0%{transform:scale(0.5);opacity:0}50%{transform:scale(1.15)}100%{transform:scale(1);opacity:1}}
@@keyframes shake{0%,100%{transform:translateX(0)}10%{transform:translateX(-6px)}20%{transform:translateX(6px)}30%{transform:translateX(-4px)}40%{transform:translateX(4px)}50%{transform:translateX(-2px)}60%{transform:translateX(2px)}}
@@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}
@@keyframes combo-flash{0%{transform:scale(1)}50%{transform:scale(1.15)}100%{transform:scale(1)}}
@@keyframes spin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}

.anim-slide-up{animation:slide-up 0.5s ease both}
.anim-shake{animation:shake 0.4s ease}
.anim-scale-pop{animation:scale-pop 0.4s ease-out both}
.anim-combo-flash{animation:combo-flash 0.3s ease-out}

/* ══════════════════════════════════════════════════════════════ */
/* SVG ICON HELPERS                                             */
/* ══════════════════════════════════════════════════════════════ */
.icon{display:inline-flex;align-items:center;justify-content:center;vertical-align:middle}
.icon svg{display:block}

/* ══════════════════════════════════════════════════════════════ */
/* BETA BANNER                                                  */
/* ══════════════════════════════════════════════════════════════ */
.beta-banner{
  background:linear-gradient(90deg,#0f172a,#1e293b,#0f172a);
  color:#f8fafc !important;
  padding:10px 20px;font-size:0.85rem;
  letter-spacing:0.03em;position:relative;
  z-index:1000;
}
.beta-banner-tag{
  background:#0ea5e9;color:white;font-weight:900;
  letter-spacing:0.1em;font-size:0.65rem;
  padding:4px 10px;border-radius:8px;
  margin-right:12px;text-transform:uppercase;
}
.beta-banner a{color:#38bdf8;text-decoration:none;transition:color 0.2s}
.beta-banner a:hover{color:#7dd3fc;text-decoration:underline}

/* ══════════════════════════════════════════════════════════════ */
/* KANABLITZ-STYLE BUTTONS (shared)                             */
/* ══════════════════════════════════════════════════════════════ */
.btn-blitz{
  font-family:'Nunito',sans-serif !important;
  font-weight:900 !important;
  letter-spacing:1px !important;
  border-radius:14px !important;
  border:none !important;
  padding:0.85rem 2rem !important;
  transition:all 0.3s ease !important;
  cursor:pointer;
  display:inline-flex;align-items:center;justify-content:center;
  gap:0.5rem;
}
.btn-blitz:hover{transform:translateY(-2px)}
.btn-blitz-primary{
  background:linear-gradient(135deg,#0ea5e9,#2563eb) !important;
  color:#fff !important;
  box-shadow:0 4px 20px rgba(37,99,235,0.3);
}
.btn-blitz-primary:hover{box-shadow:0 8px 30px rgba(37,99,235,0.4)}
.btn-blitz-gold{
  background:linear-gradient(135deg,#f59e0b,#d97706) !important;
  color:#fff !important;
  box-shadow:0 4px 20px rgba(245,158,11,0.3);
}
.btn-blitz-gold:hover{box-shadow:0 8px 30px rgba(245,158,11,0.4)}
.btn-blitz-ghost{
  background:#f1f5f9 !important;
  color:#475569 !important;
  border:2px solid #e2e8f0 !important;
}
.btn-blitz-ghost:hover{background:#e2e8f0 !important;border-color:#cbd5e1 !important}
.btn-blitz-dark{
  background:linear-gradient(135deg,#0f172a,#1e293b) !important;
  color:#fff !important;
  box-shadow:0 4px 20px rgba(15,23,42,0.3);
}
.btn-blitz-dark:hover{box-shadow:0 8px 30px rgba(15,23,42,0.4)}
.btn-blitz-sm{font-size:0.7rem !important;padding:0.5rem 1rem !important;border-radius:10px !important}
.btn-blitz-lg{font-size:0.95rem !important;padding:1rem 2.5rem !important;border-radius:16px !important}

/* ══════════════════════════════════════════════════════════════ */
/* HERO                                                         */
/* ══════════════════════════════════════════════════════════════ */
.hero-section{
  background:radial-gradient(ellipse 80% 60% at 50% -10%,rgba(14,165,233,0.05) 0%,transparent 70%),#ffffff;
  padding-bottom:0 !important;
}
.hero-headline{
  font-size:clamp(3rem,7vw,5.25rem);
  line-height:1.05;letter-spacing:-2px;
  color:#0f172a !important;
  font-family:'Nunito',sans-serif !important;
}
.hero-headline span{color:#0ea5e9 !important}
.hero-pill{
  background:#f1f5f9;
  border:1px solid #e2e8f0;
  color:#64748b;
  font-size:0.7rem;letter-spacing:1.5px;
  padding:8px 18px;border-radius:50px;
  font-weight:900;display:inline-flex;
  align-items:center;gap:6px;
  margin-bottom:1.5rem;text-transform:uppercase;
}
.hero-pill .dot{width:6px;height:6px;border-radius:50%;background:#f59e0b;animation:pulse 1.5s infinite}
.hero-trust{
  font-size:0.7rem;letter-spacing:1px;
  font-weight:800;color:#94a3b8;
}
.hero-wave{display:block;width:100%;overflow:hidden;line-height:0;margin-top:3rem}
.hero-wave svg{display:block}

/* ══════════════════════════════════════════════════════════════ */
/* STATS BAR                                                    */
/* ══════════════════════════════════════════════════════════════ */
.stats-bar{background:#ffffff;border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0}
.stat-divider{width:1px;height:50px;background:#e2e8f0;align-self:center}
.stat-label{font-size:0.65rem;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:#94a3b8;margin-top:4px}
.stat-number{font-size:2.25rem;font-weight:900;line-height:1;font-family:'Nunito',sans-serif}

/* ══════════════════════════════════════════════════════════════ */
/* SECTION HEADERS                                              */
/* ══════════════════════════════════════════════════════════════ */
.section-eyebrow{font-size:0.7rem;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:#94a3b8}
.section-heading{
  font-size:clamp(2rem,4vw,2.75rem);
  font-weight:900;letter-spacing:-1px;
  line-height:1.1;color:#0f172a !important;
  font-family:'Nunito',sans-serif !important;
}

/* ══════════════════════════════════════════════════════════════ */
/* FEATURE CARDS                                                */
/* ══════════════════════════════════════════════════════════════ */
.features-section{padding:90px 0;background-color:#f8fafc}
.static-card{
  background:#ffffff;border:2px solid #e2e8f0;
  border-radius:24px;padding:2rem;
  box-shadow:0 4px 16px rgba(15,23,42,0.04);
  transition:all 300ms ease;height:100%;
}
.feature-card-blue:hover{border-color:#38bdf8;box-shadow:0 20px 40px rgba(14,165,233,0.1);transform:translateY(-6px)}
.feature-card-warning:hover{border-color:#fbbf24;box-shadow:0 20px 40px rgba(245,158,11,0.1);transform:translateY(-6px)}
.feature-card-danger:hover{border-color:#fb7185;box-shadow:0 20px 40px rgba(244,63,94,0.1);transform:translateY(-6px)}
.feature-icon{
  width:56px;height:56px;border-radius:16px;
  display:flex;align-items:center;justify-content:center;
  margin-bottom:24px;flex-shrink:0;
  backface-visibility:hidden;transform-origin:center center;
  transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
}
.static-card:hover .feature-icon{transform:scale(1.1) rotate(-4deg)}

/* ══════════════════════════════════════════════════════════════ */
/* QUIZ SECTION — KANABLITZ ARENA STYLE                         */
/* ══════════════════════════════════════════════════════════════ */
.trial-section{padding:90px 0}

/* Main card wrapper — KanaBlitz arena card look */
.trial-card{
  background:#ffffff;
  border:2px solid #e2e8f0;
  border-radius:2rem;
  padding:0.5rem;
  box-shadow:0 12px 40px rgba(15,23,42,0.06);
  transition:border-color 0.3s,box-shadow 0.3s;
}
.trial-card:hover{border-color:#bae6fd;box-shadow:0 20px 48px rgba(14,165,233,0.1)}
.trial-card-inner{
  background:#f8fafc;
  border-radius:1.5rem;
  overflow:hidden;
  box-shadow:inset 0 2px 10px rgba(0,0,0,0.02);
}

/* Streak bar (decorative) */
.quiz-streak-bar{height:5px;background:#e2e8f0}
.quiz-streak-fill{height:100%;transition:width 0.3s;background:#38bdf8}

/* Quiz body */
.quiz-body{padding:2rem 1.5rem;text-align:center;position:relative}

/* Badge */
.quiz-badge{
  position:absolute;top:1rem;right:1rem;
  display:flex;align-items:center;gap:0.4rem;
  padding:0.3rem 0.75rem;
  background:#f1f5f9;border:1px solid #e2e8f0;
  border-radius:999px;
  font-size:0.5rem;font-weight:900;color:#64748b;
  letter-spacing:1px;text-transform:uppercase;
}
.quiz-badge .dot{width:5px;height:5px;border-radius:50%;background:#22c55e;animation:pulse 1.5s infinite}

/* Category */
.quiz-category{
  display:inline-flex;align-items:center;gap:0.3rem;
  padding:0.3rem 0.6rem;
  background:#f1f5f9;border-radius:0.5rem;
  font-size:0.5rem;font-weight:700;color:#64748b;
  text-transform:uppercase;letter-spacing:2px;margin-bottom:1.25rem;
}

/* Meaning / progress */
.quiz-meaning{font-weight:900;font-size:0.8rem;color:#e2e8f0;text-transform:uppercase;letter-spacing:2px;margin-bottom:0.25rem}
.quiz-divider{width:40px;height:3px;border-radius:999px;margin:0.75rem auto;background:linear-gradient(90deg,#fbbf24,#ea580c)}

/* Character display */
.quiz-display{font-size:4rem;font-weight:900;color:#fff;padding:1.5rem 0}

/* 2×2 option grid — KanaBlitz arena style */
.quiz-options{display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-top:0.5rem}
.quiz-option{
  padding:1.25rem 0.75rem;border-radius:1rem;
  border:2px solid #334155;background:rgba(15,23,42,0.6);
  color:#fff;
  cursor:pointer;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  position:relative;overflow:hidden;min-height:100px;
  transition:all 0.2s ease;
  font-family:'Nunito',sans-serif;
}
.quiz-option:hover:not(:disabled){
  transform:translateY(-2px);
  border-color:#fbbf24;
  box-shadow:0 4px 16px rgba(245,158,11,0.15);
}
.quiz-option .opt-badge{
  position:absolute;top:0.4rem;left:0.4rem;
  width:22px;height:22px;border-radius:0.4rem;
  background:#334155;color:#94a3b8;
  display:flex;align-items:center;justify-content:center;
  font-size:0.55rem;font-weight:900;
  transition:all 0.2s;
}
.quiz-option:hover:not(:disabled) .opt-badge{background:#fbbf24;color:#000}
.quiz-option .opt-status{position:absolute;top:0.4rem;right:0.4rem}
.quiz-option .opt-key{
  position:absolute;bottom:0.4rem;right:0.4rem;
  font-size:0.4rem;font-weight:900;letter-spacing:1px;
  padding:0.15rem 0.4rem;border-radius:0.3rem;
  border:1px solid #334155;color:#64748b;
}
.quiz-option .opt-text{font-size:1.8rem;font-weight:900;margin-top:0.3rem;transition:transform 0.2s}

/* Option correct/wrong states */
.quiz-option.correct{
  background:linear-gradient(135deg,#10b981,#059669) !important;
  border-color:#10b981 !important;color:#fff !important;
  box-shadow:0 4px 16px rgba(16,185,129,0.3);transform:scale(1.02);z-index:10;
}
.quiz-option.correct .opt-badge{background:rgba(255,255,255,0.2);color:#fff}
.quiz-option.wrong{
  background:linear-gradient(135deg,#ef4444,#dc2626) !important;
  border-color:#ef4444 !important;color:#fff !important;
  animation:shake 0.4s;
}
.quiz-option.wrong .opt-badge{background:rgba(255,255,255,0.2);color:#fff}
.quiz-option.reveal{background:#ecfdf5 !important;border-color:#10b981 !important;color:#065f46 !important}
.quiz-option.reveal .opt-badge{background:#10b981;color:#fff}

/* Feedback overlay */
.quiz-feedback{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  z-index:10;display:none;
}
.quiz-feedback.show{display:block;animation:scale-pop 0.4s ease-out both}

/* Quiz footer */
.quiz-footer{
  margin-top:1rem;
  display:flex;align-items:center;justify-content:center;gap:0.75rem;
  font-size:0.6rem;font-weight:700;color:#94a3b8;
}

/* Score/combo HUD */
.quiz-hud{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:1rem;
}
.quiz-hud-combo{
  display:none;font-size:0.5rem;font-weight:900;letter-spacing:1px;
  padding:0.2rem 0.6rem;border-radius:999px;
  background:#fef3c7;color:#92400e;border:1px solid #fde68a;
}
.quiz-hud-combo.show{display:inline-block}
.quiz-score{font-weight:900;font-size:1.2rem;font-family:'Nunito',sans-serif}

/* Quiz result */
.quiz-result-comp{text-align:center;padding:1.5rem 0}
.result-reward-box{
  background:#f8fafc;border:1px solid #e2e8f0;
  border-radius:20px;padding:1.5rem;margin-bottom:1rem;
}

/* ══════════════════════════════════════════════════════════════ */
/* FLASHCARD SECTION — KEPT EXACTLY AS-IS FROM ORIGINAL         */
/* ══════════════════════════════════════════════════════════════ */
.flashcard-section-dark{
  padding:100px 0;
  background-color:#0f172a !important;
}
.flashcard-inner{
  transition:transform 0.7s cubic-bezier(0.4,0,0.2,1);
  transform-style:preserve-3d;
}
.flashcard-container.flipped .flashcard-inner{transform:rotateY(180deg)}
.card-face{backface-visibility:hidden}
.anki-new-btn{
  border-radius:12px !important;transition:all 0.2s ease;
  padding:10px 4px !important;font-family:'Nunito',sans-serif !important;
}
.anki-new-btn:hover{transform:translateY(-2px)}
.btn-again:hover{background-color:#f43f5e !important;color:white !important}
.btn-hard:hover{background-color:#f59e0b !important;color:white !important}
.btn-good:hover{background-color:#0ea5e9 !important;color:white !important}
.btn-easy:hover{background-color:#10b981 !important;color:white !important}

/* ══════════════════════════════════════════════════════════════ */
/* MARKETPLACE                                                  */
/* ══════════════════════════════════════════════════════════════ */
.marketplace-section{padding:90px 0}
.marketplace-card{
  border-radius:28px;overflow:hidden;
  box-shadow:0 16px 48px -12px rgba(15,23,42,0.12);
  border:2px solid #e2e8f0;background:#ffffff;
  transition:transform 0.35s,box-shadow 0.35s;
}
.marketplace-card:hover{transform:translateY(-6px);box-shadow:0 30px 60px -15px rgba(15,23,42,0.18)}

/* ══════════════════════════════════════════════════════════════ */
/* TIERS — KEPT EXACTLY FROM ORIGINAL                           */
/* ══════════════════════════════════════════════════════════════ */
.tiers-section{padding:90px 0 0;background-color:#f8fafc}
.tier-track-wrapper{overflow-x:auto;padding-bottom:20px;scrollbar-width:none}
.tier-track-wrapper::-webkit-scrollbar{display:none}
.tier-track{min-width:max-content;padding:10px 20px;overflow:visible !important}
.tier-item{flex-shrink:0;transition:transform 0.3s cubic-bezier(0.4,0,0.2,1)}
.tier-item:hover{transform:scale(1.12);z-index:10}
.tier-connector{flex-grow:1;height:2px;background:#e2e8f0;min-width:20px;border-radius:2px}

/* Rank text — KEPT EXACTLY AS ORIGINAL */
.rank-text{font-weight:900;font-size:0.7rem;letter-spacing:1.5px;text-transform:uppercase;padding:6px 14px;border-radius:50px;display:inline-block}

/* ══════════════════════════════════════════════════════════════ */
/* REWARD HUD                                                   */
/* ══════════════════════════════════════════════════════════════ */
.reward-hud{
  background:#ffffff;border:1px solid #e2e8f0;
  border-radius:32px;position:relative;overflow:hidden;
  box-shadow:0 12px 32px rgba(15,23,42,0.06);
}
.reward-hud::before{
  content:'';position:absolute;
  top:-60%;right:-20%;width:400px;height:400px;
  background:radial-gradient(circle,rgba(14,165,233,0.05) 0%,transparent 70%);
  pointer-events:none;
}
.xp-badge-lg{
  width:66px;height:66px;background:#0ea5e9;
  color:white;border-radius:16px;
  display:flex;align-items:center;justify-content:center;
  font-weight:900;font-size:1.25rem;
  box-shadow:0 4px 0 #0284c7;
}
.promote-badge{
  background:#f1f5f9;border:1px solid #e2e8f0;
  color:#0f172a;border-radius:50px;
  padding:8px 18px;font-size:0.7rem;
  font-weight:900;letter-spacing:1.5px;
  display:inline-flex;align-items:center;gap:6px;
}

/* Gold coin */
.gold-coin{
  width:18px;height:18px;background:#fbbf24;
  border-radius:50%;border:2px solid #d97706;
  display:inline-flex;align-items:center;justify-content:center;
  box-shadow:0 2px 0 #b45309;font-weight:900;
  font-size:0.6rem;color:#92400e;
  transition:transform 0.3s ease;
}
.gold-coin::after{content:"G"}
.reward-hud .gold-coin{
  width:66px;height:66px;font-size:1.7rem;
  border-width:4px;box-shadow:0 6px 0 #b45309;transform:rotate(5deg);
}

/* ══════════════════════════════════════════════════════════════ */
/* ROADMAP                                                      */
/* ══════════════════════════════════════════════════════════════ */
.roadmap-section{padding:90px 0;background-color:#f8fafc}
.roadmap-container{position:relative;z-index:1}
.roadmap-node{
  width:72px;height:72px;
  background:#ffffff;border:3px solid #0f172a;
  border-radius:50%;z-index:2;position:relative;
  display:flex;align-items:center;justify-content:center;
  font-weight:900;font-size:0.95rem;
  color:#0f172a;cursor:pointer;
  transition:all 0.3s cubic-bezier(0.34,1.56,0.64,1);
  box-shadow:0 4px 16px -4px rgba(15,23,42,0.1);
}
.roadmap-node:hover{transform:scale(1.15);border-color:#0ea5e9;box-shadow:0 10px 28px -6px rgba(14,165,233,0.25);color:#0ea5e9}
.node-locked{border-color:#cbd5e1 !important;color:#94a3b8 !important;box-shadow:none}
.node-locked:hover{border-color:#94a3b8 !important;color:#64748b !important;box-shadow:0 4px 16px -4px rgba(15,23,42,0.08)}
.roadmap-line{position:absolute;top:50%;left:0;right:0;height:3px;background:#e2e8f0;z-index:1}

/* Path step */
.path-step{position:relative;padding-left:16px;border-left:2px solid var(--step-color,#334155)}

/* ══════════════════════════════════════════════════════════════ */
/* FINAL CTA                                                    */
/* ══════════════════════════════════════════════════════════════ */
.cta-section{padding:90px 0}
.cta-banner{
  background:linear-gradient(135deg,#0f172a 0%,#1e293b 60%,#0ea5e9 140%);
  border-radius:28px;padding:70px 40px;
  max-width:900px;margin:0 auto;
  position:relative;overflow:hidden;
  box-shadow:0 25px 60px -12px rgba(15,23,42,0.35);
  border:1px solid rgba(14,165,233,0.15);
}
.cta-banner::before{
  content:"";position:absolute;
  inset:-40% -10% auto auto;
  width:320px;height:320px;
  background:radial-gradient(circle,rgba(245,158,11,0.15) 0%,transparent 70%);
  pointer-events:none;
}
.cta-free-tag{color:rgba(255,255,255,0.45)}

/* ══════════════════════════════════════════════════════════════ */
/* GLOBAL POLISH                                                */
/* ══════════════════════════════════════════════════════════════ */
.hover-lift{transition:transform 0.25s ease !important}
.hover-lift:hover{transform:translateY(-3px) !important}
.btn{font-family:'Nunito',sans-serif !important}

/* ══════════════════════════════════════════════════════════════ */
/* RESPONSIVE                                                   */
/* ══════════════════════════════════════════════════════════════ */
@@media(max-width:576px){
  .hero-headline{font-size:clamp(2rem,6vw,4rem) !important}
  .quiz-display{font-size:2.5rem}
  .quiz-option .opt-text{font-size:1.4rem}
  .reward-hud .gold-coin{width:90px !important;height:90px !important;font-size:2.2rem !important;border-width:6px !important;box-shadow:0 8px 0 #b45309 !important}
  .reward-hud .xp-badge-lg{width:90px !important;height:90px !important;font-size:1.8rem !important}
  .features-section .row{flex-direction:column !important}
  .features-section .col-md-4{max-width:100% !important;margin-bottom:1.5rem}
  .features-section,.trial-section,.flashcard-section-dark,.marketplace-section,.tiers-section,.roadmap-section,.cta-section{padding:60px 0 !important}
  .stats-bar .d-flex{flex-direction:column;align-items:center}
  .stat-divider{display:none}
}
</style>

<!-- ═══ BETA BANNER ═══ -->
<div class="beta-banner d-flex justify-content-center align-items-center flex-wrap gap-2 text-center">
    <span class="beta-banner-tag">BETA V1.0</span>
    <span class="fw-bold opacity-75">NipponQuest is currently in early beta. We'd love your feedback to help us improve!</span>
    <a href="https://forms.gle/3PhMQDTUEpFpc2hp7" target="_blank" class="fw-black ms-md-2">
        Share Feedback <i class="bi bi-box-arrow-up-right ms-1" style="font-size:0.75rem;"></i>
    </a>
</div>

<!-- ═══ HERO ═══ -->
<div class="hero-section text-center" style="padding:90px 0 0;">
    <div class="container">
        <div class="reveal-up">
            <span class="hero-pill">
                <span class="dot"></span> THE WORLD'S #1 JAPANESE LEARNING ARENA
            </span>
        </div>

        <h1 class="fw-black hero-headline reveal-up delay-100">
            Master Japanese.<br>
            <span>Become Legend.</span>
        </h1>

        <p class="lead fw-bold mb-5 mt-4 px-md-5 mx-auto reveal-up delay-200"
           style="max-width:760px;font-size:1.2rem;line-height:1.65;color:#64748b;">
            The only platform where <strong class="text-dark">competitive gaming mechanics</strong> accelerate
            language mastery. Climb elite leagues, build real-world fluency, and conquer Nihongo
            with an unbreakable daily streak.
        </p>

        <div class="d-flex flex-column align-items-center gap-2 reveal-up delay-300">
            @if (currentUser != null)
            {
                <a asp-controller="Leagues" asp-action="Index"
                   class="btn btn-blitz btn-blitz-primary btn-blitz-lg">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                    RESUME YOUR QUEST
                </a>
            }
            else
            {
                <a asp-area="Identity" asp-page="/Account/Register"
                   class="btn btn-blitz btn-blitz-primary btn-blitz-lg">
                    START YOUR JOURNEY — IT'S 100% FREE
                </a>
            }
            <p class="hero-trust mt-2">
                <svg style="width:14px;height:14px;vertical-align:-2px;margin-right:3px" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
                INSTANT ACCESS &bull; NO CREDIT CARD &bull; JOIN IN 30 SECONDS
            </p>
        </div>
    </div>

    <div class="hero-wave mt-5">
        <svg viewBox="0 0 1440 48" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="height:48px;width:100%;">
            <path d="M0,24 C360,48 1080,0 1440,24 L1440,48 L0,48 Z" fill="#ffffff"/>
        </svg>
    </div>
</div>

<!-- ═══ STATS BAR ═══ -->
<div class="stats-bar py-5">
    <div class="container reveal-up">
        <div class="d-flex justify-content-center align-items-center gap-0 flex-wrap">
            <div class="text-center px-4 px-md-5">
                <div class="stat-number text-primary">@totalXpDisplay</div>
                <div class="stat-label">Total XP Earned</div>
            </div>
            <div class="stat-divider d-none d-md-block mx-2"></div>
            <div class="text-center px-4 px-md-5">
                <div class="stat-number text-warning-custom" style="color:#f59e0b !important;">@totalGoldDisplay</div>
                <div class="stat-label">Total Gold Earned</div>
            </div>
            <div class="stat-divider d-none d-md-block mx-2"></div>
            <div class="text-center px-4 px-md-5">
                <div class="stat-number" style="color:#ea580c;">@activeStreaksDisplay</div>
                <div class="stat-label">Active Streaks</div>
            </div>
        </div>
    </div>
</div>

<!-- ═══ FEATURES ═══ -->
<div class="features-section">
    <div class="container">
        <div class="text-center mb-5 reveal-up">
            <div class="section-eyebrow mb-3">Platform Features</div>
            <h2 class="section-heading">Engineered for Fluency</h2>
            <p class="text-muted fw-bold mt-3" style="font-size:1.05rem;">
                Where addictive gaming immersion meets scientific language acquisition algorithms.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-4 reveal-up">
                <div class="static-card feature-card-blue p-4 p-lg-5 d-flex flex-column h-100 text-start">
                    <div class="feature-icon bg-white border shadow-sm" style="width:56px;height:56px;font-size:1.5rem;">
                        <i class="bi bi-controller text-primary"></i>
                    </div>
                    <h4 class="fw-black mb-3 text-dark tracking-tight">Gamified Curriculum</h4>
                    <p class="text-muted mb-4 fw-bold small flex-grow-1" style="line-height:1.65;">
                        Conquer Hiragana, Katakana, and complex Kanji through dynamic timed challenges that transform stressful vocabulary tests into a rewarding RPG progression system.
                    </p>
                    <div class="mt-auto pt-3 border-top text-primary fw-bold d-flex align-items-center justify-content-between" style="font-size:0.75rem;">
                        <span>Includes live audio feedback</span>
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4 reveal-up delay-100">
                <div class="static-card feature-card-warning p-4 p-lg-5 d-flex flex-column h-100 text-start">
                    <div class="feature-icon bg-white border shadow-sm" style="width:56px;height:56px;font-size:1.5rem;">
                        <i class="bi bi-trophy text-warning-custom" style="color:#f59e0b !important;"></i>
                    </div>
                    <h4 class="fw-black mb-3 text-dark tracking-tight">Competitive Arenas</h4>
                    <p class="text-muted mb-4 fw-bold small flex-grow-1" style="line-height:1.65;">
                        Test your reaction speeds against players in your personal skill bracket. Battle for leaderboard supremacy and promotion slots every Sunday at midnight.
                    </p>
                    <div class="mt-auto pt-3 border-top text-warning-custom fw-bold d-flex align-items-center justify-content-between" style="font-size:0.75rem;color:#f59e0b !important;">
                        <span>Automatic league balancing</span>
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4 reveal-up delay-200">
                <div class="static-card feature-card-danger p-4 p-lg-5 d-flex flex-column h-100 text-start">
                    <div class="feature-icon bg-white border shadow-sm" style="width:56px;height:56px;font-size:1.5rem;">
                        <i class="bi bi-fire text-danger"></i>
                    </div>
                    <h4 class="fw-black mb-3 text-dark tracking-tight">Fluency Engine</h4>
                    <p class="text-muted mb-4 fw-bold small flex-grow-1" style="line-height:1.65;">
                        Stay laser-focused with an unbreakable streak reward engine. Accumulate pure Gold revenue to customize your showcase profile, purchase premium custom avatars, and dominate rankings.
                    </p>
                    <div class="mt-auto pt-3 border-top text-danger fw-bold d-flex align-items-center justify-content-between" style="font-size:0.75rem;">
                        <span>Prevents decay burnout</span>
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══ QUIZ SECTION — KANABLITZ ARENA STYLE (WHITE BG) ═══ -->
<div class="trial-section position-relative overflow-hidden" style="background-color:#ffffff; padding:100px 0;">
    <div class="position-absolute w-100 h-100" style="top:0; left:0; background: radial-gradient(circle at 30% 30%, rgba(245,158,11,0.06), transparent 70%); pointer-events: none;"></div>
    <div class="container position-relative" style="z-index: 10;">
        <div class="row align-items-center g-5">

            <!-- LEFT COLUMN: BLACK & GOLD ON WHITE -->
            <div class="col-lg-5 text-start reveal-up">
                <span class="badge rounded-pill border px-3 py-2 fw-black mb-4 d-inline-flex align-items-center gap-2"
                      style="background:#fef3c7; border-color:#fde68a !important; color:#92400e; letter-spacing:1.5px; font-size:0.7rem;">
                    <svg style="width:12px;height:12px;" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg> HIGH-REACTION DRILL
                </span>
                
                <h2 class="fw-black tracking-tight mb-4" style="font-size:clamp(2.5rem,4vw,3.5rem); line-height:1.1; color:#0f172a;">
                    Kana<span style="color:#f59e0b;">Blitz Arena</span>
                </h2>
                
                <p class="fw-medium mb-4 pb-2" style="font-size:1rem; line-height:1.65; color:#475569;">
                    KanaBlitz is a fast-paced reaction reading arena designed to forge <strong style="color:#0f172a;">instant character recall</strong>. Train your visual reflexes by picking correct readings under intense clock pressure. Perfect for locking in Hiragana, Katakana, and complex compounds.
                </p>

                <ul class="list-unstyled d-flex flex-column gap-3 mb-5">
                    <li class="d-flex align-items-start gap-3 p-3 rounded-4 border" style="background:#fffbeb; border-color:#fde68a !important;">
                        <div class="rounded-3 d-flex align-items-center justify-content-center fw-black flex-shrink-0" style="width:32px; height:32px; font-size:1.1rem; background-color:#fbbf24; box-shadow:0 2px 0 #d97706;"><svg style="width:14px;height:14px" viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="2.5"><polygon points="12 2 2 22 22 22"/><circle cx="12" cy="14" r="2" fill="currentColor"/></svg></div>
                        <div>
                            <span class="fw-black small d-block mb-1" style="color:#0f172a;">Four Distinct Intensity Modes</span>
                            <span class="small d-block" style="font-size: 0.75rem; line-height: 1.4; color:#64748b;">
                                <strong style="color:#475569;">Easy</strong> (120s clock, Romaji &rarr; Kana), <strong style="color:#475569;">Normal</strong> (90s fixed clock), <strong style="color:#475569;">Hard</strong> (+1s / -2s timer bank), and <strong style="color:#475569;">Insanity</strong> (45s clock, furigana blanks &amp; Kanji).
                            </span>
                        </div>
                    </li>
                    <li class="d-flex align-items-start gap-3 p-3 rounded-4 border" style="background:#f8fafc; border-color:#e2e8f0 !important;">
                        <div class="rounded-3 d-flex align-items-center justify-content-center fw-black flex-shrink-0" style="width:32px; height:32px; font-size:1.1rem; background-color:#0f172a;"><svg style="width:14px;height:14px" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
                        <div>
                            <span class="fw-black small d-block mb-1" style="color:#0f172a;">Rapid Reflex Time Banking</span>
                            <span class="small d-block" style="font-size: 0.75rem; line-height: 1.4; color:#64748b;">
                                In advanced modes, every correct answer adds precious seconds back to your clock, while every mistake burns time and crushes your active combo.
                            </span>
                        </div>
                    </li>
                    <li class="d-flex align-items-start gap-3 p-3 rounded-4 border" style="background:#fffbeb; border-color:#fde68a !important;">
                        <div class="rounded-3 d-flex align-items-center justify-content-center fw-black flex-shrink-0 bg-transparent" style="width:32px; height:32px;">
                            <div class="gold-coin" style="width:22px; height:22px; font-size:0.65rem; border-width:2px; box-shadow:0 2px 0 #b45309; margin:0;"></div>
                        </div>
                        <div>
                            <span class="fw-black small d-block mb-1" style="color:#0f172a;">Earn Premium Gold &amp; EXP</span>
                            <span class="small d-block" style="font-size: 0.75rem; line-height: 1.4; color:#64748b;">
                                Clear the arena to secure dynamic score bonuses, unlock elite higher difficulties, earn raw EXP, and harvest Gold to dominate the global league rankings.
                            </span>
                        </div>
                    </li>
                </ul>

                <a asp-controller="KanaBlitz" asp-action="Index"
                   class="btn fw-black px-4 py-3 hover-lift d-inline-flex align-items-center gap-2" 
                   style="font-size:0.75rem; letter-spacing:1px; border-radius:12px !important; font-family:'Nunito',sans-serif !important; background:linear-gradient(135deg,#f59e0b,#d97706); color:#fff; border:none; box-shadow:0 4px 16px rgba(245,158,11,0.3);">
                    ENTER THE BLITZ ARENA <svg style="width:12px;height:12px" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                </a>
            </div>

            <!-- RIGHT COLUMN: INTERACTIVE ARENA TRIAL (DARK CARD KEPT EXACT) -->
            <div class="col-lg-7 text-center reveal-up delay-200 d-flex flex-column align-items-center">
                
                <div class="mb-3">
                    <span class="badge rounded-pill border px-3 py-2 fw-bold" 
                          style="background:#f1f5f9; border-color:#e2e8f0 !important; color:#64748b; letter-spacing:1.5px; font-size:0.7rem;">
                        <svg style="width:11px;height:11px;vertical-align:-1px;margin-right:3px" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                        Test your reflexes in the live trial below
                    </span>
                </div>

                <!-- Outer KanaBlitz arena card -->
                <div class="trial-card h-100 w-100" id="quiz-card" style="max-width: 448px; border:2px solid #334155; background:rgba(30,41,59,0.5) !important;">
                    <div class="trial-card-inner" style="background:#1e293b !important; border:1px solid rgba(255,255,255,0.05)">

                        <!-- Streak bar -->
                        <div class="quiz-streak-bar" style="background:#0f172a">
                            <div class="quiz-streak-fill" id="quiz-streak-fill" style="width:0%;"></div>
                        </div>

                        <!-- Game area -->
                        <div class="quiz-body" id="quiz-game" style="padding: 3.25rem 1.5rem 2.5rem;">

                            <!-- Arena badge -->
                            <div class="quiz-badge" style="background:#0f172a; border-color:#334155; color:#94a3b8">
                                <span class="dot"></span>
                                <span>HIRAGANA RECOGNITION</span>
                            </div>

                            <!-- Category -->
                            <div class="quiz-category" id="quiz-category" style="background:#0f172a; border: 1px solid #334155; color:#fbbf24">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/></svg>
                                HIRAGANA TRIAL
                            </div>

                            <!-- Progress HUD -->
                            <div class="quiz-hud">
                                <div>
                                    <span class="badge rounded-pill fw-black px-3 py-2"
                                          style="background:#0f172a; color:#fff; font-size:0.65rem; letter-spacing:1.5px; border:1px solid #334155;"
                                          id="quiz-progress">QUEST 1 / 5</span>
                                </div>
                                <div>
                                    <span class="quiz-hud-combo" id="quiz-combo"></span>
                                    <span class="quiz-score" id="quiz-score-display" style="display:none; color:#fbbf24;">
                                        Score: <span id="quiz-score-val">0</span>
                                    </span>
                                </div>
                            </div>

                            <!-- Meaning -->
                            <div class="quiz-meaning" id="quiz-meaning" style="color:#64748b"></div>

                            <!-- Divider -->
                            <div class="quiz-divider" style="background:linear-gradient(90deg,#fbbf24,#ea580c)"></div>

                            <!-- Character display -->
                            <div class="quiz-display" id="hiragana-display" style="color:#fff; text-shadow:0 0 25px rgba(251,191,36,0.15)">あ</div>

                            <!-- Option buttons (2×2 grid) -->
                            <div class="quiz-options" id="answer-buttons"></div>

                            <!-- Footer hint -->
                            <div class="quiz-footer" style="color:#64748b">
                                <span id="score-count">0 correct</span>
                                <span style="color:#334155;">·</span>
                                <span id="footer-hint">Select the correct romaji reading</span>
                            </div>
                        </div>

                        <!-- Result -->
                        <div id="quiz-result" class="quiz-result-comp" style="display:none; background:#0f172a; padding: 2.5rem 1.5rem;">
                            <div class="mb-4">
                                <div class="gold-coin mx-auto mb-4"
                                     style="width:72px; height:72px; border-width:4px; box-shadow:0 6px 0 #b45309;"></div>
                                <h2 class="fw-black text-white mb-1" style="font-size:1.5rem;">Quest Complete!</h2>
                                <p class="display-5 fw-black text-primary mb-0" style="font-size:2rem; color:#fbbf24 !important;" id="final-score">0 / 5</p>
                            </div>

                            <div class="result-reward-box mx-auto" style="max-width:480px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.05)">
                                <p class="fw-black text-white small text-uppercase mb-3"
                                   style="letter-spacing:1.5px; opacity:0.5;">
                                    A registered account would have earned:
                                </p>
                                <div class="d-flex justify-content-center align-items-center gap-4">
                                    <span class="fw-black" style="font-size:1.25rem; color:#38bdf8">
                                        <svg style="width:14px;height:14px;vertical-align:-1px;margin-right:3px" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>10 EXP
                                    </span>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="gold-coin" style="width:22px; height:22px; border-width:2px; box-shadow:0 2px 0 #b45309;"></div>
                                        <span class="fw-black" style="color:#f59e0b; font-size:1.25rem;">5 GOLD</span>
                                    </div>
                                </div>
                            </div>

                            <a asp-area="Identity" asp-page="/Account/Register"
                               class="btn btn-blitz btn-blitz-gold mt-4">
                                CLAIM YOUR REWARDS
                            </a>
                            <button onclick="resetQuiz()"
                                    class="btn btn-link d-block mx-auto mt-3 fw-bold text-decoration-none"
                                    style="color:#64748b; font-size:0.75rem; letter-spacing:1.5px;">
                                TRY AGAIN
                            </button>
                        </div>

                    </div>
                </div>

                <p class="text-center small fw-bold mt-3 mb-0" style="color:#94a3b8">
                    <svg style="width:12px;height:12px;vertical-align:-1px;margin-right:3px" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                    Completing lessons earns you EXP and Gold to climb the leaderboards.
                </p>
            </div>

        </div>
    </div>
</div>

<!-- ═══ FLASHCARD SECTION (WHITE BG, DARK 3D CARD KEPT EXACT) ═══ -->
<div class="flashcard-section-dark position-relative overflow-hidden" style="background-color:#f8fafc !important; padding:100px 0;">
    <div class="position-absolute w-100 h-100" style="top:0;left:0;background:radial-gradient(circle at 30% 30%,rgba(14,165,233,0.06),transparent 70%);pointer-events:none;"></div>
    <div class="container position-relative" style="z-index:10;">
        <div class="row align-items-center g-5">

            <div class="col-lg-5 text-start reveal-up">
                <span class="badge rounded-pill border px-3 py-2 fw-black mb-4 d-inline-flex align-items-center gap-2"
                      style="background:#e0f2fe;border-color:#bae6fd !important;color:#0369a1;letter-spacing:1.5px;font-size:0.7rem;">
                    <i class="bi bi-stars"></i> SPACED REPETITION ENGINE
                </span>
                
                <h2 class="fw-black tracking-tight mb-4" style="font-size:clamp(2rem,4vw,3rem);line-height:1.1;color:#0f172a;">
                    The Ultimate <br />
                    <span style="color:#0ea5e9;">Flashcard System</span>
                </h2>
                
                <p class="fw-medium mb-4 pb-2" style="font-size:1rem;line-height:1.65;color:#475569;">
