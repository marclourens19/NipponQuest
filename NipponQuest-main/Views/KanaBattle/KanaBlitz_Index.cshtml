                <div class="about-title">Battle Skills & Power-Ups</div>
                <p style="font-size:.65rem;color:#64748b;margin-bottom:.75rem;font-weight:700">In KanaBattle, some falling kana carry special skills. Answer them correctly to activate the skill!</p>
                <div class="skill-list" id="about-skills"></div>
            </div>

            <div class="about-section">
                <div class="about-title">Combo System</div>
                <div class="about-card">
                    <h4>🔥 Building Combos</h4>
                    <p>Answer questions correctly in a row to build your combo multiplier. In Solo: combos add bonus points (100 + streak × 10 per correct answer). In Battle: higher combos deal more damage. Reset on any wrong answer. Max combo at 25x for 2.25× damage!</p>
                </div>
            </div>

            <div class="about-section">
                <div class="about-title">Scoring & Rewards</div>
                <div class="about-card">
                    <h4>💰 How Points Work</h4>
                    <p>Solo: Base 100 pts per correct answer + combo bonus. Submit to leaderboard on completion.<br><br>Battle: Win → double XP and Gold rewards. XP determines your level. Gold can be used in the shop. ELO changes based on win/loss in ranked matches.</p>
                </div>
            </div>
        </div>
    </div>

    <script>
            // ── PARTICLES ────────────────────────────────────────────────────────
            const pc = document.getElementById('particles');
            for (let i = 0; i < 20; i++) {
                const d = document.createElement('div'); d.className = 'bg-particle';
                d.style.cssText = `left:${Math.random()*100}%;bottom:-10px;`
                    + `width:${2+Math.random()*4}px;height:${2+Math.random()*4}px;`
                    + `background:rgba(56,189,248,.3);`
                    + `animation-duration:${8+Math.random()*12}s;animation-delay:${Math.random()*10}s;`;
                pc.appendChild(d);
            }

            // ── KANA DATA ────────────────────────────────────────────────────────
            const ALL_KANA = ['あ','い','う','え','お','か','き','く','け','こ','さ','し','す','せ','そ','た','ち','つ','て','と','な','に','ぬ','ね','の','は','ひ','ふ','へ','ほ','ま','み','む','め','も','や','ゆ','よ','ら','り','る','れ','ろ','わ','を','ん'];
            const ALL_KATA = ['ア','イ','ウ','エ','オ','カ','キ','ク','ケ','コ','サ','シ','ス','セ','ソ','タ','チ','ツ','テ','ト','ナ','ニ','ヌ','ネ','ノ','ハ','ヒ','フ','ヘ','ホ','マ','ミ','ム','メ','モ','ヤ','ユ','ヨ','ラ','リ','ル','レ','ロ','ワ','ヲ','ン'];
            const ALL_DAK = ['が','ぎ','ぐ','げ','ご','ざ','じ','ず','ぜ','ぞ','だ','ぢ','づ','で','ど','ば','び','ぶ','べ','ぼ','ぱ','ぴ','ぷ','ぺ','ぽ'];
            const ROMAJI = {
                'あ':'A','い':'I','う':'U','え':'E','お':'O','か':'KA','き':'KI','く':'KU','け':'KE','こ':'KO',
                'さ':'SA','し':'SHI','す':'SU','せ':'SE','そ':'SO','た':'TA','ち':'CHI','つ':'TSU','て':'TE','と':'TO',
                'な':'NA','に':'NI','ぬ':'NU','ね':'NE','の':'NO','は':'HA','ひ':'HI','ふ':'FU','へ':'HE','ほ':'HO',
                'ま':'MA','み':'MI','む':'MU','め':'ME','も':'MO','や':'YA','ゆ':'YU','よ':'YO',
                'ら':'RA','り':'RI','る':'RU','れ':'RE','ろ':'RO','わ':'WA','を':'WO','ん':'N',
                'が':'GA','ぎ':'GI','ぐ':'GU','げ':'GE','ご':'GO','ざ':'ZA','じ':'JI','ず':'ZU','ぜ':'ZE','ぞ':'ZO',
                'だ':'DA','ぢ':'JI','づ':'ZU','で':'DE','ど':'DO','ば':'BA','び':'BI','ぶ':'BU','べ':'BE','ぼ':'BO',
                'ぱ':'PA','ぴ':'PI','ぷ':'PU','ぺ':'PE','ぽ':'PO',
                'ア':'A','イ':'I','ウ':'U','エ':'E','オ':'O','カ':'KA','キ':'KI','ク':'KU','ケ':'KE','コ':'KO',
                'サ':'SA','シ':'SHI','ス':'SU','セ':'SE','ソ':'SO','タ':'TA','チ':'CHI','ツ':'TSU','テ':'TE','ト':'TO',
                'ナ':'NA','ニ':'NI','ヌ':'NU','ネ':'NE','ノ':'NO','ハ':'HA','ヒ':'HI','フ':'FU','ヘ':'HE','ホ':'HO',
                'マ':'MA','ミ':'MI','ム':'MU','メ':'ME','モ':'MO','ヤ':'YA','ユ':'YU','ヨ':'YO',
                'ラ':'RA','リ':'RI','ル':'RU','レ':'RE','ロ':'RO','ワ':'WA','ヲ':'WO','ン':'N',
            };

            const SCRIPT_LABELS = { hiragana:'Hiragana', katakana:'Katakana', dakuten:'Dakuten', mixed:'Mixed' };
            const DIFF_LABELS   = { easy:'Easy', normal:'Normal', hard:'Hard', insanity:'Insanity' };
            const TIME          = { easy:120, normal:90, hard:60, insanity:45 };

            // ── SKILLS (solo mode power-ups) ─────────────────────────────────────
            const SOLO_SKILLS = [
                { id:'doublePoints', icon:'✨', name:'Double Points', desc:'2× score for 10s', color:'#fbbf24', chance:.04 },
                { id:'extraLife',    icon:'❤️', name:'Extra Life',    desc:'Gain 1 life',     color:'#ef4444', chance:.03 },
                { id:'slowTime',     icon:'⏳', name:'Slow Time',     desc:'Timer pauses 5s', color:'#0ea5e9', chance:.025 },
                { id:'multiCombo',   icon:'🔥', name:'Combo Boost',   desc:'Streak ×2 for next 5', color:'#f59e0b', chance:.03 },
            ];

            const RANKS = [
                { name:'Sprout',    icon:'🌱', min:0,    max:799,   color:'#4ade80', desc:'Just beginning your kana journey. Every answer counts — keep growing!' },
                { name:'Wood',      icon:'🪵', min:800,  max:1199,  color:'#a3a3a3', desc:'Solid foundation forming. You know your basics and are building speed.' },
                { name:'Iron',      icon:'⚔️', min:1200, max:1599,  color:'#94a3b8', desc:'Your kana is sharp. Combos are becoming natural and reflexes are improving.' },
                { name:'Gold',      icon:'🥇', min:1600, max:1999,  color:'#fbbf24', desc:'Top-tier player. Your accuracy and speed are well above average.' },
                { name:'Diamond',   icon:'💎', min:2000, max:2399,  color:'#38bdf8', desc:'Elite kana warrior. Few players reach this level — your dedication shows.' },
                { name:'Master',    icon:'🧙', min:2400, max:2799,  color:'#a78bfa', desc:'Near-perfect kana mastery. You answer without thinking. Truly impressive.' },
                { name:'Challenger',icon:'🏆', min:2800, max:3199,  color:'#f97316', desc:'Among the best in the world. Your battle skills are a force to be reckoned with.' },
                { name:'Dragon',    icon:'🐉', min:3200, max:3699,  color:'#f43f5e', desc:'Legendary speed and accuracy. You breathe kana. Opponents tremble at your name.' },
                { name:'Legend',    icon:'⭐', min:3700, max:Infinity, color:'#fef08a', desc:'The pinnacle. Untouchable. A living monument to kana mastery. You are the benchmark.' },
            ];

            const ABOUT_SKILLS = [
                { icon:'⚔️', name:'Sword',      desc:'2× damage for 15 seconds' },
                { icon:'🛡️', name:'Shield',     desc:'Block the next 3 incoming hits' },
                { icon:'🔥', name:'Fireball',   desc:'Instant AoE burst — 2.5× base damage' },
                { icon:'⚡', name:'Lightning',  desc:'Instant strike — 1.8× damage' },
                { icon:'❄️', name:'Ice',        desc:'Freeze AI — no attacks for 5 seconds' },
                { icon:'☠️', name:'Poison',     desc:'Damage over time — 5 damage × 8 ticks' },
                { icon:'💚', name:'Heal',       desc:'Restore 80 HP to your character' },
                { icon:'🎯', name:'Critical',   desc:'Your next hit deals triple damage' },
                { icon:'✨', name:'Double',     desc:'Strike twice — main + 45% followup' },
            ];

            // ── STATE ────────────────────────────────────────────────────────────
            let selAlpha = null, selDiff = null;
            let hp = 3, tLeft = 0, score = 0, pts = 0, streak = 0, maxCombo = 0;
            let pool = [], cur = null, timerIv = null;
            let totalCorrect = 0, totalWrong = 0, skillsUsed = 0;
            let doublePointsActive = false, slowTimeActive = false;
            let timerFrozen = false;

            // ── TAB NAVIGATION ───────────────────────────────────────────────────
            function showTab(name) {
                document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
                document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
                document.getElementById('tab-' + name).classList.add('active');
                const tabs = ['play','ranks','about'];
                const idx = tabs.indexOf(name);
                document.querySelectorAll('.nav-tab')[idx].classList.add('active');
                if (name === 'ranks') buildRanks();
                if (name === 'about') buildAbout();
            }

            function buildRanks() {
                const grid = document.getElementById('ranks-grid');
                if (grid.children.length) return;
                grid.innerHTML = RANKS.map(r => `
                    <div class="rank-card" style="border-left:4px solid ${r.color}22">
                        <div class="rank-icon">${r.icon}</div>
                        <div class="rank-info">
                            <div class="rank-name" style="color:${r.color}">${r.name}</div>
                            <div class="rank-desc">${r.desc}</div>
                        </div>
                        <div class="rank-elo" style="color:${r.color};border-color:${r.color}44;background:${r.color}11">
                            ${r.max === Infinity ? r.min + '+' : r.min + '–' + r.max}
                        </div>
                    </div>`).join('');
            }

            function buildAbout() {
                const sl = document.getElementById('about-skills');
                if (sl && !sl.children.length) {
                    sl.innerHTML = ABOUT_SKILLS.map(s => `
                        <div class="skill-item">
                            <div class="skill-icon">${s.icon}</div>
                            <div class="skill-text">
                                <div class="skill-name">${s.name}</div>
                                <div class="skill-desc">${s.desc}</div>
                            </div>
                        </div>`).join('');
                }
            }

            // ── LOBBY ────────────────────────────────────────────────────────────
            function selA(el) {
                document.querySelectorAll('[data-alpha]').forEach(c => { c.classList.remove('selected'); c.style.borderColor = ''; });
                el.classList.add('selected'); el.style.borderColor = '#0ea5e9';
                selAlpha = el.dataset.alpha; checkReady();
            }
            function selD(el) {
                document.querySelectorAll('[data-diff]').forEach(c => { c.classList.remove('selected'); c.style.borderColor = ''; });
                el.classList.add('selected'); el.style.borderColor = '#0ea5e9';
                selDiff = el.dataset.diff; checkReady();
            }
            function checkReady() {
                const btn = document.getElementById('btn-start');
                if (selAlpha && selDiff) {
                    btn.disabled = false;
                    btn.className = 'cta-btn';
                    btn.style.background = 'linear-gradient(135deg,#0ea5e9,#0284c7)';
                }
            }

            // ── AUDIO ────────────────────────────────────────────────────────────
            let _actx = null;
            function getACtx() {
                if (!_actx) _actx = new (window.AudioContext || window.webkitAudioContext)();
                return _actx;
            }
            function playTone(type, freq, dur, vol = 0.12) {
                try {
                    const a = getACtx(), o = a.createOscillator(), g = a.createGain();
                    o.type = type; o.frequency.value = freq;
                    g.gain.setValueAtTime(0, a.currentTime);
                    g.gain.linearRampToValueAtTime(vol, a.currentTime + .03);
                    g.gain.exponentialRampToValueAtTime(.001, a.currentTime + dur);
                    o.connect(g).connect(a.destination); o.start(); o.stop(a.currentTime + dur + .05);
                } catch {}
            }
            function playSweep(type, f1, f2, dur, vol = 0.15) {
                try {
                    const a = getACtx(), o = a.createOscillator(), g = a.createGain();
                    o.type = type;
                    o.frequency.setValueAtTime(f1, a.currentTime);
                    o.frequency.linearRampToValueAtTime(f2, a.currentTime + dur);
                    g.gain.setValueAtTime(vol, a.currentTime);
                    g.gain.exponentialRampToValueAtTime(.001, a.currentTime + dur + .05);
                    o.connect(g).connect(a.destination); o.start(); o.stop(a.currentTime + dur + .1);
                } catch {}
            }
            function playCorrect()   { playTone('sine', 523.25, .25, .15); }
            function playWrong()     { playSweep('sawtooth', 150, 80, .3, .2); }
            function playSkill()     { [400,500,700].forEach(f => playTone('sine', f, .2, .1)); }
            function playComboMilestone() { [523, 659, 784].forEach((f,i) => setTimeout(() => playTone('sine', f, .2, .1), i * 80)); }
            function playVictory()   { [523,659,784,1046].forEach((f,i) => setTimeout(() => playTone('sine', f, .4, .12), i * 120)); }
            function playDefeat()    { [392,349,293,220].forEach((f,i) => setTimeout(() => playTone('triangle', f, .5, .12), i * 120)); }

            // ── START GAME ───────────────────────────────────────────────────────
            async function startGame() {
                if (!selAlpha || !selDiff) return;
                try { getACtx().resume(); } catch {}

                document.getElementById('ui-lobby').style.display = 'none';
                document.getElementById('ui-arena').style.display = 'block';
                document.getElementById('arena-label').textContent = `${SCRIPT_LABELS[selAlpha]} · ${DIFF_LABELS[selDiff]}`;

                pool = [];
                try {
                    const r = await fetch(`/KanaBlitz/GetArenaPayload?alphabet=${selAlpha}&difficulty=${selDiff}`);
                    if (r.ok) { const res = await r.json(); pool = res.words ?? []; }
                } catch {}

                if (!pool.length) {
                    const kanaPool = selAlpha === 'katakana' ? ALL_KATA
                        : selAlpha === 'dakuten' ? ALL_DAK
                        : selAlpha === 'mixed' ? [...ALL_KANA, ...ALL_KATA, ...ALL_DAK]
                        : ALL_KANA;
                    pool = kanaPool.map(k => ({
                        kana: k, romaji: ROMAJI[k] ?? k,
                        missing: ROMAJI[k] ?? k,
                        display: `<span style="font-size:3rem">${k}</span>`,
                        meaning: 'Select the matching romaji'
                    }));
                    // Assign random skills to ~15% of questions
                    pool.forEach(q => {
                        const r2 = Math.random();
                        let cum = 0;
                        for (const s of SOLO_SKILLS) {
                            cum += s.chance;
                            if (r2 < cum) { q.skill = s.id; break; }
                        }
                    });
                }

                pool = pool.sort(() => Math.random() - .5);
                hp = 3; tLeft = TIME[selDiff]; score = 0; pts = 0; streak = 0; maxCombo = 0;
                totalCorrect = 0; totalWrong = 0; skillsUsed = 0;
                doublePointsActive = false; slowTimeActive = false; timerFrozen = false;

                document.getElementById('hearts').innerHTML = '❤️❤️❤️';
                document.getElementById('pts').textContent = '0';
                document.getElementById('combo-display').textContent = '';

                timerIv = setInterval(() => {
                    if (!timerFrozen) tLeft -= 0.1;
                    if (tLeft <= 0) { clearInterval(timerIv); endGame('time'); return; }
                    const pct = tLeft / TIME[selDiff] * 100;
                    const tbf = document.getElementById('tbf');
                    const tmr = document.getElementById('tmr');
                    const tc = tLeft <= 10 ? '#ef4444' : tLeft <= 20 ? '#f59e0b' : '#22c55e';
                    if (tbf) { tbf.style.width = pct + '%'; tbf.style.background = tc; }
                    if (tmr) { tmr.textContent = fmtTime(tLeft); tmr.style.color = tc; }
                }, 100);

                nextQuestion();
            }

            function fmtTime(s) {
                const m = Math.floor(Math.max(0, s) / 60);
                const sec = Math.ceil(Math.max(0, s)) % 60;
                return `${m.toString().padStart(2,'0')}:${sec.toString().padStart(2,'0')}`;
            }

            // ── QUESTION ─────────────────────────────────────────────────────────
            function nextQuestion() {
                if (!pool.length) { endGame('win'); return; }
                cur = pool.shift();
                document.getElementById('am').textContent = cur.meaning || 'Select the matching romaji';
                document.getElementById('ad').innerHTML = cur.display || cur.kana || cur.romaji;

                // Show skill indicator if this question has a skill
                const banner = document.getElementById('skill-banner');
                if (cur.skill) {
                    const si = SOLO_SKILLS.find(s => s.id === cur.skill);
                    if (si) {
                        banner.className = 'skill-banner show';
                        banner.style.cssText = `display:flex;background:${si.color}22;border:1px solid ${si.color}44;color:${si.color}`;
                        banner.innerHTML = `${si.icon} <strong>${si.name}</strong> — ${si.desc} — Answer correctly to activate!`;
                    }
                } else {
                    banner.className = 'skill-banner';
                }

                const distPool = (selAlpha === 'katakana' ? ALL_KATA
                    : selAlpha === 'dakuten' ? ALL_DAK
                    : selAlpha === 'mixed' ? [...ALL_KANA,...ALL_KATA,...ALL_DAK]
                    : ALL_KANA).map(k => ROMAJI[k] ?? k).filter(r => r !== cur.missing);
                const opts = [cur.missing];
                const shuffled = distPool.sort(() => Math.random() - .5);
                while (opts.length < 4 && shuffled.length) opts.push(shuffled.pop());
                opts.sort(() => Math.random() - .5);

                document.getElementById('ao').innerHTML = opts.map(o =>
                    `<button class="option-btn default" onclick="checkAnswer('${o.replace(/'/g,"\\'")}')">${o}</button>`
                ).join('');
            }

            // ── ANSWER ───────────────────────────────────────────────────────────
            function checkAnswer(val) {
                const correct = val === cur.missing;
                const btns = document.querySelectorAll('.option-btn');
                btns.forEach(b => {
                    if (b.textContent === val) b.className = `option-btn ${correct ? 'correct' : 'wrong'}`;
                    b.onclick = null;
                });

                if (correct) {
                    score++; totalCorrect++; streak++;
                    if (streak > maxCombo) maxCombo = streak;
                    let basePoints = 100 + streak * 10;
                    if (doublePointsActive) basePoints *= 2;
                    pts += basePoints;

                    document.getElementById('pts').textContent = pts;
                    document.getElementById('strk').style.width = Math.min(streak * 4, 100) + '%';

                    const cd = document.getElementById('combo-display');
                    if (streak >= 3) {
                        cd.textContent = `🔥 ${streak}x COMBO! +${basePoints}pts`;
                        if (streak === 3 || streak === 5 || streak === 10) playComboMilestone();
                    } else { cd.textContent = `+${basePoints}pts`; }

                    document.getElementById('ac').classList.add('correct-glow');
                    setTimeout(() => document.getElementById('ac').classList.remove('correct-glow'), 300);
                    flashScreen('flash-green');
                    playCorrect();

                    // Activate skill if present
                    if (cur.skill) {
                        activateSoloSkill(cur.skill);
                        skillsUsed++;
                    }

                    setTimeout(() => nextQuestion(), 350);
                } else {
                    streak = 0; hp--; totalWrong++;
                    document.getElementById('strk').style.width = '0%';
                    document.getElementById('combo-display').textContent = '';
                    document.getElementById('hearts').innerHTML = '❤️'.repeat(hp) + '🖤'.repeat(3 - hp);
                    flashScreen('flash-red');
                    playWrong();
                    if (hp <= 0) {
                        setTimeout(() => { clearInterval(timerIv); endGame('loss'); }, 400);
                    } else {
                        setTimeout(() => nextQuestion(), 500);
                    }
                }
            }

            function activateSoloSkill(skillId) {
                playSkill();
                const si = SOLO_SKILLS.find(s => s.id === skillId);
                if (!si) return;
                switch (skillId) {
                    case 'doublePoints':
                        doublePointsActive = true;
                        setTimeout(() => { doublePointsActive = false; }, 10000);
                        break;
                    case 'extraLife':
                        if (hp < 3) { hp++; document.getElementById('hearts').innerHTML = '❤️'.repeat(hp) + '🖤'.repeat(3 - hp); }
                        break;
                    case 'slowTime':
                        timerFrozen = true;
                        setTimeout(() => { timerFrozen = false; }, 5000);
                        break;
                    case 'multiCombo':
                        streak = Math.min(streak * 2, 50);
                        break;
                }
            }

            function flashScreen(id) {
                const el = document.getElementById(id);
                if (!el) return;
                el.classList.add('show');
                setTimeout(() => el.classList.remove('show'), 200);
            }

            // ── END GAME ─────────────────────────────────────────────────────────
            function endGame(reason) {
                clearInterval(timerIv);
                document.getElementById('ui-arena').style.display = 'none';
                const res = document.getElementById('ui-results');
                res.style.display = 'block';
                const win = reason === 'win';
                const acc = totalCorrect + totalWrong > 0 ? Math.round(totalCorrect / (totalCorrect + totalWrong) * 100) : 0;

                document.getElementById('r-title').textContent = win ? 'Arena Cleared!' : reason === 'time' ? "Time's Up!" : 'Defeated!';
                document.getElementById('r-title').style.color = win ? '#34d399' : '#ef4444';
                document.getElementById('r-icon').textContent = win ? '🎌' : reason === 'time' ? '⏰' : '💀';
                document.getElementById('r-cor').textContent = totalCorrect;
                document.getElementById('r-pts').textContent = pts;
                document.getElementById('r-max').textContent = maxCombo;
                document.getElementById('r-acc').textContent = acc + '%';
                document.getElementById('r-time').textContent = Math.ceil(tLeft) + 's';
                document.getElementById('r-skills').textContent = skillsUsed;

                if (win) playVictory(); else playDefeat();

                fetch('/KanaBlitz/SubmitScore', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        Alphabet: selAlpha, Difficulty: selDiff,
                        CorrectAnswers: totalCorrect, Mistakes: totalWrong,
                        MaxCombo: maxCombo, Points: pts,
                        DurationSeconds: TIME[selDiff] - Math.ceil(tLeft)
                    })
                }).catch(() => {});
            }

            function exitArena() { clearInterval(timerIv); location.reload(); }
    </script>
</body>
</html>