@*
    ╔══════════════════════════════════════════════════════════════════╗
    ║  KanaBlitz_Index.cshtml  —  Mode Selection Hub                 ║
    ║  Controller : KanaBlitzController → Index()                     ║
    ║  Route      : /KanaBlitz/Index  (or /KanaBlitz)                 ║
    ║  Purpose    : Solo / Multiplayer mode picker with full info     ║
    ║  Aesthetic  : White background · Black / Gold / White / Blue    ║
    ╚══════════════════════════════════════════════════════════════════╝
*@
@{
    ViewData["Title"] = "KanaBlitz — Choose Your Path";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ══════════════════════════════════════════════════════════════
           NIPPONQUEST — KanaBlitz Mode Selection Hub
           Palette : White bg · Black text · Gold accents · Blue action
        ══════════════════════════════════════════════════════════════ */
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');

    :root {
        --kb-bg: #ffffff;
        --kb-surface: #f8fafc;
        --kb-surface2: #f1f5f9;
        --kb-border: #e2e8f0;
        --kb-border2: #cbd5e1;
        --kb-black: #0f172a;
        --kb-charcoal: #1e293b;
        --kb-dark: #334155;
        --kb-muted: #64748b;
        --kb-faint: #94a3b8;
        --kb-gold: #d97706;
        --kb-gold-lt: #f59e0b;
        --kb-gold-bg: #fef3c7;
        --kb-gold-bd: #fcd34d;
        --kb-blue: #1e40af;
        --kb-blue-lt: #3b82f6;
        --kb-blue-bg: #eff6ff;
        --kb-blue-bd: #93c5fd;
        --kb-green: #065f46;
        --kb-green-lt: #10b981;
        --kb-green-bg: #ecfdf5;
        --kb-red: #991b1b;
        --kb-red-lt: #ef4444;
        --kb-red-bg: #fff1f2;
        --kb-red-bd: #fca5a5;
        --kb-radius: 14px;
        --kb-radius-sm: 10px;
        --kb-radius-lg: 20px;
        --kb-shadow: 0 4px 16px rgba(15,23,42,0.08);
        --kb-shadow-lg: 0 8px 32px rgba(15,23,42,0.12);
        --kb-trans: all 0.22s cubic-bezier(0.4,0,0.2,1);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    .kb-page {
        background: var(--kb-bg);
        min-height: 100vh;
        color: var(--kb-black);
        font-family: 'Nunito', 'Segoe UI', sans-serif;
        padding-bottom: 80px;
    }

        .kb-page::before {
            content: '';
            display: block;
            height: 4px;
            background: linear-gradient(90deg, #0f172a 0%, #d97706 50%, #1e40af 100%);
        }

    .kb-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 32px 16px;
    }

    /* ── Keyframes ── */
    @@keyframes kbFadeUp {
        0% {
            opacity: 0;
            transform: translateY(24px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes kbFloat {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-6px);
        }
    }

    @@keyframes kbPulseGlow {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(245,158,11,0.3);
        }

        50% {
            box-shadow: 0 0 20px 4px rgba(245,158,11,0.15);
        }
    }

    @@keyframes kbShimmer {
        0% {
            background-position: -200% center;
        }

        100% {
            background-position: 200% center;
        }
    }

    @@keyframes kbScaleIn {
        0% {
            transform: scale(0.92);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes kbBreathe {
        0%, 100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.03);
        }
    }

    /* ── Hero ── */
    .kb-hero {
        text-align: center;
        padding: 28px 0 40px;
        animation: kbFadeUp 0.6s ease both;
    }

    .kb-hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--kb-gold-bg);
        border: 1.5px solid var(--kb-gold-bd);
        border-radius: 100px;
        padding: 6px 20px;
        font-size: 0.68rem;
        font-weight: 900;
        letter-spacing: 0.18em;
        color: var(--kb-gold);
        text-transform: uppercase;
        margin-bottom: 18px;
        animation: kbFloat 3s ease-in-out infinite;
    }

    .kb-hero h1 {
        font-size: clamp(2.2rem, 5vw, 3.4rem);
        font-weight: 900;
        letter-spacing: 0.02em;
        color: var(--kb-black);
        line-height: 1.12;
        margin-bottom: 12px;
    }

        .kb-hero h1 .gold {
            color: var(--kb-gold);
        }

        .kb-hero h1 .blue {
            color: var(--kb-blue-lt);
        }

    .kb-hero p {
        color: var(--kb-muted);
        font-size: 1rem;
        max-width: 540px;
        margin: 0 auto;
        line-height: 1.7;
    }

    /* ── Mode Grid ── */
    .mode-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
        gap: 24px;
        margin: 36px 0 40px;
    }

    .mode-card {
        background: var(--kb-bg);
        border: 2px solid var(--kb-border);
        border-radius: var(--kb-radius-lg);
        padding: 36px 28px 32px;
        cursor: pointer;
        transition: var(--kb-trans);
        position: relative;
        overflow: hidden;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        min-height: 480px;
        animation: kbScaleIn 0.5s ease both;
    }

        .mode-card:nth-child(1) {
            animation-delay: 0.1s;
        }

        .mode-card:nth-child(2) {
            animation-delay: 0.2s;
        }

        .mode-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .mode-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 48px rgba(15,23,42,0.14);
        }

            .mode-card:hover::before {
                opacity: 1;
            }

        .mode-card.solo-card::before {
            background: linear-gradient(90deg, var(--kb-gold), var(--kb-gold-lt));
        }

        .mode-card.solo-card:hover {
            border-color: var(--kb-gold);
        }

            .mode-card.solo-card:hover .mode-icon {
                background: var(--kb-gold-bg);
                color: var(--kb-gold);
                animation: kbBreathe 2s ease-in-out infinite;
            }

        .mode-card.multi-card::before {
            background: linear-gradient(90deg, var(--kb-red-lt), var(--kb-gold));
        }

        .mode-card.multi-card:hover {
            border-color: var(--kb-red-lt);
        }

            .mode-card.multi-card:hover .mode-icon {
                background: var(--kb-red-bg);
                color: var(--kb-red-lt);
                animation: kbBreathe 2s ease-in-out infinite;
            }

    .mode-icon {
        width: 68px;
        height: 68px;
        border-radius: 18px;
        background: var(--kb-surface);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin-bottom: 20px;
        transition: var(--kb-trans);
        color: var(--kb-charcoal);
    }

    .mode-card h2 {
        font-size: 1.6rem;
        font-weight: 900;
        color: var(--kb-black);
        margin-bottom: 6px;
        letter-spacing: 0.01em;
    }

    .mode-card .mode-subtitle {
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--kb-faint);
        margin-bottom: 16px;
    }

    .mode-card .mode-desc {
        font-size: 0.9rem;
        color: var(--kb-dark);
        line-height: 1.7;
        margin-bottom: 20px;
        flex: 1;
    }

    .mode-features {
        list-style: none;
        padding: 0;
        margin: 0 0 16px;
    }

        .mode-features li {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            font-size: 0.82rem;
            color: var(--kb-dark);
            margin-bottom: 10px;
            line-height: 1.5;
        }

            .mode-features li .feat-icon {
                width: 22px;
                height: 22px;
                border-radius: 6px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 0.7rem;
                flex-shrink: 0;
                margin-top: 2px;
            }

    .solo-card .feat-icon {
        background: var(--kb-gold-bg);
        color: var(--kb-gold);
    }

    .multi-card .feat-icon {
        background: var(--kb-red-bg);
        color: var(--kb-red-lt);
    }

    /* ── Spell/Ability Info ── */
    .spell-section {
        background: var(--kb-surface);
        border: 1px solid var(--kb-border);
        border-radius: var(--kb-radius-sm);
        padding: 14px 16px;
        margin-bottom: 20px;
    }

        .spell-section .spell-title {
            font-size: 0.65rem;
            font-weight: 900;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--kb-faint);
            margin-bottom: 10px;
        }

    .spell-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 6px 0;
    }

        .spell-item + .spell-item {
            border-top: 1px solid var(--kb-border);
        }

    .spell-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .solo-card .spell-icon {
        background: var(--kb-gold-bg);
    }

    .multi-card .spell-icon {
        background: var(--kb-red-bg);
    }

    .spell-info {
        flex: 1;
    }

        .spell-info .spell-name {
            font-size: 0.8rem;
            font-weight: 800;
            color: var(--kb-charcoal);
        }

        .spell-info .spell-desc {
            font-size: 0.7rem;
            color: var(--kb-muted);
            line-height: 1.4;
        }

    /* ── CTA Buttons ── */
    .mode-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 28px;
        border-radius: 12px;
        font-weight: 900;
        font-size: 0.88rem;
        letter-spacing: 0.06em;
        border: none;
        cursor: pointer;
        transition: var(--kb-trans);
        text-decoration: none;
        width: 100%;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .mode-btn::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -60%;
            width: 30%;
            height: 200%;
            background: rgba(255,255,255,0.2);
            transform: rotate(30deg);
            transition: left 0.6s ease;
        }

        .mode-btn:hover::after {
            left: 140%;
        }

        .mode-btn.btn-gold {
            background: linear-gradient(135deg, var(--kb-gold), var(--kb-gold-lt));
            color: #fff;
            box-shadow: 0 6px 20px rgba(217,119,6,0.3);
        }

            .mode-btn.btn-gold:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 30px rgba(217,119,6,0.4);
            }

        .mode-btn.btn-red {
            background: linear-gradient(135deg, var(--kb-red-lt), var(--kb-gold));
            color: #fff;
            box-shadow: 0 6px 20px rgba(239,68,68,0.3);
        }

            .mode-btn.btn-red:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 30px rgba(239,68,68,0.4);
            }

    /* ── Info Banner ── */
    .info-banner {
        background: var(--kb-surface);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-lg);
        padding: 24px 28px;
        margin-top: 16px;
        display: flex;
        align-items: flex-start;
        gap: 16px;
        animation: kbFadeUp 0.6s ease 0.3s both;
    }

        .info-banner .info-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: var(--kb-blue-bg);
            border: 1px solid var(--kb-blue-bd);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .info-banner h3 {
            font-size: 1rem;
            font-weight: 900;
            color: var(--kb-black);
            margin-bottom: 6px;
        }

        .info-banner p {
            font-size: 0.85rem;
            color: var(--kb-muted);
            line-height: 1.6;
            margin: 0;
        }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        .mode-grid {
            grid-template-columns: 1fr;
            gap: 18px;
        }

        .mode-card {
            min-height: auto;
            padding: 28px 22px 26px;
        }

        .kb-hero {
            padding: 20px 0 28px;
        }

            .kb-hero h1 {
                font-size: 2rem;
            }

        .info-banner {
            flex-direction: column;
            padding: 20px;
        }
    }

    @@media (max-width: 480px) {
        .kb-wrapper {
            padding: 20px 12px;
        }

        .mode-card {
            padding: 22px 16px 22px;
        }

        .mode-icon {
            width: 56px;
            height: 56px;
            font-size: 1.6rem;
        }

        .mode-card h2 {
            font-size: 1.35rem;
        }
    }
</style>

<div class="kb-page">
    <div class="kb-wrapper">

        <!-- ═══ Hero ═══ -->
        <div class="kb-hero">
            <div class="kb-hero-badge">⚡ Game Arena</div>
            <h1>Choose Your <span class="gold">Path</span></h1>
            <p>Select a game mode to begin your training. Earn XP, build streaks, and master every kana character through immersive challenges.</p>
        </div>

        <!-- ═══ Mode Cards ═══ -->
        <div class="mode-grid">

            <!-- ── Solo Mode Card ── -->
            <div class="mode-card solo-card" onclick="SoundFX.play('click'); window.location.href='/KanaBlitz/Play'" tabindex="0" role="button" aria-label="Launch Solo Training">
                <div class="mode-icon">⚔️</div>
                <h2>Solo Training</h2>
                <div class="mode-subtitle">KanaBlitz · Single Player</div>
                <p class="mode-desc">
                    Sharpen your kana recognition at your own pace. Choose your difficulty and alphabet, then answer as many questions as you can. Build combos, beat your high score, and earn XP to level up your profile.
                </p>

                <ul class="mode-features">
                    <li>
                        <span class="feat-icon">🎯</span>
                        <span>4 Difficulty tiers — Easy, Normal, Hard, and Insanity — each with unique word pools drawn from your database.</span>
                    </li>
                    <li>
                        <span class="feat-icon">🔤</span>
                        <span>4 Alphabet modes — Hiragana, Katakana, Dakuten, and Mixed — covering the full kana syllabary.</span>
                    </li>
                    <li>
                        <span class="feat-icon">🔥</span>
                        <span>Combo Streak system — consecutive correct answers multiply your score up to 5×.</span>
                    </li>
                    <li>
                        <span class="feat-icon">⏱️</span>
                        <span>Timed rounds — faster answers earn bonus points, keeping you on your toes.</span>
                    </li>
                    <li>
                        <span class="feat-icon">📊</span>
                        <span>Progress tracking — accuracy stats, highest scores, and unlock tracking saved to your profile.</span>
                    </li>
                </ul>

                <div class="spell-section">
                    <div class="spell-title">Spells &amp; Abilities</div>
                    <div class="spell-item">
                        <div class="spell-icon">🔥</div>
                        <div class="spell-info">
                            <div class="spell-name">Combo Blaze</div>
                            <div class="spell-desc">Each consecutive correct answer increases your multiplier. Reach 5× for maximum points!</div>
                        </div>
                    </div>
                    <div class="spell-item">
                        <div class="spell-icon">⚡</div>
                        <div class="spell-info">
                            <div class="spell-name">Quick Draw</div>
                            <div class="spell-desc">Answer within the first 3 seconds for a time bonus. Speed is rewarded!</div>
                        </div>
                    </div>
                    <div class="spell-item">
                        <div class="spell-icon">🌟</div>
                        <div class="spell-info">
                            <div class="spell-name">Perfect Round</div>
                            <div class="spell-desc">Achieve 100% accuracy in a round for a massive XP bonus and unlock progress.</div>
                        </div>
                    </div>
                </div>

                <button class="mode-btn btn-gold" onclick="event.stopPropagation(); SoundFX.play('click'); window.location.href='/KanaBlitz/Play'">
                    ⚔️ Launch Solo Training
                </button>
            </div>

            <!-- ── Multiplayer / AI Battle Card ── -->
            <div class="mode-card multi-card" onclick="SoundFX.play('click'); window.location.href='/KanaBattle/MainView'" tabindex="0" role="button" aria-label="Launch AI Battle">
                <div class="mode-icon">🗡️</div>
                <h2>AI Battle Arena</h2>
                <div class="mode-subtitle">KanaBattle · vs AI Opponent</div>
                <p class="mode-desc">
                    Face off against an intelligent AI opponent in a head-to-head kana battle. Answer correctly to deal damage, answer fast for critical hits. Deplete the AI's health bar before it drains yours. Difficulty scales the AI's health, speed, and accuracy.
                </p>

                <ul class="mode-features">
                    <li>
                        <span class="feat-icon">🤖</span>
                        <span>Adaptive AI opponent — difficulty changes the AI's health pool, answering speed, and accuracy.</span>
                    </li>
                    <li>
                        <span class="feat-icon">❤️</span>
                        <span>Health-based combat — correct answers deal damage. First to zero HP loses the battle.</span>
                    </li>
                    <li>
                        <span class="feat-icon">💥</span>
                        <span>Critical hits — fast answers deal bonus damage. Combo streaks unlock devastating strikes.</span>
                    </li>
                    <li>
                        <span class="feat-icon">🛡️</span>
                        <span>Shield system — consecutive correct answers build a shield that reduces incoming damage.</span>
                    </li>
                    <li>
                        <span class="feat-icon">🏆</span>
                        <span>Victory rewards — defeat the AI to earn bonus XP and progress toward harder challenges.</span>
                    </li>
                </ul>

                <div class="spell-section">
                    <div class="spell-title">Spells &amp; Abilities</div>
                    <div class="spell-item">
                        <div class="spell-icon">⚡</div>
                        <div class="spell-info">
                            <div class="spell-name">Quick Slash</div>
                            <div class="spell-desc">Answer within 2 seconds to deal double damage. Strike fast and hard!</div>
                        </div>
                    </div>
                    <div class="spell-item">
                        <div class="spell-icon">🛡️</div>
                        <div class="spell-info">
                            <div class="spell-name">Perfect Guard</div>
                            <div class="spell-desc">3 consecutive correct answers activate a shield, reducing AI damage by 50%.</div>
                        </div>
                    </div>
                    <div class="spell-item">
                        <div class="spell-icon">💀</div>
                        <div class="spell-info">
                            <div class="spell-name">Execution Blow</div>
                            <div class="spell-desc">A 5× combo streak unleashes a devastating attack dealing triple damage!</div>
                        </div>
                    </div>
                </div>

                <button class="mode-btn btn-red" onclick="event.stopPropagation(); SoundFX.play('click'); window.location.href='/KanaBattle/MainView'">
                    🗡️ Enter AI Battle Arena
                </button>
            </div>

        </div>

        <!-- ═══ Info Banner ═══ -->
        <div class="info-banner">
            <div class="info-icon">💡</div>
            <div>
                <h3>About KanaBlitz &amp; KanaBattle</h3>
                <p>
                    KanaBlitz and KanaBattle are gamified learning modules within NipponQuest designed to make kana mastery engaging and effective.
                    Words and characters are drawn directly from the database, covering Hiragana, Katakana, and Dakuten across multiple difficulty tiers.
                    Your progress, accuracy stats, and unlock achievements are tracked and saved to your profile. Earn XP to level up and unlock harder challenges!
                </p>
            </div>
        </div>

    </div>
</div>

<script>
    /* ═══ SoundFX Engine (Web Audio API) ═══ */
    const SoundFX = {
        ctx: null,
        init() {
            try { this.ctx = new (window.AudioContext || window.webkitAudioContext)(); } catch(e) {}
        },
        play(type) {
            if (!this.ctx) { this.init(); }
            if (!this.ctx) return;
            if (this.ctx.state === 'suspended') this.ctx.resume();
            const now = this.ctx.currentTime;
            switch(type) {
                case 'click': {
                    const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                    o.connect(g); g.connect(this.ctx.destination);
                    o.frequency.setValueAtTime(800, now);
                    g.gain.setValueAtTime(0.08, now);
                    g.gain.linearRampToValueAtTime(0, now + 0.05);
                    o.start(now); o.stop(now + 0.05);
                    break;
                }
            }
        }
    };

    /* Keyboard accessibility for mode cards */
    document.querySelectorAll('.mode-card').forEach(card => {
        card.addEventListener('keydown', e => {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
        });
    });
</script>
