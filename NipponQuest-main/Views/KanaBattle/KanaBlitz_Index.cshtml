@section Scripts {
    <script>
        /* ══════════════════════════════════════════════════════════
           KanaBlitz Solo Arena — Full Game Engine
           API    : GET /KanaBlitz/GetWords?difficulty={d}&script={s}
           Expects: JSON array of { wordKana, wordRomaji, meaningEnglish,
                    missingKana, categoryTag, displayHtml }
        ══════════════════════════════════════════════════════════ */
        (function () {
            'use strict';

            /* ── Config ── */
            const CFG = {
                totalQuestions : 20,
                basePoints     : 100,
                comboThreshold : 3,
                diffTimers     : { easy: 30, normal: 25, hard: 20, insanity: 15 },
                diffMCThreshold: 'easy',   // easy uses MC buttons
                minWords       : { easy: 4, normal: 5, hard: 4, insanity: 4 },
                apiEndpoint    : '/KanaBlitz/GetWords'
            };

            /* ── State ── */
            const S = {
                words        : [],
                queue        : [],
                current      : null,
                qIndex       : 0,
                score        : 0,
                correct      : 0,
                incorrect    : 0,
                combo        : 0,
                bestCombo    : 0,
                timerSecs    : 30,
                timerInterval: null,
                timeBonus    : 0,
                difficulty   : 'normal',
                script       : 'hiragana',
                loading      : false,
                answered     : false
            };

            /* ── DOM Refs ── */
            const $ = id => document.getElementById(id);
            const $$ = sel => document.querySelectorAll(sel);

            const dom = {
                setupPanel    : $('setup-panel'),
                gameArena     : $('game-arena'),
                resultsPanel  : $('results-panel'),
                errorPanel    : $('error-panel'),
                errorMsg      : $('error-msg'),
                btnStart      : $('btn-start'),
                btnSubmit     : $('btn-submit'),
                btnPlayAgain  : $('btn-play-again'),
                btnBackSetup  : $('btn-back-setup'),
                answerInput   : $('answer-input'),
                kanaChar      : $('kana-char'),
                kanaCard      : $('kana-card'),
                kanaMeaning   : $('kana-meaning'),
                fillDisplay   : $('fill-display'),
                kanaMeta      : $('kana-meta'),
                feedbackFlash : $('feedback-flash'),
                hudScore      : $('hud-score'),
                hudCorrect    : $('hud-correct'),
                hudCombo      : $('hud-combo'),
                hudQ          : $('hud-q'),
                hudTime       : $('hud-time'),
                timerArc      : $('timer-arc'),
                streakVal     : $('streak-val'),
                streakBadge   : $('streak-badge'),
                progressFill  : $('progress-fill'),
                mcArea        : $('mc-area'),
                mcGrid        : $('mc-grid'),
                typeInputArea : $('type-input-area'),
                wordWarning   : $('word-warning'),
                warningTitle  : $('warning-title'),
                warningMsg    : $('warning-msg'),
                countdownOver : $('countdown-overlay'),
                countdownNum  : $('countdown-num'),
                resScore      : $('res-score'),
                resCorrect    : $('res-correct'),
                resTotal      : $('res-total'),
                resAccuracy   : $('res-accuracy'),
                resCombo      : $('res-combo'),
                resRank       : $('res-rank'),
                resultsKana   : $('results-kana'),
                resultsTitle  : $('results-title'),
                resultsSub    : $('results-subtitle'),
                pbBadge       : $('pb-badge'),
                toastContainer: $('toast-container')
            };

            /* ── Audio Hooks (expandable) ── */
            const Audio = {
                play(type) {
                    // Placeholder: wire up actual AudioContext tones or files here
                    // types: 'correct' | 'incorrect' | 'victory' | 'countdown' | 'click'
                }
            };

            /* ── Utilities ── */
            function shuffle(arr) {
                const a = [...arr];
                for (let i = a.length - 1; i > 0; i--) {
                    const j = Math.floor(Math.random() * (i + 1));
                    [a[i], a[j]] = [a[j], a[i]];
                }
                return a;
            }

            function normalise(str) {
                return (str || '').trim().toLowerCase()
                    .replace(/[āáàä]/g, 'a')
                    .replace(/[ūúùü]/g, 'u')
                    .replace(/[ōóòö]/g, 'o')
                    .replace(/[ēéèë]/g, 'e')
                    .replace(/[īíìï]/g, 'i')
                    .replace(/\s+/g, ' ');
            }

            function toast(msg, type = 'default') {
                const el = document.createElement('div');
                el.className = `toast ${type}`;
                el.textContent = msg;
                dom.toastContainer.appendChild(el);
                setTimeout(() => el.remove(), 3200);
            }

            function calcRank(accuracy, score) {
                if (accuracy >= 0.95 && score >= 1800) return 'S+';
                if (accuracy >= 0.90) return 'S';
                if (accuracy >= 0.80) return 'A';
                if (accuracy >= 0.65) return 'B';
                if (accuracy >= 0.50) return 'C';
                return 'D';
            }

            /* ── Word Count Loader ── */
            async function loadWordCounts() {
                const diffs = ['easy', 'normal', 'hard', 'insanity'];
                const script = S.script;
                const results = await Promise.allSettled(
                    diffs.map(d => fetch(`${CFG.apiEndpoint}?difficulty=${d}&script=${script}`)
                        .then(r => r.ok ? r.json() : Promise.reject(r.status)))
                );
                results.forEach((r, i) => {
                    const el = $(`cnt-${diffs[i]}`);
                    if (!el) return;
                    if (r.status === 'fulfilled') {
                        const cnt = Array.isArray(r.value) ? r.value.length : 0;
                        el.textContent = cnt > 0 ? `${cnt} words` : 'No words';
                        const card = el.closest('.choice-card');
                        if (card && cnt < CFG.minWords[diffs[i]]) {
                            card.title = 'Not enough words for this difficulty';
                            card.style.opacity = '0.5';
                            card.style.cursor = 'not-allowed';
                            card.setAttribute('aria-disabled', 'true');
                        }
                    } else {
                        el.textContent = 'Error';
                    }
                });
            }

            /* ── Selection Logic ── */
            function setupSelectionCards() {
                $$('.choice-card[data-type="script"]').forEach(card => {
                    card.addEventListener('click', () => selectCard(card, 'script'));
                    card.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectCard(card, 'script'); } });
                });
                $$('.choice-card[data-type="diff"]').forEach(card => {
                    card.addEventListener('click', () => selectCard(card, 'diff'));
                    card.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectCard(card, 'diff'); } });
                });
            }

            function selectCard(card, type) {
                if (card.getAttribute('aria-disabled') === 'true') return;
                const group = $$('.choice-card[data-type="' + type + '"]');
                group.forEach(c => { c.classList.remove('active'); c.setAttribute('aria-pressed', 'false'); });
                card.classList.add('active');
                card.setAttribute('aria-pressed', 'true');
                Audio.play('click');
                if (type === 'script') {
                    S.script = card.dataset.val;
                    loadWordCounts();
                } else {
                    S.difficulty = card.dataset.val;
                }
                validateStart();
            }

            function validateStart() {
                dom.wordWarning.classList.remove('visible');
                dom.btnStart.disabled = false;
            }

            /* ── Fetch Words ── */
            async function fetchWords() {
                S.loading = true;
                dom.btnStart.disabled = true;
                dom.btnStart.innerHTML = '<span class="loading-dots"><span></span><span></span><span></span></span>';
                dom.errorPanel.classList.remove('visible');

                try {
                    const url = `${CFG.apiEndpoint}?difficulty=${encodeURIComponent(S.difficulty)}&script=${encodeURIComponent(S.script)}`;
                    const resp = await fetch(url);
                    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
                    const data = await resp.json();
                    if (!Array.isArray(data)) throw new Error('Invalid response format');

                    if (data.length < CFG.minWords[S.difficulty]) {
                        dom.wordWarning.classList.add('visible');
                        dom.warningTitle.textContent = 'Not enough words';
                        dom.warningMsg.textContent = `Only ${data.length} words found for ${S.difficulty} / ${S.script}. Need at least ${CFG.minWords[S.difficulty]}.`;
                        dom.btnStart.disabled = true;
                        dom.btnStart.innerHTML = '⚠ Not Enough Words';
                        S.loading = false;
                        return null;
                    }

                    return data;
                } catch (err) {
                    console.error('[KanaBlitz] fetchWords error:', err);
                    dom.errorPanel.classList.add('visible');
                    dom.errorMsg.textContent = `Failed to load words: ${err.message}. Ensure the database is seeded and the server is running.`;
                    dom.btnStart.disabled = false;
                    dom.btnStart.innerHTML = '⚡ START TRAINING';
                    S.loading = false;
                    return null;
                }
            }

            /* ── Game Lifecycle ── */
            async function startGame() {
                const words = await fetchWords();
                if (!words) return;

                S.words     = words;
                S.queue     = shuffle(words).slice(0, CFG.totalQuestions);
                S.qIndex    = 0;
                S.score     = 0;
                S.correct   = 0;
                S.incorrect = 0;
                S.combo     = 0;
                S.bestCombo = 0;
                S.loading   = false;

                dom.btnStart.innerHTML = '⚡ START TRAINING';

                dom.setupPanel.style.display = 'none';
                dom.resultsPanel.style.display = 'none';
                dom.errorPanel.classList.remove('visible');

                await runCountdown();

                dom.gameArena.style.display = 'block';
                dom.gameArena.scrollIntoView({ behavior: 'smooth', block: 'start' });
                nextQuestion();
            }

            async function runCountdown() {
                return new Promise(resolve => {
                    dom.countdownOver.classList.add('visible');
                    let n = 3;
                    dom.countdownNum.textContent = n;
                    Audio.play('countdown');
                    const iv = setInterval(() => {
                        n--;
                        if (n <= 0) {
                            clearInterval(iv);
                            dom.countdownOver.classList.remove('visible');
                            resolve();
                        } else {
                            dom.countdownNum.textContent = n;
                            dom.countdownNum.style.animation = 'none';
                            requestAnimationFrame(() => {
                                requestAnimationFrame(() => {
                                    dom.countdownNum.style.animation = 'kbCountPulse 0.85s cubic-bezier(0.34,1.56,0.64,1)';
                                });
                            });
                            Audio.play('countdown');
                        }
                    }, 900);
                });
            }

            function nextQuestion() {
                if (S.qIndex >= S.queue.length) { endGame(); return; }

                S.current   = S.queue[S.qIndex];
                S.answered  = false;
                S.timerSecs = CFG.diffTimers[S.difficulty] ?? 25;
                clearInterval(S.timerInterval);

                dom.feedbackFlash.textContent = '';
                dom.feedbackFlash.className   = 'feedback-flash';
                dom.answerInput.value         = '';
                dom.answerInput.className     = '';
                dom.answerInput.disabled      = false;
                dom.btnSubmit.disabled        = false;

                const w = S.current;

                // Kana display
                dom.kanaChar.textContent = w.wordKana || '—';

                // Meaning hint (show for hard/insanity)
                dom.kanaMeaning.textContent = (S.difficulty === 'hard' || S.difficulty === 'insanity')
                    ? (w.meaningEnglish || '') : '';

                // Fill-blank for normal+
                if ((S.difficulty === 'normal' || S.difficulty === 'hard' || S.difficulty === 'insanity') && w.missingKana) {
                    const fillText = w.wordKana.replace(w.missingKana, '___');
                    dom.fillDisplay.innerHTML = buildFillHtml(w.wordKana, w.missingKana);
                } else {
                    dom.fillDisplay.textContent = '';
                }

                // Meta tags
                dom.kanaMeta.innerHTML = buildMetaHtml(w);

                // Animate card
                dom.kanaCard.style.animation = 'none';
                requestAnimationFrame(() => {
                    requestAnimationFrame(() => {
                        dom.kanaCard.style.animation = 'kbSlideIn 0.35s cubic-bezier(0.34,1.56,0.64,1)';
                    });
                });

                // Multiple choice for easy
                const useMC = S.difficulty === CFG.diffMCThreshold;
                dom.typeInputArea.style.display = useMC ? 'none' : 'block';
                dom.mcArea.style.display        = useMC ? 'block' : 'none';

                if (useMC) buildMCOptions(w);
                else { setTimeout(() => dom.answerInput.focus(), 80); }

                updateHUD();
                startTimer();
            }

            function buildFillHtml(word, missing) {
                if (!missing || !word.includes(missing)) return word;
                const idx  = word.indexOf(missing);
                const pre  = word.slice(0, idx);
                const post = word.slice(idx + missing.length);
                return `${pre}<span class="fill-blank">${missing}</span>${post}`;
            }

            function buildMetaHtml(w) {
                let html = '';
                if (w.categoryTag) html += `<span class="kana-tag">${escHtml(w.categoryTag)}</span>`;
                const diffLabels = { easy:'Easy', normal:'Normal', hard:'Hard', insanity:'Insanity' };
                if (diffLabels[S.difficulty]) {
                    const cls = S.difficulty === 'hard' ? 'gold' : (S.difficulty === 'easy' ? '' : 'blue');
                    html += `<span class="kana-tag ${cls}">${diffLabels[S.difficulty]}</span>`;
                }
                return html;
            }

            function buildMCOptions(current) {
                // Pick 3 distractors from words pool, avoiding the correct one
                const distractors = shuffle(S.words.filter(w => w.wordRomaji !== current.wordRomaji))
                    .slice(0, 3);
                const options = shuffle([current, ...distractors]);

                dom.mcGrid.innerHTML = '';
                options.forEach(opt => {
                    const btn = document.createElement('button');
                    btn.className = 'mc-btn';
                    btn.textContent = opt.wordRomaji.toUpperCase();
                    btn.setAttribute('aria-label', `Answer: ${opt.wordRomaji}`);
                    btn.addEventListener('click', () => handleMCAnswer(btn, opt, current));
                    dom.mcGrid.appendChild(btn);
                });
            }

            function handleMCAnswer(btn, chosen, correct) {
                if (S.answered) return;
                S.answered = true;
                clearInterval(S.timerInterval);
                const isCorrect = normalise(chosen.wordRomaji) === normalise(correct.wordRomaji);
                processFeedback(isCorrect, correct.wordRomaji);

                dom.mcGrid.querySelectorAll('.mc-btn').forEach(b => {
                    b.disabled = true;
                    if (normalise(b.textContent) === normalise(correct.wordRomaji).toUpperCase()) {
                        b.classList.add('correct');
                    } else if (b === btn && !isCorrect) {
                        b.classList.add('incorrect');
                    }
                });

                setTimeout(advanceQuestion, 1100);
            }

            /* ── Timer ── */
            function startTimer() {
                const totalSecs = S.timerSecs;
                const circumference = 169.6;
                updateTimerArc(1, circumference);

                S.timerInterval = setInterval(() => {
                    S.timerSecs--;
                    dom.hudTime.textContent = Math.max(0, S.timerSecs);
                    updateTimerArc(S.timerSecs / totalSecs, circumference);

                    if (S.timerSecs <= 5) dom.timerArc.style.stroke = '#ef4444';
                    else if (S.timerSecs <= 10) dom.timerArc.style.stroke = '#f59e0b';
                    else dom.timerArc.style.stroke = '#f59e0b';

                    if (S.timerSecs <= 0) {
                        clearInterval(S.timerInterval);
                        if (!S.answered) handleTimeout();
                    }
                }, 1000);
            }

            function updateTimerArc(fraction, circ) {
                const offset = circ * (1 - Math.max(0, fraction));
                dom.timerArc.style.strokeDashoffset = offset;
            }

            function handleTimeout() {
                S.answered = true;
                S.combo    = 0;
                S.incorrect++;
                dom.feedbackFlash.textContent = `⏱ Time's up! Answer: ${S.current.wordRomaji.toUpperCase()}`;
                dom.feedbackFlash.className   = 'feedback-flash incorrect';
                Audio.play('incorrect');
                updateStreak();
                updateHUD();
                setTimeout(advanceQuestion, 1400);
            }

            /* ── Answer Handling ── */
            function submitAnswer() {
                if (S.answered || !S.current) return;
                const val = dom.answerInput.value.trim();
                if (!val) return;

                S.answered = true;
                clearInterval(S.timerInterval);

                const isCorrect = normalise(val) === normalise(S.current.wordRomaji);
                processFeedback(isCorrect, S.current.wordRomaji);

                dom.answerInput.className = isCorrect ? 'correct' : 'incorrect';
                dom.answerInput.disabled  = true;
                dom.btnSubmit.disabled    = true;

                setTimeout(advanceQuestion, 1000);
            }

            function processFeedback(isCorrect, correctAnswer) {
                if (isCorrect) {
                    S.correct++;
                    S.combo++;
                    if (S.combo > S.bestCombo) S.bestCombo = S.combo;
                    const timeBonus  = Math.floor(S.timerSecs * 2);
                    const comboBonus = S.combo >= CFG.comboThreshold ? Math.floor(S.combo * 15) : 0;
                    S.score += CFG.basePoints + timeBonus + comboBonus;
                    dom.feedbackFlash.textContent = comboBonus > 0
                        ? `✓ Correct! +${CFG.basePoints + timeBonus} pts (+${comboBonus} combo!)`
                        : `✓ Correct! +${CFG.basePoints + timeBonus} pts`;
                    dom.feedbackFlash.className = 'feedback-flash correct';
                    dom.kanaCard.style.animation = 'kbCorrectPop 0.3s ease';
                    Audio.play('correct');
                } else {
                    S.combo    = 0;
                    S.incorrect++;
                    dom.feedbackFlash.textContent = `✗ Wrong — ${correctAnswer.toUpperCase()}`;
                    dom.feedbackFlash.className   = 'feedback-flash incorrect';
                    dom.kanaCard.style.animation  = 'kbShake 0.4s ease';
                    Audio.play('incorrect');
                }
                updateStreak();
                updateHUD();
            }

            function advanceQuestion() {
                S.qIndex++;
                nextQuestion();
            }

            /* ── HUD / Streak Updates ── */
            function updateHUD() {
                dom.hudScore.textContent   = S.score.toLocaleString();
                dom.hudCorrect.textContent = S.correct;
                dom.hudCombo.textContent   = S.combo;
                dom.hudQ.textContent       = `${S.qIndex + 1}/${S.queue.length}`;
                dom.hudTime.textContent    = Math.max(0, S.timerSecs);
                const pct = (S.qIndex / S.queue.length) * 100;
                dom.progressFill.style.width = `${Math.min(100, pct)}%`;
            }

            function updateStreak() {
                dom.streakVal.textContent = S.combo;
                if (S.combo >= CFG.comboThreshold) {
                    dom.streakBadge.textContent = `${S.combo}× COMBO!`;
                    dom.streakBadge.classList.add('visible');
                } else {
                    dom.streakBadge.classList.remove('visible');
                }
            }

            /* ── End Game ── */
            function endGame() {
                clearInterval(S.timerInterval);
                dom.gameArena.style.display = 'none';
                dom.progressFill.style.width = '100%';

                const total    = S.correct + S.incorrect;
                const accuracy = total > 0 ? S.correct / total : 0;
                const rank     = calcRank(accuracy, S.score);
                const perfect  = accuracy >= 1.0;

                dom.resultsKana.textContent    = perfect ? '🏆' : (accuracy >= 0.7 ? '⚔️' : '📖');
                dom.resultsTitle.textContent   = perfect ? 'Perfect Run!' : (accuracy >= 0.7 ? 'Great Work!' : 'Keep Practising!');
                dom.resultsSub.textContent     = `${S.difficulty.charAt(0).toUpperCase() + S.difficulty.slice(1)} · ${S.script.charAt(0).toUpperCase() + S.script.slice(1)}`;
                dom.resScore.textContent       = S.score.toLocaleString();
                dom.resCorrect.textContent     = S.correct;
                dom.resTotal.textContent       = total;
                dom.resAccuracy.textContent    = `${Math.round(accuracy * 100)}%`;
                dom.resCombo.textContent       = S.bestCombo;
                dom.resRank.textContent        = rank;
                dom.resRank.style.color        = rank === 'S+' || rank === 'S' ? '#d97706' : '';
                dom.pbBadge.classList.remove('visible');

                dom.resultsPanel.style.display = 'block';
                dom.resultsPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });

                Audio.play('victory');

                // Save personal best via API if endpoint exists
                savePersonalBest(accuracy);
            }

            async function savePersonalBest(accuracy) {
                try {
                    const payload = {
                        difficulty  : S.difficulty,
                        alphabet    : S.script,
                        bestCorrect : S.correct,
                        bestPoints  : S.score,
                        bestCombo   : S.bestCombo,
                        bestAccuracy: accuracy
                    };
                    const resp = await fetch('/KanaBlitz/SavePersonalBest', {
                        method : 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
                        body   : JSON.stringify(payload)
                    });
                    if (resp.ok) {
                        const data = await resp.json();
                        if (data && data.isNewBest) {
                            dom.pbBadge.classList.add('visible');
                            toast('🏅 New Personal Best!', 'success');
                        }
                    }
                } catch (e) {
                    // Non-critical — silently fail
                    console.warn('[KanaBlitz] savePersonalBest failed:', e);
                }
            }

            function getAntiForgeryToken() {
                const el = document.querySelector('input[name="__RequestVerificationToken"]');
                return el ? el.value : '';
            }

            /* ── Keyboard Navigation ── */
            document.addEventListener('keydown', e => {
                if (e.key === 'Enter' && !S.answered && dom.gameArena.style.display !== 'none') {
                    if (dom.typeInputArea.style.display !== 'none') submitAnswer();
                }
            });

            /* ── Button Wiring ── */
            dom.btnStart.addEventListener('click', () => {
                Audio.play('click');
                startGame();
            });

            dom.btnSubmit.addEventListener('click', () => {
                Audio.play('click');
                submitAnswer();
            });

            dom.btnPlayAgain.addEventListener('click', () => {
                dom.resultsPanel.style.display = 'none';
                dom.gameArena.style.display = 'none';
                dom.setupPanel.style.display = 'block';
                dom.btnStart.disabled = false;
                dom.btnStart.innerHTML = '⚡ START TRAINING';
                validateStart();
                Audio.play('click');
            });

            dom.btnBackSetup.addEventListener('click', () => {
                clearInterval(S.timerInterval);
                dom.resultsPanel.style.display = 'none';
                dom.gameArena.style.display    = 'none';
                dom.setupPanel.style.display   = 'block';
                dom.btnStart.disabled = false;
                dom.btnStart.innerHTML = '⚡ START TRAINING';
                Audio.play('click');
            });

            /* ── HTML Escape ── */
            function escHtml(str) {
                return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
            }

            /* ── Init ── */
            setupSelectionCards();
            loadWordCounts();

        })();
    </script>
}
