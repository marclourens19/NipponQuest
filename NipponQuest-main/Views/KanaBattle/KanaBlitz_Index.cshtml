@*
    ╔══════════════════════════════════════════════════════════════════╗
    ║  KanaBlitz_Index.cshtml  —  Mode Selection Hub                 ║
    ║  Controller : KanaBlitzController → Index()                     ║
    ║  Also used  : KanaBattleController → Index()                    ║
    ║  Route      : /KanaBlitz  |  /KanaBattle/Index                  ║
    ║  Purpose    : Solo / Multiplayer mode picker with full info     ║
    ║  Aesthetic  : White background · Black / Gold / White / Blue    ║
    ╚══════════════════════════════════════════════════════════════════╝
*@
@{
    ViewData["Title"] = "KanaBlitz — Choose Your Path";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');

    :root {
        --kb-bg: #ffffff;
        --kb-surface: #f8fafc;
        --kb-surface2: #f1f5f9;
        --kb-border: #e2e8f0;
        --kb-border2: #cbd5e1;
        --kb-black: #0f172a;
        --kb-charcoal: #1e293b;
        --kb-dark: #334155;
        --kb-muted: #64748b;
        --kb-faint: #94a3b8;
        --kb-gold: #d97706;
        --kb-gold-lt: #f59e0b;
        --kb-gold-bg: #fef3c7;
        --kb-gold-bd: #fcd34d;
        --kb-blue: #1e40af;
        --kb-blue-lt: #3b82f6;
        --kb-blue-bg: #eff6ff;
        --kb-blue-bd: #93c5fd;
        --kb-green: #065f46;
        --kb-green-lt: #10b981;
        --kb-green-bg: #ecfdf5;
        --kb-red: #991b1b;
        --kb-red-lt: #ef4444;
        --kb-red-bg: #fff1f2;
        --kb-red-bd: #fca5a5;
        --kb-radius: 14px;
        --kb-radius-sm: 10px;
        --kb-radius-lg: 20px;
        --kb-shadow: 0 4px 16px rgba(15,23,42,0.08);
        --kb-shadow-lg: 0 8px 32px rgba(15,23,42,0.12);
        --kb-trans: all 0.22s cubic-bezier(0.4,0,0.2,1);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    .kb-page {
        background: var(--kb-bg);
        min-height: 100vh;
        color: var(--kb-black);
        font-family: 'Nunito', 'Segoe UI', sans-serif;
        padding-bottom: 80px;
    }

        .kb-page::before {
            content: '';
            display: block;
            height: 4px;
            background: linear-gradient(90deg, #0f172a 0%, #d97706 50%, #1e40af 100%);
        }

    .kb-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 32px 16px;
    }

    /* ══ Keyframes ══ */
    @@keyframes kbFadeUp {
        0% {
            opacity: 0;
            transform: translateY(24px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes kbFloat {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-6px);
        }
    }

    @@keyframes kbPulseGold {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(217,119,6,0.25);
        }

        50% {
            box-shadow: 0 0 0 12px rgba(217,119,6,0);
        }
    }

    @@keyframes kbPulseBlue {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(30,64,175,0.25);
        }

        50% {
            box-shadow: 0 0 0 12px rgba(30,64,175,0);
        }
    }

    @@keyframes kbShimmer {
        0% {
            background-position: -200% center;
        }

        100% {
            background-position: 200% center;
        }
    }

    @@keyframes kbScaleIn {
        0% {
            transform: scale(0.92);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes kbBreathe {
        0%, 100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.04);
        }
    }

    @@keyframes kbParticleDrift {
        0% {
            opacity: 0;
            transform: translateY(10px) rotate(0deg);
        }

        20% {
            opacity: 1;
        }

        80% {
            opacity: 0.6;
        }

        100% {
            opacity: 0;
            transform: translateY(-60px) rotate(180deg);
        }
    }

    @@keyframes kbGlowPulse {
        0%, 100% {
            opacity: 0.4;
        }

        50% {
            opacity: 1;
        }
    }

    /* ══ Hero ══ */
    .kb-hero {
        text-align: center;
        padding: 32px 0 44px;
        animation: kbFadeUp 0.6s ease both;
        position: relative;
    }

    .kb-hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--kb-gold-bg);
        border: 1.5px solid var(--kb-gold-bd);
        border-radius: 100px;
        padding: 6px 22px;
        font-size: 0.68rem;
        font-weight: 900;
        letter-spacing: 0.18em;
        color: var(--kb-gold);
        text-transform: uppercase;
        margin-bottom: 20px;
        animation: kbFloat 3s ease-in-out infinite;
    }

    .kb-hero h1 {
        font-size: clamp(2.2rem, 5vw, 3.4rem);
        font-weight: 900;
        letter-spacing: 0.02em;
        color: var(--kb-black);
        line-height: 1.12;
        margin-bottom: 14px;
    }

        .kb-hero h1 .gold {
            color: var(--kb-gold);
        }

        .kb-hero h1 .blue {
            color: var(--kb-blue-lt);
        }

    .kb-hero-sub {
        color: var(--kb-muted);
        font-size: 1.02rem;
        max-width: 560px;
        margin: 0 auto 28px;
        line-height: 1.72;
    }

    .kb-hero-stats {
        display: flex;
        justify-content: center;
        gap: 20px;
        flex-wrap: wrap;
        margin-top: 8px;
    }

    .kb-hero-stat {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--kb-muted);
        background: var(--kb-surface);
        border: 1px solid var(--kb-border);
        border-radius: 100px;
        padding: 5px 14px;
    }

        .kb-hero-stat .stat-icon {
            font-size: 1rem;
        }

    /* ══ Mode Grid ══ */
    .mode-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
        gap: 28px;
        margin: 20px 0 48px;
    }

    .mode-card {
        background: var(--kb-bg);
        border: 2px solid var(--kb-border);
        border-radius: var(--kb-radius-lg);
        padding: 36px 30px 32px;
        cursor: pointer;
        transition: var(--kb-trans);
        position: relative;
        overflow: hidden;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        min-height: 560px;
        animation: kbScaleIn 0.5s ease both;
    }

        .mode-card:nth-child(1) {
            animation-delay: 0.08s;
        }

        .mode-card:nth-child(2) {
            animation-delay: 0.18s;
        }

        .mode-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .mode-card::after {
            content: '';
            position: absolute;
            inset: 0;
            opacity: 0;
            transition: opacity 0.4s ease;
            pointer-events: none;
            border-radius: var(--kb-radius-lg);
        }

        .mode-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 56px rgba(15,23,42,0.14);
        }

            .mode-card:hover::before {
                opacity: 1;
            }

            .mode-card:hover::after {
                opacity: 1;
            }

    /* Solo Card */
    .solo-card::before {
        background: linear-gradient(90deg, var(--kb-gold), var(--kb-gold-lt), var(--kb-gold));
    }

    .solo-card::after {
        background: radial-gradient(ellipse at top, rgba(217,119,6,0.04) 0%, transparent 70%);
    }

    .solo-card:hover {
        border-color: var(--kb-gold);
        animation: kbPulseGold 2s ease-in-out infinite;
    }

        .solo-card:hover .mode-icon {
            background: var(--kb-gold-bg);
            color: var(--kb-gold);
            animation: kbBreathe 1.8s ease-in-out infinite;
        }

    /* Multi Card */
    .multi-card::before {
        background: linear-gradient(90deg, var(--kb-red-lt), var(--kb-gold), var(--kb-blue-lt));
    }

    .multi-card::after {
        background: radial-gradient(ellipse at top, rgba(239,68,68,0.04) 0%, transparent 70%);
    }

    .multi-card:hover {
        border-color: var(--kb-red-lt);
        animation: kbPulseBlue 2s ease-in-out infinite;
    }

        .multi-card:hover .mode-icon {
            background: var(--kb-red-bg);
            color: var(--kb-red-lt);
            animation: kbBreathe 1.8s ease-in-out infinite;
        }

    .mode-icon {
        width: 72px;
        height: 72px;
        border-radius: 20px;
        background: var(--kb-surface);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.1rem;
        margin-bottom: 22px;
        transition: var(--kb-trans);
        color: var(--kb-charcoal);
        border: 1.5px solid var(--kb-border);
    }

    .mode-label {
        font-size: 0.68rem;
        font-weight: 900;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--kb-faint);
        margin-bottom: 6px;
    }

    .mode-card h2 {
        font-size: 1.75rem;
        font-weight: 900;
        color: var(--kb-black);
        margin-bottom: 6px;
        letter-spacing: 0.01em;
    }

    .mode-card .mode-tagline {
        font-size: 0.88rem;
        color: var(--kb-muted);
        font-weight: 700;
        margin-bottom: 18px;
        font-style: italic;
    }

    .mode-card .mode-desc {
        font-size: 0.91rem;
        color: var(--kb-dark);
        line-height: 1.75;
        margin-bottom: 22px;
        flex: 1;
    }

    /* Feature pills */
    .mode-features {
        list-style: none;
        padding: 0;
        margin: 0 0 22px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .mode-features li {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            font-size: 0.84rem;
            color: var(--kb-dark);
            font-weight: 600;
            line-height: 1.5;
        }

            .mode-features li .feat-icon {
                font-size: 1rem;
                flex-shrink: 0;
                margin-top: 1px;
            }

    /* Difficulty badges */
    .diff-badges {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-bottom: 24px;
    }

    .diff-badge {
        padding: 4px 12px;
        border-radius: 100px;
        font-size: 0.66rem;
        font-weight: 900;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        border: 1.5px solid transparent;
    }

        .diff-badge.easy {
            background: #ecfdf5;
            color: #065f46;
            border-color: #6ee7b7;
        }

        .diff-badge.normal {
            background: #eff6ff;
            color: #1e40af;
            border-color: #93c5fd;
        }

        .diff-badge.hard {
            background: #fef3c7;
            color: #d97706;
            border-color: #fcd34d;
        }

        .diff-badge.insanity {
            background: #fff1f2;
            color: #991b1b;
            border-color: #fca5a5;
        }

    /* CTA Buttons */
    .mode-cta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 14px 24px;
        border-radius: var(--kb-radius);
        font-size: 0.94rem;
        font-weight: 900;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        text-decoration: none;
        transition: var(--kb-trans);
        border: none;
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

        .mode-cta::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -60%;
            width: 30%;
            height: 200%;
            background: rgba(255,255,255,0.25);
            transform: rotate(30deg);
            transition: left 0.4s ease;
        }

        .mode-cta:hover::after {
            left: 130%;
        }

    .cta-solo {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        color: #fff;
        box-shadow: 0 6px 20px rgba(15,23,42,0.25);
    }

        .cta-solo:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(15,23,42,0.32);
            color: #fff;
        }

    .cta-multi {
        background: linear-gradient(135deg, #991b1b 0%, #dc2626 100%);
        color: #fff;
        box-shadow: 0 6px 20px rgba(153,27,27,0.3);
    }

        .cta-multi:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(153,27,27,0.4);
            color: #fff;
        }

    /* ══ Combo / Mechanic Info Section ══ */
    .kb-section-title {
        font-size: 1.25rem;
        font-weight: 900;
        color: var(--kb-black);
        margin-bottom: 6px;
        letter-spacing: 0.02em;
    }

    .kb-section-sub {
        font-size: 0.88rem;
        color: var(--kb-muted);
        margin-bottom: 20px;
    }

    .mechanic-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
        margin-bottom: 48px;
        animation: kbFadeUp 0.7s ease 0.3s both;
    }

    .mechanic-card {
        background: var(--kb-surface);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius);
        padding: 20px 18px;
        transition: var(--kb-trans);
    }

        .mechanic-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--kb-shadow);
            border-color: var(--kb-border2);
        }

    .mechanic-icon {
        font-size: 1.6rem;
        margin-bottom: 10px;
    }

    .mechanic-card h4 {
        font-size: 0.88rem;
        font-weight: 900;
        color: var(--kb-black);
        margin-bottom: 5px;
        letter-spacing: 0.02em;
    }

    .mechanic-card p {
        font-size: 0.8rem;
        color: var(--kb-muted);
        line-height: 1.6;
        margin: 0;
    }

    /* ══ Difficulty Section ══ */
    .diff-section {
        background: var(--kb-surface);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-lg);
        padding: 28px;
        margin-bottom: 48px;
        animation: kbFadeUp 0.7s ease 0.4s both;
    }

    .diff-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 14px;
        margin-top: 18px;
    }

    .diff-info-card {
        background: var(--kb-bg);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius);
        padding: 16px;
        transition: var(--kb-trans);
    }

        .diff-info-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--kb-shadow);
        }

        .diff-info-card .diff-name {
            font-size: 0.78rem;
            font-weight: 900;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

    .diff-easy .diff-name {
        color: var(--kb-green);
    }

    .diff-normal .diff-name {
        color: var(--kb-blue);
    }

    .diff-hard .diff-name {
        color: var(--kb-gold);
    }

    .diff-insanity .diff-name {
        color: var(--kb-red);
    }

    .diff-info-card p {
        font-size: 0.78rem;
        color: var(--kb-muted);
        line-height: 1.6;
        margin: 0;
    }

    /* ══ Kana Alphabet Scrollbar ══ */
    .kana-scroll-row {
        display: flex;
        gap: 10px;
        overflow-x: auto;
        padding: 8px 0 14px;
        margin-bottom: 48px;
        animation: kbFadeUp 0.7s ease 0.5s both;
        scrollbar-width: thin;
        scrollbar-color: var(--kb-border2) transparent;
    }

        .kana-scroll-row::-webkit-scrollbar {
            height: 4px;
        }

        .kana-scroll-row::-webkit-scrollbar-track {
            background: transparent;
        }

        .kana-scroll-row::-webkit-scrollbar-thumb {
            background: var(--kb-border2);
            border-radius: 10px;
        }

    .kana-chip {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        padding: 10px 14px;
        background: var(--kb-surface);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-sm);
        font-size: 1.4rem;
        color: var(--kb-black);
        flex-shrink: 0;
        transition: var(--kb-trans);
        cursor: default;
    }

        .kana-chip span {
            font-size: 0.62rem;
            font-weight: 800;
            color: var(--kb-muted);
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        .kana-chip:hover {
            border-color: var(--kb-gold-bd);
            background: var(--kb-gold-bg);
            transform: translateY(-2px);
        }

    /* ══ Spell / Combo Section ══ */
    .spell-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 16px;
        margin-bottom: 48px;
        animation: kbFadeUp 0.7s ease 0.35s both;
    }

    .spell-card {
        background: var(--kb-bg);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius);
        padding: 20px;
        transition: var(--kb-trans);
        position: relative;
        overflow: hidden;
    }

        .spell-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
        }

        .spell-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--kb-shadow-lg);
        }

        .spell-card.combo::before {
            background: linear-gradient(90deg, #d97706, #f59e0b);
        }

        .spell-card.streak::before {
            background: linear-gradient(90deg, #1e40af, #3b82f6);
        }

        .spell-card.burst::before {
            background: linear-gradient(90deg, #991b1b, #ef4444);
        }

        .spell-card.perfect::before {
            background: linear-gradient(90deg, #065f46, #10b981);
        }

        .spell-card h4 {
            font-size: 0.92rem;
            font-weight: 900;
            color: var(--kb-black);
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .spell-card p {
            font-size: 0.8rem;
            color: var(--kb-muted);
            line-height: 1.65;
            margin: 0;
        }

    /* ══ Floating Particles ══ */
    .kb-particles {
        position: fixed;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        z-index: 0;
    }

    .kb-particle {
        position: absolute;
        font-size: 1.4rem;
        opacity: 0;
        animation: kbParticleDrift 6s ease-in-out infinite;
    }

    /* ══ Responsive ══ */
    @@media (max-width: 768px) {
        .mode-grid {
            grid-template-columns: 1fr;
        }

        .mode-card {
            min-height: auto;
        }

        .kb-hero h1 {
            font-size: 2rem;
        }

        .mechanic-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .diff-row {
            grid-template-columns: repeat(2, 1fr);
        }

        .spell-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 480px) {
        .kb-wrapper {
            padding: 20px 12px;
        }

        .mechanic-grid {
            grid-template-columns: 1fr;
        }

        .diff-row {
            grid-template-columns: 1fr;
        }

        .kb-hero-stats {
            gap: 10px;
        }
    }
</style>

<div class="kb-page">

    <!-- Floating particles (kana characters) -->
    <div class="kb-particles" aria-hidden="true" id="kb-particles"></div>

    <div class="kb-wrapper" style="position:relative; z-index:1;">

        <!-- ══ Hero ══ -->
        <section class="kb-hero">
            <div class="kb-hero-badge">
                ⚔️ <span>NipponQuest · KanaBlitz</span>
            </div>
            <h1>Master the <span class="gold">Kana</span><br>Conquer the <span class="blue">Arena</span></h1>
            <p class="kb-hero-sub">
                A fast-paced Japanese kana recognition game. Race the clock, build combos,
                defeat AI opponents, and level up your reading speed — one character at a time.
            </p>
            <div class="kb-hero-stats">
                <div class="kb-hero-stat"><span class="stat-icon">📚</span> 500+ Words</div>
                <div class="kb-hero-stat"><span class="stat-icon">🎌</span> Hiragana · Katakana · Kanji</div>
                <div class="kb-hero-stat"><span class="stat-icon">🤖</span> AI Opponent</div>
                <div class="kb-hero-stat"><span class="stat-icon">🏆</span> Score &amp; XP System</div>
            </div>
        </section>

        <!-- ══ Mode Selection Cards ══ -->
        <section aria-label="Game mode selection">
            <div class="mode-grid">

                <!-- SOLO CARD -->
                <a href="/KanaBlitz/Play" class="mode-card solo-card" id="solo-mode-card" aria-label="Start Solo Mode">
                    <div class="mode-label">Solo Training</div>
                    <div class="mode-icon" aria-hidden="true">🏋️</div>
                    <h2>Solo Mode</h2>
                    <div class="mode-tagline">"Train alone. Master everything."</div>
                    <p class="mode-desc">
                        Face kana characters and words at your own pace. Type the correct rōmaji reading
                        before time runs out. Unlock harder difficulty tiers as your accuracy climbs.
                        Build unstoppable combos. Beat your own high scores.
                    </p>

                    <ul class="mode-features" aria-label="Solo mode features">
                        <li><span class="feat-icon">⌨️</span> Type rōmaji to match displayed kana</li>
                        <li><span class="feat-icon">⏱️</span> Countdown timer — type fast or lose points</li>
                        <li><span class="feat-icon">🔥</span> Combo streaks multiply your score</li>
