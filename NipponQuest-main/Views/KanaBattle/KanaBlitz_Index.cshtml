</div><!-- /kb-wrapper -->

<script>
    // ══════════════════════════════════════════════════════════════
    //  KanaBlitz Solo — pulls words from KanaBlitzController.GetWords
    //  Endpoint: GET /KanaBlitz/GetWords?difficulty=&alphabet=
    // ══════════════════════════════════════════════════════════════

    // ── selection state ──
    let selectedScript = 'hiragana';
    let selectedDiff   = 'normal';

    // ── game state ──
    let wordPool    = [];
    let current     = null;
    let score       = 0;
    let lives       = 3;
    let streak      = 0;
    let maxStreak   = 0;
    let correct     = 0;
    let wrong       = 0;
    let timerSecs   = 90;
    let timerHandle = null;
    let answered    = false;
    let gameActive  = false;

    // ── time map (matches DbInitializer difficulty levels) ──
    const TIMES = { easy: 120, normal: 90, hard: 60, insanity: 45 };

    // ── selector logic ──
    document.querySelectorAll('#script-grid .choice-card').forEach(card => {
        card.addEventListener('click', () => {
            document.querySelectorAll('#script-grid .choice-card').forEach(c => c.classList.remove('active'));
            card.classList.add('active');
            selectedScript = card.dataset.val;
        });
    });
    document.querySelectorAll('#diff-grid .choice-card').forEach(card => {
        card.addEventListener('click', () => {
            document.querySelectorAll('#diff-grid .choice-card').forEach(c => c.classList.remove('active'));
            card.classList.add('active');
            selectedDiff = card.dataset.val;
        });
    });

    document.getElementById('btn-start').addEventListener('click', startGame);

    // ── fetch words from KanaBlitzController ──
    // Route: /KanaBlitz/GetWords?difficulty={diff}&alphabet={script}
    async function fetchWords(diff, alphabet) {
        try {
            const url = `/KanaBlitz/GetWords?difficulty=${encodeURIComponent(diff)}&alphabet=${encodeURIComponent(alphabet)}`;
            const res = await fetch(url);
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const data = await res.json();
            return data; // array of { wordKana, wordRomaji, meaningEnglish, alphabet, difficultyLevel, missingKana, categoryTag }
        } catch (e) {
            console.error('GetWords failed:', e);
            return [];
        }
    }

    // ── start game ──
    async function startGame() {
        // Show loading state
        document.getElementById('btn-start').textContent = '⏳ Loading words…';
        document.getElementById('btn-start').disabled = true;

        // Fetch from KanaBlitzController.GetWords — passes difficulty + alphabet matching DbInitializer values
        wordPool = await fetchWords(selectedDiff, selectedScript);

        if (wordPool.length < 4) {
            alert('Not enough words loaded for this combination. Try a different script or difficulty.');
            document.getElementById('btn-start').textContent = '⚡ Start KanaBlitz!';
            document.getElementById('btn-start').disabled = false;
            return;
        }

        // Shuffle pool
        wordPool = shuffle(wordPool);

        // Reset state
        score     = 0;
        lives     = 3;
        streak    = 0;
        maxStreak = 0;
        correct   = 0;
        wrong     = 0;
        timerSecs = TIMES[selectedDiff] ?? 90;
        gameActive = true;

        // UI swap
        document.getElementById('setup-panel').style.display = 'none';
        document.getElementById('arena').style.display = 'block';
        document.getElementById('hud-label').textContent =
            capitalize(selectedDiff) + ' · ' + capitalize(selectedScript);

        updateHUD();
        nextQuestion();
        startTimer();

        document.getElementById('btn-start').textContent = '⚡ Start KanaBlitz!';
        document.getElementById('btn-start').disabled = false;
    }

    // ── timer ──
    function startTimer() {
        clearInterval(timerHandle);
        timerHandle = setInterval(() => {
            if (!gameActive) { clearInterval(timerHandle); return; }
            timerSecs--;
            updateTimerDisplay();
            if (timerSecs <= 0) endGame('time');
        }, 1000);
    }

    function updateTimerDisplay() {
        const m = Math.floor(timerSecs / 60);
        const s = timerSecs % 60;
        document.getElementById('hud-timer').textContent =
            String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
        document.getElementById('hud-timer').style.color =
            timerSecs <= 10 ? '#ef4444' : '#f59e0b';
    }

    // ── question logic ──
    function nextQuestion() {
        if (!gameActive) return;
        answered = false;
        clearOptClasses();
        document.getElementById('feedback').textContent = '\u00a0';

        if (wordPool.length === 0) {
            endGame('cleared');
            return;
        }

        current = wordPool.pop();

        // Display kana word
        document.getElementById('q-kana').textContent    = current.wordKana   ?? '?';
        document.getElementById('q-romaji').textContent  = '';               // revealed on answer
        document.getElementById('q-meaning').textContent = '';               // revealed on answer
        document.getElementById('q-cat').textContent     =
            current.categoryTag ? '📂 ' + current.categoryTag : '';

        // Build 4 options: 1 correct + 3 distractors
        // Correct answer = wordRomaji (matches DbInitializer WordRomaji field)
        const correctRomaji = (current.wordRomaji ?? '').toUpperCase();
        const distractors   = getDistractors(current, 3);
        const options       = shuffle([correctRomaji, ...distractors]);

        const btns = document.querySelectorAll('.opt-btn');
        options.forEach((opt, i) => {
            btns[i].textContent = opt;
            btns[i].dataset.romaji = opt;
            btns[i].onclick = () => handleAnswer(opt, correctRomaji, btns[i]);
        });
    }

    // get 3 distractor romaji values from the pool (different word, same difficulty)
    function getDistractors(excludeWord, count) {
        const pool = wordPool
            .filter(w => (w.wordRomaji ?? '').toUpperCase() !== (excludeWord.wordRomaji ?? '').toUpperCase())
            .map(w => (w.wordRomaji ?? '').toUpperCase());
        const unique = [...new Set(pool)];
        shuffle(unique);
        return unique.slice(0, count).length >= count
            ? unique.slice(0, count)
            : padDistractors(unique, count);
    }

    // fallback distractors from the full hiragana set in case pool is too small
    const FALLBACK = ['KA','KI','KU','KE','KO','SA','SHI','SU','SE','SO','TA','CHI','TSU','TE','TO',
                      'NA','NI','NU','NE','NO','HA','HI','FU','HE','HO','MA','MI','MU','ME','MO'];
    function padDistractors(arr, count) {
        const extra = shuffle([...FALLBACK]).filter(r => !arr.includes(r));
        return [...arr, ...extra].slice(0, count);
    }

    // ── answer handler ──
    function handleAnswer(chosen, correct_romaji, btn) {
        if (answered || !gameActive) return;
        answered = true;

        const isCorrect = chosen === correct_romaji;

        // Reveal romaji + meaning after answer
        document.getElementById('q-romaji').textContent  = current.wordRomaji  ?? '';
        document.getElementById('q-meaning').textContent = current.meaningEnglish ?? '';

        if (isCorrect) {
            streak++;
            maxStreak = Math.max(maxStreak, streak);
            correct++;
            const bonus = streak * 10;
            score += 100 + bonus;
            btn.classList.add('correct');
            document.getElementById('feedback').textContent = `✅ Correct! +${100+bonus} pts (${streak > 1 ? streak+'x combo' : 'no combo'})`;
            document.getElementById('feedback').style.color = '#10b981';
        } else {
            streak = 0;
            wrong++;
            lives--;
            // Highlight correct answer green
            document.querySelectorAll('.opt-btn').forEach(b => {
                if (b.dataset.romaji === correct_romaji) b.classList.add('correct');
            });
            btn.classList.add('wrong');
            document.getElementById('feedback').textContent = `❌ Wrong! Answer was: ${correct_romaji}`;
            document.getElementById('feedback').style.color = '#ef4444';
            if (lives <= 0) {
                updateHUD();
                setTimeout(() => endGame('lives'), 600);
                return;
            }
        }

        updateHUD();
        setTimeout(nextQuestion, 1000);
    }

    // ── HUD update ──
    function updateHUD() {
        document.getElementById('hud-score').textContent = 'Score: ' + score;
        document.getElementById('hud-lives').textContent = '❤️'.repeat(Math.max(lives,0)) + '🖤'.repeat(Math.max(3-lives,0));
        document.getElementById('hud-combo').textContent = (streak >= 4 ? '🔥' : '⚡') + ' Combo: ' + streak + 'x';
    }

    // ── end game ──
    function endGame(reason) {
        gameActive = false;
        clearInterval(timerHandle);

        const total = correct + wrong;
        const acc   = total > 0 ? Math.round((correct/total)*100) : 0;

        document.getElementById('res-title').textContent =
            reason === 'cleared' ? '🏆 Arena Cleared!' :
            reason === 'time'    ? '⏰ Time\'s Up!'    : '💀 Game Over!';
        document.getElementById('res-correct').textContent = correct;
        document.getElementById('res-score').textContent   = score;
        document.getElementById('res-combo').textContent   = maxStreak + 'x';
        document.getElementById('res-acc').textContent     = acc + '%';
        document.getElementById('res-time').textContent    = timerSecs + 's';
        document.getElementById('res-wrong').textContent   = wrong;

        document.getElementById('result-overlay').classList.add('show');
    }

    // ── replay / back ──
    function replayGame() {
        document.getElementById('result-overlay').classList.remove('show');
        startGame();
    }
    function backToSetup() {
        document.getElementById('result-overlay').classList.remove('show');
        document.getElementById('arena').style.display        = 'none';
        document.getElementById('setup-panel').style.display  = 'block';
        clearInterval(timerHandle);
        gameActive = false;
    }

    // ── helpers ──
    function shuffle(arr) {
        for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
    }
    function clearOptClasses() {
        document.querySelectorAll('.opt-btn').forEach(b => {
            b.classList.remove('correct','wrong');
        });
    }
    function capitalize(str) {
        return str ? str.charAt(0).toUpperCase() + str.slice(1) : str;
    }
</script>
