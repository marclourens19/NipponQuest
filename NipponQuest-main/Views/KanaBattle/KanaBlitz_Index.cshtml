@using Microsoft.AspNetCore.Identity
@inject UserManager<NipponQuest.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = "KanaBlitz Arena";
    Layout = null;
    var currentUser = await UserManager.GetUserAsync(User);
    var isDev = currentUser?.GamerTag == "NQDev" ? "true" : "false";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>KanaBlitz Arena</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <style>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0
            }

            body {
                font-family: 'Nunito', sans-serif;
                background: #020617;
                color: #e2e8f0;
                min-height: 100vh;
                overflow-x: hidden
            }

            .container {
                max-width: 800px;
                margin: 0 auto;
                padding: 1.5rem 1rem;
                position: relative;
                z-index: 10
            }

            .nq-back-btn {
                position: fixed;
                top: 1.5rem;
                left: 1.5rem;
                z-index: 100;
                display: flex;
                align-items: center;
                gap: .4rem;
                padding: .4rem .8rem;
                border-radius: 999px;
                background: rgba(30,41,59,.8);
                border: 1px solid #334155;
                color: #94a3b8;
                font-size: .65rem;
                font-weight: 900;
                letter-spacing: 1px;
                text-transform: uppercase;
                text-decoration: none;
                backdrop-filter: blur(8px);
                transition: all .2s
            }

                .nq-back-btn:hover {
                    background: rgba(51,65,85,.8);
                    color: #e2e8f0;
                    transform: translateX(-3px)
                }

            .bg-layer {
                position: fixed;
                inset: 0;
                z-index: 0;
                pointer-events: none
            }

            .bg-aurora {
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg,#020617,#1e1b4b22,#020617);
                background-size: 200% 200%;
                animation: aurora 8s ease infinite
            }

            .bg-vignette {
                position: fixed;
                inset: 0;
                pointer-events: none;
                z-index: 1;
                box-shadow: inset 0 0 150px rgba(0,0,0,.6), inset 0 0 50px rgba(0,0,0,.3)
            }

            .bg-particle {
                position: absolute;
                border-radius: 50%;
                animation: particle-float linear infinite;
                opacity: 0
            }

            @@keyframes aurora {
                0% {
                    background-position: 0% 50%
                }

                50% {
                    background-position: 100% 50%
                }

                100% {
                    background-position: 0% 50%
                }
            }

            @@keyframes particle-float {
                0% {
                    transform: translateY(0);
                    opacity: 0
                }

                10% {
                    opacity: 1
                }

                90% {
                    opacity: 1
                }

                100% {
                    transform: translateY(-400px);
                    opacity: 0
                }
            }

            @@keyframes slide-up {
                0% {
                    opacity: 0;
                    transform: translateY(24px)
                }

                100% {
                    opacity: 1;
                    transform: translateY(0)
                }
            }

            @@keyframes shake {
                0%, 100% {
                    transform: translateX(0)
                }

                10% {
                    transform: translateX(-6px)
                }

                20% {
                    transform: translateX(6px)
                }

                30% {
                    transform: translateX(-4px)
                }

                40% {
                    transform: translateX(4px)
                }

                50% {
                    transform: translateX(-2px)
                }

                60% {
                    transform: translateX(2px)
                }
            }

            @@keyframes pulse {
                0%, 100% {
                    opacity: 1
                }

                50% {
                    opacity: .5
                }
            }

            @@keyframes combo-flash {
                0% {
                    transform: scale(1);
                    filter: brightness(1)
                }

                50% {
                    transform: scale(1.15);
                    filter: brightness(1.4)
                }

                100% {
                    transform: scale(1);
                    filter: brightness(1)
                }
            }

            @@keyframes pop-in {
                0% {
                    transform: scale(0.5);
                    opacity: 0
                }

                70% {
                    transform: scale(1.1)
                }

                100% {
                    transform: scale(1);
                    opacity: 1
                }
            }

            .anim-slide-up {
                animation: slide-up .5s ease both
            }

            .screen-flash {
                position: fixed;
                inset: 0;
                z-index: 50;
                pointer-events: none;
                transition: opacity .2s;
                opacity: 0
            }

                .screen-flash.show {
                    opacity: 1
                }

                .screen-flash.green {
                    background: radial-gradient(circle,rgba(16,185,129,.2),transparent 70%)
                }

                .screen-flash.red {
                    background: radial-gradient(circle,rgba(239,68,68,.2),transparent 70%)
                }

            /* ── TOP BAR ── */
            .top-bar {
                text-align: center;
                margin-bottom: 1.25rem;
                display: flex;
                justify-content: space-between;
                align-items: center
            }

            .top-bar-inner {
                display: inline-flex;
                align-items: center;
                gap: .5rem;
                font-size: .5rem;
                font-weight: 900;
                letter-spacing: .3em;
                text-transform: uppercase;
                color: #475569;
                margin: 0 auto
            }

            .top-bar-line {
                width: 48px;
                height: 1px;
                background: linear-gradient(90deg,transparent,rgba(56,189,248,.3),transparent)
            }

            .mp-btn {
                color: #fbbf24;
                font-size: .6rem;
                font-weight: 900;
                text-decoration: none;
                text-transform: uppercase;
                border: 1px solid #fbbf24;
                padding: .3rem .65rem;
                border-radius: 4px;
                transition: all .2s;
                display: inline-flex;
                align-items: center;
                gap: .25rem
            }

                .mp-btn:hover {
                    background: rgba(251,191,36,.1);
                    transform: translateY(-1px)
                }

            /* ── NAV TABS ── */
            .nav-tabs {
                display: flex;
                gap: .5rem;
                margin-bottom: 1.5rem;
                background: rgba(15,23,42,.6);
                border: 1px solid #1e293b;
                border-radius: .8rem;
                padding: .3rem
            }

            .nav-tab {
                flex: 1;
                padding: .5rem;
                border-radius: .6rem;
                border: none;
                background: transparent;
                color: #64748b;
                font-size: .6rem;
                font-weight: 900;
                letter-spacing: 1px;
                text-transform: uppercase;
                cursor: pointer;
                font-family: inherit;
                transition: all .2s
            }

                .nav-tab.active {
                    background: rgba(14,165,233,.15);
                    color: #38bdf8;
                    border: 1px solid rgba(14,165,233,.2)
                }

                .nav-tab:hover:not(.active) {
                    color: #94a3b8
                }

            /* ── TAB PANELS ── */
            .tab-panel {
                display: none
            }

                .tab-panel.active {
                    display: block
                }

            /* ── LOBBY ── */
            .lobby-header {
                text-align: center;
                margin-bottom: 2rem
            }

            .lobby-badge {
                display: inline-flex;
                align-items: center;
                gap: .4rem;
                padding: .35rem .75rem;
                border-radius: 999px;
                background: rgba(120,53,15,.3);
                border: 1px solid rgba(245,158,11,.2);
                color: #fcd34d;
                font-size: .6rem;
                font-weight: 900;
                letter-spacing: 1.5px;
                text-transform: uppercase;
                margin-bottom: 1rem
            }

                .lobby-badge .dot {
                    width: 6px;
                    height: 6px;
                    border-radius: 50%;
                    background: #fbbf24;
                    animation: pulse 1.5s infinite
                }

            .lobby-header h1 {
                font-size: 3.2rem;
                font-weight: 900;
                letter-spacing: -2px;
                color: #fff
            }

                .lobby-header h1 span {
                    color: #fbbf24
                }

            .lobby-header .sub {
                color: #64748b;
                font-weight: 700;
                font-size: .85rem;
                margin-bottom: .75rem
            }

            .section-header {
                display: flex;
                align-items: center;
                gap: .5rem;
                margin-bottom: .5rem
            }

                .section-header h3 {
                    font-size: .6rem;
                    font-weight: 900;
                    color: #475569;
                    text-transform: uppercase;
                    letter-spacing: 2px
                }

            .choice-grid {
                display: grid;
                grid-template-columns: repeat(4,1fr);
                gap: .75rem;
                margin-bottom: 1.5rem
            }

            @@media(max-width:640px) {
                .choice-grid {
                    grid-template-columns: repeat(2,1fr)
                }
            }

            .choice-card {
                padding: 1rem .5rem;
                border-radius: 1rem;
                border: 2px solid #334155;
                background: rgba(30,41,59,.5);
                text-align: center;
                cursor: pointer;
                transition: all .2s
            }

                .choice-card:hover:not(.selected) {
                    border-color: #475569;
                    transform: translateY(-2px);
                    box-shadow: 0 4px 16px rgba(0,0,0,.3)
                }

                .choice-card.selected {
                    transform: translateY(-3px) scale(1.02)
                }

                .choice-card .kana-display {
                    font-size: 1.8rem;
                    font-weight: 900;
                    margin-bottom: .25rem;
                    line-height: 1.2
                }

                .choice-card .label {
                    font-size: .7rem;
                    font-weight: 900;
                    letter-spacing: 1px;
                    text-transform: uppercase;
                    color: #fff
                }

                .choice-card .time-row {
                    font-size: .55rem;
                    font-weight: 700;
                    color: #64748b;
                    margin-top: .2rem
                }

                .choice-card .desc-row {
                    font-size: .5rem;
                    font-weight: 700;
                    color: #475569;
                    margin-top: .15rem;
                    line-height: 1.3
                }

            .cta-btn {
                width: 100%;
                padding: .85rem;
                border-radius: 1rem;
                font-weight: 900;
                font-size: .85rem;
                letter-spacing: 1px;
                border: none;
                cursor: pointer;
                transition: all .3s;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: .5rem;
                color: #fff;
                font-family: inherit
            }

                .cta-btn.disabled {
                    background: rgba(30,41,59,.5);
                    color: #475569;
                    cursor: not-allowed;
                    border: 1px solid #334155
                }

                .cta-btn:not(.disabled):hover {
                    transform: translateY(-2px);
                    filter: brightness(1.1)
                }

            /* ── ARENA ── */
            .arena {
                display: none
            }

            .arena-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: .75rem
            }

            .exit-btn {
                padding: .35rem .6rem;
                border-radius: 999px;
                background: rgba(30,41,59,.5);
                border: 1px solid #334155;
                color: #94a3b8;
                font-size: .55rem;
                font-weight: 900;
                cursor: pointer;
                font-family: inherit
            }

            .hud {
                background: rgba(30,41,59,.6);
                border: 1px solid rgba(51,65,85,.5);
                border-radius: 1rem;
                padding: .75rem 1rem;
                margin-bottom: .75rem
            }

            .timer-bar {
                height: 6px;
                background: rgba(51,65,85,.5);
                border-radius: 3px;
                overflow: hidden;
                margin-bottom: .6rem
            }

            .timer-bar-fill {
                height: 100%;
                border-radius: 3px;
                transition: width .3s linear, background .3s
            }

            .hud-row {
                display: flex;
                align-items: center;
                justify-content: space-between
            }

            .time {
                font-size: 1.4rem;
                font-weight: 900;
                font-variant-numeric: tabular-nums
            }

            .hud-score {
                font-size: .6rem;
                font-weight: 900;
                color: #64748b;
                text-transform: uppercase
            }

                .hud-score span {
                    color: #fff
                }

            .hearts {
                display: flex;
                gap: .2rem;
                font-size: 1.2rem
            }

            .arena-card {
                border-radius: 1.5rem;
                border: 2px solid rgba(51,65,85,.5);
                padding: .35rem;
                transition: border-color .3s
            }

                .arena-card.correct-glow {
                    border-color: #22c55e
                }

            .arena-card-inner {
                background: rgba(30,41,59,.4);
                border-radius: 1.25rem;
                overflow: hidden;
                border: 1px solid rgba(51,65,85,.3)
            }

            .streak-bar {
                height: 5px;
                background: rgba(51,65,85,.5)
            }

            .streak-fill {
                height: 100%;
                transition: width .3s
            }

            .arena-body {
                padding: 2rem 1rem;
                text-align: center
            }

            .arena-display {
                font-size: 3.5rem;
                font-weight: 900;
                color: #fff;
                padding: 1.5rem 0
            }

            .combo-display {
                font-size: .75rem;
                font-weight: 900;
                color: #fbbf24;
                margin-bottom: .5rem;
                min-height: 1.2rem;
                animation: combo-flash .3s ease
            }

            .options-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: .75rem;
                margin-top: 1rem
            }

            .option-btn {
                padding: 1.25rem .75rem;
                border-radius: .75rem;
                border: 2px solid;
                transition: all .2s;
                cursor: pointer;
                font-size: 2rem;
                font-weight: 900;
                font-family: inherit
            }

                .option-btn.default {
                    background: rgba(51,65,85,.5);
                    border-color: #475569;
                    color: #e2e8f0
                }

                .option-btn.correct {
                    background: linear-gradient(135deg,#059669,#047857);
                    border-color: #10b981;
                    color: #fff
                }

                .option-btn.wrong {
                    background: linear-gradient(135deg,#dc2626,#b91c1c);
                    border-color: #ef4444;
                    color: #fff
                }

                .option-btn:hover.default {
                    border-color: #94a3b8;
                    transform: scale(1.03)
                }

            /* ── SKILL BANNER ── */
            .skill-banner {
                display: none;
                align-items: center;
                justify-content: center;
                gap: .5rem;
                padding: .5rem 1rem;
                border-radius: .75rem;
                margin-bottom: .5rem;
                font-size: .75rem;
                font-weight: 900;
                animation: pop-in .3s ease both
            }

                .skill-banner.show {
                    display: flex
                }

            /* ── RESULTS ── */
            .results {
                display: none;
                max-width: 520px;
                margin: 0 auto;
                text-align: center
            }

                .results h1 {
                    font-size: 2rem;
                    font-weight: 900;
                    margin-bottom: 1rem;
                    color: #34d399
                }

            .results-grid {
                display: grid;
                grid-template-columns: repeat(3,1fr);
                gap: .6rem;
                margin-bottom: .75rem
            }

            .results-stat {
                background: rgba(30,41,59,.6);
                border: 1px solid rgba(51,65,85,.5);
                border-radius: 1rem;
                padding: 1rem;
                text-align: center
            }

                .results-stat span {
                    display: block;
                    font-size: 1.4rem;
                    font-weight: 900;
                    color: #fff
                }

                .results-stat small {
                    font-size: .5rem;
                    font-weight: 900;
                    color: #475569;
                    text-transform: uppercase;
                    letter-spacing: 1px
                }

            .racts {
                display: flex;
                gap: .5rem;
                justify-content: center
            }

                .racts button {
                    padding: .8rem 1.5rem;
                    border-radius: 999px;
                    font-weight: 900;
                    border: none;
                    cursor: pointer;
                    color: #fff;
                    font-family: inherit
                }

            .rsec {
                background: rgba(51,65,85,.5);
                border: 1px solid #475569
            }

            /* ── RANKS TAB ── */
            .ranks-grid {
                display: grid;
                gap: .6rem
            }

            .rank-card {
                background: rgba(15,23,42,.7);
                border: 1px solid rgba(51,65,85,.4);
                border-radius: 1rem;
                padding: 1rem 1.25rem;
                display: flex;
                align-items: center;
                gap: 1rem
            }

            .rank-icon {
                font-size: 2rem;
                flex-shrink: 0;
                width: 48px;
                text-align: center
            }

            .rank-info {
                flex: 1
            }

            .rank-name {
                font-size: .85rem;
                font-weight: 900;
                color: #fff;
                margin-bottom: .15rem
            }

            .rank-desc {
                font-size: .58rem;
                font-weight: 700;
                color: #64748b;
                line-height: 1.4
            }

            .rank-elo {
                font-size: .55rem;
                font-weight: 900;
                padding: .2rem .5rem;
                border-radius: 999px;
                border: 1px solid;
                text-transform: uppercase;
                letter-spacing: 1px
            }

            /* ── ABOUT TAB ── */
            .about-section {
                margin-bottom: 1.5rem
            }

            .about-title {
                font-size: .65rem;
                font-weight: 900;
                color: #475569;
                text-transform: uppercase;
                letter-spacing: 2px;
                margin-bottom: .75rem;
                display: flex;
                align-items: center;
                gap: .4rem
            }

                .about-title::before {
                    content: '';
                    display: block;
                    width: 3px;
                    height: 14px;
                    border-radius: 2px;
                    background: #0ea5e9
                }

            .about-card {
                background: rgba(15,23,42,.7);
                border: 1px solid rgba(51,65,85,.4);
                border-radius: 1rem;
                padding: 1rem 1.25rem;
                margin-bottom: .6rem
            }

                .about-card h4 {
                    font-size: .75rem;
                    font-weight: 900;
                    color: #fff;
                    margin-bottom: .4rem
                }

                .about-card p {
                    font-size: .65rem;
                    font-weight: 700;
                    color: #64748b;
                    line-height: 1.6
                }

            .mode-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: .6rem
            }

            .mode-card {
                background: rgba(15,23,42,.7);
                border: 1px solid rgba(51,65,85,.4);
                border-radius: 1rem;
                padding: 1rem;
                text-align: center
            }

                .mode-card .mode-icon {
                    font-size: 1.8rem;
                    margin-bottom: .4rem
                }

                .mode-card h4 {
                    font-size: .7rem;
                    font-weight: 900;
                    color: #fff;
                    margin-bottom: .25rem
                }

                .mode-card p {
                    font-size: .58rem;
                    font-weight: 700;
                    color: #64748b;
                    line-height: 1.4
                }

            .skill-list {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: .4rem
            }

            .skill-item {
                background: rgba(15,23,42,.5);
                border: 1px solid rgba(51,65,85,.3);
                border-radius: .6rem;
                padding: .5rem .75rem;
                display: flex;
                align-items: center;
                gap: .5rem
            }

                .skill-item .skill-icon {
                    font-size: 1.2rem
                }

                .skill-item .skill-text {
                    flex: 1
                }

                .skill-item .skill-name {
                    font-size: .6rem;
                    font-weight: 900;
                    color: #fff
                }

                .skill-item .skill-desc {
                    font-size: .5rem;
                    font-weight: 700;
                    color: #64748b
                }
    </style>
</head>
<body>
    <a href="@Url.Action("Index", "Home")" class="nq-back-btn">← Back</a>
    <div class="bg-layer"><div class="bg-aurora"></div><div id="particles"></div></div>
    <div class="bg-vignette"></div>
    <div class="screen-flash green" id="flash-green"></div>
    <div class="screen-flash red" id="flash-red"></div>

    <div class="container">
        <!-- TOP BAR -->
        <div class="top-bar">
            <div style="flex:1"></div>
            <div class="top-bar-inner">
                <span class="top-bar-line"></span>
                <span>KANABLITZ SOLO</span>
                <span class="top-bar-line"></span>
            </div>
            <div style="flex:1;text-align:right">
                <a href="@Url.Action("MainView", "KanaBattle")" class="mp-btn" title="Enter the multiplayer arena to battle real players or AI with ELO ranking">⚔ Multiplayer</a>
            </div>
        </div>

        <!-- NAV TABS -->
        <div class="nav-tabs">
            <button class="nav-tab active" onclick="showTab('play')" title="Practice kana with single-player training sessions">🎮 Play</button>
            <button class="nav-tab" onclick="showTab('ranks')" title="View all league ranks and ELO thresholds">🏆 Ranks</button>
            <button class="nav-tab" onclick="showTab('about')" title="Learn about game modes, skills, and how to play">📖 About</button>
        </div>

        <!-- ═══ PLAY TAB ═══ -->
        <div id="tab-play" class="tab-panel active">
            <!-- LOBBY -->
            <div id="ui-lobby" class="anim-slide-up">
                <div class="lobby-header">
                    <div class="lobby-badge"><span class="dot"></span>High Intensity Training</div>
                    <h1>Kana<span>Blitz</span></h1>
                    <p class="sub">Lock in kana fluency through rapid pattern recognition. Earn skills by answering correctly!</p>
                </div>

                <div class="section-header"><h3>01 Choose Your Script</h3></div>
                <div class="choice-grid">
                    <div class="choice-card" data-alpha="hiragana" onclick="selA(this)" title="Practice the 46 basic hiragana characters — perfect for beginners">
                        <div class="kana-display" style="color:#0ea5e9">あ</div>
                        <div class="label">Hiragana</div>
                        <div class="time-row">46 characters</div>
                        <div class="desc-row">Core Japanese script for native words</div>
                    </div>
                    <div class="choice-card" data-alpha="katakana" onclick="selA(this)" title="Practice the 46 katakana characters — used for foreign loanwords">
                        <div class="kana-display" style="color:#f43f5e">ア</div>
                        <div class="label">Katakana</div>
                        <div class="time-row">46 characters</div>
                        <div class="desc-row">Used for foreign & technical words</div>
                    </div>
                    <div class="choice-card" data-alpha="dakuten" onclick="selA(this)" title="Practice voiced and semi-voiced kana with dakuten marks">
                        <div class="kana-display" style="color:#8b5cf6">が</div>
                        <div class="label">Dakuten</div>
                        <div class="time-row">Voiced marks</div>
                        <div class="desc-row">が、ざ、だ、ば、ぱ sounds</div>
                    </div>
                    <div class="choice-card" data-alpha="mixed" onclick="selA(this)" title="All scripts mixed together — the ultimate challenge!">
                        <div class="kana-display" style="color:#f59e0b">混</div>
                        <div class="label">Mixed</div>
                        <div class="time-row">All scripts</div>
                        <div class="desc-row">Full kana mastery challenge</div>
                    </div>
