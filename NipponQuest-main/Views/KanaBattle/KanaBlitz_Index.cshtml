@*
    ╔══════════════════════════════════════════════════════════════╗
    ║  KanaBlitz_Index.cshtml  —  Solo KanaBlitz Game             ║
    ║  Controller : KanaBlitzController → Index()                 ║
    ║  Route      : /KanaBlitz/Index  (or /KanaBlitz)             ║
    ║  Data       : KanaBlitzController → GetWords(diff, alpha)   ║
    ╚══════════════════════════════════════════════════════════════╝
*@
@{
    ViewData["Title"] = "KanaBlitz Solo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ── palette ── */
    :root {
        --bg: #0d0d1a;
        --panel: #12122a;
        --border: #2a2a55;
        --accent: #7c3aed;
        --accent2: #a855f7;
        --gold: #f59e0b;
        --green: #10b981;
        --red: #ef4444;
        --text: #e2e8f0;
        --muted: #94a3b8;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Segoe UI', sans-serif;
    }

    /* ── layout shells ── */
    .kb-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 24px 16px;
    }

    .kb-header {
        text-align: center;
        margin-bottom: 28px;
    }

        .kb-header h1 {
            font-size: 2.4rem;
            font-weight: 800;
            letter-spacing: .05em;
            background: linear-gradient(135deg,#7c3aed,#a855f7,#ec4899);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .kb-header p {
            color: var(--muted);
            margin-top: 6px;
        }

    /* ── setup panel ── */
    #setup-panel {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 28px;
        margin-bottom: 24px;
    }

    .section-title {
        font-size: .75rem;
        font-weight: 700;
        letter-spacing: .12em;
        color: var(--accent2);
        text-transform: uppercase;
        margin-bottom: 14px;
    }

    .choice-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px,1fr));
        gap: 12px;
        margin-bottom: 24px;
    }

    .choice-card {
        background: #1a1a35;
        border: 2px solid var(--border);
        border-radius: 12px;
        padding: 16px 12px;
        cursor: pointer;
        transition: all .2s;
        text-align: center;
    }

        .choice-card:hover {
            border-color: var(--accent2);
            background: #1e1e40;
        }

        .choice-card.active {
            border-color: var(--accent);
            background: #2d1b6e;
            box-shadow: 0 0 16px rgba(124,58,237,.35);
        }

        .choice-card .icon {
            font-size: 1.8rem;
            margin-bottom: 6px;
        }

        .choice-card .label {
            font-weight: 700;
            font-size: .95rem;
        }

        .choice-card .sub {
            font-size: .72rem;
            color: var(--muted);
            margin-top: 3px;
        }

        .choice-card .tag {
            font-size: .68rem;
            color: var(--accent2);
            margin-top: 2px;
        }

    /* ── start button ── */
    #btn-start {
        width: 100%;
        padding: 16px;
        border-radius: 12px;
        border: none;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        background: linear-gradient(135deg,#7c3aed,#a855f7);
        color: #fff;
        letter-spacing: .05em;
        transition: opacity .2s;
    }

        #btn-start:hover {
            opacity: .9;
        }

    /* ── arena ── */
    #arena {
        display: none;
    }

    /* HUD bar */
    .hud {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 14px 20px;
        margin-bottom: 16px;
        gap: 12px;
        flex-wrap: wrap;
    }

    .hud-timer {
        font-size: 2rem;
        font-weight: 800;
        color: var(--gold);
        font-variant-numeric: tabular-nums;
    }

    .hud-score {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--green);
    }

    .hud-lives {
        font-size: 1.3rem;
        letter-spacing: 4px;
    }

    .hud-combo {
        font-size: .85rem;
        color: var(--accent2);
        font-weight: 600;
    }

    .hud-diff {
        font-size: .75rem;
        color: var(--muted);
    }

    /* question card */
    .q-card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 32px 24px;
        text-align: center;
        margin-bottom: 16px;
    }

    .q-kana {
        font-size: 4.5rem;
        line-height: 1;
        margin-bottom: 6px;
    }

    .q-romaji {
        font-size: 1rem;
        color: var(--muted);
        min-height: 1.4em;
    }

    .q-meaning {
        font-size: .85rem;
        color: #64748b;
        min-height: 1.2em;
    }

    .q-cat {
        font-size: .7rem;
        color: var(--accent2);
        margin-top: 4px;
    }

    /* answer options */
    .opt-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 16px;
    }

    .opt-btn {
        background: #1a1a35;
        border: 2px solid var(--border);
        border-radius: 10px;
        padding: 14px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        color: var(--text);
        transition: all .15s;
    }

        .opt-btn:hover {
            border-color: var(--accent2);
            background: #1e1e40;
        }

        .opt-btn.correct {
            border-color: var(--green) !important;
            background: #052e16 !important;
            color: var(--green) !important;
        }

        .opt-btn.wrong {
            border-color: var(--red) !important;
            background: #2c0000 !important;
            color: var(--red) !important;
        }

    /* feedback flash */
    #feedback {
        text-align: center;
        font-size: 1rem;
        font-weight: 700;
        min-height: 1.6em;
        transition: color .2s;
    }

    /* ── result overlay ── */
    #result-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.75);
        z-index: 999;
        align-items: center;
        justify-content: center;
    }

        #result-overlay.show {
            display: flex;
        }

    .result-card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 40px 32px;
        text-align: center;
        max-width: 500px;
        width: 90%;
    }

    .result-title {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 6px;
    }

    .result-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 16px;
        margin: 24px 0;
    }

    .result-stat {
        background: #1a1a35;
        border-radius: 10px;
        padding: 14px;
    }

        .result-stat .val {
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--gold);
        }

        .result-stat .lbl {
            font-size: .72rem;
            color: var(--muted);
            margin-top: 4px;
        }

    .result-btns {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-primary, .btn-secondary {
        padding: 12px 24px;
        border-radius: 10px;
        border: none;
        font-size: .95rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity .2s;
    }

    .btn-primary {
        background: linear-gradient(135deg,#7c3aed,#a855f7);
        color: #fff;
    }

    .btn-secondary {
        background: #1a1a35;
        color: var(--text);
        border: 1px solid var(--border);
    }

        .btn-primary:hover, .btn-secondary:hover {
            opacity: .85;
        }

    /* ── info section ── */
    .info-section {
        margin-top: 32px;
    }

    .info-card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 22px 20px;
        margin-bottom: 16px;
    }

        .info-card h3 {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 12px;
            color: var(--accent2);
        }

        .info-card p, .info-card li {
            font-size: .88rem;
            color: var(--muted);
            line-height: 1.65;
        }

        .info-card ul {
            padding-left: 18px;
        }

    .diff-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px,1fr));
        gap: 12px;
    }

    .diff-item {
        background: #1a1a35;
        border-radius: 10px;
        padding: 14px;
    }

        .diff-item .d-icon {
            font-size: 1.5rem;
            margin-bottom: 6px;
        }

        .diff-item .d-name {
            font-weight: 700;
            font-size: .9rem;
        }

        .diff-item .d-desc {
            font-size: .78rem;
            color: var(--muted);
            margin-top: 4px;
            line-height: 1.5;
        }

    /* ── responsive ── */
    @@media (max-width: 500px) {
        .opt-grid {
            grid-template-columns: 1fr;
        }

        .result-grid {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>

