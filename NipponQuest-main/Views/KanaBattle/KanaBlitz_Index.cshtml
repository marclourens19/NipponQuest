@*
    ╔══════════════════════════════════════════════════════════════════╗
    ║  KanaBlitz_Index.cshtml  —  Mode Selection Hub                 ║
    ║  Controller : KanaBlitzController → Index()                     ║
    ║  Route      : /KanaBlitz/Index  (or /KanaBlitz)                 ║
    ║  Purpose    : Solo / Multiplayer mode picker with full info     ║
    ║  Aesthetic  : White background · Black / Gold / White / Blue    ║
    ╚══════════════════════════════════════════════════════════════════╝
*@
@{
    ViewData["Title"] = "KanaBlitz — Choose Your Path";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ══════════════════════════════════════════════════════════════
               NIPPONQUEST — KanaBlitz Mode Selection Hub
               Palette : White bg · Black text · Gold accents · Blue action
               Font    : Nunito (loaded via site.css)
            ══════════════════════════════════════════════════════════════ */
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');

    :root {
        --kb-bg: #ffffff;
        --kb-surface: #f8fafc;
        --kb-surface2: #f1f5f9;
        --kb-border: #e2e8f0;
        --kb-border2: #cbd5e1;
        --kb-black: #0f172a;
        --kb-charcoal: #1e293b;
        --kb-dark: #334155;
        --kb-muted: #64748b;
        --kb-faint: #94a3b8;
        --kb-gold: #d97706;
        --kb-gold-lt: #f59e0b;
        --kb-gold-bg: #fef3c7;
        --kb-gold-bd: #fcd34d;
        --kb-blue: #1e40af;
        --kb-blue-lt: #3b82f6;
        --kb-blue-bg: #eff6ff;
        --kb-blue-bd: #93c5fd;
        --kb-green: #065f46;
        --kb-green-lt: #10b981;
        --kb-green-bg: #ecfdf5;
        --kb-red: #991b1b;
        --kb-red-lt: #ef4444;
        --kb-red-bg: #fff1f2;
        --kb-red-bd: #fca5a5;
        --kb-radius: 14px;
        --kb-radius-sm: 10px;
        --kb-radius-lg: 20px;
        --kb-shadow: 0 4px 16px rgba(15,23,42,0.08);
        --kb-shadow-lg: 0 8px 32px rgba(15,23,42,0.12);
        --kb-trans: all 0.22s cubic-bezier(0.4,0,0.2,1);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    .kb-page {
        background: var(--kb-bg);
        min-height: 100vh;
        color: var(--kb-black);
        font-family: 'Nunito', 'Segoe UI', sans-serif;
        padding-bottom: 80px;
    }

        .kb-page::before {
            content: '';
            display: block;
            height: 4px;
            background: linear-gradient(90deg, #0f172a 0%, #d97706 50%, #1e40af 100%);
        }

    .kb-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 32px 16px;
    }

    /* ── Hero ── */
    .kb-hero {
        text-align: center;
        padding: 28px 0 40px;
    }

    .kb-hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--kb-gold-bg);
        border: 1.5px solid var(--kb-gold-bd);
        border-radius: 100px;
        padding: 6px 20px;
        font-size: 0.68rem;
        font-weight: 900;
        letter-spacing: 0.18em;
        color: var(--kb-gold);
        text-transform: uppercase;
        margin-bottom: 18px;
    }

    .kb-hero h1 {
        font-size: clamp(2.2rem, 5vw, 3.4rem);
        font-weight: 900;
        letter-spacing: 0.02em;
        color: var(--kb-black);
        line-height: 1.12;
        margin-bottom: 12px;
    }

        .kb-hero h1 .gold {
            color: var(--kb-gold);
        }

        .kb-hero h1 .blue {
            color: var(--kb-blue-lt);
        }

    .kb-hero p {
        color: var(--kb-muted);
        font-size: 1rem;
        max-width: 540px;
        margin: 0 auto;
        line-height: 1.7;
    }

    /* ── Mode Cards ── */
    .mode-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
        gap: 24px;
        margin: 36px 0 40px;
    }

    .mode-card {
        background: var(--kb-bg);
        border: 2px solid var(--kb-border);
        border-radius: var(--kb-radius-lg);
        padding: 36px 28px 32px;
        cursor: pointer;
        transition: var(--kb-trans);
        position: relative;
        overflow: hidden;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        min-height: 420px;
    }

        .mode-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--kb-blue-lt);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .mode-card:hover {
            border-color: var(--kb-blue-lt);
            transform: translateY(-4px);
            box-shadow: 0 12px 40px rgba(15,23,42,0.12);
        }

            .mode-card:hover::before {
                opacity: 1;
            }

        .mode-card.solo-card:hover {
            border-color: var(--kb-gold);
        }

            .mode-card.solo-card:hover::before {
                background: linear-gradient(90deg, var(--kb-gold), var(--kb-gold-lt));
                opacity: 1;
            }

            .mode-card.solo-card:hover .mode-icon {
                background: var(--kb-gold-bg);
                color: var(--kb-gold);
            }

        .mode-card.multi-card:hover {
            border-color: var(--kb-red-lt);
        }

            .mode-card.multi-card:hover::before {
                background: linear-gradient(90deg, var(--kb-red-lt), var(--kb-gold));
                opacity: 1;
            }

            .mode-card.multi-card:hover .mode-icon {
                background: var(--kb-red-bg);
                color: var(--kb-red-lt);
            }

    .mode-icon {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        background: var(--kb-surface);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin-bottom: 20px;
        transition: var(--kb-trans);
        color: var(--kb-charcoal);
    }

    .mode-card h2 {
        font-size: 1.6rem;
        font-weight: 900;
        color: var(--kb-black);
        margin-bottom: 6px;
        letter-spacing: 0.01em;
    }

    .mode-card .mode-subtitle {
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--kb-faint);
        margin-bottom: 16px;
    }

    .mode-card .mode-desc {
        font-size: 0.9rem;
        color: var(--kb-dark);
        line-height: 1.7;
        margin-bottom: 20px;
        flex: 1;
    }

    .mode-features {
        list-style: none;
        padding: 0;
        margin: 0 0 24px;
    }

        .mode-features li {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            font-size: 0.82rem;
            color: var(--kb-dark);
            margin-bottom: 10px;
            line-height: 1.5;
        }

            .mode-features li .feat-icon {
                width: 22px;
                height: 22px;
                border-radius: 6px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 0.7rem;
                flex-shrink: 0;
                margin-top: 2px;
            }

    .solo-card .feat-icon {
        background: var(--kb-gold-bg);
        color: var(--kb-gold);
    }

    .multi-card .feat-icon {
        background: var(--kb-red-bg);
        color: var(--kb-red-lt);
    }

    .mode-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 28px;
        border-radius: 12px;
        font-weight: 900;
        font-size: 0.88rem;
        letter-spacing: 0.06em;
        border: none;
        cursor: pointer;
        transition: var(--kb-trans);
        text-decoration: none;
        width: 100%;
        text-align: center;
    }

        .mode-btn:hover {
            transform: translateY(-2px);
            text-decoration: none;
        }

        .mode-btn.btn-solo {
            background: linear-gradient(135deg, var(--kb-gold), var(--kb-gold-lt));
            color: #fff;
            box-shadow: 0 4px 16px rgba(217,119,6,0.3);
        }

            .mode-btn.btn-solo:hover {
                box-shadow: 0 8px 24px rgba(217,119,6,0.4);
                color: #fff;
            }

        .mode-btn.btn-multi {
            background: linear-gradient(135deg, var(--kb-red-lt), var(--kb-gold));
            color: #fff;
            box-shadow: 0 4px 16px rgba(239,68,68,0.25);
        }

            .mode-btn.btn-multi:hover {
                box-shadow: 0 8px 24px rgba(239,68,68,0.35);
                color: #fff;
            }

    /* ── Spells Info Section ── */
    .spells-section {
        background: var(--kb-surface);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-lg);
        padding: 32px 28px;
        margin-top: 32px;
    }

        .spells-section h3 {
            font-size: 1.2rem;
            font-weight: 900;
            color: var(--kb-black);
            margin-bottom: 6px;
        }

        .spells-section .spells-sub {
            font-size: 0.82rem;
            color: var(--kb-muted);
            margin-bottom: 24px;
        }

    .spells-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
    }

    .spell-card {
        background: var(--kb-bg);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius);
        padding: 20px 16px;
        transition: var(--kb-trans);
    }

        .spell-card:hover {
            border-color: var(--kb-blue-bd);
            box-shadow: var(--kb-shadow);
            transform: translateY(-2px);
        }

        .spell-card .spell-icon {
            font-size: 1.6rem;
            margin-bottom: 10px;
            display: block;
        }

        .spell-card .spell-name {
            font-weight: 900;
            font-size: 0.88rem;
            color: var(--kb-charcoal);
            margin-bottom: 4px;
        }

        .spell-card .spell-desc {
            font-size: 0.76rem;
            color: var(--kb-muted);
            line-height: 1.6;
        }

    /* ── Difficulty Preview ── */
    .diff-preview {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-top: 28px;
    }

    .diff-chip {
        text-align: center;
        padding: 14px 10px;
        border-radius: var(--kb-radius-sm);
        background: var(--kb-bg);
        border: 1.5px solid var(--kb-border);
        transition: var(--kb-trans);
    }

        .diff-chip:hover {
            transform: translateY(-2px);
            box-shadow: var(--kb-shadow);
        }

        .diff-chip .diff-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            display: inline-block;
            margin-bottom: 8px;
        }

        .diff-chip.easy .diff-dot {
            background: var(--kb-green-lt);
        }

        .diff-chip.normal .diff-dot {
            background: var(--kb-blue-lt);
        }

        .diff-chip.hard .diff-dot {
            background: var(--kb-gold);
        }

        .diff-chip.insanity .diff-dot {
            background: var(--kb-red-lt);
        }

        .diff-chip .diff-label {
            font-weight: 900;
            font-size: 0.78rem;
            color: var(--kb-charcoal);
            display: block;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .diff-chip .diff-desc {
            font-size: 0.68rem;
            color: var(--kb-faint);
            margin-top: 4px;
            display: block;
            line-height: 1.4;
        }

    /* ── Animations ── */
    @@keyframes fadeInUp {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes floatSoft {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-6px);
        }
    }

    @@keyframes pulseGlow {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(217,119,6,0.3);
        }

        50% {
            box-shadow: 0 0 20px 4px rgba(217,119,6,0.15);
        }
    }

    .anim-fade-up {
        animation: fadeInUp 0.6s cubic-bezier(0.16,1,0.3,1) both;
    }

    .anim-delay-1 {
        animation-delay: 0.1s;
    }

    .anim-delay-2 {
        animation-delay: 0.2s;
    }

    .anim-delay-3 {
        animation-delay: 0.3s;
    }

    .anim-delay-4 {
        animation-delay: 0.4s;
    }

    .float-soft {
        animation: floatSoft 4s ease-in-out infinite;
    }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        .mode-grid {
            grid-template-columns: 1fr;
        }

        .mode-card {
            min-height: auto;
        }

        .diff-preview {
            grid-template-columns: repeat(2, 1fr);
        }

        .spells-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 480px) {
        .kb-hero h1 {
            font-size: 1.8rem;
        }

        .mode-card {
            padding: 24px 18px;
        }

        .spells-section {
            padding: 20px 16px;
        }
    }
</style>

<div class="kb-page">
    <div class="kb-wrapper">
        <!-- Hero -->
        <div class="kb-hero anim-fade-up">
            <div class="kb-hero-badge">⚔️ Training Arena</div>
            <h1>Choose Your <span class="gold">Path</span></h1>
            <p>Master Japanese kana through intense solo drills or challenge a rival in real-time multiplayer battles. Select your mode and begin your quest.</p>
        </div>

        <!-- Mode Selection Cards -->
        <div class="mode-grid">
            <!-- Solo Mode Card -->
            <a href="/KanaBlitz/Play" class="mode-card solo-card anim-fade-up anim-delay-1" id="solo-card">
                <div class="mode-icon">🗡️</div>
                <h2>Solo Training</h2>
                <div class="mode-subtitle">KanaBlitz · Single Player</div>
                <div class="mode-desc">
                    Sharpen your kana recognition skills through timed solo drills. Choose your difficulty and alphabet, then race against the clock to match as many words as possible. Perfect your accuracy, build combos, and chase your personal best.
                </div>
                <ul class="mode-features">
                    <li>
                        <span class="feat-icon">⚡</span>
                        <span><strong>Timed Rounds</strong> — Race against a countdown clock. Every correct answer adds bonus time.</span>
                    </li>
                    <li>
                        <span class="feat-icon">🔥</span>
                        <span><strong>Combo System</strong> — Chain correct answers to build multipliers and earn massive XP.</span>
                    </li>
                    <li>
                        <span class="feat-icon">📊</span>
                        <span><strong>Progress Tracking</strong> — Your accuracy is tracked per alphabet and difficulty for unlocks.</span>
                    </li>
                    <li>
                        <span class="feat-icon">🏆</span>
                        <span><strong>Difficulty Scaling</strong> — Progress from Easy (single characters) through Insanity (kanji compounds).</span>
                    </li>
                    <li>
                        <span class="feat-icon">🎯</span>
                        <span><strong>Missing Kana Challenge</strong> — Identify the missing kana in each word to answer correctly.</span>
                    </li>
                </ul>
                <button class="mode-btn btn-solo" onclick="event.preventDefault(); window.location.href='/KanaBlitz/Play';">
                    Enter Solo Training →
                </button>
            </a>

            <!-- Multiplayer Mode Card -->
            <a href="/KanaBattle/MainView" class="mode-card multi-card anim-fade-up anim-delay-2" id="multi-card">
                <div class="mode-icon">⚔️</div>
                <h2>Multiplayer Battle</h2>
                <div class="mode-subtitle">KanaBattle · Versus Mode</div>
                <div class="mode-desc">
                    Challenge another player in a head-to-head kana showdown. Both players compete on the same set of words, racing to identify the correct missing kana. The fastest and most accurate warrior claims victory and earns bonus XP.
                </div>
                <ul class="mode-features">
                    <li>
                        <span class="feat-icon">👤👤</span>
                        <span><strong>1v1 Battles</strong> — Go head-to-head against another player in real-time kana combat.</span>
                    </li>
                    <li>
                        <span class="feat-icon">⏱️</span>
                        <span><strong>Speed Matters</strong> — Answer faster than your opponent to gain the upper hand.</span>
                    </li>
                    <li>
                        <span class="feat-icon">💎</span>
                        <span><strong>Bonus XP Rewards</strong> — Winners earn boosted XP and gold for their NipponQuest profile.</span>
                    </li>
                    <li>
                        <span class="feat-icon">🗡️</span>
                        <span><strong>Shared Word Pool</strong> — Both players face identical questions for a fair fight.</span>
                    </li>
                    <li>
                        <span class="feat-icon">🎌</span>
                        <span><strong>Custom Names</strong> — Enter your warrior name before entering the arena.</span>
                    </li>
                </ul>
                <button class="mode-btn btn-multi" onclick="event.preventDefault(); window.location.href='/KanaBattle/MainView';">
                    Enter Battle Arena →
                </button>
            </a>
        </div>

        <!-- Spells & Power-ups Info -->
        <div class="spells-section anim-fade-up anim-delay-3">
            <h3>✨ Spells & Game Mechanics</h3>
            <div class="spells-sub">Understanding the mechanics that drive your KanaBlitz & KanaBattle experience</div>

            <div class="spells-grid">
                <div class="spell-card">
                    <span class="spell-icon">⏳</span>
                    <div class="spell-name">Time Bonus</div>
                    <div class="spell-desc">Each correct answer grants bonus seconds. Build combos to multiply the time added and keep your run alive longer.</div>
                </div>
                <div class="spell-card">
                    <span class="spell-icon">🔥</span>
                    <div class="spell-name">Combo Multiplier</div>
                    <div class="spell-desc">Consecutive correct answers build a combo streak. Higher combos mean more XP per answer. Break your streak and the multiplier resets.</div>
                </div>
                <div class="spell-card">
                    <span class="spell-icon">🎯</span>
                    <div class="spell-name">Missing Kana</div>
                    <div class="spell-desc">Each word has a hidden kana. Read the romaji/meaning hint and select the correct character from four options.</div>
                </div>
                <div class="spell-card">
                    <span class="spell-icon">🛡️</span>
                    <div class="spell-name">Accuracy Gate</div>
                    <div class="spell-desc">Hard and Insanity modes unlock only after reaching accuracy thresholds on easier difficulties. Prove your mastery first.</div>
                </div>
                <div class="spell-card">
                    <span class="spell-icon">⭐</span>
                    <div class="spell-name">XP Reward</div>
                    <div class="spell-desc">All game modes award XP to your NipponQuest profile. Higher difficulties and longer streaks yield exponentially more XP.</div>
                </div>
                <div class="spell-card">
                    <span class="spell-icon">🏆</span>
                    <div class="spell-name">Personal Bests</div>
                    <div class="spell-desc">Your highest scores are recorded per difficulty and alphabet. Beat your records and climb the leaderboard rankings.</div>
                </div>
            </div>

            <!-- Difficulty Preview -->
            <div class="diff-preview">
                <div class="diff-chip easy">
                    <span class="diff-dot"></span>
                    <span class="diff-label">Easy</span>
                    <span class="diff-desc">Single kana characters · Hiragana & Katakana basics</span>
                </div>
                <div class="diff-chip normal">
                    <span class="diff-dot"></span>
                    <span class="diff-label">Normal</span>
                    <span class="diff-desc">Common words · Animals, food, nature & daily life</span>
                </div>
                <div class="diff-chip hard">
                    <span class="diff-dot"></span>
                    <span class="diff-label">Hard</span>
                    <span class="diff-desc">Yōon, Sokuon & compound words · Longer kana strings</span>
                </div>
                <div class="diff-chip insanity">
                    <span class="diff-dot"></span>
                    <span class="diff-label">Insanity</span>
                    <span class="diff-desc">Kanji + furigana · Idioms, abstract concepts & mastery-level</span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // ── Audio Architecture (placeholder hooks for future sound effects) ──
    const AudioHooks = {
        correct: () => { /* placeholder: play correct answer sound */ },
        incorrect: () => { /* placeholder: play incorrect answer sound */ },
        victory: () => { /* placeholder: play victory fanfare */ },
        countdown: () => { /* placeholder: play countdown tick */ },
        click: () => { /* placeholder: play button click */ },
        combo: () => { /* placeholder: play combo streak sound */ }
    };

    // ── Mode Card Interactions ──
    document.querySelectorAll('.mode-card').forEach(card => {
        card.addEventListener('mouseenter', () => AudioHooks.click());
    });

    // ── Scroll Reveal Animation ──
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('.anim-fade-up').forEach(el => observer.observe(el));
</script>
