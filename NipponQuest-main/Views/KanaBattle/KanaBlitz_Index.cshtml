    /* Toast */
    #toast-container {
        position: fixed;
        bottom: 24px;
        right: 24px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        z-index: 500;
        pointer-events: none;
    }

    .toast {
        background: var(--kb-black);
        color: #ffffff;
        padding: 12px 20px;
        border-radius: var(--kb-radius-sm);
        font-size: 0.82rem;
        font-weight: 700;
        box-shadow: 0 6px 20px rgba(0,0,0,0.2);
        animation: kbSlideInRight 0.3s cubic-bezier(0.34,1.56,0.64,1), kbFadeOut 0.4s ease 2.5s forwards;
        border-left: 4px solid var(--kb-gold);
    }

        .toast.success {
            border-left-color: var(--kb-green-lt);
        }

        .toast.error {
            border-left-color: var(--kb-red-lt);
        }

    /* Loading state */
    .loading-dots {
        display: inline-flex;
        gap: 6px;
    }

        .loading-dots span {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--kb-faint);
            animation: kbBounce 0.9s ease infinite;
        }

            .loading-dots span:nth-child(2) {
                animation-delay: 0.15s;
            }

            .loading-dots span:nth-child(3) {
                animation-delay: 0.3s;
