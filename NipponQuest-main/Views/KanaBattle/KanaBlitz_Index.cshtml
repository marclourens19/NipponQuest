@section Scripts {
    <script>
        (function () {
            'use strict';

            /* ── Floating kana particles ── */
            const kanaPool = ['あ','い','う','え','お','か','き','く','け','こ','さ','し','す','な','に','は','ひ','ま','み','も','や','ゆ','よ','ら','り','る','ア','イ','ウ','カ','サ','タ','ナ','ハ','マ','ら','学','心','夢','力','道'];
            const container = document.getElementById('kb-particles');

            if (container) {
                const createParticle = () => {
                    const el = document.createElement('div');
                    el.className = 'kb-particle';
                    el.textContent = kanaPool[Math.floor(Math.random() * kanaPool.length)];
                    el.style.cssText = [
                        `left:${Math.random() * 100}%`,
                        `top:${60 + Math.random() * 40}%`,
                        `animation-duration:${5 + Math.random() * 6}s`,
                        `animation-delay:${Math.random() * 4}s`,
                        `font-size:${0.9 + Math.random() * 1.2}rem`,
                        `opacity:0`,
                        `color:${Math.random() > 0.5 ? 'rgba(217,119,6,0.2)' : 'rgba(30,64,175,0.15)'}`,
                    ].join(';');
                    container.appendChild(el);
                    setTimeout(() => el.remove(), 12000);
                };

                // Initial burst
                for (let i = 0; i < 12; i++) setTimeout(createParticle, i * 300);
                // Ongoing
                setInterval(createParticle, 1800);
            }

            /* ── Mode card keyboard navigation ── */
            const cards = document.querySelectorAll('.mode-card');
            cards.forEach(card => {
                card.setAttribute('tabindex', '0');
                card.addEventListener('keydown', e => {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        card.click();
                    }
                });
            });

            /* ── Ripple effect on CTA buttons ── */
            document.querySelectorAll('.mode-cta').forEach(btn => {
                btn.addEventListener('click', function (e) {
                    const ripple = document.createElement('span');
                    const rect = this.getBoundingClientRect();
                    const size = Math.max(rect.width, rect.height);
                    ripple.style.cssText = `
                        position:absolute;
                        width:${size}px; height:${size}px;
                        left:${e.clientX - rect.left - size/2}px;
                        top:${e.clientY - rect.top - size/2}px;
                        background:rgba(255,255,255,0.3);
                        border-radius:50%;
                        transform:scale(0);
                        animation:kbRipple 0.5s ease-out forwards;
                        pointer-events:none;
                    `;
                    this.appendChild(ripple);
                    setTimeout(() => ripple.remove(), 600);
                });
            });

            /* Inject ripple keyframe */
            if (!document.querySelector('#kb-ripple-style')) {
                const s = document.createElement('style');
                s.id = 'kb-ripple-style';
                s.textContent = '@@keyframes kbRipple{to{transform:scale(2);opacity:0;}}';
                document.head.appendChild(s);
            }

        })();
    </script>
}
