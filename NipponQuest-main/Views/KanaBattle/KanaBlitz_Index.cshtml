@*
    ╔══════════════════════════════════════════════════════════════════╗
    ║  KanaBlitz_Index.cshtml  —  KanaBlitz Solo Game Arena           ║
    ║  Controller : KanaBlitzController → Index()                     ║
    ║  Route      : /KanaBlitz/Index  (or /KanaBlitz)                 ║
    ║  API        : GET /KanaBlitz/GetWords?difficulty=&script=       ║
    ║  Refactored : Full audit, debug, redesign & UX overhaul         ║
    ║  Aesthetic  : White background · Black / Gold / White / Blue    ║
    ╚══════════════════════════════════════════════════════════════════╝
*@
@{
    ViewData["Title"] = "KanaBlitz — Solo Training";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ══════════════════════════════════════════════════════════════
           NIPPONQUEST — KanaBlitz Solo Arena
           Palette : White bg · Black text · Gold accents · Blue action
           Font    : Nunito (loaded via site.css)
        ══════════════════════════════════════════════════════════════ */
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');

    :root {
        --kb-bg: #ffffff;
        --kb-surface: #f8fafc;
        --kb-surface2: #f1f5f9;
        --kb-border: #e2e8f0;
        --kb-border2: #cbd5e1;
        --kb-black: #0f172a;
        --kb-charcoal: #1e293b;
        --kb-dark: #334155;
        --kb-muted: #64748b;
        --kb-faint: #94a3b8;
        --kb-gold: #d97706;
        --kb-gold-lt: #f59e0b;
        --kb-gold-bg: #fef3c7;
        --kb-gold-bd: #fcd34d;
        --kb-blue: #1e40af;
        --kb-blue-lt: #3b82f6;
        --kb-blue-bg: #eff6ff;
        --kb-blue-bd: #93c5fd;
        --kb-green: #065f46;
        --kb-green-lt: #10b981;
        --kb-green-bg: #ecfdf5;
        --kb-red: #991b1b;
        --kb-red-lt: #ef4444;
        --kb-red-bg: #fff1f2;
        --kb-red-bd: #fca5a5;
        --kb-radius: 14px;
        --kb-radius-sm: 10px;
        --kb-radius-lg: 20px;
        --kb-shadow: 0 4px 16px rgba(15,23,42,0.08);
        --kb-shadow-lg: 0 8px 32px rgba(15,23,42,0.12);
        --kb-trans: all 0.22s cubic-bezier(0.4,0,0.2,1);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    .kb-page {
        background: var(--kb-bg);
        min-height: 100vh;
        color: var(--kb-black);
        font-family: 'Nunito', 'Segoe UI', sans-serif;
        padding-bottom: 80px;
    }

        /* Subtle top accent bar */
        .kb-page::before {
            content: '';
            display: block;
            height: 4px;
            background: linear-gradient(90deg, #0f172a 0%, #d97706 50%, #1e40af 100%);
        }

    .kb-wrapper {
        max-width: 1060px;
        margin: 0 auto;
        padding: 32px 16px;
    }

    /* ── Hero ── */
    .kb-hero {
        text-align: center;
        padding: 24px 0 36px;
    }

    .kb-hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--kb-gold-bg);
        border: 1.5px solid var(--kb-gold-bd);
        border-radius: 100px;
        padding: 6px 20px;
        font-size: 0.68rem;
        font-weight: 900;
        letter-spacing: 0.18em;
        color: var(--kb-gold);
        text-transform: uppercase;
        margin-bottom: 18px;
    }

    .kb-hero h1 {
        font-size: clamp(2rem,5vw,3.2rem);
        font-weight: 900;
        letter-spacing: 0.03em;
        color: var(--kb-black);
        line-height: 1.12;
        margin-bottom: 10px;
    }

        .kb-hero h1 span.gold {
            color: var(--kb-gold);
        }

        .kb-hero h1 span.blue {
            color: var(--kb-blue-lt);
        }

    .kb-hero p {
        color: var(--kb-muted);
        font-size: 0.96rem;
        max-width: 520px;
        margin: 0 auto;
        line-height: 1.7;
    }

    /* ── Section label dividers ── */
    .section-label {
        font-size: 0.67rem;
        font-weight: 900;
        letter-spacing: 0.2em;
        color: var(--kb-blue);
        text-transform: uppercase;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .section-label::after {
            content: '';
            flex: 1;
            height: 1.5px;
            background: linear-gradient(90deg, var(--kb-border2), transparent);
        }

    /* ── Setup Panel ── */
    #setup-panel {
        background: var(--kb-surface);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-lg);
        padding: 32px 28px;
        margin-bottom: 24px;
        box-shadow: var(--kb-shadow);
    }

    /* ── Choice Cards ── */
    .choice-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px,1fr));
        gap: 12px;
        margin-bottom: 28px;
    }

    .choice-card {
        background: var(--kb-bg);
        border: 2px solid var(--kb-border);
        border-radius: var(--kb-radius);
        padding: 18px 12px;
        cursor: pointer;
        transition: var(--kb-trans);
        text-align: center;
        position: relative;
        overflow: hidden;
        user-select: none;
    }

        .choice-card:hover {
            border-color: var(--kb-blue-lt);
            background: var(--kb-blue-bg);
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(30,64,175,0.12);
        }

        .choice-card.active {
            border-color: var(--kb-blue);
            background: var(--kb-blue-bg);
            box-shadow: 0 0 0 3px rgba(30,64,175,0.15);
            transform: translateY(-2px);
        }

        /* Difficulty-specific active states */
        .choice-card[data-diff="easy"].active {
            border-color: var(--kb-green-lt);
            background: var(--kb-green-bg);
            box-shadow: 0 0 0 3px rgba(16,185,129,0.15);
        }

        .choice-card[data-diff="normal"].active {
            border-color: var(--kb-blue-lt);
            background: var(--kb-blue-bg);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
        }

        .choice-card[data-diff="hard"].active {
            border-color: var(--kb-gold);
            background: var(--kb-gold-bg);
            box-shadow: 0 0 0 3px rgba(217,119,6,0.18);
        }

        .choice-card[data-diff="insanity"].active {
            border-color: var(--kb-red-lt);
            background: var(--kb-red-bg);
            box-shadow: 0 0 0 3px rgba(239,68,68,0.15);
        }

        .choice-card .c-icon {
            font-size: 2rem;
            margin-bottom: 8px;
            display: block;
        }

        .choice-card .c-label {
            font-weight: 800;
            font-size: 0.92rem;
            color: var(--kb-charcoal);
            display: block;
        }

        .choice-card .c-sub {
            font-size: 0.7rem;
            color: var(--kb-muted);
            margin-top: 4px;
            display: block;
        }

        .choice-card .c-tag {
            font-size: 0.66rem;
            color: var(--kb-blue);
            margin-top: 3px;
            display: block;
            font-weight: 700;
        }

        .choice-card .c-count {
            font-size: 0.63rem;
            color: var(--kb-faint);
            margin-top: 2px;
            display: block;
        }

    .diff-pip {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-bottom: 6px;
    }

    .pip-easy {
        background: var(--kb-green-lt);
    }

    .pip-normal {
        background: var(--kb-blue-lt);
    }

    .pip-hard {
        background: var(--kb-gold);
    }

    .pip-insanity {
        background: var(--kb-red-lt);
    }

    /* ── Word Count Warning ── */
    #word-warning {
        display: none;
        background: var(--kb-red-bg);
        border: 1.5px solid var(--kb-red-bd);
        border-radius: var(--kb-radius-sm);
        padding: 14px 18px;
        margin-bottom: 20px;
        font-size: 0.85rem;
        color: var(--kb-red);
        font-weight: 700;
        gap: 10px;
        align-items: flex-start;
    }

        #word-warning.visible {
            display: flex;
        }

    /* ── Start Button ── */
    #btn-start {
        width: 100%;
        padding: 18px;
        border-radius: var(--kb-radius);
        border: none;
        font-size: 1.05rem;
        font-weight: 900;
        cursor: pointer;
        background: linear-gradient(135deg, #0f172a 0%, #1e40af 100%);
        color: #ffffff;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        transition: var(--kb-trans);
        position: relative;
        overflow: hidden;
        box-shadow: 0 6px 20px rgba(30,64,175,0.25);
    }

        #btn-start::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -60%;
            width: 30%;
            height: 200%;
            background: rgba(255,255,255,0.18);
            transform: rotate(30deg);
            transition: left 0.6s ease;
        }

        #btn-start:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(30,64,175,0.35);
            filter: brightness(1.08);
        }

            #btn-start:hover::after {
                left: 140%;
            }

        #btn-start:disabled {
            background: var(--kb-surface2);
            color: var(--kb-faint);
            cursor: not-allowed;
            box-shadow: none;
            transform: none;
            filter: none;
        }

            #btn-start:disabled::after {
                display: none;
            }

    /* ── Arena ── */
    #game-arena {
        display: none;
    }

    /* HUD Bar */
    .hud-bar {
        display: flex;
        align-items: center;
        gap: 12px;
        background: var(--kb-black);
        color: #ffffff;
        border-radius: var(--kb-radius);
        padding: 14px 20px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .hud-tile {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-width: 72px;
    }

        .hud-tile .ht-val {
            font-size: 1.4rem;
            font-weight: 900;
            line-height: 1;
            color: var(--kb-gold-lt);
        }

        .hud-tile .ht-lbl {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            color: rgba(255,255,255,0.5);
            text-transform: uppercase;
            margin-top: 2px;
        }

    .hud-sep {
        width: 1px;
        height: 36px;
        background: rgba(255,255,255,0.12);
        margin: 0 4px;
    }

    /* Timer arc */
    .hud-timer-wrap {
        margin-left: auto;
        position: relative;
        width: 64px;
        height: 64px;
    }

    .hud-timer-svg {
        width: 100%;
        height: 100%;
        transform: rotate(-90deg);
    }

    .timer-track {
        fill: none;
        stroke: rgba(255,255,255,0.1);
        stroke-width: 5;
    }

    .timer-arc {
        fill: none;
        stroke: var(--kb-gold-lt);
        stroke-width: 5;
        stroke-linecap: round;
        transition: stroke-dashoffset 1s linear, stroke 0.3s;
    }

    .timer-text {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        font-weight: 900;
        color: #ffffff;
    }

    /* Streak bar */
    .streak-bar {
        display: flex;
        align-items: center;
        gap: 8px;
        background: var(--kb-surface);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-sm);
        padding: 10px 16px;
        margin-bottom: 18px;
        font-size: 0.82rem;
        color: var(--kb-dark);
    }

        .streak-bar .streak-val {
            font-weight: 900;
            color: var(--kb-gold);
            font-size: 1rem;
        }

    .streak-badge {
        display: none;
        background: var(--kb-gold-bg);
        border: 1.5px solid var(--kb-gold-bd);
        color: var(--kb-gold);
        font-size: 0.7rem;
        font-weight: 900;
        padding: 3px 10px;
        border-radius: 100px;
        letter-spacing: 0.1em;
        margin-left: auto;
        animation: kbPop 0.3s cubic-bezier(0.34,1.56,0.64,1);
    }

        .streak-badge.visible {
            display: inline-block;
        }

    /* Kana Card */
    .kana-card {
        background: var(--kb-bg);
        border: 2px solid var(--kb-border);
        border-radius: var(--kb-radius-lg);
        padding: 40px 24px 32px;
        text-align: center;
        margin-bottom: 20px;
        box-shadow: var(--kb-shadow-lg);
        transition: var(--kb-trans);
        position: relative;
        overflow: hidden;
        animation: kbSlideIn 0.35s cubic-bezier(0.34,1.56,0.64,1);
    }

        .kana-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--kb-gold), var(--kb-blue-lt));
        }

    .kana-char {
        font-size: clamp(4rem,14vw,7rem);
        font-weight: 900;
        color: var(--kb-black);
        line-height: 1;
        margin-bottom: 12px;
        display: block;
        letter-spacing: -0.02em;
        transition: transform 0.2s;
    }

    .kana-meaning {
        font-size: 0.82rem;
        color: var(--kb-muted);
        margin-bottom: 6px;
        font-weight: 600;
    }

    .kana-meta {
        display: flex;
        justify-content: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 8px;
    }

    .kana-tag {
        background: var(--kb-surface2);
        border: 1px solid var(--kb-border);
        border-radius: 100px;
        padding: 3px 12px;
        font-size: 0.67rem;
        font-weight: 700;
        color: var(--kb-dark);
        letter-spacing: 0.08em;
    }

        .kana-tag.gold {
            background: var(--kb-gold-bg);
            border-color: var(--kb-gold-bd);
            color: var(--kb-gold);
        }

        .kana-tag.blue {
            background: var(--kb-blue-bg);
            border-color: var(--kb-blue-bd);
            color: var(--kb-blue);
        }

    /* Fill-blank display */
    .fill-display {
        font-size: clamp(1.8rem,6vw,3rem);
        font-weight: 900;
        color: var(--kb-charcoal);
        margin: 12px 0 8px;
        letter-spacing: 0.06em;
        display: block;
    }

    .fill-blank {
        display: inline-block;
        min-width: 52px;
        border-bottom: 3px solid var(--kb-gold);
        color: var(--kb-gold);
        padding: 0 4px;
    }

    /* Answer Input */
    .answer-row {
        display: flex;
        gap: 10px;
        margin-bottom: 16px;
    }

    #answer-input {
        flex: 1;
        padding: 14px 18px;
        border-radius: var(--kb-radius);
        border: 2px solid var(--kb-border);
        font-size: 1.1rem;
        font-weight: 700;
        font-family: inherit;
        color: var(--kb-black);
        background: var(--kb-bg);
        transition: var(--kb-trans);
        outline: none;
    }

        #answer-input:focus {
            border-color: var(--kb-blue-lt);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
        }

        #answer-input.correct {
            border-color: var(--kb-green-lt);
            background: var(--kb-green-bg);
            color: var(--kb-green);
            box-shadow: 0 0 0 3px rgba(16,185,129,0.15);
        }

        #answer-input.incorrect {
            border-color: var(--kb-red-lt);
            background: var(--kb-red-bg);
            color: var(--kb-red);
            box-shadow: 0 0 0 3px rgba(239,68,68,0.15);
        }

    #btn-submit {
        padding: 14px 24px;
        border-radius: var(--kb-radius);
        border: none;
        background: linear-gradient(135deg, #0f172a, #1e40af);
        color: #ffffff;
        font-size: 0.9rem;
        font-weight: 900;
        cursor: pointer;
        transition: var(--kb-trans);
        letter-spacing: 0.06em;
        white-space: nowrap;
    }

        #btn-submit:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(30,64,175,0.3);
        }

        #btn-submit:active {
            transform: translateY(0);
        }

    /* Feedback flash */
    .feedback-flash {
        text-align: center;
        min-height: 28px;
        font-weight: 800;
        font-size: 0.92rem;
        margin-bottom: 12px;
        transition: var(--kb-trans);
    }

        .feedback-flash.correct {
            color: var(--kb-green-lt);
        }

        .feedback-flash.incorrect {
            color: var(--kb-red-lt);
        }

    /* Progress bar */
    .progress-wrap {
        background: var(--kb-surface2);
        border-radius: 100px;
        height: 8px;
        overflow: hidden;
        margin-bottom: 20px;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--kb-gold), var(--kb-blue-lt));
        border-radius: 100px;
        transition: width 0.4s cubic-bezier(0.4,0,0.2,1);
    }

    /* Multiple-choice buttons */
    .mc-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 16px;
    }

    .mc-btn {
        padding: 16px 12px;
        border-radius: var(--kb-radius);
        border: 2px solid var(--kb-border);
        background: var(--kb-bg);
        font-size: 0.92rem;
        font-weight: 800;
        color: var(--kb-charcoal);
        cursor: pointer;
        transition: var(--kb-trans);
        font-family: inherit;
        text-align: center;
    }

        .mc-btn:hover {
            border-color: var(--kb-blue-lt);
            background: var(--kb-blue-bg);
            transform: translateY(-1px);
        }

        .mc-btn.correct {
            border-color: var(--kb-green-lt);
            background: var(--kb-green-bg);
            color: var(--kb-green);
        }

        .mc-btn.incorrect {
            border-color: var(--kb-red-lt);
            background: var(--kb-red-bg);
            color: var(--kb-red);
        }

        .mc-btn:disabled {
            cursor: not-allowed;
            opacity: 0.7;
            transform: none;
        }

    /* Results Screen */
    #results-panel {
        display: none;
        background: var(--kb-surface);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-lg);
        padding: 40px 28px;
        text-align: center;
        box-shadow: var(--kb-shadow-lg);
        animation: kbFadeIn 0.45s ease;
    }

    .results-kana {
        font-size: 4rem;
        margin-bottom: 8px;
    }

    .results-title {
        font-size: 2rem;
        font-weight: 900;
        color: var(--kb-black);
        margin-bottom: 6px;
    }

    .results-subtitle {
        color: var(--kb-muted);
        font-size: 0.9rem;
        margin-bottom: 28px;
    }

    .results-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px,1fr));
        gap: 14px;
        margin-bottom: 28px;
    }

    .results-stat {
        background: var(--kb-bg);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius);
        padding: 18px 12px;
        text-align: center;
    }

        .results-stat .rs-val {
            font-size: 2rem;
            font-weight: 900;
            color: var(--kb-black);
            display: block;
        }

        .results-stat .rs-lbl {
            font-size: 0.67rem;
            font-weight: 700;
            color: var(--kb-muted);
            text-transform: uppercase;
            letter-spacing: 0.12em;
            margin-top: 4px;
            display: block;
        }

        .results-stat.gold-stat .rs-val {
            color: var(--kb-gold);
        }

        .results-stat.blue-stat .rs-val {
            color: var(--kb-blue-lt);
        }

        .results-stat.green-stat .rs-val {
            color: var(--kb-green-lt);
        }

    .pb-badge {
        display: none;
        background: var(--kb-gold-bg);
        border: 1.5px solid var(--kb-gold-bd);
        color: var(--kb-gold);
        border-radius: var(--kb-radius-sm);
        padding: 10px 18px;
        font-size: 0.82rem;
        font-weight: 800;
        margin-bottom: 20px;
        animation: kbPop 0.4s cubic-bezier(0.34,1.56,0.64,1);
    }

        .pb-badge.visible {
            display: block;
        }

    .results-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-primary {
        padding: 14px 28px;
        border-radius: var(--kb-radius);
        border: none;
        background: linear-gradient(135deg, #0f172a, #1e40af);
        color: #ffffff;
        font-size: 0.9rem;
        font-weight: 900;
        cursor: pointer;
        transition: var(--kb-trans);
        font-family: inherit;
        letter-spacing: 0.06em;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(30,64,175,0.3);
        }

    .btn-secondary {
        padding: 14px 28px;
        border-radius: var(--kb-radius);
        border: 2px solid var(--kb-border);
        background: var(--kb-bg);
        color: var(--kb-charcoal);
        font-size: 0.9rem;
        font-weight: 800;
        cursor: pointer;
        transition: var(--kb-trans);
        font-family: inherit;
    }

        .btn-secondary:hover {
            border-color: var(--kb-blue-lt);
            background: var(--kb-blue-bg);
            transform: translateY(-1px);
        }

    /* Countdown Overlay */
    #countdown-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(6px);
        z-index: 200;
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }

        #countdown-overlay.visible {
            display: flex;
        }

    .countdown-num {
        font-size: clamp(6rem,20vw,12rem);
        font-weight: 900;
        color: var(--kb-black);
        line-height: 1;
        animation: kbCountPulse 0.85s cubic-bezier(0.34,1.56,0.64,1);
    }

    .countdown-label {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--kb-muted);
        margin-top: 16px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
