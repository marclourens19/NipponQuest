@*
    ╔══════════════════════════════════════════════════════════════╗
    ║  KanaBlitz_View.cshtml  —  KanaBattle Lobby / Setup         ║
    ║  Controller : KanaBattleController → MainView()             ║
    ║  Route      : /KanaBattle/MainView                          ║
    ║  Launches   : /KanaBattle/Battle?difficulty=&script=        ║
    ╚══════════════════════════════════════════════════════════════╝
*@
@{
    ViewData["Title"] = "KanaBattle — Choose Your Battle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ── palette ── */
    :root {
        --bg: #0d0d1a;
        --panel: #12122a;
        --border: #2a2a55;
        --accent: #7c3aed;
        --accent2: #a855f7;
        --gold: #f59e0b;
        --green: #10b981;
        --red: #ef4444;
        --text: #e2e8f0;
        --muted: #94a3b8;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Segoe UI', sans-serif;
    }

    .lv-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 24px 16px;
    }

    /* ── hero ── */
    .hero {
        text-align: center;
        padding: 40px 20px;
    }

        .hero h1 {
            font-size: 2.8rem;
            font-weight: 900;
            letter-spacing: .06em;
            background: linear-gradient(135deg,#ef4444,#f59e0b,#a855f7);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero p {
            color: var(--muted);
            margin-top: 8px;
            font-size: 1rem;
            max-width: 560px;
            margin-inline: auto;
        }

    /* ── live stats bar ── */
    .live-stats {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
        margin: 16px 0 28px;
    }

    .stat-pill {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 8px 20px;
        font-size: .82rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .stat-pill .val {
            font-weight: 700;
            color: var(--gold);
        }

    /* ── section title ── */
    .section-title {
        font-size: .75rem;
        font-weight: 700;
        letter-spacing: .12em;
        color: var(--accent2);
        text-transform: uppercase;
        margin-bottom: 14px;
    }

    /* ── choice grid ── */
    .choice-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px,1fr));
        gap: 12px;
        margin-bottom: 28px;
    }

    .choice-card {
        background: #1a1a35;
        border: 2px solid var(--border);
        border-radius: 14px;
        padding: 18px 14px;
        cursor: pointer;
        transition: all .2s;
        text-align: center;
    }

        .choice-card:hover {
            border-color: var(--accent2);
            background: #1e1e40;
        }

        .choice-card.active {
            border-color: var(--accent);
            background: #2d1b6e;
            box-shadow: 0 0 18px rgba(124,58,237,.4);
        }

        .choice-card .icon {
            font-size: 2rem;
            margin-bottom: 8px;
        }

        .choice-card .label {
            font-weight: 700;
            font-size: 1rem;
        }

        .choice-card .sub {
            font-size: .74rem;
            color: var(--muted);
            margin-top: 4px;
        }

        .choice-card .tag {
            font-size: .7rem;
            color: var(--accent2);
            margin-top: 3px;
        }

    /* ── battle button ── */
    #btn-battle {
        display: block;
        width: 100%;
        padding: 18px;
        border-radius: 14px;
        border: none;
        font-size: 1.15rem;
        font-weight: 800;
        cursor: pointer;
        letter-spacing: .06em;
        background: linear-gradient(135deg,#ef4444,#f59e0b);
        color: #fff;
        transition: opacity .2s;
        margin-bottom: 32px;
    }

        #btn-battle:hover {
            opacity: .88;
        }

    /* ── info panels ── */
    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 20px;
    }

    @@media (max-width: 640px) {
        .info-grid {
            grid-template-columns: 1fr;
        }
    }

    .info-card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 22px 20px;
    }

        .info-card h3 {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 12px;
            color: var(--accent2);
        }

        .info-card p, .info-card li {
            font-size: .86rem;
            color: var(--muted);
            line-height: 1.65;
        }

        .info-card ul {
            padding-left: 18px;
        }

    /* ── rank table ── */
    .rank-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .84rem;
        margin-top: 10px;
    }

        .rank-table th {
            color: var(--accent2);
            text-align: left;
            padding: 6px 10px;
            border-bottom: 1px solid var(--border);
            font-size: .72rem;
            letter-spacing: .08em;
        }

        .rank-table td {
            padding: 8px 10px;
            border-bottom: 1px solid #1a1a35;
            color: var(--muted);
        }

        .rank-table tr:last-child td {
            border-bottom: none;
        }

    /* ── elo table ── */
    .elo-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .84rem;
        margin-top: 10px;
    }

        .elo-table th {
            color: var(--accent2);
            text-align: left;
            padding: 6px 10px;
            border-bottom: 1px solid var(--border);
            font-size: .72rem;
            letter-spacing: .08em;
        }

        .elo-table td {
            padding: 8px 10px;
            border-bottom: 1px solid #1a1a35;
            color: var(--muted);
        }

            .elo-table td:nth-child(2) {
                color: var(--green);
                font-weight: 700;
            }

            .elo-table td:nth-child(3) {
                color: var(--red);
                font-weight: 700;
            }

        .elo-table tr:last-child td {
            border-bottom: none;
        }

    /* ── how to play ── */
    .howto-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
        margin-top: 12px;
    }

    @@media (max-width: 700px) {
        .howto-grid {
            grid-template-columns: 1fr;
        }
    }

    .howto-item {
        background: #1a1a35;
        border-radius: 10px;
        padding: 14px;
    }

        .howto-item .h-icon {
            font-size: 1.5rem;
            margin-bottom: 6px;
        }

        .howto-item .h-name {
            font-weight: 700;
            font-size: .88rem;
            margin-bottom: 4px;
        }

        .howto-item .h-desc {
            font-size: .78rem;
            color: var(--muted);
            line-height: 1.55;
        }

    /* ── diff breakdown ── */
    .diff-row {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        padding: 12px 0;
        border-bottom: 1px solid #1a1a35;
    }

        .diff-row:last-child {
            border-bottom: none;
        }

        .diff-row .d-icon {
            font-size: 1.6rem;
            flex-shrink: 0;
        }

        .diff-row .d-name {
            font-weight: 700;
            font-size: .9rem;
        }

        .diff-row .d-desc {
            font-size: .8rem;
            color: var(--muted);
            margin-top: 3px;
            line-height: 1.5;
        }

    /* ── skill list ── */
    .skill-list {
        display: grid;
        gap: 10px;
        margin-top: 10px;
    }

    .skill-item {
        background: #1a1a35;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: .82rem;
        color: var(--muted);
        display: flex;
        gap: 10px;
        align-items: center;
    }

        .skill-item .s-icon {
            font-size: 1.2rem;
            flex-shrink: 0;
        }
</style>

<div class="lv-wrapper">

    <!-- HERO -->
    <div class="hero">
        <h1>⚔️ KanaBattle — Live Arena</h1>
        <p>
            Type romaji to attack your opponent — first to KO wins!<br>
            Collect power-up skills from falling kana to turn the tide.
        </p>
    </div>

    <!-- LIVE STATS BAR (decorative — real data via SignalR in future) -->
    <div class="live-stats">
        <div class="stat-pill">👥 Players online <span class="val" id="stat-online">—</span></div>
        <div class="stat-pill">⚔️ Matches today <span class="val" id="stat-matches">—</span></div>
        <div class="stat-pill">🏅 Your ELO <span class="val" id="stat-elo">—</span></div>
    </div>

    <!-- ① SCRIPT SELECTOR -->
    <div class="section-title">① Choose Your Script</div>
    <div class="choice-grid" id="script-grid">
        <div class="choice-card active" data-val="hiragana">
            <div class="icon">あ</div>
            <div class="label">Hiragana</div>
            <div class="sub">46 characters</div>
            <div class="tag">Core native script</div>
        </div>
        <div class="choice-card" data-val="katakana">
            <div class="icon">ア</div>
            <div class="label">Katakana</div>
            <div class="sub">46 characters</div>
            <div class="tag">Foreign &amp; tech words</div>
        </div>
        <div class="choice-card" data-val="dakuten">
            <div class="icon">が</div>
            <div class="label">Dakuten</div>
            <div class="sub">Voiced marks</div>
            <div class="tag">Advanced variant sounds</div>
        </div>
        <div class="choice-card" data-val="mixed">
            <div class="icon">混</div>
            <div class="label">Mixed</div>
            <div class="sub">All scripts</div>
            <div class="tag">Ultimate challenge</div>
        </div>
    </div>

    <!-- ② DIFFICULTY SELECTOR -->
    <div class="section-title">② Choose Intensity</div>
    <div class="choice-grid" id="diff-grid">
        <div class="choice-card" data-val="easy">
            <div class="icon">🌿</div>
            <div class="label">Easy</div>
            <div class="sub">Relaxed pace</div>
            <div class="tag">3 min · ±12 ELO</div>
        </div>
        <div class="choice-card active" data-val="normal">
            <div class="icon">⚡</div>
            <div class="label">Normal</div>
            <div class="sub">Balanced</div>
            <div class="tag">2:15 · ±20 ELO</div>
        </div>
        <div class="choice-card" data-val="hard">
            <div class="icon">🔥</div>
            <div class="label">Hard</div>
            <div class="sub">Fast &amp; furious</div>
            <div class="tag">1:45 · ±32 ELO</div>
        </div>
        <div class="choice-card" data-val="insanity">
            <div class="icon">💀</div>
            <div class="label">Insanity</div>
            <div class="sub">No mercy</div>
            <div class="tag">1:30 · ±50 ELO</div>
        </div>
    </div>

    <!-- SUMMARY + BATTLE BUTTON -->
    <div style="text-align:center;color:var(--muted);font-size:.9rem;margin-bottom:16px;">
        Selected: <span id="sel-script" style="color:#a855f7;font-weight:700;">Hiragana</span>
        &nbsp;·&nbsp;
        <span id="sel-diff" style="color:#f59e0b;font-weight:700;">Normal</span>
        &nbsp;·&nbsp;
        <span id="sel-elo" style="color:#10b981;font-weight:700;">±20 ELO</span>
    </div>

    <!-- Routes to KanaBattleController.Battle(difficulty, script) -->
    <button id="btn-battle" onclick="launchBattle()">⚔️ ENTER THE ARENA</button>

    <!-- INFO PANELS -->
    <div class="info-grid">

        <!-- Rank table -->
        <div class="info-card">
            <h3>🏆 League Ranks</h3>
            <p style="margin-bottom:10px">Win battles to earn ELO and climb the ranks. Each rank unlocks new titles and profile badges.</p>
            <table class="rank-table">
                <thead><tr><th>Rank</th><th>ELO Range</th><th>Badge</th></tr></thead>
                <tbody>
                    <tr><td>🌱 Seedling</td><td>0 – 499</td><td>Bronze Frame</td></tr>
                    <tr><td>🌿 Apprentice</td><td>500 – 999</td><td>Silver Frame</td></tr>
                    <tr><td>⚡ Adept</td><td>1000 – 1499</td><td>Gold Frame</td></tr>
                    <tr><td>🔥 Veteran</td><td>1500 – 1999</td><td>Flame Frame</td></tr>
                    <tr><td>💀 Master</td><td>2000+</td><td>Oni Frame</td></tr>
                </tbody>
            </table>
        </div>

        <!-- ELO table -->
        <div class="info-card">
            <h3>📊 ELO &amp; Matchmaking</h3>
            <p style="margin-bottom:10px">KanaBattle uses an ELO rating system. Win → gain ELO. Lose → lose ELO. Amount depends on difficulty:</p>
            <table class="elo-table">
                <thead><tr><th>Difficulty</th><th>Win</th><th>Loss</th><th>Duration</th></tr></thead>
                <tbody>
                    <tr><td>🌿 Easy</td><td>+12</td><td>-8</td><td>3 min</td></tr>
                    <tr><td>⚡ Normal</td><td>+20</td><td>-15</td><td>2:15</td></tr>
                    <tr><td>🔥 Hard</td><td>+32</td><td>-24</td><td>1:45</td></tr>
                    <tr><td>💀 Insanity</td><td>+50</td><td>-38</td><td>1:30</td></tr>
                </tbody>
            </table>
        </div>

    </div>

    <!-- Matchmaking note -->
    <div class="info-card" style="margin-bottom:20px">
        <h3>🤖 Current Matchmaking</h3>
        <p>
            All battles are currently fought against AI opponents tuned to the difficulty you select.
            The AI difficulty scales precisely — Easy AI is patient and slow, while Insanity AI attacks relentlessly with double strikes.
            Real multiplayer with ELO-based matchmaking is coming in a future update!
        </p>
    </div>

    <!-- How to play -->
    <div class="info-card" style="margin-bottom:20px">
        <h3>📖 How To Play — Battle Mechanics</h3>
        <div class="howto-grid">
            <div class="howto-item">
                <div class="h-icon">⚔️</div>
                <div class="h-name">Core Combat Loop</div>
                <div class="h-desc">
                    Kana cards fall from the top of the arena. Type the romaji answer (e.g. "ka" for か) and press Enter or tap Attack to deal damage.
                    The faster you answer, the more damage you deal. Build combos by answering correctly in a row.
                </div>
            </div>
            <div class="howto-item">
                <div class="h-icon">🤖</div>
                <div class="h-name">AI Opponent</div>
                <div class="h-desc">
                    Your AI opponent attacks on a timer. Difficulty controls both how fast kana falls AND how often the AI attacks.
                    On Insanity, the AI can double-strike and gains sword buffs. If kana reaches the bottom unanswered, you take chip damage.
                </div>
            </div>
            <div class="howto-item">
                <div class="h-icon">❤️</div>
                <div class="h-name">HP &amp; Winning</div>
                <div class="h-desc">
                    Both you and the opponent start with 1000 HP. Reduce the opponent's HP to 0 to win.
                    If your HP reaches 0, you lose. If time runs out, the player with more HP wins.
                    Wrong answers deal small self-damage — accuracy matters!
                </div>
            </div>
        </div>
    </div>

    <!-- Difficulty breakdown -->
    <div class="info-card" style="margin-bottom:20px">
        <h3>🗓️ Difficulty Breakdown</h3>
        <div class="diff-row">
            <div class="d-icon">🌿</div>
            <div>
                <div class="d-name">Easy</div>
                <div class="d-desc">
                    Slow fall speed, AI attacks every ~4 s, low damage. Great for beginners. 3 minute matches.
                    Words sourced from <code>easy</code> difficulty entries in the database.
                </div>
            </div>
        </div>
        <div class="diff-row">
            <div class="d-icon">⚡</div>
            <div>
                <div class="d-name">Normal</div>
                <div class="d-desc">
                    Medium fall speed, AI attacks every ~2.7 s. Balanced damage. 2:15 matches.
                    Words sourced from <code>normal</code> difficulty entries.
                </div>
            </div>
        </div>
        <div class="diff-row">
            <div class="d-icon">🔥</div>
            <div>
                <div class="d-name">Hard</div>
                <div class="d-desc">
                    Fast fall speed, AI attacks every ~1.7 s. Higher damage. Sword buffs for AI. 1:45 matches.
                    Words sourced from <code>hard</code> difficulty entries.
                </div>
            </div>
        </div>
        <div class="diff-row">
            <div class="d-icon">💀</div>
            <div>
                <div class="d-name">Insanity</div>
                <div class="d-desc">
                    Extreme speed, AI attacks every ~0.9 s with double strikes. Maximum chaos. 1:30 matches.
                    Words sourced from <code>insanity</code> difficulty entries including kanji.
                </div>
            </div>
        </div>
    </div>

    <!-- Skills -->
    <div class="info-card" style="margin-bottom:20px">
        <h3>✨ Skills &amp; Power-Ups</h3>
        <p style="margin-bottom:10px">
            Some falling kana carry special power-up skills (shown with a glowing border).
            Answer them correctly to activate the skill. Wrong answers on skill kana do NOT activate the skill.
        </p>
        <div class="skill-list">
            <div class="skill-item"><span class="s-icon">🛡️</span><strong>Shield</strong> — absorbs the next AI attack completely.</div>
            <div class="skill-item"><span class="s-icon">⚡</span><strong>Speed Boost</strong> — your next 3 answers deal 1.5× damage.</div>
            <div class="skill-item"><span class="s-icon">❤️</span><strong>Heal</strong> — restores 100 HP instantly.</div>
            <div class="skill-item"><span class="s-icon">🗡️</span><strong>Critical Strike</strong> — next answer deals 3× damage regardless of speed.</div>
        </div>
    </div>

    <!-- Combo system -->
    <div class="info-card" style="margin-bottom:20px">
        <h3>🔥 Combo System</h3>
        <p>
            Answer correctly in a row to build your combo streak. Each combo level adds 5% bonus damage (up to 25× = 2.25× total).
            On top of combos, answer quickly for a speed bonus.<br><br>
            At streak ≥ 4 you get ⚡ &nbsp;|&nbsp; ≥ 7 you get 🔥 &nbsp;|&nbsp; ≥ 12 you get 💥<br><br>
            Wrong answer resets your streak to 0.
        </p>
    </div>

</div><!-- /lv-wrapper -->

<script>
    // ══════════════════════════════════════════════════════════════
    //  KanaBlitz_View — Lobby / Setup  (KanaBattleController.MainView)
    //  Launches → KanaBattleController.Battle(difficulty, script)
    // ══════════════════════════════════════════════════════════════

    let selectedScript = 'hiragana';
    let selectedDiff   = 'normal';

    // ── ELO map (matches DbInitializer difficulty labels) ──
    const ELO_MAP = { easy: '±12', normal: '±20', hard: '±32', insanity: '±50' };

    // Script selector
    document.querySelectorAll('#script-grid .choice-card').forEach(card => {
        card.addEventListener('click', () => {
            document.querySelectorAll('#script-grid .choice-card').forEach(c => c.classList.remove('active'));
            card.classList.add('active');
            selectedScript = card.dataset.val;
            updateSummary();
        });
    });

    // Difficulty selector
    document.querySelectorAll('#diff-grid .choice-card').forEach(card => {
        card.addEventListener('click', () => {
            document.querySelectorAll('#diff-grid .choice-card').forEach(c => c.classList.remove('active'));
            card.classList.add('active');
            selectedDiff = card.dataset.val;
            updateSummary();
        });
    });

    function updateSummary() {
        document.getElementById('sel-script').textContent = capitalize(selectedScript);
        document.getElementById('sel-diff').textContent   = capitalize(selectedDiff);
        document.getElementById('sel-elo').textContent    = ELO_MAP[selectedDiff] + ' ELO';
    }

    // Launch → KanaBattleController.Battle(difficulty, script)
    // Route: /KanaBattle/Battle?difficulty={diff}&script={script}
    function launchBattle() {
        const url = `/KanaBattle/Battle?difficulty=${encodeURIComponent(selectedDiff)}&script=${encodeURIComponent(selectedScript)}`;
        window.location.href = url;
    }

    function capitalize(str) {
        return str ? str.charAt(0).toUpperCase() + str.slice(1) : str;
    }

    // Fetch live ELO from user profile (if authenticated)
    // Route: /KanaBlitz/GetPlayerStats
    async function loadLiveStats() {
        try {
            const res = await fetch('/KanaBlitz/GetPlayerStats');
            if (!res.ok) return;
            const d = await res.json();
            if (d.elo !== undefined)
                document.getElementById('stat-elo').textContent = d.elo;
            if (d.matchesToday !== undefined)
                document.getElementById('stat-matches').textContent = d.matchesToday;
            if (d.playersOnline !== undefined)
                document.getElementById('stat-online').textContent = d.playersOnline;
        } catch { /* silently ignore if endpoint not available */ }
    }
    loadLiveStats();
</script>
