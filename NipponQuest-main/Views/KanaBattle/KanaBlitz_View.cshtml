        </div>

    </div>
</div>

<!-- ── Loading Overlay ── -->
<div id="loading-overlay">
    <div class="spinner"></div>
    <div class="loading-text">Preparing arena...</div>
</div>

@section Scripts {
    <script>
        /*
         * ═══════════════════════════════════════════════════════════════
         *  KanaBlitz_View — Battle Hub / Lobby
         *  Handles script & difficulty selection, word count validation,
         *  and launches the battle arena at /KanaBattle/Battle
         * ═══════════════════════════════════════════════════════════════
         */

        'use strict';

        const MIN_WORDS = 5;

        // Current selections
        let sel = { script: 'hiragana', diff: 'easy' };

        // Word count cache
        const wCache = {};

        // ── DOM ──────────────────────────────────────────────────────────
        const $$ = id => document.getElementById(id);

        // ── Script / Diff selection ──────────────────────────────────────
        function selectScript(val, el) {
            sel.script = val;
            document.querySelectorAll('#grid-script .choice-card').forEach(c => c.classList.remove('active'));
            el.classList.add('active');
            updateWordCounts();
            validateSelection();
        }

        function selectDiff(val, el) {
            sel.diff = val;
            document.querySelectorAll('#grid-diff .choice-card').forEach(c => c.classList.remove('active'));
            el.classList.add('active');
            validateSelection();
        }

        // ── Word count fetch (with caching) ─────────────────────────────
        async function fetchCount(diff, script) {
            const key = `${diff}|${script}`;
            if (wCache[key] !== undefined) return wCache[key];
            try {
                const r = await fetch(`/KanaBlitz/GetWords?difficulty=${encodeURIComponent(diff)}&script=${encodeURIComponent(script)}`);
                if (!r.ok) return 0;
                const d = await r.json();
                const c = Array.isArray(d) ? d.length : 0;
                wCache[key] = c;
                return c;
            } catch {
                return 0;
            }
        }

        // ── Update all difficulty word counts for current script ─────────
        async function updateWordCounts() {
            const diffs = ['easy', 'normal', 'hard', 'insanity'];

            // Update total stat pill
            let totalForScript = 0;

            for (const d of diffs) {
                const cnt = await fetchCount(d, sel.script);
                totalForScript += cnt;

                const el    = $$(`cnt-${d}`);
                const card  = el ? el.closest('.choice-card') : null;

                if (el) el.textContent = cnt > 0 ? `${cnt} words` : 'No words';

                if (card) {
                    const ok = cnt >= MIN_WORDS;
                    card.style.opacity = ok ? '' : '0.45';
                    card.style.cursor  = ok ? '' : 'not-allowed';
                    card.title = ok ? '' : `Not enough words (${cnt}/${MIN_WORDS} minimum)`;
                }
            }

            const statEl = $$('stat-words');
            if (statEl) statEl.textContent = totalForScript;
        }

        // ── Validate current selection ───────────────────────────────────
        async function validateSelection() {
            const cnt = await fetchCount(sel.diff, sel.script);
            const ok  = cnt >= MIN_WORDS;

            const warningEl = $$('word-warning');
            const textEl    = $$('warning-text');
            const btn       = $$('btn-battle');

            if (warningEl) warningEl.classList.toggle('visible', !ok);
            if (!ok && textEl) {
                textEl.textContent = `Only ${cnt} word(s) for "${sel.diff}" + "${sel.script}". Minimum ${MIN_WORDS} required. Try another combination.`;
            }
            if (btn) btn.disabled = !ok;
            return ok;
        }

        // ── Launch battle ────────────────────────────────────────────────
        async function launchBattle() {
            const ok = await validateSelection();
            if (!ok) return;

            const overlay = $$('loading-overlay');
            if (overlay) overlay.classList.add('show');

            // Navigate to battle arena with selected params
            // Route: /KanaBattle/Battle?difficulty=&script=
            const url = `/KanaBattle/Battle?difficulty=${encodeURIComponent(sel.diff)}&script=${encodeURIComponent(sel.script)}`;
            window.location.href = url;
        }

        // ── Init ──────────────────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', () => {
            updateWordCounts();
            validateSelection();

            // Keyboard shortcut: Enter to launch
            document.addEventListener('keydown', e => {
                if (e.key === 'Enter') {
                    const btn = $$('btn-battle');
                    if (btn && !btn.disabled) launchBattle();
                }
            });
        });
    </script>
}
