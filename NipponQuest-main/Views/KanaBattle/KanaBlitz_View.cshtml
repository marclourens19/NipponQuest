@model NipponQuest.Models.KanaBattleModel
@{
    ViewData["Title"] = "KanaBattle Arena";
    Layout = null;
    var script = Model?.Script ?? "hiragana";
    var diff = Model?.Difficulty ?? "normal";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <style>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0
            }

            body {
                font-family: 'Nunito', sans-serif;
                background: #020617;
                color: #e2e8f0;
                min-height: 100vh;
                overflow-x: hidden
            }

            .container {
                max-width: 860px;
                margin: 0 auto;
                padding: 1rem;
                position: relative;
                z-index: 10
            }

            .ct {
                padding-bottom: .5rem
            }

            .bl {
                position: fixed;
                inset: 0;
                z-index: 0;
                pointer-events: none
            }

            .ba2 {
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg,#020617,#2d1b4b15,#0f172a);
                background-size: 300% 300%;
                animation: au 12s ease infinite
            }

            .bv {
                position: fixed;
                inset: 0;
                pointer-events: none;
                z-index: 1;
                box-shadow: inset 0 0 120px rgba(0,0,0,.55)
            }

            .pt {
                position: absolute;
                border-radius: 50%;
                animation: pf linear infinite;
                opacity: 0
            }

            @@keyframes au {
                0% {
                    background-position: 0% 50%
                }

                50% {
                    background-position: 100% 50%
                }

                100% {
                    background-position: 0% 50%
                }
            }

            @@keyframes pf {
                0% {
                    transform: translateY(0);
                    opacity: 0
                }

                10% {
                    opacity: 1
                }

                90% {
                    opacity: 1
                }

                100% {
                    transform: translateY(-400px);
                    opacity: 0
                }
            }

            @@keyframes su {
                0% {
                    opacity: 0;
                    transform: translateY(14px)
                }

                100% {
                    opacity: 1;
                    transform: translateY(0)
                }
            }

            .su {
                animation: su .4s ease both
            }

            @@keyframes pu {
                0%, 100% {
                    opacity: 1
                }

                50% {
                    opacity: .4
                }
            }

            @@keyframes sk {
                0%, 100% {
                    transform: translateX(0)
                }

                15% {
                    transform: translateX(-4px)
                }

                30% {
                    transform: translateX(4px)
                }

                45% {
                    transform: translateX(-3px)
                }

                60% {
                    transform: translateX(3px)
                }
            }

            @@keyframes cp {
                0% {
                    transform: scale(.5);
                    opacity: 0
                }

                50% {
                    transform: scale(1.2)
                }

                100% {
                    transform: scale(1);
                    opacity: 1
                }
            }

            @@keyframes fu {
                0% {
                    transform: translateY(0);
                    opacity: 1
                }

                100% {
                    transform: translateY(-60px);
                    opacity: 0
                }
            }

            @@keyframes fi {
                0% {
                    transform: translateY(-12px);
                    opacity: 0
                }

                100% {
                    transform: translateY(0);
                    opacity: 1
                }
            }

            @@keyframes ar {
                0% {
                    transform: translate(0,0) scale(1);
                    opacity: 1
                }

                60% {
                    transform: translate(80px,-10px) scale(1.4);
                    opacity: 1
                }

                100% {
                    transform: translate(160px,-20px) scale(.4);
                    opacity: 0
                }
            }

            @@keyframes al {
                0% {
                    transform: translate(0,0) scale(1);
                    opacity: 1
                }

                60% {
                    transform: translate(-80px,-10px) scale(1.4);
                    opacity: 1
                }

                100% {
                    transform: translate(-160px,-20px) scale(.4);
                    opacity: 0
                }
            }

            @@keyframes skpop {
                0% {
                    transform: translate(-50%,-50%) scale(.5);
                    opacity: 0
                }

                30% {
                    transform: translate(-50%,-50%) scale(1.2);
                    opacity: 1
                }

                100% {
                    transform: translate(-50%,-50%) scale(1);
                    opacity: 0
                }
            }

            @@keyframes confetti-fall {
                0% {
                    transform: translateY(-10px) rotate(0deg);
                    opacity: 1
                }

                100% {
                    transform: translateY(110vh) rotate(720deg);
                    opacity: 0
                }
            }

            @@keyframes hp-flash {
                0% {
                    filter: brightness(1)
                }

                50% {
                    filter: brightness(2)
                }

                100% {
                    filter: brightness(1)
                }
            }

            @@keyframes char-attack-r {
                0% {
                    transform: translateX(0)
                }

                30% {
                    transform: translateX(30px) scaleX(1.1)
                }

                60% {
                    transform: translateX(60px)
                }

                100% {
                    transform: translateX(0)
                }
            }

            @@keyframes char-attack-l {
                0% {
                    transform: translateX(0)
                }

                30% {
                    transform: translateX(-30px) scaleX(1.1)
                }

                60% {
                    transform: translateX(-60px)
                }

                100% {
                    transform: translateX(0)
                }
            }

            @@keyframes char-hit {
                0%, 100% {
                    transform: translateX(0)
                }

                25% {
                    transform: translateX(-8px)
                }

                50% {
                    transform: translateX(8px)
                }

                75% {
                    transform: translateX(-4px)
                }
            }

            .sf {
                position: fixed;
                inset: 0;
                z-index: 50;
                pointer-events: none;
                transition: opacity .18s;
                opacity: 0
            }

            .sfs {
                opacity: 1
            }

            .green {
                background: radial-gradient(circle,rgba(16,185,129,.28),transparent 65%)
            }

            .red {
                background: radial-gradient(circle,rgba(239,68,68,.28),transparent 65%)
            }

            .ae {
                position: fixed;
                top: 38%;
                font-size: 3.5rem;
                pointer-events: none;
                z-index: 45
            }

            .aep {
                left: 25%;
                animation: ar .55s ease-out forwards
            }

            .aeo {
                right: 25%;
                animation: al .55s ease-out forwards
            }

            .aet {
                filter: drop-shadow(0 0 12px rgba(255,255,255,.3))
            }

            .dp {
                position: fixed;
                top: 28%;
                left: 50%;
                transform: translateX(-50%);
                font-size: 2.4rem;
                font-weight: 900;
                pointer-events: none;
                z-index: 46;
                animation: fu .9s ease-out forwards;
                text-shadow: 0 2px 8px rgba(0,0,0,.5)
            }

            .dpp {
                color: #ef4444;
                text-shadow: 0 0 16px rgba(239,68,68,.7)
            }

            .dpe {
                color: #34d399;
                text-shadow: 0 0 16px rgba(16,185,129,.7)
            }

            .skp {
                position: fixed;
                top: 50%;
                left: 50%;
                transform: translate(-50%,-50%);
                font-size: 1.6rem;
                font-weight: 900;
                pointer-events: none;
                z-index: 48;
                animation: skpop 1.4s ease-out forwards;
                text-shadow: 0 0 20px currentColor;
                display: flex;
                align-items: center;
                gap: .4rem
            }

            .skpi {
                font-size: 2.5rem
            }

            .ifb {
                background: rgba(15,23,42,.92);
                border: 1px solid rgba(239,68,68,.15);
                border-radius: 1.2rem;
                padding: 2rem 2.5rem;
                text-align: center;
                max-width: 400px;
                width: 100%
            }

            .ift {
                font-size: 1.5rem;
                font-weight: 900;
                color: #fff;
                margin-bottom: .3rem
            }

            .ifs {
                color: #64748b;
                font-size: .78rem;
                font-weight: 700;
                margin-bottom: 1rem
            }

            .avr {
                display: flex;
                justify-content: center;
                align-items: center;
                gap: 1.2rem;
                margin-bottom: .8rem
            }

            .avc {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: .15rem
            }

            .avi {
                width: 52px;
                height: 52px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.6rem
            }

            .avc span {
                font-size: .48rem;
                font-weight: 900;
                text-transform: uppercase
            }

            .avvs {
                font-size: 1rem;
                font-weight: 900;
                color: #ef4444
            }

            .ifc {
                font-size: .55rem;
                color: #475569;
                font-weight: 700
            }

            .cdn {
                font-size: 7rem;
                font-weight: 900;
                color: #ef4444;
                animation: cp .5s ease-out both;
                text-align: center
            }

            .cds {
                color: #64748b;
                font-size: .72rem;
                font-weight: 700;
                text-align: center;
                margin-top: .5rem
            }

            .ah {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: .35rem
            }

            .ex {
                display: flex;
                align-items: center;
                gap: .2rem;
                padding: .25rem .5rem;
                border-radius: 999px;
                background: rgba(15,23,42,.7);
                border: 1px solid #1e293b;
                color: #64748b;
                font-size: .48rem;
                font-weight: 900;
                letter-spacing: 1px;
                text-transform: uppercase;
                cursor: pointer;
                font-family: inherit;
                transition: all .2s
            }

                .ex:hover {
                    background: rgba(127,29,29,.25);
                    border-color: rgba(239,68,68,.25);
                    color: #fca5a5
                }

            .at {
                display: flex;
                gap: .2rem;
                align-items: center
            }

                .at span {
                    padding: .15rem .35rem;
                    border-radius: .3rem;
                    background: rgba(15,23,42,.6);
                    border: 1px solid #1e293b;
                    font-size: .42rem;
                    font-weight: 700
                }

            .hud {
                background: rgba(15,23,42,.75);
                backdrop-filter: blur(10px);
                border: 1px solid #1e293b;
                border-radius: .8rem;
                padding: .5rem .7rem;
                margin-bottom: .35rem
            }

            .tb2 {
                height: 4px;
                background: #0f172a;
                border-radius: 2px;
                overflow: hidden;
                margin-bottom: .35rem
            }

            .tbf {
                height: 100%;
                border-radius: 2px;
                transition: width .3s linear
            }

            .hr {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: .3rem
            }

            .pi {
                flex: 1;
                display: flex;
                flex-direction: column;
                gap: .1rem
            }

            .po {
                text-align: right;
                align-items: flex-end
            }

            .pn {
                font-size: .52rem;
                font-weight: 900;
                letter-spacing: 1px;
                text-transform: uppercase
            }

            .hpb {
                width: 100%;
                height: 9px;
                background: #0f172a;
                border-radius: 4px;
                overflow: hidden
            }

            .hpf {
                height: 100%;
                border-radius: 4px;
                transition: width .3s, background .3s
            }

            .hpt {
                font-size: .45rem;
                font-weight: 700;
                color: #475569
            }

            .pup {
                display: flex;
                gap: .15rem;
                font-size: .55rem;
                margin-top: .05rem;
                flex-wrap: wrap
            }

            .po .pup {
                justify-content: flex-end
            }

            .pub {
                animation: pu .6s infinite;
                display: flex;
                align-items: center;
                gap: 1px;
                font-size: .5rem;
                font-weight: 900
            }

            .tmw {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: .15rem;
                min-width: 60px
            }

            .tm {
                font-size: 1.3rem;
                font-weight: 900;
                font-variant-numeric: tabular-nums
            }

            .cb2 {
                font-size: .42rem;
                font-weight: 900;
                padding: .12rem .35rem;
                border-radius: 999px
            }

            .cl {
                background: rgba(245,158,11,.2);
                color: #fcd34d;
                border: 1px solid rgba(245,158,11,.2)
            }

            .ch2 {
                background: linear-gradient(135deg,#f59e0b,#ea580c);
                color: #fff
            }

            .cm {
                background: linear-gradient(135deg,#ef4444,#f59e0b);
                color: #fff;
                animation: pu .35s infinite
            }

            .arena {
                position: relative;
                height: 290px;
                background: linear-gradient(180deg,rgba(10,15,30,.95),rgba(20,30,50,.7));
                border: 1px solid #1e293b;
                border-radius: .8rem;
                overflow: hidden;
                margin-bottom: .35rem
            }

                .arena.arh {
                    border-color: rgba(239,68,68,.3)
                }

            .arena-floor {
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: rgba(239,68,68,.15)
            }

            .ch3 {
                position: absolute;
                bottom: 6px;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: .08rem;
                transition: transform .15s
            }

            .cp {
                left: 3%
            }

            .co {
                right: 3%
            }

            .ca {
                font-size: 2.8rem;
                filter: drop-shadow(0 3px 6px rgba(0,0,0,.4))
            }

            .cn {
                font-size: .42rem;
                font-weight: 900;
                letter-spacing: 1px;
                text-transform: uppercase;
                background: rgba(10,15,30,.7);
                padding: .08rem .3rem;
                border-radius: .2rem
            }

            .chh .ca {
                filter: drop-shadow(0 0 16px rgba(239,68,68,.6)) brightness(1.4);
                animation: char-hit .3s ease
            }

            .ch3.attacking-r {
                animation: char-attack-r .4s ease
            }

            .ch3.attacking-l {
                animation: char-attack-l .4s ease
            }

            .avs {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%,-50%);
                font-size: .7rem;
                font-weight: 900;
                color: rgba(239,68,68,.15);
                letter-spacing: 4px
            }

            .fw {
                position: absolute;
                transform: translateX(-50%);
                display: flex;
                flex-direction: column;
                align-items: center;
                padding: .3rem .55rem;
                background: rgba(10,15,30,.92);
                border: 2px solid #1e293b;
                border-radius: .7rem;
                cursor: default;
                animation: fi .25s ease-out;
                backdrop-filter: blur(4px);
                min-width: 44px
            }

            .fwa {
                border-color: #0ea5e9;
                box-shadow: 0 0 16px rgba(14,165,233,.3)
            }

            .fwsk {
                box-shadow: 0 0 14px rgba(255,255,255,.1)
            }

            .fwdanger {
                border-color: rgba(239,68,68,.6) !important;
                box-shadow: 0 0 12px rgba(239,68,68,.2)
            }

            .fk {
                font-size: 1.85rem;
                font-weight: 900;
                color: #fff;
                line-height: 1;
                transition: color .15s
            }

            .ft {
                font-size: .52rem;
                font-weight: 900;
                color: #0ea5e9;
                letter-spacing: 1px;
                margin-top: .03rem
            }

            .fsi {
                font-size: .8rem;
                line-height: 1;
                margin-top: .1rem
            }

            .fw-meaning {
                font-size: .42rem;
                font-weight: 700;
                color: #64748b;
                margin-top: .05rem;
                text-align: center;
                max-width: 80px
            }

            .clg {
                position: absolute;
                bottom: 6px;
                left: 50%;
                transform: translateX(-50%);
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 1px;
                pointer-events: none
            }

            .cli {
                font-size: .42rem;
                font-weight: 800;
                padding: .08rem .35rem;
                border-radius: .2rem;
                background: rgba(0,0,0,.6);
                white-space: nowrap;
                animation: fi .2s ease-out
            }

            .ia {
                background: rgba(15,23,42,.85);
                backdrop-filter: blur(12px);
                border: 1px solid #1e293b;
                border-radius: .8rem;
                padding: .6rem .7rem
            }

            .iaf {
                display: flex;
                flex-direction: column;
                gap: .4rem
            }

            .tgt {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: .5rem;
                flex-wrap: wrap;
                min-height: 1.8rem
            }

            .tgl {
                font-size: .45rem;
                font-weight: 900;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: #475569
            }

            .tgk {
                font-size: 2.4rem;
                font-weight: 900;
                line-height: 1
            }

            .tgm {
                font-size: .5rem;
                font-weight: 700;
                color: #64748b
            }

            .tgsk {
                font-size: .45rem;
                font-weight: 900;
                padding: .12rem .4rem;
                border-radius: 999px;
                border: 1px solid;
                display: flex;
                align-items: center;
                gap: .2rem
            }

            .ir {
                display: flex;
                gap: .35rem
            }

            .ii {
                flex: 1;
                padding: .55rem .7rem;
                border-radius: .6rem;
                border: 2px solid #1e293b;
                background: rgba(2,6,23,.7);
                color: #fff;
                font-size: 1.1rem;
                font-weight: 700;
                font-family: inherit;
                text-align: center;
                outline: none;
                transition: border-color .15s;
                letter-spacing: 2px
            }

                .ii:focus {
                    border-color: #0ea5e9;
                    box-shadow: 0 0 12px rgba(14,165,233,.12)
                }

                .ii:disabled {
                    opacity: .25;
                    cursor: not-allowed
                }

                .ii::placeholder {
                    color: #1e293b;
                    letter-spacing: 0
                }

            .ib {
                padding: .55rem 1rem;
                border-radius: .6rem;
                border: none;
                background: linear-gradient(135deg,#ef4444,#b91c1c);
                color: #fff;
                font-weight: 900;
                font-size: .7rem;
                letter-spacing: 1px;
                cursor: pointer;
                transition: all .18s;
                font-family: inherit;
                white-space: nowrap
            }

                .ib:hover:not(:disabled) {
                    transform: translateY(-1px);
                    box-shadow: 0 4px 14px rgba(239,68,68,.3)
                }

                .ib:disabled {
