@*
    ╔══════════════════════════════════════════════════════════════════╗
    ║  KanaBlitz_View.cshtml  —  KanaBattle Hub / Lobby & Setup       ║
    ║  Controller : KanaBattleController → MainView()                 ║
    ║  Route      : /KanaBattle/MainView                              ║
    ║  Launches   : /KanaBattle/Battle?difficulty=&script=            ║
    ║  Refactored : Full audit, debug, redesign & UX overhaul         ║
    ╚══════════════════════════════════════════════════════════════════╝
*@
@{
    ViewData["Title"] = "KanaBattle — Choose Your Battle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ═══════════════════════════════════════════════
           NIPPONQUEST DESIGN TOKENS — KanaBattle Hub
           Matches site.css palette & Nunito font stack
        ═══════════════════════════════════════════════ */
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');

    :root {
        --nq-bg: #0b0b18;
        --nq-surface: #12122a;
        --nq-surface2: #1a1a38;
        --nq-border: #2a2a55;
        --nq-border2: #3a3a6a;
        --nq-accent: #7c3aed;
        --nq-accent2: #a855f7;
        --nq-pink: #ec4899;
        --nq-gold: #f59e0b;
        --nq-green: #10b981;
        --nq-red: #ef4444;
        --nq-blue: #0ea5e9;
        --nq-text: #e2e8f0;
        --nq-muted: #94a3b8;
        --nq-faint: #64748b;
        --nq-radius: 14px;
        --nq-radius-sm: 10px;
        --nq-radius-lg: 20px;
        --nq-transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .lv-page {
        background: var(--nq-bg);
        min-height: 100vh;
        color: var(--nq-text);
        font-family: 'Nunito', 'Segoe UI', sans-serif;
        padding-bottom: 80px;
    }

        /* ── Ambient gradient ── */
        .lv-page::before {
            content: '';
            position: fixed;
            inset: 0;
            background: radial-gradient(ellipse 80% 60% at 10% 10%, rgba(239,68,68,0.05) 0%, transparent 55%), radial-gradient(ellipse 70% 50% at 90% 80%, rgba(124,58,237,0.06) 0%, transparent 55%), radial-gradient(ellipse 60% 40% at 50% 50%, rgba(245,158,11,0.03) 0%, transparent 55%);
            pointer-events: none;
            z-index: 0;
        }

    .lv-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 24px 16px;
        position: relative;
        z-index: 1;
    }

    /* ── Hero Section ── */
    .hero {
        text-align: center;
        padding: 36px 20px 40px;
        position: relative;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(239,68,68,0.12);
        border: 1px solid rgba(239,68,68,0.3);
        border-radius: 100px;
        padding: 6px 18px;
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 0.16em;
        color: #fca5a5;
        text-transform: uppercase;
        margin-bottom: 18px;
    }

    .hero h1 {
        font-size: clamp(2.2rem, 6vw, 3.8rem);
        font-weight: 900;
        letter-spacing: 0.04em;
        background: linear-gradient(135deg, #ef4444 0%, #f59e0b 50%, #a855f7 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1.1;
        margin-bottom: 12px;
    }

    .hero p {
        color: var(--nq-muted);
        font-size: 1rem;
        max-width: 560px;
        margin-inline: auto;
        line-height: 1.7;
    }

    /* ── Live stats pills ── */
    .live-stats {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
        margin: 20px 0 40px;
    }

    .stat-pill {
        background: var(--nq-surface);
        border: 1px solid var(--nq-border);
        border-radius: 100px;
        padding: 8px 20px;
        font-size: 0.8rem;
        display: flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }

        .stat-pill .pill-val {
            font-weight: 900;
            color: var(--nq-gold);
        }

    /* ── Section Labels ── */
    .section-label {
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 0.18em;
        color: var(--nq-accent2);
        text-transform: uppercase;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .section-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--nq-border);
        }

    /* ── Config Panel ── */
    .config-panel {
        background: var(--nq-surface);
        border: 1px solid var(--nq-border);
        border-radius: 20px;
        padding: 32px 28px;
        margin-bottom: 24px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.35);
    }

    /* ── Choice Grids ── */
    .choice-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 12px;
        margin-bottom: 28px;
    }

    .choice-card {
        background: var(--nq-surface2);
        border: 2px solid var(--nq-border);
        border-radius: var(--nq-radius);
        padding: 20px 14px;
        cursor: pointer;
        transition: var(--nq-transition);
        text-align: center;
        position: relative;
        overflow: hidden;
        user-select: none;
    }

        .choice-card:hover {
            border-color: var(--nq-accent2);
            background: #1e1e42;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(124,58,237,0.2);
        }

        .choice-card.active {
            border-color: var(--nq-accent);
            background: rgba(45,27,110,0.7);
            box-shadow: 0 0 22px rgba(124,58,237,0.4), inset 0 0 0 1px rgba(168,85,247,0.3);
            transform: translateY(-2px);
        }

        /* Difficulty-colored active states */
        .choice-card[data-diff="easy"].active {
            border-color: var(--nq-green);
            box-shadow: 0 0 22px rgba(16,185,129,0.35);
        }

        .choice-card[data-diff="normal"].active {
            border-color: var(--nq-blue);
            box-shadow: 0 0 22px rgba(14,165,233,0.35);
        }

        .choice-card[data-diff="hard"].active {
            border-color: var(--nq-gold);
            box-shadow: 0 0 22px rgba(245,158,11,0.35);
        }

        .choice-card[data-diff="insanity"].active {
            border-color: var(--nq-red);
            box-shadow: 0 0 22px rgba(239,68,68,0.35);
        }

        .choice-card .c-icon {
            font-size: 2.2rem;
            margin-bottom: 9px;
            display: block;
        }

        .choice-card .c-label {
            font-weight: 800;
            font-size: 1rem;
            display: block;
        }

        .choice-card .c-sub {
            font-size: 0.72rem;
            color: var(--nq-muted);
            margin-top: 4px;
            display: block;
        }

        .choice-card .c-tag {
            font-size: 0.68rem;
            color: var(--nq-accent2);
            margin-top: 3px;
            display: block;
        }

        .choice-card .c-count {
            font-size: 0.65rem;
            color: var(--nq-faint);
            margin-top: 2px;
            display: block;
        }

    .diff-pip {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-bottom: 6px;
    }

    .pip-easy {
        background: var(--nq-green);
    }

    .pip-normal {
        background: var(--nq-blue);
    }

    .pip-hard {
        background: var(--nq-gold);
    }

    .pip-insanity {
        background: var(--nq-red);
    }

    /* ── Word Warning ── */
    #word-warning {
        display: none;
        background: rgba(239,68,68,0.1);
        border: 1px solid rgba(239,68,68,0.4);
        border-radius: var(--nq-radius-sm);
        padding: 12px 16px;
        font-size: 0.82rem;
        color: #fca5a5;
        margin-bottom: 16px;
        align-items: center;
        gap: 10px;
    }

        #word-warning.visible {
            display: flex;
        }

    /* ── Battle Button ── */
    #btn-battle {
        display: block;
        width: 100%;
        padding: 20px;
        border-radius: var(--nq-radius);
        border: none;
        font-size: 1.1rem;
        font-weight: 900;
        cursor: pointer;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        background: linear-gradient(135deg, #ef4444 0%, #f59e0b 60%, #a855f7 100%);
        color: #fff;
        transition: var(--nq-transition);
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 28px rgba(239,68,68,0.35);
        margin-bottom: 12px;
    }

        #btn-battle::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -60%;
            width: 30%;
            height: 200%;
            background: rgba(255,255,255,0.18);
            transform: rotate(30deg);
        }

        #btn-battle:hover {
            opacity: 0.9;
            transform: translateY(-2px);
            box-shadow: 0 12px 36px rgba(239,68,68,0.5);
        }

            #btn-battle:hover::after {
                animation: btnSheen 0.7s ease;
            }

        #btn-battle:disabled {
            opacity: 0.4;
            cursor: not-allowed;
            transform: none;
        }

    @@keyframes btnSheen {
        from {
            left: -60%;
        }

        to {
            left: 140%;
        }
    }

    /* ── Solo Link ── */
    .solo-link-wrap {
        text-align: center;
        margin-bottom: 40px;
    }

    .solo-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--nq-muted);
        font-size: 0.85rem;
        font-weight: 700;
        text-decoration: none;
        padding: 10px 20px;
        border: 1px solid var(--nq-border);
        border-radius: 100px;
        transition: var(--nq-transition);
    }

        .solo-link:hover {
            color: var(--nq-accent2);
            border-color: var(--nq-accent2);
            background: rgba(168,85,247,0.05);
        }

    /* ── Info Grid ── */
    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 24px;
    }

    @@media (max-width: 700px) {
        .info-grid {
            grid-template-columns: 1fr;
        }
    }

    .info-card {
        background: var(--nq-surface);
        border: 1px solid var(--nq-border);
        border-radius: var(--nq-radius-lg);
        padding: 24px 20px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    }

    .info-card-title {
        font-size: 0.95rem;
        font-weight: 800;
        color: var(--nq-accent2);
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .info-card p,
    .info-card li {
        font-size: 0.85rem;
        color: var(--nq-muted);
        line-height: 1.7;
    }

    .info-card ul {
        padding-left: 18px;
    }

    .info-card li {
        margin-bottom: 4px;
    }

    /* ── How to play cards ── */
    .howto-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-top: 14px;
    }

    @@media (max-width: 600px) {
        .howto-grid {
            grid-template-columns: 1fr;
        }
    }

    .howto-item {
        background: var(--nq-surface2);
        border: 1px solid var(--nq-border);
        border-radius: var(--nq-radius-sm);
        padding: 16px;
        text-align: center;
        transition: var(--nq-transition);
    }

        .howto-item:hover {
            border-color: var(--nq-border2);
            transform: translateY(-1px);
        }

        .howto-item .hi-icon {
            font-size: 1.7rem;
            margin-bottom: 8px;
            display: block;
        }

        .howto-item .hi-name {
            font-weight: 800;
            font-size: 0.85rem;
            margin-bottom: 4px;
            color: var(--nq-text);
        }

        .howto-item .hi-desc {
            font-size: 0.76rem;
            color: var(--nq-muted);
            line-height: 1.55;
        }

    /* ── Difficulty breakdown ── */
    .diff-breakdown {
        display: grid;
        gap: 0;
        margin-top: 12px;
    }

    .diff-row {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 14px 0;
        border-bottom: 1px solid rgba(42,42,85,0.5);
    }

        .diff-row:last-child {
            border-bottom: none;
        }

        .diff-row .dr-icon {
            font-size: 1.6rem;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .diff-row .dr-name {
            font-weight: 800;
            font-size: 0.9rem;
            margin-bottom: 3px;
        }

        .diff-row .dr-desc {
            font-size: 0.78rem;
            color: var(--nq-muted);
            line-height: 1.55;
        }

    /* ── Rank table ── */
    .nq-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.83rem;
        margin-top: 12px;
    }

        .nq-table th {
            color: var(--nq-accent2);
            text-align: left;
            padding: 7px 10px;
            border-bottom: 1px solid var(--nq-border);
            font-size: 0.68rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            font-weight: 900;
        }

        .nq-table td {
            padding: 9px 10px;
            border-bottom: 1px solid rgba(42,42,85,0.4);
            color: var(--nq-muted);
            vertical-align: middle;
        }

        .nq-table tr:last-child td {
            border-bottom: none;
        }

        .nq-table td:nth-child(2) {
            color: var(--nq-green);
            font-weight: 700;
        }

        .nq-table td:nth-child(3) {
            color: var(--nq-red);
            font-weight: 700;
        }

    /* ── Skill chips ── */
    .skill-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--nq-surface2);
        border: 1px solid var(--nq-border);
        border-radius: 100px;
        padding: 6px 14px;
        font-size: 0.78rem;
        color: var(--nq-muted);
        margin: 4px;
    }

        .skill-chip .sc-icon {
            font-size: 1rem;
        }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        .config-panel {
            padding: 20px 16px;
        }

        .choice-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .hero h1 {
            font-size: 2.2rem;
        }
    }

    @@media (max-width: 420px) {
        .choice-grid {
            grid-template-columns: 1fr;
        }
    }

    /* ── Loading overlay ── */
    #loading-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(11,11,24,0.88);
        backdrop-filter: blur(4px);
        z-index: 9000;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 20px;
    }

        #loading-overlay.show {
            display: flex;
        }

    .spinner {
        width: 48px;
        height: 48px;
        border: 3px solid var(--nq-border);
        border-top-color: #f59e0b;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .loading-text {
        color: var(--nq-muted);
        font-size: 0.88rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }
</style>

<div class="lv-page">
    <div class="lv-wrapper">

        <!-- ── Hero ── -->
        <div class="hero">
            <div class="hero-badge">⚔️ Battle Mode</div>
            <h1>KanaBattle</h1>
            <p>
                Face off against an AI opponent in real-time kana combat.
                Choose your script, pick your difficulty, and prove your mastery.
            </p>

            <div class="live-stats">
                <div class="stat-pill">
                    ⚡ <span class="pill-val" id="stat-words">—</span> words available
                </div>
                <div class="stat-pill">
                    🎮 <span class="pill-val">Solo + Multiplayer</span>
                </div>
                <div class="stat-pill">
                    📚 <span class="pill-val">4</span> difficulty tiers
                </div>
            </div>
        </div>

        <!-- ══════════════════════════════════
             CONFIG PANEL
        ══════════════════════════════════ -->
        <div class="config-panel">

            <!-- Script Selection -->
            <div class="section-label">① Select Script</div>
            <div class="choice-grid" id="grid-script">
                <div class="choice-card active" data-val="hiragana" onclick="selectScript('hiragana',this)">
                    <span class="c-icon">あ</span>
                    <span class="c-label">Hiragana</span>
                    <span class="c-sub">Core syllabary</span>
                    <span class="c-tag">Recommended start</span>
                </div>
                <div class="choice-card" data-val="katakana" onclick="selectScript('katakana',this)">
                    <span class="c-icon">ア</span>
                    <span class="c-label">Katakana</span>
                    <span class="c-sub">Foreign loanwords</span>
                    <span class="c-tag">Essential vocab</span>
                </div>
                <div class="choice-card" data-val="dakuten" onclick="selectScript('dakuten',this)">
                    <span class="c-icon">が</span>
                    <span class="c-label">Dakuten</span>
                    <span class="c-sub">Voiced + small kana</span>
                    <span class="c-tag">50+ characters</span>
                </div>
                <div class="choice-card" data-val="mixed" onclick="selectScript('mixed',this)">
                    <span class="c-icon">混</span>
                    <span class="c-label">Mixed</span>
                    <span class="c-sub">All scripts blended</span>
                    <span class="c-tag">Ultimate challenge</span>
                </div>
            </div>

            <!-- Difficulty Selection -->
            <div class="section-label">② Select Difficulty</div>
            <div class="choice-grid" id="grid-diff">
                <div class="choice-card active" data-diff="easy" data-val="easy" onclick="selectDiff('easy',this)">
                    <span class="diff-pip pip-easy"></span>
                    <span class="c-icon">🌸</span>
                    <span class="c-label">Easy</span>
                    <span class="c-sub">Single kana · slow timer</span>
                    <span class="c-tag">Beginner</span>
                    <span class="c-count" id="cnt-easy">—</span>
                </div>
                <div class="choice-card" data-diff="normal" data-val="normal" onclick="selectDiff('normal',this)">
                    <span class="diff-pip pip-normal"></span>
                    <span class="c-icon">⚔️</span>
                    <span class="c-label">Normal</span>
                    <span class="c-sub">Common vocab · medium pace</span>
                    <span class="c-tag">Intermediate</span>
                    <span class="c-count" id="cnt-normal">—</span>
                </div>
                <div class="choice-card" data-diff="hard" data-val="hard" onclick="selectDiff('hard',this)">
                    <span class="diff-pip pip-hard"></span>
                    <span class="c-icon">🔥</span>
                    <span class="c-label">Hard</span>
                    <span class="c-sub">Yōon & compounds · fast</span>
                    <span class="c-tag">Advanced</span>
                    <span class="c-count" id="cnt-hard">—</span>
                </div>
                <div class="choice-card" data-diff="insanity" data-val="insanity" onclick="selectDiff('insanity',this)">
                    <span class="diff-pip pip-insanity"></span>
                    <span class="c-icon">💀</span>
                    <span class="c-label">Insanity</span>
                    <span class="c-sub">Kanji + furigana · brutal</span>
                    <span class="c-tag">Expert</span>
                    <span class="c-count" id="cnt-insanity">—</span>
                </div>
            </div>

            <!-- Warning -->
            <div id="word-warning" role="alert">
                <span>⚠️</span>
                <span id="warning-text">Not enough words available. Please choose another combination.</span>
            </div>

            <!-- Battle Button -->
            <button id="btn-battle" onclick="launchBattle()">
                ⚔️ Enter the Battle Arena
            </button>

            <!-- Solo Mode Link -->
            <div class="solo-link-wrap">
                <a href="/KanaBlitz/Index" class="solo-link">
                    ⚡ Switch to Solo Training Mode →
                </a>
            </div>
        </div>

        <!-- ══════════════════════════════════
             INFO PANELS
        ══════════════════════════════════ -->
        <div class="info-grid">

            <!-- How to Play -->
            <div class="info-card">
                <div class="info-card-title">⚔️ How Battle Works</div>
                <div class="howto-grid">
                    <div class="howto-item">
                        <span class="hi-icon">👁️</span>
                        <div class="hi-name">Read the Kana</div>
                        <div class="hi-desc">A kana character or word appears on screen.</div>
                    </div>
                    <div class="howto-item">
                        <span class="hi-icon">⌨️</span>
                        <div class="hi-name">Type Romaji</div>
                        <div class="hi-desc">Type the correct romaji pronunciation fast.</div>
                    </div>
                    <div class="howto-item">
                        <span class="hi-icon">💥</span>
                        <div class="hi-name">Deal Damage</div>
                        <div class="hi-desc">Correct answers hit the enemy. Misses hurt you.</div>
                    </div>
                </div>
                <div style="margin-top:16px">
                    <div class="info-card-title" style="font-size:0.82rem; margin-bottom:10px">Battle Skills</div>
                    <div>
                        <span class="skill-chip"><span class="sc-icon">🌊</span> Kana Strike</span>
                        <span class="skill-chip"><span class="sc-icon">⚡</span> Speed Burst</span>
                        <span class="skill-chip"><span class="sc-icon">🔥</span> Combo Flame</span>
                        <span class="skill-chip"><span class="sc-icon">🛡️</span> Guard Rune</span>
                        <span class="skill-chip"><span class="sc-icon">💎</span> Perfect Block</span>
                    </div>
                </div>
            </div>

            <!-- Difficulty Breakdown -->
            <div class="info-card">
                <div class="info-card-title">🎯 Difficulty Breakdown</div>
                <div class="diff-breakdown">
                    <div class="diff-row">
                        <span class="dr-icon">🌸</span>
                        <div>
                            <div class="dr-name" style="color:var(--nq-green)">Easy</div>
                            <div class="dr-desc">Single hiragana/katakana/dakuten characters. Slow timer. Perfect for beginners learning basic kana recognition.</div>
                        </div>
                    </div>
                    <div class="diff-row">
                        <span class="dr-icon">⚔️</span>
                        <div>
                            <div class="dr-name" style="color:var(--nq-blue)">Normal</div>
                            <div class="dr-desc">Common vocabulary words. Medium-pace timer. Ideal for learners with basic kana knowledge.</div>
                        </div>
                    </div>
                    <div class="diff-row">
                        <span class="dr-icon">🔥</span>
                        <div>
                            <div class="dr-name" style="color:var(--nq-gold)">Hard</div>
                            <div class="dr-desc">Yōon (compound kana) and sokuon. Fast timer. For intermediate to advanced learners.</div>
                        </div>
                    </div>
                    <div class="diff-row">
                        <span class="dr-icon">💀</span>
                        <div>
                            <div class="dr-name" style="color:var(--nq-red)">Insanity</div>
                            <div class="dr-desc">Kanji with furigana and idioms. Brutal timer. Only for those who have truly mastered kana.</div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ── ELO / Ranking Info ── -->
        <div class="info-grid">

            <div class="info-card">
                <div class="info-card-title">🏆 Ranking & ELO</div>
                <p style="margin-bottom:12px">Win battles to earn ELO points and climb the leaderboard. Your rank reflects your kana mastery.</p>
                <table class="nq-table">
                    <thead>
                        <tr><th>Rank</th><th>ELO</th><th>Loss</th></tr>
                    </thead>
                    <tbody>
                        <tr><td>🌱 Sprout</td><td>+8</td><td>-4</td></tr>
                        <tr><td>🪵 Wood</td><td>+12</td><td>-6</td></tr>
                        <tr><td>⚙️ Iron</td><td>+15</td><td>-8</td></tr>
                        <tr><td>🥇 Gold</td><td>+18</td><td>-10</td></tr>
                        <tr><td>💎 Diamond</td><td>+20</td><td>-14</td></tr>
                        <tr><td>🔮 Master</td><td>+22</td><td>-16</td></tr>
                        <tr><td>🐉 Dragon</td><td>+25</td><td>-20</td></tr>
                        <tr><td>⭐ Legend</td><td>+28</td><td>-24</td></tr>
                        <tr><td>👑 Challenger</td><td>+30</td><td>-28</td></tr>
                    </tbody>
                </table>
            </div>

            <div class="info-card">
                <div class="info-card-title">📊 Battle Tips</div>
                <ul style="margin-bottom:14px">
                    <li>Type romaji <strong>exactly</strong> as shown — use standard Hepburn romanization.</li>
                    <li>Build combo streaks to multiply damage dealt per correct answer.</li>
                    <li>Use skills strategically — each has a cooldown timer.</li>
                    <li>Watch the enemy's HP bar — burst them down before time expires.</li>
                    <li>Missing an answer deals damage to <em>you</em>. Stay focused.</li>
                    <li>Mixed mode combines all scripts — the highest XP reward.</li>
                    <li>Practice in <a href="/KanaBlitz/Index" style="color:var(--nq-accent2); font-weight:700; text-decoration:none">Solo Training</a> first to warm up.</li>
                </ul>
                <div class="info-card-title" style="font-size:0.82rem; margin-bottom:8px">Common Romaji Notes</div>
                <p>し = <strong>shi</strong>, ち = <strong>chi</strong>, つ = <strong>tsu</strong>, ふ = <strong>fu</strong>, じ = <strong>ji</strong></p>
