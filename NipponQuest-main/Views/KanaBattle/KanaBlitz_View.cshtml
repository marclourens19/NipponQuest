<script>
    /* ══════════════════════════════════════════════════════════════
       SoundFX Engine — Web Audio API Synthesized Sounds
    ══════════════════════════════════════════════════════════════ */
    const SoundFX = {
        ctx: null,
        init() {
            try { this.ctx = new (window.AudioContext || window.webkitAudioContext)(); } catch(e) {}
        },
        _ensure() {
            if (!this.ctx) this.init();
            if (!this.ctx) return false;
            if (this.ctx.state === 'suspended') this.ctx.resume();
            return true;
        },
        play(type) {
            if (!this._ensure()) return;
            const now = this.ctx.currentTime;
            switch (type) {
                case 'correct': {
                    const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                    o.connect(g); g.connect(this.ctx.destination);
                    o.type = 'sine';
                    o.frequency.setValueAtTime(523, now);
                    o.frequency.linearRampToValueAtTime(784, now + 0.1);
                    g.gain.setValueAtTime(0.15, now);
                    g.gain.linearRampToValueAtTime(0, now + 0.2);
                    o.start(now); o.stop(now + 0.2);
                    break;
                }
                case 'incorrect': {
                    const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                    o.connect(g); g.connect(this.ctx.destination);
                    o.type = 'sawtooth';
                    o.frequency.setValueAtTime(300, now);
                    o.frequency.linearRampToValueAtTime(150, now + 0.2);
                    g.gain.setValueAtTime(0.1, now);
                    g.gain.linearRampToValueAtTime(0, now + 0.3);
                    o.start(now); o.stop(now + 0.3);
                    break;
                }
                case 'combo': {
                    [600, 800, 1000, 1200].forEach((f, i) => {
                        const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                        o.connect(g); g.connect(this.ctx.destination);
                        o.type = 'sine';
                        o.frequency.setValueAtTime(f, now + i * 0.06);
                        g.gain.setValueAtTime(0.1, now + i * 0.06);
                        g.gain.linearRampToValueAtTime(0, now + i * 0.06 + 0.1);
                        o.start(now + i * 0.06); o.stop(now + i * 0.06 + 0.1);
                    });
                    break;
                }
                case 'victory': {
                    [523, 659, 784, 1047].forEach((f, i) => {
                        const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                        o.connect(g); g.connect(this.ctx.destination);
                        o.type = 'sine';
                        o.frequency.setValueAtTime(f, now + i * 0.15);
                        g.gain.setValueAtTime(0.12, now + i * 0.15);
                        g.gain.linearRampToValueAtTime(0, now + i * 0.15 + 0.25);
                        o.start(now + i * 0.15); o.stop(now + i * 0.15 + 0.25);
                    });
                    break;
                }
                case 'defeat': {
                    const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                    o.connect(g); g.connect(this.ctx.destination);
                    o.type = 'sine';
                    o.frequency.setValueAtTime(400, now);
                    o.frequency.linearRampToValueAtTime(100, now + 0.6);
                    g.gain.setValueAtTime(0.12, now);
                    g.gain.linearRampToValueAtTime(0, now + 0.7);
                    o.start(now); o.stop(now + 0.7);
                    break;
                }
                case 'countdown': {
                    const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                    o.connect(g); g.connect(this.ctx.destination);
                    o.type = 'sine';
                    o.frequency.setValueAtTime(440, now);
                    g.gain.setValueAtTime(0.1, now);
                    g.gain.linearRampToValueAtTime(0, now + 0.12);
                    o.start(now); o.stop(now + 0.12);
                    break;
                }
                case 'click': {
                    const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                    o.connect(g); g.connect(this.ctx.destination);
                    o.type = 'sine';
                    o.frequency.setValueAtTime(800, now);
                    g.gain.setValueAtTime(0.06, now);
                    g.gain.linearRampToValueAtTime(0, now + 0.04);
                    o.start(now); o.stop(now + 0.04);
                    break;
                }
                case 'tick': {
                    const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                    o.connect(g); g.connect(this.ctx.destination);
                    o.type = 'sine';
                    o.frequency.setValueAtTime(1000, now);
                    g.gain.setValueAtTime(0.04, now);
                    g.gain.linearRampToValueAtTime(0, now + 0.03);
                    o.start(now); o.stop(now + 0.03);
                    break;
                }
            }
        }
    };

    /* ══════════════════════════════════════════════════════════════
       Game State
    ══════════════════════════════════════════════════════════════ */
    const G = {
        difficulty: 'normal',
        alphabet: 'hiragana',
        words: [],
        currentWord: null,
        round: 0,
        totalRounds: 10,
        score: 0,
        combo: 0,
        maxCombo: 0,
        correct: 0,
        incorrect: 0,
        timePerRound: 15,
        timeLeft: 0,
        timerInterval: null,
        answered: false,
        running: false
    };

    /* ── Time limits per difficulty ── */
    const TIME_MAP = { easy: 20, normal: 15, hard: 10, insanity: 7 };

    /* ── Init: Load word counts ── */
    document.addEventListener('DOMContentLoaded', () => {
        loadWordCounts();
    });

    async function loadWordCounts() {
        const diffs = ['easy', 'normal', 'hard', 'insanity'];
        const alphas = ['hiragana', 'katakana', 'dakuten', 'mixed'];

        for (const d of diffs) {
            try {
                let total = 0;
                for (const a of alphas) {
                    const resp = await fetch(`/KanaBlitz/GetWords?difficulty=${d}&alphabet=${a}`);
                    if (resp.ok) {
                        const data = await resp.json();
                        if (Array.isArray(data)) total += data.length;
                    }
                }
                const el = document.getElementById(`count-${d}`);
                if (el) el.textContent = `${total} words`;
            } catch (e) {
                const el = document.getElementById(`count-${d}`);
                if (el) el.textContent = 'Error loading';
            }
        }
    }

    /* ── Selection ── */
    function selectDifficulty(diff) {
        SoundFX.play('click');
        document.querySelectorAll('#diff-grid .choice-card').forEach(c => c.classList.remove('active'));
        document.querySelector(`#diff-grid .choice-card[data-diff="${diff}"]`).classList.add('active');
        G.difficulty = diff;
    }

    function selectAlphabet(alpha) {
        SoundFX.play('click');
        document.querySelectorAll('#alpha-grid .choice-card').forEach(c => c.classList.remove('active'));
        document.querySelector(`#alpha-grid .choice-card[data-alpha="${alpha}"]`).classList.add('active');
        G.alphabet = alpha;
    }

    /* ── Show Error ── */
    function showError(msg) {
        const el = document.getElementById('error-banner');
        el.textContent = msg;
        el.style.display = 'block';
        setTimeout(() => { el.style.display = 'none'; }, 5000);
    }

    /* ── Start Game ── */
    async function startGame() {
        SoundFX.play('click');
        const btn = document.getElementById('start-btn');
        btn.disabled = true;
        btn.innerHTML = '<span class="loading-spinner"></span> Loading...';

        try {
            const resp = await fetch(`/KanaBlitz/GetWords?difficulty=${G.difficulty}&alphabet=${G.alphabet}`);
            if (!resp.ok) throw new Error('Failed to fetch words from database.');
            const data = await resp.json();

            if (!Array.isArray(data) || data.length < 4) {
                throw new Error(`Not enough words available for ${G.difficulty}/${G.alphabet} (${data?.length || 0} found). Try a different combination.`);
            }

            G.words = shuffleArray([...data]);
            G.totalRounds = Math.min(10, G.words.length);
            G.round = 0;
            G.score = 0;
            G.combo = 0;
            G.maxCombo = 0;
            G.correct = 0;
            G.incorrect = 0;
            G.timePerRound = TIME_MAP[G.difficulty] || 15;
            G.running = true;

            btn.disabled = false;
            btn.innerHTML = '⚔️ Start Training';

            document.getElementById('setup-panel').style.display = 'none';
            document.getElementById('results-screen').style.display = 'none';
            document.getElementById('game-arena').style.display = 'block';

            await showCountdown();
            nextRound();

        } catch (err) {
            btn.disabled = false;
            btn.innerHTML = '⚔️ Start Training';
            showError(err.message);
        }
    }

    /* ── Countdown ── */
    function showCountdown() {
        return new Promise(resolve => {
            const overlay = document.getElementById('countdown-overlay');
            const display = document.getElementById('countdown-display');
            overlay.style.display = 'flex';

            let count = 3;
            display.className = 'countdown-number';
            display.textContent = count;
            SoundFX.play('countdown');

            const iv = setInterval(() => {
                count--;
                if (count > 0) {
                    display.textContent = count;
                    display.style.animation = 'none';
                    void display.offsetHeight;
                    display.style.animation = '';
                    SoundFX.play('countdown');
                } else if (count === 0) {
                    display.className = 'countdown-go';
                    display.textContent = 'GO!';
                    display.style.animation = 'none';
                    void display.offsetHeight;
                    display.style.animation = '';
                    SoundFX.play('correct');
                } else {
                    clearInterval(iv);
                    overlay.style.display = 'none';
                    resolve();
                }
            }, 800);
        });
    }

    /* ── Next Round ── */
    function nextRound() {
        if (G.round >= G.totalRounds || !G.running) {
            endGame();
            return;
        }

        G.answered = false;
        G.currentWord = G.words[G.round];
        G.round++;

        // Update HUD
        document.getElementById('hud-score').textContent = G.score;
        document.getElementById('hud-combo').textContent = G.combo + '×';
        document.getElementById('hud-round').textContent = G.round + '/' + G.totalRounds;
        document.getElementById('hud-correct').textContent = G.correct;

        // Display question
        const qCard = document.getElementById('question-card');
        qCard.style.animation = 'none';
        void qCard.offsetHeight;
        qCard.style.animation = 'kbScaleIn 0.3s ease both';

        document.getElementById('q-kana').textContent = G.currentWord.wordKana || G.currentWord.WordKana || '—';
        document.getElementById('q-category').textContent = G.currentWord.categoryTag || G.currentWord.CategoryTag || 'Kana';

        // Build options — pick 3 wrong answers from the word pool
        buildOptions();

        // Start timer
        startTimer();
    }

    /* ── Build Options ── */
    function buildOptions() {
        const correctRomaji = G.currentWord.wordRomaji || G.currentWord.WordRomaji || '';
        const pool = G.words.filter(w => {
            const r = w.wordRomaji || w.WordRomaji || '';
            return r && r !== correctRomaji;
        });

        const wrongAnswers = shuffleArray([...pool]).slice(0, 3).map(w => w.wordRomaji || w.WordRomaji || '');
        const allAnswers = shuffleArray([correctRomaji, ...wrongAnswers]);

        const grid = document.getElementById('options-grid');
        grid.innerHTML = '';

        allAnswers.forEach((ans, i) => {
            const btn = document.createElement('button');
            btn.className = 'option-btn';
            btn.textContent = ans || '—';
            btn.dataset.answer = ans;
            btn.style.animation = `kbFadeUp 0.3s ease ${i * 0.05}s both`;
            btn.addEventListener('click', () => handleAnswer(ans, correctRomaji, btn));
            grid.appendChild(btn);
        });
    }

    /* ── Handle Answer ── */
    function handleAnswer(selected, correct, btnEl) {
        if (G.answered) return;
        G.answered = true;
        clearInterval(G.timerInterval);

        const allBtns = document.querySelectorAll('.option-btn');
        allBtns.forEach(b => b.disabled = true);

        if (selected === correct) {
            // Correct!
            btnEl.classList.add('correct');
            G.correct++;
            G.combo++;
            if (G.combo > G.maxCombo) G.maxCombo = G.combo;

            const comboMultiplier = Math.min(G.combo, 5);
            const timeBonus = Math.floor(G.timeLeft / G.timePerRound * 50);
            const points = 100 * comboMultiplier + timeBonus;
            G.score += points;

            document.getElementById('hud-score').textContent = G.score;
            document.getElementById('hud-combo').textContent = G.combo + '×';
            document.getElementById('hud-correct').textContent = G.correct;

            showXPFloat(btnEl, '+' + points);

            if (G.combo >= 3) {
                SoundFX.play('combo');
                showToast(`${G.combo}× Combo!`, 'combo-toast');
            } else {
                SoundFX.play('correct');
                showToast('Correct!', 'correct-toast');
            }
        } else {
            // Incorrect
            btnEl.classList.add('incorrect');
            G.incorrect++;
            G.combo = 0;

            document.getElementById('hud-combo').textContent = '0×';

            // Reveal the correct answer
            allBtns.forEach(b => {
                if (b.dataset.answer === correct) {
                    b.classList.add('reveal-correct');
                }
            });

            SoundFX.play('incorrect');
            showToast('Incorrect', 'incorrect-toast');
        }

        // Next round after delay
        setTimeout(() => nextRound(), 1200);
    }

    /* ── Timer ── */
    function startTimer() {
        G.timeLeft = G.timePerRound;
        const bar = document.getElementById('timer-bar');
        bar.style.width = '100%';
        bar.className = 'timer-bar-fill';

        const startTime = Date.now();
        const duration = G.timePerRound * 1000;

        G.timerInterval = setInterval(() => {
            const elapsed = Date.now() - startTime;
            const pct = Math.max(0, 1 - elapsed / duration) * 100;
            bar.style.width = pct + '%';
            G.timeLeft = Math.max(0, G.timePerRound - elapsed / 1000);

            if (pct < 20) {
                bar.className = 'timer-bar-fill danger';
                if (Math.floor(G.timeLeft * 2) % 2 === 0) SoundFX.play('tick');
            } else if (pct < 40) {
                bar.className = 'timer-bar-fill warning';
            } else {
                bar.className = 'timer-bar-fill';
            }

            if (pct <= 0) {
                clearInterval(G.timerInterval);
                handleTimeout();
            }
        }, 100);
    }

    function handleTimeout() {
        if (G.answered) return;
        G.answered = true;
        G.incorrect++;
        G.combo = 0;

        const correctRomaji = G.currentWord.wordRomaji || G.currentWord.WordRomaji || '';
        const allBtns = document.querySelectorAll('.option-btn');
        allBtns.forEach(b => {
            b.disabled = true;
            if (b.dataset.answer === correctRomaji) {
                b.classList.add('reveal-correct');
            }
        });

        document.getElementById('hud-combo').textContent = '0×';
        SoundFX.play('incorrect');
        showToast('Time\'s Up!', 'incorrect-toast');

        setTimeout(() => nextRound(), 1200);
    }

    /* ── End Game ── */
    async function endGame() {
        G.running = false;
        clearInterval(G.timerInterval);

        const accuracy = G.totalRounds > 0 ? Math.round((G.correct / G.totalRounds) * 100) : 0;
        const xpEarned = Math.floor(G.score * 0.5 + G.correct * 5);

        // Play sound
        if (accuracy >= 80) {
            SoundFX.play('victory');
        } else {
            SoundFX.play('defeat');
        }

        // Submit score
        try {
            await fetch('/KanaBlitz/SubmitScore', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    score: G.score,
                    difficulty: G.difficulty,
                    alphabet: G.alphabet,
                    correct: G.correct,
                    total: G.totalRounds,
                    maxCombo: G.maxCombo,
                    xpEarned: xpEarned
                })
            });
        } catch (e) { /* silent fail */ }

        // Show results
        document.getElementById('game-arena').style.display = 'none';
        document.getElementById('results-screen').style.display = 'block';

        const icon = accuracy >= 90 ? '🏆' : accuracy >= 70 ? '⭐' : accuracy >= 50 ? '💪' : '📚';
        const title = accuracy >= 90 ? 'Outstanding!' : accuracy >= 70 ? 'Great Job!' : accuracy >= 50 ? 'Keep Practicing!' : 'Don\'t Give Up!';
        const sub = accuracy >= 90 ? 'You\'re a kana master!' : accuracy >= 70 ? 'Strong performance!' : accuracy >= 50 ? 'You\'re making progress!' : 'Every attempt makes you stronger!';

        document.getElementById('results-icon').textContent = icon;
        document.getElementById('results-title').textContent = title;
        document.getElementById('results-subtitle').textContent = sub;
        document.getElementById('rs-score').textContent = G.score;
        document.getElementById('rs-accuracy').textContent = accuracy + '%';
        document.getElementById('rs-combo').textContent = G.maxCombo + '×';
        document.getElementById('rs-xp').textContent = '+' + xpEarned;
    }

    /* ── Play Again ── */
    async function playAgain() {
        SoundFX.play('click');
        document.getElementById('results-screen').style.display = 'none';
        try {
            const resp = await fetch(`/KanaBlitz/GetWords?difficulty=${G.difficulty}&alphabet=${G.alphabet}`);
            if (!resp.ok) throw new Error('Failed to fetch words.');
            const data = await resp.json();
            if (!Array.isArray(data) || data.length < 4) throw new Error('Not enough words.');
            G.words = shuffleArray([...data]);
            G.totalRounds = Math.min(10, G.words.length);
            G.round = 0; G.score = 0; G.combo = 0; G.maxCombo = 0; G.correct = 0; G.incorrect = 0;
            G.running = true;
            document.getElementById('game-arena').style.display = 'block';
            await showCountdown();
            nextRound();
        } catch (e) {
            showError(e.message);
            backToSetup();
        }
    }

    function backToSetup() {
        SoundFX.play('click');
        G.running = false;
        clearInterval(G.timerInterval);
        document.getElementById('game-arena').style.display = 'none';
        document.getElementById('results-screen').style.display = 'none';
        document.getElementById('setup-panel').style.display = 'block';
    }

    /* ── Helpers ── */
    function shuffleArray(arr) {
        for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
    }

    function showToast(msg, cls) {
        const t = document.getElementById('feedback-toast');
        t.textContent = msg;
        t.className = 'feedback-toast ' + cls + ' show';
        setTimeout(() => { t.className = 'feedback-toast'; }, 800);
    }

    function showXPFloat(anchor, text) {
        const el = document.createElement('div');
        el.className = 'xp-float';
        el.textContent = text;
        const rect = anchor.getBoundingClientRect();
        el.style.left = rect.left + rect.width / 2 + 'px';
        el.style.top = rect.top + 'px';
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 1000);
    }

    /* Keyboard shortcuts: 1-4 for options */
    document.addEventListener('keydown', e => {
        if (!G.running || G.answered) return;
        const num = parseInt(e.key);
        if (num >= 1 && num <= 4) {
            const btns = document.querySelectorAll('.option-btn');
            if (btns[num - 1]) btns[num - 1].click();
        }
    });
</script>
