            const statCorrect      = $('stat-correct');
            const statWrong        = $('stat-wrong');
            const statAcc          = $('stat-acc');
            const accBar           = $('acc-bar');
            const qNum             = $('q-num');
            const qTotal           = $('q-total');
            const normalSection    = $('normal-input-section');
            const hardSection      = $('kana-selector-section');
            const kanaWordPartial  = $('kana-word-partial');
            const kanaOptionGrid   = $('kana-option-grid');
            const submitWordBtn    = $('submit-word-btn');
            const unlockNotice     = $('unlock-notice');
            const unlockNoticeText = $('unlock-notice-text');
            const selAlphabet      = $('sel-alphabet');
            const wordCountInfo    = $('word-count-info');

            /* ── Difficulty Cards ── */
            document.querySelectorAll('.diff-card').forEach(card => {
                card.addEventListener('click', () => selectDifficulty(card.dataset.diff));
                card.addEventListener('keydown', e => {
                    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectDifficulty(card.dataset.diff); }
                });
            });

            function selectDifficulty(diff) {
                if (diff === 'hard' && !STATE.unlocks.hard) {
                    showUnlockNotice('Hard Mode is locked. Achieve 90%+ accuracy in Normal across all alphabets to unlock.');
                    return;
                }
                if (diff === 'insanity' && !STATE.unlocks.insanity) {
                    showUnlockNotice('Insanity Mode is locked. Achieve 95%+ accuracy in Hard and reach Level 15.');
                    return;
                }
                SFX.click();
                document.querySelectorAll('.diff-card').forEach(c => { c.classList.remove('selected'); c.setAttribute('aria-pressed','false'); });
                const card = document.querySelector(`.diff-card[data-diff="${diff}"]`);
                if (card) { card.classList.add('selected'); card.setAttribute('aria-pressed','true'); }
                STATE.difficulty = diff;
                updateTagDiff(diff);
                updateWordCountInfo();
            }

            function showUnlockNotice(msg) {
                unlockNoticeText.textContent = msg;
                unlockNotice.style.display = 'flex';
                setTimeout(() => { unlockNotice.style.display = 'none'; }, 4000);
            }

            function updateTagDiff(diff) {
                const tagEl = $('tag-diff');
                const labels = { easy:'Easy', normal:'Normal', hard:'Hard ★', insanity:'Insanity ★★' };
                const classes = { easy:'green', normal:'blue', hard:'gold', insanity:'red' };
                tagEl.textContent = labels[diff] || diff;
                tagEl.className = `arena-tag ${classes[diff] || 'gold'}`;
            }

            /* ── Alphabet select change ── */
            selAlphabet.addEventListener('change', () => {
                STATE.alphabet = selAlphabet.value;
                $('tag-alpha').textContent = selAlphabet.options[selAlphabet.selectedIndex].text.split(' ')[0];
                updateWordCountInfo();
                SFX.click();
            });

            /* ── Fetch word counts for info panel ── */
            async function updateWordCountInfo() {
                try {
                    const r = await fetch(`/KanaBlitz/GetArenaPayload?alphabet=${encodeURIComponent(STATE.alphabet)}&difficulty=${encodeURIComponent(STATE.difficulty)}`);
                    if (!r.ok) throw new Error('HTTP ' + r.status);
                    const data = await r.json();
                    const total = data.wordCount ?? 0;
                    wordCountInfo.innerHTML = `<span style="color:var(--kb-green);font-weight:900;">${total}</span> words available &bull; ${data.hardLocked ? '🔒 Hard locked' : '✅ Hard unlocked'} &bull; ${data.insanityLocked ? '🔒 Insanity locked' : '✅ Insanity unlocked'}`;

                    // Update lock badges
                    if (data.hardLocked === false) { $('hard-lock-badge').style.display = 'none'; STATE.unlocks.hard = true; }
                    else                           { $('hard-lock-badge').style.display = 'inline-block'; }

                    if (data.insanityLocked === false) { $('insanity-lock-badge').style.display = 'none'; STATE.unlocks.insanity = true; }
                    else                               { $('insanity-lock-badge').style.display = 'inline-block'; }

                } catch (e) {
                    wordCountInfo.textContent = 'Could not load word counts. Please check your connection.';
                }
            }

            /* ── Fetch unlocks on load ── */
            async function fetchUnlocks() {
                try {
                    const r = await fetch('/KanaBlitz/GetUnlocks');
                    if (!r.ok) return;
                    const data = await r.json();
                    STATE.unlocks.hard = data.hard?.unlocked ?? false;
                    STATE.unlocks.insanity = data.insanity?.unlocked ?? false;
                    if (STATE.unlocks.hard)     { $('hard-lock-badge').style.display = 'none'; }
                    if (STATE.unlocks.insanity) { $('insanity-lock-badge').style.display = 'none'; }
                } catch (e) { /* anonymous user or network error */ }
            }

            /* ── Fetch words from DB ── */
            async function fetchWords() {
                const diff  = STATE.difficulty;
                const alpha = STATE.alphabet;

                try {
                    const url = `/KanaBlitz/GetWords?difficulty=${encodeURIComponent(diff)}&alphabet=${encodeURIComponent(alpha)}`;
                    const r = await fetch(url);
                    if (!r.ok) throw new Error(`HTTP ${r.status} from GetWords`);
                    const data = await r.json();

                    if (!Array.isArray(data) || data.length === 0) {
                        throw new Error('No words returned from database');
                    }
                    return data;
                } catch (e) {
                    console.error('[KanaBlitz] fetchWords error:', e);
                    throw e;
                }
            }

            /* ── Shuffle array ── */
            function shuffle(arr) {
                const a = [...arr];
                for (let i = a.length - 1; i > 0; i--) {
                    const j = Math.floor(Math.random() * (i + 1));
                    [a[i], a[j]] = [a[j], a[i]];
                }
                return a;
            }

            /* ── Get time per question by difficulty ── */
            function getTimePerQ(diff) {
                return { easy: 10, normal: 8, hard: 12, insanity: 10 }[diff] ?? 8;
            }

            /* ── Get question count ── */
            function getQuestionCount(diff) {
                return { easy: 20, normal: 20, hard: 15, insanity: 12 }[diff] ?? 20;
            }

            /* ── Start button ── */
            startBtn.addEventListener('click', async () => {
                SFX.click();
                startBtn.disabled = true;
                startBtn.innerHTML = '<span>⏳</span> Loading words...';

                try {
                    const words = await fetchWords();
                    STATE.words = words;
                    STATE.difficulty = document.querySelector('.diff-card.selected')?.dataset.diff ?? 'easy';
                    STATE.alphabet   = selAlphabet.value;
                    STATE.isHardMode = STATE.difficulty === 'hard' || STATE.difficulty === 'insanity';
                    STATE.totalQuestions = Math.min(getQuestionCount(STATE.difficulty), words.length);
                    STATE.timePerQ = getTimePerQ(STATE.difficulty);

                    if (words.length < 5) {
                        alert(`⚠️ Only ${words.length} word(s) found for this combination. Please try a different alphabet or difficulty.`);
                        startBtn.disabled = false;
                        startBtn.innerHTML = '<span>⚡</span> Start Training';
                        return;
                    }

                    startBtn.innerHTML = '<span>⚡</span> Start Training';
                    startBtn.disabled = false;
                    showCountdown();

                } catch (err) {
                    console.error('[KanaBlitz] Start error:', err);
                    alert('❌ Failed to load words. Please check your database connection and try again.\n\nError: ' + err.message);
                    startBtn.disabled = false;
                    startBtn.innerHTML = '<span>⚡</span> Start Training';
                }
            });

            /* ── Countdown ── */
            function showCountdown() {
                countdownOverlay.style.display = 'flex';
                countdownOverlay.style.flexDirection = 'column';
                countdownOverlay.style.alignItems = 'center';
                countdownOverlay.style.justifyContent = 'center';
                countdownOverlay.style.position = 'fixed';
                countdownOverlay.style.inset = '0';
                countdownOverlay.style.background = 'rgba(255,255,255,0.92)';
                countdownOverlay.style.backdropFilter = 'blur(8px)';
                countdownOverlay.style.zIndex = '9000';

                const counts = [3, 2, 1, '⚡ GO!'];
                let i = 0;

                const tick = () => {
                    SFX.countdown();
                    countdownOverlay.innerHTML = `
                        <div class="countdown-number" style="font-size:${counts[i] === '⚡ GO!' ? '4rem' : '8rem'};font-weight:900;color:var(--kb-black);animation:kbCountdownPop 0.7s ease both;">
                            ${counts[i]}
                        </div>
                        <div class="countdown-text" style="font-size:1rem;font-weight:800;color:var(--kb-muted);letter-spacing:0.15em;text-transform:uppercase;margin-top:12px;">
                            ${i < 3 ? 'Get ready...' : 'Start typing!'}
                        </div>
                    `;
                    i++;
                    if (i < counts.length) {
                        setTimeout(tick, 900);
                    } else {
                        SFX.go();
                        setTimeout(() => {
                            countdownOverlay.style.display = 'none';
                            beginGame();
                        }, 700);
                    }
                };
                tick();
            }

            /* ── Begin game ── */
            function beginGame() {
                resetState();
                STATE.queue = shuffle(STATE.words).slice(0, STATE.totalQuestions);
                STATE.gameActive = true;

                setupPanel.style.display = 'none';
                gameArena.style.display = 'block';
                resultOverlay.style.display = 'none';

                qTotal.textContent = STATE.totalQuestions;
                loadQuestion();
            }

            /* ── Reset state ── */
            function resetState() {
                clearInterval(STATE.timerInterval);
                STATE.currentIndex = 0;
                STATE.score        = 0;
                STATE.correct      = 0;
                STATE.wrong        = 0;
                STATE.combo        = 0;
                STATE.maxCombo     = 0;
                STATE.multiplier   = 1.0;
                STATE.timings      = [];
                STATE.gameActive   = false;
                updateScoreDisplay();
                updateComboDisplay();
            }

            /* ── Load question ── */
            function loadQuestion() {
                clearInterval(STATE.timerInterval);
                feedbackBubble.textContent = '';
                feedbackBubble.className = 'feedback-bubble';
                kanaCard.classList.remove('correct','wrong');

                if (STATE.currentIndex >= STATE.totalQuestions) {
                    endGame();
                    return;
                }

                const word = STATE.queue[STATE.currentIndex];
                STATE.currentWord = word;
                qNum.textContent = STATE.currentIndex + 1;

                /* Display kana */
                kanaDisplay.textContent  = word.wordKana;
                kanaMeaning.textContent  = word.meaningEnglish || '';
                kanaCat.textContent      = word.categoryTag || '';

                /* Furigana for insanity (kanji words contain furigana in parens) */
                if (STATE.difficulty === 'insanity' && word.wordKana.includes('(')) {
                    const m = word.wordKana.match(/\(([^)]+)\)/);
                    if (m) {
                        kanaFurigana.textContent = m[1];
                        kanaFurigana.style.display = 'block';
                    }
                } else {
                    kanaFurigana.style.display = 'none';
                }

                /* Mode routing */
                if (STATE.isHardMode) {
                    buildHardMode(word);
                } else {
                    buildNormalMode();
                }

                startTimer();
            }

            /* ── Normal mode ── */
            function buildNormalMode() {
                normalSection.style.display = 'block';
                hardSection.style.display   = 'none';
                romajiInput.value           = '';
                romajiInput.className       = 'romaji-input';
                romajiInput.disabled        = false;
                setTimeout(() => romajiInput.focus(), 50);
            }

            /* ── Hard mode — build blanks ── */
            function buildHardMode(word) {
                normalSection.style.display = 'none';
                hardSection.style.display   = 'block';
                submitWordBtn.disabled      = true;

                /* Parse kana characters from the word (skip kanji/parens) */
                const kana = extractKana(word.wordKana);
                if (kana.length === 0) { buildNormalMode(); return; }

                /* Choose how many blanks based on difficulty */
                const numBlanks = STATE.difficulty === 'insanity'
                    ? Math.min(3, Math.max(1, Math.floor(kana.length * 0.5)))
                    : STATE.difficulty === 'hard'
                        ? Math.min(2, Math.max(1, Math.floor(kana.length * 0.4)))
                        : 1;

                /* Pick random indices to blank */
                const allIdx = Array.from({ length: kana.length }, (_, i) => i);
                const blankIdx = shuffle(allIdx).slice(0, numBlanks).sort((a,b)=>a-b);

                STATE.hardBlanks  = blankIdx.map(i => ({ idx: i, char: kana[i], filled: false, userAnswer: null }));
                STATE.hardAnswers = [];

                /* Render partial word */
                renderPartialWord(kana, blankIdx);

                /* Build option pool */
                buildKanaOptions(word, kana, blankIdx);
            }

            /* Extract individual kana from a word string */
            function extractKana(wordKana) {
                /* For insanity mode, extract furigana from parens */
                const furi = wordKana.match(/\(([^)]+)\)/);
                const src = furi ? furi[1] : wordKana;
                /* Split into individual characters, ignore kanji & latin */
                return [...src].filter(c => {
                    const cp = c.codePointAt(0);
                    return (cp >= 0x3040 && cp <= 0x30FF) || (cp >= 0xFF65 && cp <= 0xFF9F);
                });
            }

            /* Render the partially-blanked word */
            function renderPartialWord(kana, blankIdx) {
                kanaWordPartial.innerHTML = '';
                kana.forEach((char, i) => {
                    if (blankIdx.includes(i)) {
                        const blank = document.createElement('span');
                        blank.className = 'kana-blank';
                        blank.dataset.blankIdx = String(blankIdx.indexOf(i));
                        blank.textContent = '＿';
                        blank.setAttribute('aria-label', 'Missing kana ' + (blankIdx.indexOf(i) + 1));
                        kanaWordPartial.appendChild(blank);
                    } else {
                        const span = document.createElement('span');
                        span.className = 'kana-char';
                        span.textContent = char;
                        span.setAttribute('lang','ja');
                        kanaWordPartial.appendChild(span);
                    }
                });
            }

            /* Build the option buttons */
            function buildKanaOptions(word, kana, blankIdx) {
                kanaOptionGrid.innerHTML = '';

                /* Always include the correct answers */
                const correctChars = blankIdx.map(i => kana[i]);

                /* Choose pool based on alphabet */
                const pool = STATE.alphabet === 'katakana' ? KATAKANA_POOL : HIRAGANA_POOL;

                /* Pick distractors */
                const distractors = shuffle(pool.filter(c => !correctChars.includes(c))).slice(0, 8 - correctChars.length);
                const options     = shuffle([...correctChars, ...distractors]);

                options.forEach(char => {
                    const btn = document.createElement('button');
                    btn.className    = 'kana-option-btn';
                    btn.textContent  = char;
                    btn.lang         = 'ja';
                    btn.dataset.char = char;
                    btn.type         = 'button';
                    btn.setAttribute('aria-label', `Select kana ${char}`);
                    btn.addEventListener('click', () => handleKanaOptionClick(char, btn));
                    kanaOptionGrid.appendChild(btn);
                });
            }

            /* Handle option button click */
            function handleKanaOptionClick(char, btn) {
                if (!STATE.gameActive) return;
                const nextBlank = STATE.hardBlanks.find(b => !b.filled);
                if (!nextBlank) return;

                SFX.click();
                nextBlank.filled     = true;
                nextBlank.userAnswer = char;
                STATE.hardAnswers.push(char);

                /* Update blank display */
                const blankEl = kanaWordPartial.querySelector(`[data-blank-idx="${STATE.hardBlanks.indexOf(nextBlank)}"]`);
                if (blankEl) {
                    blankEl.textContent = char;
                    blankEl.classList.add('filled');
                }
                btn.classList.add('used');
                btn.disabled = true;

                /* Check if all blanks filled */
                if (STATE.hardBlanks.every(b => b.filled)) {
                    submitWordBtn.disabled = false;
                }
            }

            /* Submit hard answer */
            submitWordBtn.addEventListener('click', checkHardAnswer);

            function checkHardAnswer() {
                clearInterval(STATE.timerInterval);
                const correct = STATE.hardBlanks.every(b => b.userAnswer === b.char);

                if (correct) {
                    handleCorrect(true);
                } else {
                    handleWrong(true);
                }
            }

            /* ── Normal mode — check on Enter ── */
            romajiInput.addEventListener('keydown', e => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    if (!STATE.gameActive) return;
                    checkNormalAnswer();
                }
            });

            function checkNormalAnswer() {
                const val    = romajiInput.value.trim().toLowerCase().replace(/\s+/g,'');
                const answer = (STATE.currentWord?.wordRomaji ?? '').toLowerCase();
                if (!val) return;

                clearInterval(STATE.timerInterval);

                if (val === answer) {
                    handleCorrect(false);
                } else {
                    handleWrong(false);
                }
            }

            /* ── Handle correct ── */
            function handleCorrect(isHard) {
                SFX.correct();
                STATE.correct++;
                STATE.combo++;
                STATE.maxCombo = Math.max(STATE.maxCombo, STATE.combo);

                /* Score calculation */
                const baseScore = isHard ? 150 : 100;
                const timeBonus = Math.round(STATE.timeLeft * 5);
                const comboMult = Math.min(3.0, 1 + (STATE.combo - 1) * 0.25);
                const earned    = Math.round((baseScore + timeBonus) * comboMult);
                STATE.score    += earned;
                STATE.multiplier = comboMult;

                /* Feedback */
                kanaCard.classList.add('correct');
                romajiInput.classList.add('correct-state');
                showFeedback('✅ Correct!', 'correct');
                floatScore(earned, true);

                /* Combo sound */
                if (STATE.combo >= 3) SFX.combo();

                updateScoreDisplay();
                updateComboDisplay();

                setTimeout(() => {
                    kanaCard.classList.remove('correct');
                    romajiInput.classList.remove('correct-state');
                    STATE.currentIndex++;
                    loadQuestion();
                }, 600);
            }

            /* ── Handle wrong ── */
            function handleWrong(isHard) {
                SFX.wrong();
                STATE.wrong++;
                STATE.combo = 0;
                STATE.multiplier = 1.0;

                kanaCard.classList.add('wrong');
                romajiInput.classList.add('wrong-state');
                showFeedback(`❌ Wrong — answer: ${STATE.currentWord.wordRomaji}`, 'wrong');
                floatScore(-10, false);

                STATE.score = Math.max(0, STATE.score - 10);
                updateScoreDisplay();
                updateComboDisplay();

                setTimeout(() => {
                    kanaCard.classList.remove('wrong');
                    romajiInput.classList.remove('wrong-state');
                    STATE.currentIndex++;
                    loadQuestion();
                }, 1000);
            }

            /* ── Timer ── */
            function startTimer() {
                STATE.timeLeft = STATE.timePerQ;
                timerBar.style.width = '100%';
                timerBar.className = 'timer-bar';
                timerBar.parentElement.setAttribute('aria-valuenow', 100);

                const totalMs = STATE.timePerQ * 1000;
                const startTs = Date.now();

                STATE.timerInterval = setInterval(() => {
                    const elapsed = Date.now() - startTs;
                    const pct     = Math.max(0, 1 - elapsed / totalMs);
                    STATE.timeLeft = Math.max(0, STATE.timePerQ - elapsed / 1000);
                    timerBar.style.width = (pct * 100).toFixed(1) + '%';
                    timerBar.parentElement.setAttribute('aria-valuenow', Math.round(pct * 100));

                    if (pct < 0.25)     timerBar.className = 'timer-bar danger';
                    else if (pct < 0.5) timerBar.className = 'timer-bar warn';
                    else                timerBar.className = 'timer-bar';

                    if (elapsed >= totalMs) {
                        clearInterval(STATE.timerInterval);
                        handleTimeOut();
                    }
                }, 80);
            }

            function handleTimeOut() {
                STATE.wrong++;
                STATE.combo = 0;
                STATE.multiplier = 1.0;
                showFeedback(`⏰ Time! Answer: ${STATE.currentWord?.wordRomaji ?? ''}`, 'wrong');
                SFX.wrong();
                floatScore(-5, false);
                STATE.score = Math.max(0, STATE.score - 5);
                updateScoreDisplay();
                updateComboDisplay();
                timerBar.style.width = '0%';

                setTimeout(() => {
                    STATE.currentIndex++;
                    loadQuestion();
                }, 1000);
            }

            /* ── Update score display ── */
            function updateScoreDisplay() {
                statScore.textContent   = STATE.score.toLocaleString();
                statCorrect.textContent = STATE.correct;
                statWrong.textContent   = STATE.wrong;

                const total = STATE.correct + STATE.wrong;
                const acc   = total > 0 ? Math.round((STATE.correct / total) * 100) : 100;
                statAcc.textContent = acc + '%';
                accBar.style.width  = acc + '%';

                /* Brief color flash on score */
                statScore.classList.add('score-bump');
                setTimeout(() => statScore.classList.remove('score-bump'), 400);
            }

            /* ── Update combo display ── */
            function updateComboDisplay() {
                comboBadge.textContent = `🔥 ${STATE.combo} Combo`;
                multiplierBadge.textContent = `×${STATE.multiplier.toFixed(1)}`;
                comboBadge.className = STATE.combo >= 3 ? 'combo-badge active' : 'combo-badge inactive';
            }

            /* ── Feedback bubble ── */
            function showFeedback(text, type) {
                feedbackBubble.textContent = text;
                feedbackBubble.className   = `feedback-bubble ${type}`;
            }

            /* ── Floating score pop ── */
            function floatScore(val, isGood) {
                const el = document.createElement('div');
                el.className = 'score-float' + (isGood ? '' : ' neg');
                el.textContent = (isGood ? '+' : '') + val;
                el.style.cssText = `
                    left: ${40 + Math.random() * 20}%;
                    top: ${30 + Math.random() * 20}%;
                `;
                document.body.appendChild(el);
                setTimeout(() => el.remove(), 900);
            }

            /* ── End game ── */
            function endGame() {
                clearInterval(STATE.timerInterval);
                STATE.gameActive = false;
                SFX.victory();

                const total    = STATE.correct + STATE.wrong;
                const acc      = total > 0 ? Math.round((STATE.correct / total) * 100) : 0;
                const xpEarned = Math.round(STATE.score * 0.5 + STATE.correct * 5);

                /* Populate result card */
                $('r-score').textContent   = STATE.score.toLocaleString();
                $('r-correct').textContent = STATE.correct;
                $('r-acc').textContent     = acc + '%';
                $('r-combo').textContent   = STATE.maxCombo;
                $('r-time').textContent    = getAvgTime() + 's';
                $('r-xp').textContent      = xpEarned;

                /* Result emoji / title */
                let emoji = '🏆', title = 'Round Complete!', sub = '';
                if (acc >= 95) { emoji = '🌟'; title = 'Exceptional!'; sub = 'Near-perfect accuracy — you are a kana master!'; }
                else if (acc >= 80) { emoji = '⭐'; title = 'Excellent!'; sub = 'Great performance — keep pushing!'; }
                else if (acc >= 60) { emoji = '👍'; title = 'Good Job!'; sub = 'Solid round — practice makes perfect!'; }
                else { emoji = '💪'; title = 'Keep Training!'; sub = 'Focus on accuracy — you will get there!'; }

                $('result-emoji').textContent = emoji;
                $('result-title').textContent = title;
                $('result-sub').textContent   = sub;
                $('xp-pill').innerHTML        = `⭐ +${xpEarned} XP Earned`;

                resultOverlay.style.display = 'flex';
                resultOverlay.style.alignItems = 'center';
                resultOverlay.style.justifyContent = 'center';
                resultOverlay.style.position = 'fixed';
                resultOverlay.style.inset = '0';
                resultOverlay.style.background = 'rgba(255,255,255,0.94)';
                resultOverlay.style.backdropFilter = 'blur(10px)';
                resultOverlay.style.zIndex = '8000';

                submitScore(xpEarned, acc, total);
            }

            function getAvgTime() {
                if (!STATE.timings.length) return STATE.timePerQ;
                return (STATE.timings.reduce((a,b) => a+b, 0) / STATE.timings.length).toFixed(1);
            }

            /* ── Submit score to server ── */
            async function submitScore(xpEarned, acc, total) {
                try {
                    await fetch('/KanaBlitz/SubmitScore', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
                        body: JSON.stringify({
                            score:      STATE.score,
                            difficulty: STATE.difficulty,
                            alphabet:   STATE.alphabet,
                            correct:    STATE.correct,
                            total:      total,
                            maxCombo:   STATE.maxCombo,
                            xpEarned:   xpEarned
                        })
                    });
                } catch (e) { /* score submission not critical */ }
            }

            function getAntiForgeryToken() {
                const el = document.querySelector('input[name="__RequestVerificationToken"]');
                return el ? el.value : '';
            }

            /* ── Result buttons ── */
            $('play-again-btn').addEventListener('click', () => {
                SFX.click();
                resultOverlay.style.display = 'none';
                showCountdown();
            });

            $('change-setup-btn').addEventListener('click', () => {
                SFX.click();
                resultOverlay.style.display = 'none';
                gameArena.style.display     = 'none';
                setupPanel.style.display    = 'block';
            });

            /* ── Init ── */
            (async function init() {
                await fetchUnlocks();
                updateWordCountInfo();
                selectDifficulty('easy');
            })();

        })();
    </script>
}
