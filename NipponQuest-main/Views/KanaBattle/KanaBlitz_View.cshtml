@*
    ╔══════════════════════════════════════════════════════════════════╗
    ║  KanaBlitz_View.cshtml  —  KanaBattle Hub / Lobby & Setup       ║
    ║  Controller : KanaBattleController → MainView()                 ║
    ║  Route      : /KanaBattle/MainView                              ║
    ║  Launches   : /KanaBattle/Battle?difficulty=&script=            ║
    ║  Refactored : Full audit, debug, redesign & UX overhaul         ║
    ║  Aesthetic  : White background · Black / Gold / White / Blue    ║
    ╚══════════════════════════════════════════════════════════════════╝
*@
@{
    ViewData["Title"] = "KanaBattle — Choose Your Battle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ══════════════════════════════════════════════════════════════
           NIPPONQUEST — KanaBattle Lobby & Hub
           Palette : White bg · Black text · Gold accents · Blue action
           Font    : Nunito (loaded via site.css)
        ══════════════════════════════════════════════════════════════ */
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');

    :root {
        --lv-bg: #ffffff;
        --lv-surface: #f8fafc;
        --lv-surface2: #f1f5f9;
        --lv-border: #e2e8f0;
        --lv-border2: #cbd5e1;
        --lv-black: #0f172a;
        --lv-charcoal: #1e293b;
        --lv-dark: #334155;
        --lv-muted: #64748b;
        --lv-faint: #94a3b8;
        --lv-gold: #d97706;
        --lv-gold-lt: #f59e0b;
        --lv-gold-bg: #fef3c7;
        --lv-gold-bd: #fcd34d;
        --lv-blue: #1e40af;
        --lv-blue-lt: #3b82f6;
        --lv-blue-bg: #eff6ff;
        --lv-blue-bd: #93c5fd;
        --lv-green: #065f46;
        --lv-green-lt: #10b981;
        --lv-green-bg: #ecfdf5;
        --lv-green-bd: #6ee7b7;
        --lv-red: #991b1b;
        --lv-red-lt: #ef4444;
        --lv-red-bg: #fff1f2;
        --lv-red-bd: #fca5a5;
        --lv-radius: 14px;
        --lv-radius-sm: 10px;
        --lv-radius-lg: 20px;
        --lv-shadow: 0 4px 16px rgba(15,23,42,0.08);
        --lv-shadow-lg: 0 8px 32px rgba(15,23,42,0.12);
        --lv-trans: all 0.22s cubic-bezier(0.4,0,0.2,1);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    .lv-page {
        background: var(--lv-bg);
        min-height: 100vh;
        color: var(--lv-black);
        font-family: 'Nunito', 'Segoe UI', sans-serif;
        padding-bottom: 80px;
    }

        /* Accent bar */
        .lv-page::before {
            content: '';
            display: block;
            height: 4px;
            background: linear-gradient(90deg, #0f172a 0%, #d97706 40%, #ef4444 70%, #1e40af 100%);
        }

    .lv-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 32px 16px;
    }

    /* ── Hero ── */
    .hero {
        text-align: center;
        padding: 32px 20px 44px;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--lv-red-bg);
        border: 1.5px solid var(--lv-red-bd);
        border-radius: 100px;
        padding: 6px 20px;
        font-size: 0.68rem;
        font-weight: 900;
        letter-spacing: 0.18em;
        color: var(--lv-red);
        text-transform: uppercase;
        margin-bottom: 18px;
    }

    .hero h1 {
        font-size: clamp(2.2rem,6vw,3.8rem);
        font-weight: 900;
        letter-spacing: 0.03em;
        color: var(--lv-black);
        line-height: 1.1;
        margin-bottom: 12px;
    }

        .hero h1 .gold {
            color: var(--lv-gold);
        }

        .hero h1 .blue {
            color: var(--lv-blue-lt);
        }

        .hero h1 .red {
            color: var(--lv-red-lt);
        }

    .hero p {
        color: var(--lv-muted);
        font-size: 1rem;
        max-width: 560px;
        margin: 0 auto;
        line-height: 1.7;
    }

    /* ── Live Stats Pills ── */
    .live-stats {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
        margin: 24px 0 44px;
    }

    .stat-pill {
        background: var(--lv-surface);
        border: 1.5px solid var(--lv-border);
        border-radius: 100px;
        padding: 9px 22px;
        font-size: 0.8rem;
        display: flex;
        align-items: center;
        gap: 8px;
        box-shadow: var(--lv-shadow);
        color: var(--lv-dark);
        font-weight: 600;
    }

        .stat-pill .pill-val {
            font-weight: 900;
            color: var(--lv-gold);
        }

    /* ── Section Label ── */
    .section-label {
        font-size: 0.67rem;
        font-weight: 900;
        letter-spacing: 0.2em;
        color: var(--lv-blue);
        text-transform: uppercase;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .section-label::after {
            content: '';
            flex: 1;
            height: 1.5px;
            background: linear-gradient(90deg, var(--lv-border2), transparent);
        }

    /* ── Config Panel ── */
    .config-panel {
        background: var(--lv-surface);
        border: 1.5px solid var(--lv-border);
        border-radius: var(--lv-radius-lg);
        padding: 32px 28px;
        margin-bottom: 24px;
        box-shadow: var(--lv-shadow);
    }

    /* ── Choice Cards ── */
    .choice-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px,1fr));
        gap: 12px;
        margin-bottom: 28px;
    }

    .choice-card {
        background: var(--lv-bg);
        border: 2px solid var(--lv-border);
        border-radius: var(--lv-radius);
        padding: 20px 14px;
        cursor: pointer;
        transition: var(--lv-trans);
        text-align: center;
        position: relative;
        overflow: hidden;
        user-select: none;
    }

        .choice-card:hover {
            border-color: var(--lv-blue-lt);
            background: var(--lv-blue-bg);
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(30,64,175,0.12);
        }

        .choice-card.active {
            border-color: var(--lv-blue);
            background: var(--lv-blue-bg);
            box-shadow: 0 0 0 3px rgba(30,64,175,0.15);
            transform: translateY(-2px);
        }

        .choice-card[data-diff="easy"].active {
            border-color: var(--lv-green-lt);
            background: var(--lv-green-bg);
            box-shadow: 0 0 0 3px rgba(16,185,129,0.15);
        }

        .choice-card[data-diff="normal"].active {
            border-color: var(--lv-blue-lt);
            background: var(--lv-blue-bg);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
        }

        .choice-card[data-diff="hard"].active {
            border-color: var(--lv-gold);
            background: var(--lv-gold-bg);
            box-shadow: 0 0 0 3px rgba(217,119,6,0.18);
        }

        .choice-card[data-diff="insanity"].active {
            border-color: var(--lv-red-lt);
            background: var(--lv-red-bg);
            box-shadow: 0 0 0 3px rgba(239,68,68,0.15);
        }

        .choice-card .c-icon {
            font-size: 2.2rem;
            margin-bottom: 9px;
            display: block;
        }

        .choice-card .c-label {
            font-weight: 800;
            font-size: 0.98rem;
            color: var(--lv-charcoal);
            display: block;
        }

        .choice-card .c-sub {
            font-size: 0.7rem;
            color: var(--lv-muted);
            margin-top: 4px;
            display: block;
        }

        .choice-card .c-tag {
            font-size: 0.66rem;
            color: var(--lv-blue);
            margin-top: 3px;
            display: block;
            font-weight: 700;
        }

        .choice-card .c-count {
            font-size: 0.63rem;
            color: var(--lv-faint);
            margin-top: 2px;
            display: block;
        }

    .diff-pip {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-bottom: 6px;
    }

    .pip-easy {
        background: var(--lv-green-lt);
    }

    .pip-normal {
        background: var(--lv-blue-lt);
    }

    .pip-hard {
        background: var(--lv-gold);
    }

    .pip-insanity {
        background: var(--lv-red-lt);
    }

    /* ── Word Warning ── */
    #word-warning {
        display: none;
        background: var(--lv-red-bg);
        border: 1.5px solid var(--lv-red-bd);
        border-radius: var(--lv-radius-sm);
        padding: 14px 18px;
        margin-bottom: 20px;
        font-size: 0.85rem;
        color: var(--lv-red);
        font-weight: 700;
        gap: 10px;
        align-items: flex-start;
    }

        #word-warning.visible {
            display: flex;
        }

    /* ── Player Name ── */
    .player-name-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 28px;
    }

        .player-name-row label {
            font-size: 0.78rem;
            font-weight: 800;
            color: var(--lv-dark);
            white-space: nowrap;
        }

    #player-name-input {
        flex: 1;
        padding: 12px 16px;
        border-radius: var(--lv-radius-sm);
        border: 2px solid var(--lv-border);
        font-size: 0.95rem;
        font-weight: 700;
        font-family: inherit;
        color: var(--lv-black);
        background: var(--lv-bg);
        outline: none;
        transition: var(--lv-trans);
    }

        #player-name-input:focus {
            border-color: var(--lv-blue-lt);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
        }

    /* ── Launch Button ── */
    #btn-launch {
        width: 100%;
        padding: 19px;
        border-radius: var(--lv-radius);
        border: none;
        font-size: 1.1rem;
        font-weight: 900;
        cursor: pointer;
        background: linear-gradient(135deg, #0f172a 0%, #991b1b 50%, #1e40af 100%);
        color: #ffffff;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        transition: var(--lv-trans);
        position: relative;
        overflow: hidden;
        box-shadow: 0 6px 22px rgba(15,23,42,0.22);
    }

        #btn-launch::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -60%;
            width: 30%;
            height: 200%;
            background: rgba(255,255,255,0.18);
            transform: rotate(30deg);
            transition: left 0.6s ease;
        }

        #btn-launch:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 32px rgba(15,23,42,0.3);
            filter: brightness(1.08);
        }

            #btn-launch:hover::after {
                left: 140%;
            }

        #btn-launch:disabled {
            background: var(--lv-surface2);
            color: var(--lv-faint);
            cursor: not-allowed;
            box-shadow: none;
            transform: none;
            filter: none;
        }

    /* ── Mode Cards ── */
    .mode-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px,1fr));
        gap: 20px;
        margin-bottom: 36px;
    }

    .mode-card {
        background: var(--lv-bg);
        border: 2px solid var(--lv-border);
        border-radius: var(--lv-radius-lg);
        padding: 32px 24px;
        text-align: center;
        cursor: pointer;
        transition: var(--lv-trans);
        position: relative;
        overflow: hidden;
        user-select: none;
    }

        .mode-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--lv-border);
            transition: var(--lv-trans);
        }

        .mode-card.solo-card::before {
            background: linear-gradient(90deg, var(--lv-blue-lt), var(--lv-gold));
        }

        .mode-card.multi-card::before {
            background: linear-gradient(90deg, var(--lv-red-lt), var(--lv-gold));
        }

        .mode-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--lv-shadow-lg);
        }

        .mode-card.active {
            box-shadow: 0 0 0 3px rgba(30,64,175,0.2), var(--lv-shadow-lg);
        }

        .mode-card.solo-card.active {
            border-color: var(--lv-blue-lt);
        }

        .mode-card.multi-card.active {
            border-color: var(--lv-red-lt);
        }

    .mode-icon {
        font-size: 3.5rem;
        margin-bottom: 14px;
        display: block;
    }

    .mode-title {
        font-size: 1.3rem;
        font-weight: 900;
        color: var(--lv-black);
        margin-bottom: 8px;
    }

    .mode-desc {
        font-size: 0.85rem;
        color: var(--lv-muted);
        line-height: 1.6;
        margin-bottom: 16px;
    }

    .mode-badge {
        display: inline-block;
        padding: 5px 14px;
        border-radius: 100px;
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

        .mode-badge.blue {
            background: var(--lv-blue-bg);
            color: var(--lv-blue);
            border: 1px solid var(--lv-blue-bd);
        }

        .mode-badge.red {
            background: var(--lv-red-bg);
            color: var(--lv-red);
            border: 1px solid var(--lv-red-bd);
        }

    /* ── Solo Config (hidden by default, shown when solo selected) ── */
    #solo-config {
        display: none;
    }

    #multi-config {
        display: none;
    }

    /* ── Player slots for multiplayer ── */
    .player-slots {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px,1fr));
        gap: 14px;
        margin-bottom: 20px;
    }

    .player-slot {
        background: var(--lv-bg);
        border: 2px solid var(--lv-border);
        border-radius: var(--lv-radius);
        padding: 16px;
    }

        .player-slot label {
            display: block;
            font-size: 0.7rem;
            font-weight: 800;
            letter-spacing: 0.12em;
            color: var(--lv-blue);
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .player-slot input {
            width: 100%;
            padding: 10px 14px;
            border-radius: var(--lv-radius-sm);
            border: 2px solid var(--lv-border);
            font-size: 0.9rem;
            font-weight: 700;
            font-family: inherit;
            color: var(--lv-black);
            background: var(--lv-surface);
            outline: none;
            transition: var(--lv-trans);
        }

            .player-slot input:focus {
                border-color: var(--lv-blue-lt);
                box-shadow: 0 0 0 2px rgba(59,130,246,0.1);
            }

    /* ── Quick-access navigation ── */
    .quick-nav {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .quick-nav-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 11px 22px;
        border-radius: var(--lv-radius);
        border: 2px solid var(--lv-border);
        background: var(--lv-bg);
        color: var(--lv-charcoal);
        font-size: 0.84rem;
        font-weight: 800;
        text-decoration: none;
        transition: var(--lv-trans);
        cursor: pointer;
        font-family: inherit;
    }

        .quick-nav-btn:hover {
            border-color: var(--lv-blue-lt);
            background: var(--lv-blue-bg);
            color: var(--lv-blue);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(30,64,175,0.12);
            text-decoration: none;
        }

        .quick-nav-btn.gold-btn {
            background: var(--lv-gold-bg);
            border-color: var(--lv-gold-bd);
            color: var(--lv-gold);
        }

            .quick-nav-btn.gold-btn:hover {
                background: var(--lv-gold);
                color: #ffffff;
                border-color: var(--lv-gold);
            }

    /* ── Countdown overlay ── */
    #countdown-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(6px);
        z-index: 300;
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }

        #countdown-overlay.visible {
            display: flex;
        }

    .countdown-num {
        font-size: clamp(6rem,20vw,12rem);
        font-weight: 900;
        color: var(--lv-black);
        line-height: 1;
        animation: lvCountPop 0.85s cubic-bezier(0.34,1.56,0.64,1);
    }

    .countdown-label {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--lv-muted);
        margin-top: 16px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    /* ── Toast ── */
    #toast-container {
        position: fixed;
        bottom: 24px;
        right: 24px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        z-index: 500;
        pointer-events: none;
    }

    .toast {
        background: var(--lv-black);
        color: #ffffff;
        padding: 12px 20px;
        border-radius: var(--lv-radius-sm);
        font-size: 0.82rem;
        font-weight: 700;
        box-shadow: 0 6px 20px rgba(0,0,0,0.2);
        animation: lvSlideInRight 0.3s cubic-bezier(0.34,1.56,0.64,1), lvFadeOut 0.4s ease 2.5s forwards;
        border-left: 4px solid var(--lv-gold);
    }

    /* ── @@keyframes ── */
    @@keyframes lvSlideIn {
        from {
            opacity: 0;
            transform: translateY(16px) scale(0.97);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @@keyframes lvFadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes lvPop {
        0% {
            transform: scale(0.8);
            opacity: 0;
        }

        60% {
            transform: scale(1.08);
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes lvCountPop {
        0% {
            transform: scale(0.4);
            opacity: 0;
        }

        60% {
            transform: scale(1.08);
            opacity: 1;
        }

        100% {
            transform: scale(1);
        }
    }

    @@keyframes lvPulse {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(217,119,6,0.35);
        }

        50% {
            box-shadow: 0 0 0 10px rgba(217,119,6,0);
        }
    }

    @@keyframes lvSlideInRight {
        from {
            opacity: 0;
            transform: translateX(30px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes lvFadeOut {
        to {
            opacity: 0;
            transform: translateX(20px);
        }
    }

    @@keyframes lvShimmer {
        0% {
            left: -60%;
        }

        100% {
            left: 140%;
        }
    }

    /* ── Responsive ── */
    @@media (max-width: 640px) {
        .config-panel {
            padding: 22px 16px;
        }

        .mode-grid {
            grid-template-columns: 1fr;
        }

        .hero h1 {
            font-size: 2rem;
        }

        .hero p {
            font-size: 0.9rem;
        }

        .choice-grid {
            grid-template-columns: repeat(2,1fr);
        }

        .live-stats {
            gap: 8px;
        }

        .stat-pill {
            padding: 7px 14px;
            font-size: 0.75rem;
        }

        .quick-nav {
            flex-direction: column;
            align-items: center;
        }
    }
</style>

<!-- Countdown overlay -->
<div id="countdown-overlay" role="dialog" aria-live="assertive">
    <div class="countdown-num" id="countdown-num">3</div>
    <div class="countdown-label">Battle Begins…</div>
</div>

<!-- Toast -->
<div id="toast-container" aria-live="polite"></div>

<div class="lv-page">
    <div class="lv-wrapper">

        <!-- Hero -->
        <div class="hero">
            <div class="hero-badge">⚔️ PvP Battle Arena</div>
            <h1>Kana<span class="red">Battle</span></h1>
            <p>Challenge a friend or sharpen your solo kana skills in the ultimate timed recognition arena. Choose your mode, configure your battle, and fight.</p>

            <div class="live-stats">
                <div class="stat-pill">⚡ <span class="pill-val" id="stat-easy">—</span> Easy words</div>
                <div class="stat-pill">⚔️ <span class="pill-val" id="stat-normal">—</span> Normal words</div>
                <div class="stat-pill">🔥 <span class="pill-val" id="stat-hard">—</span> Hard words</div>
                <div class="stat-pill">💀 <span class="pill-val" id="stat-insanity">—</span> Insanity words</div>
            </div>
        </div>

        <!-- Mode Selection -->
        <div class="section-label">① Choose Mode</div>
        <div class="mode-grid">
            <div class="mode-card solo-card" id="mode-solo" tabindex="0" role="button" aria-pressed="false">
                <span class="mode-icon">🧘</span>
                <div class="mode-title">Solo Training</div>
                <p class="mode-desc">Train alone against the clock. Perfect your kana recognition speed and build accuracy before challenging others.</p>
                <span class="mode-badge blue">Single Player</span>
            </div>
            <div class="mode-card multi-card" id="mode-multi" tabindex="0" role="button" aria-pressed="false">
                <span class="mode-icon">⚔️</span>
                <div class="mode-title">Multiplayer Battle</div>
                <p class="mode-desc">Head-to-head kana recognition duel. Two players, one keyboard, same words — who answers first wins the round.</p>
                <span class="mode-badge red">2 Players</span>
            </div>
        </div>

        <!-- Solo Config -->
        <div id="solo-config">
            <div class="config-panel" style="animation: lvFadeIn 0.35s ease;">

                <!-- Script -->
                <div class="section-label">② Script</div>
                <div class="choice-grid">
                    <div class="choice-card active" data-type="script" data-val="hiragana" tabindex="0" role="button" aria-pressed="true">
                        <span class="c-icon">あ</span>
                        <span class="c-label">Hiragana</span>
                        <span class="c-sub">Core Japanese</span>
                    </div>
                    <div class="choice-card" data-type="script" data-val="katakana" tabindex="0" role="button" aria-pressed="false">
                        <span class="c-icon">ア</span>
                        <span class="c-label">Katakana</span>
                        <span class="c-sub">Loanwords</span>
                    </div>
                    <div class="choice-card" data-type="script" data-val="dakuten" tabindex="0" role="button" aria-pressed="false">
                        <span class="c-icon">が</span>
                        <span class="c-label">Dakuten</span>
                        <span class="c-sub">Voiced + special</span>
                    </div>
                    <div class="choice-card" data-type="script" data-val="mixed" tabindex="0" role="button" aria-pressed="false">
                        <span class="c-icon">漢</span>
                        <span class="c-label">Mixed</span>
                        <span class="c-sub">All scripts</span>
                    </div>
                </div>

                <!-- Difficulty -->
                <div class="section-label">③ Difficulty</div>
                <div class="choice-grid" id="solo-diff-grid">
                    <div class="choice-card" data-type="diff" data-diff="easy" data-val="easy" tabindex="0" role="button" aria-pressed="false">
                        <span class="diff-pip pip-easy"></span>
                        <span class="c-icon">🌱</span>
                        <span class="c-label">Easy</span>
                        <span class="c-sub">Single characters</span>
                        <span class="c-count" id="s-cnt-easy">—</span>
                    </div>
                    <div class="choice-card active" data-type="diff" data-diff="normal" data-val="normal" tabindex="0" role="button" aria-pressed="true">
                        <span class="diff-pip pip-normal"></span>
                        <span class="c-icon">⚔️</span>
                        <span class="c-label">Normal</span>
                        <span class="c-sub">Common words</span>
                        <span class="c-count" id="s-cnt-normal">—</span>
                    </div>
                    <div class="choice-card" data-type="diff" data-diff="hard" data-val="hard" tabindex="0" role="button" aria-pressed="false">
                        <span class="diff-pip pip-hard"></span>
                        <span class="c-icon">🔥</span>
                        <span class="c-label">Hard</span>
                        <span class="c-sub">Compounds</span>
                        <span class="c-count" id="s-cnt-hard">—</span>
                    </div>
                    <div class="choice-card" data-type="diff" data-diff="insanity" data-val="insanity" tabindex="0" role="button" aria-pressed="false">
                        <span class="diff-pip pip-insanity"></span>
                        <span class="c-icon">💀</span>
                        <span class="c-label">Insanity</span>
                        <span class="c-sub">Kanji + furigana</span>
                        <span class="c-count" id="s-cnt-insanity">—</span>
                    </div>
                </div>

                <!-- Player Name -->
                <div class="section-label">④ Player Name</div>
                <div class="player-name-row" style="margin-bottom:28px">
                    <label for="solo-player-name">Your Name</label>
                    <input type="text" id="solo-player-name" placeholder="Enter player name…" maxlength="32" value="Player 1" />
                </div>

                <!-- Warning -->
                <div id="word-warning" role="alert">
                    <span style="font-size:1.2rem">⚠️</span>
                    <div>
                        <strong id="warning-title">Not enough words</strong>
                        <div id="warning-msg" style="font-weight:600;margin-top:2px;font-size:0.8rem;"></div>
                    </div>
                </div>

                <button id="btn-launch" aria-label="Launch Solo Battle">⚔️ LAUNCH SOLO BATTLE</button>
            </div>
        </div>

        <!-- Multiplayer Config -->
        <div id="multi-config">
            <div class="config-panel" style="animation: lvFadeIn 0.35s ease;">

                <!-- Script -->
                <div class="section-label">② Script</div>
                <div class="choice-grid">
                    <div class="choice-card active" data-type="m-script" data-val="hiragana" tabindex="0" role="button" aria-pressed="true">
                        <span class="c-icon">あ</span>
                        <span class="c-label">Hiragana</span>
                        <span class="c-sub">Core Japanese</span>
                    </div>
                    <div class="choice-card" data-type="m-script" data-val="katakana" tabindex="0" role="button" aria-pressed="false">
                        <span class="c-icon">ア</span>
                        <span class="c-label">Katakana</span>
                        <span class="c-sub">Loanwords</span>
                    </div>
                    <div class="choice-card" data-type="m-script" data-val="dakuten" tabindex="0" role="button" aria-pressed="false">
                        <span class="c-icon">が</span>
                        <span class="c-label">Dakuten</span>
                        <span class="c-sub">Voiced</span>
                    </div>
                    <div class="choice-card" data-type="m-script" data-val="mixed" tabindex="0" role="button" aria-pressed="false">
                        <span class="c-icon">漢</span>
                        <span class="c-label">Mixed</span>
                        <span class="c-sub">All scripts</span>
                    </div>
                </div>

                <!-- Difficulty -->
                <div class="section-label">③ Difficulty</div>
                <div class="choice-grid" id="multi-diff-grid">
                    <div class="choice-card" data-type="m-diff" data-diff="easy" data-val="easy" tabindex="0" role="button" aria-pressed="false">
                        <span class="diff-pip pip-easy"></span>
                        <span class="c-icon">🌱</span>
                        <span class="c-label">Easy</span>
                        <span class="c-count" id="m-cnt-easy">—</span>
                    </div>
                    <div class="choice-card active" data-type="m-diff" data-diff="normal" data-val="normal" tabindex="0" role="button" aria-pressed="true">
                        <span class="diff-pip pip-normal"></span>
                        <span class="c-icon">⚔️</span>
                        <span class="c-label">Normal</span>
                        <span class="c-count" id="m-cnt-normal">—</span>
                    </div>
                    <div class="choice-card" data-type="m-diff" data-diff="hard" data-val="hard" tabindex="0" role="button" aria-pressed="false">
                        <span class="diff-pip pip-hard"></span>
                        <span class="c-icon">🔥</span>
                        <span class="c-label">Hard</span>
                        <span class="c-count" id="m-cnt-hard">—</span>
                    </div>
                    <div class="choice-card" data-type="m-diff" data-diff="insanity" data-val="insanity" tabindex="0" role="button" aria-pressed="false">
                        <span class="diff-pip pip-insanity"></span>
                        <span class="c-icon">💀</span>
                        <span class="c-label">Insanity</span>
                        <span class="c-count" id="m-cnt-insanity">—</span>
                    </div>
                </div>

                <!-- Player Names -->
                <div class="section-label">④ Players</div>
                <div class="player-slots">
                    <div class="player-slot">
                        <label for="p1-name">🔵 Player 1</label>
                        <input type="text" id="p1-name" placeholder="Player 1 name…" maxlength="24" value="Player 1" />
                    </div>
                    <div class="player-slot">
                        <label for="p2-name">🔴 Player 2</label>
                        <input type="text" id="p2-name" placeholder="Player 2 name…" maxlength="24" value="Player 2" />
                    </div>
                </div>

                <!-- Word warning for multi -->
                <div id="m-word-warning" style="display:none;background:var(--lv-red-bg);border:1.5px solid var(--lv-red-bd);border-radius:var(--lv-radius-sm);padding:14px 18px;margin-bottom:20px;font-size:0.85rem;color:var(--lv-red);font-weight:700;" role="alert">
                    ⚠️ <span id="m-warning-msg">Not enough words for this selection.</span>
                </div>

                <button id="btn-launch-multi" aria-label="Launch Multiplayer Battle">⚔️ LAUNCH BATTLE</button>
            </div>
        </div>

        <!-- Quick Nav -->
        <div class="quick-nav">
            <a href="/KanaBlitz/Index" class="quick-nav-btn">⚡ Solo KanaBlitz</a>
            <a href="/" class="quick-nav-btn">🏠 Home</a>
            <a href="/Leaderboard" class="quick-nav-btn gold-btn">🏆 Leaderboard</a>
        </div>

    </div><!-- /lv-wrapper -->
</div><!-- /lv-page -->
@section Scripts {
    <script>
        /* ══════════════════════════════════════════════════════════════
           KanaBattle Lobby Script
           Handles: mode selection, word-count loading, launch routing
           Routes solo  → /KanaBattle/Battle?difficulty=&script=&playerName=
           Routes multi → /KanaBattle/Battle?difficulty=&script=&playerName=&multiplayer=true
           API    : GET /KanaBlitz/GetWords?difficulty=&script=
        ══════════════════════════════════════════════════════════════ */
        (function () {
            'use strict';

            const API       = '/KanaBlitz/GetWords';
            const MIN_WORDS = { easy: 4, normal: 5, hard: 4, insanity: 4 };

            /* ── State ── */
            const S = {
                mode       : null,    // 'solo' | 'multi'
                soloScript : 'hiragana',
                soloDiff   : 'normal',
                multiScript: 'hiragana',
                multiDiff  : 'normal'
            };

            /* ── DOM ── */
            const $ = id => document.getElementById(id);

            const dom = {
                modeSolo      : $('mode-solo'),
                modeMulti     : $('mode-multi'),
                soloConfig    : $('solo-config'),
                multiConfig   : $('multi-config'),
                btnLaunch     : $('btn-launch'),
                btnLaunchMulti: $('btn-launch-multi'),
                soloName      : $('solo-player-name'),
                p1Name        : $('p1-name'),
                p2Name        : $('p2-name'),
                wordWarning   : $('word-warning'),
                warningMsg    : $('warning-msg'),
                warningTitle  : $('warning-title'),
                mWordWarning  : $('m-word-warning'),
                mWarningMsg   : $('m-warning-msg'),
                statEasy      : $('stat-easy'),
                statNormal    : $('stat-normal'),
                statHard      : $('stat-hard'),
                statInsanity  : $('stat-insanity'),
                countdownOver : $('countdown-overlay'),
                countdownNum  : $('countdown-num'),
                toastContainer: $('toast-container')
            };

            /* ── Audio hooks ── */
            const Audio = { play(type) { /* expandable */ } };

            /* ── Toast ── */
            function toast(msg, type = 'default') {
                const el = document.createElement('div');
                el.className = `toast ${type}`;
                el.textContent = msg;
                dom.toastContainer.appendChild(el);
                setTimeout(() => el.remove(), 3200);
            }

            /* ── Mode Selection ── */
            function selectMode(mode) {
                S.mode = mode;
                dom.modeSolo.classList.toggle('active', mode === 'solo');
                dom.modeMulti.classList.toggle('active', mode === 'multi');
                dom.modeSolo.setAttribute('aria-pressed',  mode === 'solo' ? 'true' : 'false');
                dom.modeMulti.setAttribute('aria-pressed', mode === 'multi' ? 'true' : 'false');

                dom.soloConfig.style.display  = mode === 'solo'  ? 'block' : 'none';
                dom.multiConfig.style.display = mode === 'multi' ? 'block' : 'none';

                if (mode === 'solo')  loadSoloCounts();
                if (mode === 'multi') loadMultiCounts();
                Audio.play('click');
            }

            dom.modeSolo.addEventListener('click',  () => selectMode('solo'));
            dom.modeMulti.addEventListener('click', () => selectMode('multi'));
            dom.modeSolo.addEventListener('keydown',  e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectMode('solo'); } });
            dom.modeMulti.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectMode('multi'); } });

            /* ── Generic card selector ── */
            function wireCards(type, stateKey) {
                document.querySelectorAll(`.choice-card[data-type="${type}"]`).forEach(card => {
                    card.addEventListener('click', () => {
                        if (card.getAttribute('aria-disabled') === 'true') return;
                        document.querySelectorAll(`.choice-card[data-type="${type}"]`).forEach(c => {
                            c.classList.remove('active');
                            c.setAttribute('aria-pressed', 'false');
                        });
                        card.classList.add('active');
                        card.setAttribute('aria-pressed', 'true');
                        S[stateKey] = card.dataset.val;
                        Audio.play('click');
                        if (type === 'script')    loadSoloCounts();
                        if (type === 'm-script')  loadMultiCounts();
                        if (type === 'diff')      validateSolo();
                        if (type === 'm-diff')    validateMulti();
                    });
                    card.addEventListener('keydown', e => {
                        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
                    });
                });
            }

            wireCards('script',   'soloScript');
            wireCards('diff',     'soloDiff');
            wireCards('m-script', 'multiScript');
            wireCards('m-diff',   'multiDiff');

            /* ── Word Count Loaders ── */
            async function loadSoloCounts() {
                const script = S.soloScript;
                const diffs  = ['easy','normal','hard','insanity'];
                const res = await Promise.allSettled(diffs.map(d =>
                    fetch(`${API}?difficulty=${d}&script=${encodeURIComponent(script)}`).then(r => r.ok ? r.json() : Promise.reject(r.status))
                ));
                res.forEach((r, i) => {
                    const el = $(`s-cnt-${diffs[i]}`);
                    if (!el) return;
                    if (r.status === 'fulfilled') {
                        const cnt = Array.isArray(r.value) ? r.value.length : 0;
                        el.textContent = `${cnt} words`;
                        const card = el.closest('.choice-card');
                        if (card) {
                            const enough = cnt >= MIN_WORDS[diffs[i]];
                            card.style.opacity = enough ? '1' : '0.5';
                            card.style.cursor  = enough ? 'pointer' : 'not-allowed';
                            card.setAttribute('aria-disabled', enough ? 'false' : 'true');
                            card.title = enough ? '' : `Only ${cnt} words — need ${MIN_WORDS[diffs[i]]}`;
                        }
                    } else {
                        el.textContent = 'Error';
                    }
                });
                validateSolo();
            }

            async function loadMultiCounts() {
                const script = S.multiScript;
                const diffs  = ['easy','normal','hard','insanity'];
                const res = await Promise.allSettled(diffs.map(d =>
                    fetch(`${API}?difficulty=${d}&script=${encodeURIComponent(script)}`).then(r => r.ok ? r.json() : Promise.reject(r.status))
                ));
                res.forEach((r, i) => {
                    const el = $(`m-cnt-${diffs[i]}`);
                    if (!el) return;
                    if (r.status === 'fulfilled') {
                        const cnt = Array.isArray(r.value) ? r.value.length : 0;
                        el.textContent = `${cnt} words`;
                        const card = el.closest('.choice-card');
                        if (card) {
                            const enough = cnt >= MIN_WORDS[diffs[i]];
                            card.style.opacity = enough ? '1' : '0.5';
                            card.style.cursor  = enough ? 'pointer' : 'not-allowed';
                            card.setAttribute('aria-disabled', enough ? 'false' : 'true');
                            card.title = enough ? '' : `Only ${cnt} words — need ${MIN_WORDS[diffs[i]]}`;
                        }
                    } else {
                        el.textContent = 'Error';
                    }
                });
                validateMulti();
            }

            async function loadHeroStats() {
                const diffs = ['easy','normal','hard','insanity'];
                const statEls = { easy: dom.statEasy, normal: dom.statNormal, hard: dom.statHard, insanity: dom.statInsanity };
                await Promise.allSettled(diffs.map(async d => {
                    try {
                        const r = await fetch(`${API}?difficulty=${d}&script=hiragana`);
                        if (!r.ok) return;
                        const data = await r.json();
                        if (statEls[d]) statEls[d].textContent = Array.isArray(data) ? data.length : '—';
                    } catch { statEls[d].textContent = '—'; }
                }));
            }

            /* ── Validation ── */
            function validateSolo() {
                if (!dom.btnLaunch) return;
                dom.wordWarning.classList.remove('visible');
                dom.wordWarning.style.display = 'none';
                dom.btnLaunch.disabled = false;
                dom.btnLaunch.textContent = '⚔️ LAUNCH SOLO BATTLE';
            }

            function validateMulti() {
                if (!dom.btnLaunchMulti) return;
                dom.btnLaunchMulti.disabled = false;
                dom.btnLaunchMulti.textContent = '⚔️ LAUNCH BATTLE';
            }

            /* ── Launch Handlers ── */
            if (dom.btnLaunch) {
                dom.btnLaunch.addEventListener('click', () => {
                    const diff   = S.soloDiff;
                    const script = S.soloScript;
                    const name   = (dom.soloName?.value || 'Player 1').trim() || 'Player 1';
                    Audio.play('click');
                    const url = `/KanaBattle/Battle?difficulty=${encodeURIComponent(diff)}&script=${encodeURIComponent(script)}&playerName=${encodeURIComponent(name)}`;
                    window.location.href = url;
                });
            }

            if (dom.btnLaunchMulti) {
                dom.btnLaunchMulti.addEventListener('click', () => {
                    const diff   = S.multiDiff;
                    const script = S.multiScript;
                    const p1     = (dom.p1Name?.value || 'Player 1').trim() || 'Player 1';
                    const p2     = (dom.p2Name?.value || 'Player 2').trim() || 'Player 2';
                    Audio.play('click');
                    const url = `/KanaBattle/Battle?difficulty=${encodeURIComponent(diff)}&script=${encodeURIComponent(script)}&playerName=${encodeURIComponent(p1)}&player2Name=${encodeURIComponent(p2)}&multiplayer=true`;
                    window.location.href = url;
                });
            }

            /* ── Init ── */
            loadHeroStats();

        })();
    </script>
}
