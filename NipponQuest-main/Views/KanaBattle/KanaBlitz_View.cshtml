@*
    ╔══════════════════════════════════════════════════════════════════╗
    ║  KanaBlitz_View.cshtml  —  Solo Game Arena                     ║
    ║  Controller : KanaBlitzController → Play()                     ║
    ║  Route      : /KanaBlitz/Play                                   ║
    ║  API        : GET /KanaBlitz/GetWords?difficulty=&alphabet=     ║
    ║  API        : GET /KanaBlitz/GetArenaPayload?alphabet=&diff=    ║
    ║  API        : GET /KanaBlitz/GetUnlocks                         ║
    ║  API        : POST /KanaBlitz/SubmitScore                       ║
    ║  Purpose    : Full solo KanaBlitz game with difficulty select   ║
    ║  Aesthetic  : White background · Black / Gold / White / Blue    ║
    ╚══════════════════════════════════════════════════════════════════╝
*@
@{
    ViewData["Title"] = "KanaBlitz — Solo Training";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ══════════════════════════════════════════════════════════════
           NIPPONQUEST — KanaBlitz Solo Arena
           Palette : White bg · Black text · Gold accents · Blue action
        ══════════════════════════════════════════════════════════════ */
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');

    :root {
        --kb-bg: #ffffff;
        --kb-surface: #f8fafc;
        --kb-surface2: #f1f5f9;
        --kb-border: #e2e8f0;
        --kb-border2: #cbd5e1;
        --kb-black: #0f172a;
        --kb-charcoal: #1e293b;
        --kb-dark: #334155;
        --kb-muted: #64748b;
        --kb-faint: #94a3b8;
        --kb-gold: #d97706;
        --kb-gold-lt: #f59e0b;
        --kb-gold-bg: #fef3c7;
        --kb-gold-bd: #fcd34d;
        --kb-blue: #1e40af;
        --kb-blue-lt: #3b82f6;
        --kb-blue-bg: #eff6ff;
        --kb-blue-bd: #93c5fd;
        --kb-green: #065f46;
        --kb-green-lt: #10b981;
        --kb-green-bg: #ecfdf5;
        --kb-green-bd: #6ee7b7;
        --kb-red: #991b1b;
        --kb-red-lt: #ef4444;
        --kb-red-bg: #fff1f2;
        --kb-red-bd: #fca5a5;
        --kb-radius: 14px;
        --kb-radius-sm: 10px;
        --kb-radius-lg: 20px;
        --kb-shadow: 0 4px 16px rgba(15,23,42,0.08);
        --kb-shadow-lg: 0 8px 32px rgba(15,23,42,0.12);
        --kb-trans: all 0.22s cubic-bezier(0.4,0,0.2,1);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    .kb-page {
        background: var(--kb-bg);
        min-height: 100vh;
        color: var(--kb-black);
        font-family: 'Nunito', 'Segoe UI', sans-serif;
        padding-bottom: 80px;
    }

        .kb-page::before {
            content: '';
            display: block;
            height: 4px;
            background: linear-gradient(90deg, #0f172a 0%, #d97706 50%, #1e40af 100%);
        }

    .kb-wrapper {
        max-width: 1060px;
        margin: 0 auto;
        padding: 32px 16px;
    }

    /* ── Keyframes ── */
    @@keyframes kbFadeUp {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes kbScaleIn {
        0% {
            transform: scale(0.9);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes kbShake {
        0%, 100% {
            transform: translateX(0);
        }

        10%, 50%, 90% {
            transform: translateX(-4px);
        }

        30%, 70% {
            transform: translateX(4px);
        }
    }

    @@keyframes kbPopCorrect {
        0% {
            transform: scale(1);
        }

        40% {
            transform: scale(1.08);
        }

        100% {
            transform: scale(1);
        }
    }

    @@keyframes kbComboFlash {
        0% {
            transform: scale(1);
            opacity: 1;
        }

        50% {
            transform: scale(1.3);
            opacity: 0.8;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes kbCountdownPop {
        0% {
            transform: scale(0.3);
            opacity: 0;
        }

        50% {
            transform: scale(1.2);
            opacity: 1;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes kbTimerPulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.5;
        }
    }

    @@keyframes kbSlideUp {
        0% {
            opacity: 0;
            transform: translateY(30px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes kbFloat {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-4px);
        }
    }

    @@keyframes kbVictoryBounce {
        0% {
            transform: scale(0);
            opacity: 0;
        }

        50% {
            transform: scale(1.15);
        }

        70% {
            transform: scale(0.95);
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes kbXPFloat {
        0% {
            opacity: 1;
            transform: translateY(0);
        }

        100% {
            opacity: 0;
            transform: translateY(-40px);
        }
    }

    @@keyframes kbPulseRing {
        0% {
            box-shadow: 0 0 0 0 rgba(16,185,129,0.4);
        }

        100% {
            box-shadow: 0 0 0 20px rgba(16,185,129,0);
        }
    }

    /* ── Header Bar ── */
    .arena-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 24px;
        padding-bottom: 18px;
        border-bottom: 1.5px solid var(--kb-border);
    }

    .arena-title-wrap h2 {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--kb-black);
        margin-bottom: 4px;
    }

    .arena-title-wrap .arena-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 4px;
    }

    .arena-tag {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 100px;
        font-size: 0.67rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

        .arena-tag.black {
            background: var(--kb-black);
            color: #fff;
        }

        .arena-tag.gold {
            background: var(--kb-gold-bg);
            color: var(--kb-gold);
            border: 1px solid var(--kb-gold-bd);
        }

        .arena-tag.blue {
            background: var(--kb-blue-bg);
            color: var(--kb-blue);
            border: 1px solid var(--kb-blue-bd);
        }

        .arena-tag.green {
            background: var(--kb-green-bg);
            color: var(--kb-green);
            border: 1px solid var(--kb-green-bd);
        }

        .arena-tag.red {
            background: var(--kb-red-bg);
            color: var(--kb-red);
            border: 1px solid var(--kb-red-bd);
        }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--kb-muted);
        text-decoration: none;
        transition: var(--kb-trans);
        padding: 8px 16px;
        border-radius: var(--kb-radius-sm);
        border: 1.5px solid var(--kb-border);
        background: var(--kb-surface);
    }

        .back-link:hover {
            color: var(--kb-blue);
            border-color: var(--kb-blue-bd);
            background: var(--kb-blue-bg);
            transform: translateY(-1px);
        }

    /* ── Setup Panel ── */
    #setup-panel {
        background: var(--kb-surface);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-lg);
        padding: 32px 28px;
        margin-bottom: 24px;
        box-shadow: var(--kb-shadow);
        animation: kbFadeUp 0.4s ease both;
    }

    .section-label {
        font-size: 0.67rem;
        font-weight: 900;
        letter-spacing: 0.2em;
        color: var(--kb-blue);
        text-transform: uppercase;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .section-label::after {
            content: '';
            flex: 1;
            height: 1.5px;
            background: linear-gradient(90deg, var(--kb-border2), transparent);
        }

    /* ── Choice Cards ── */
    .choice-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 12px;
        margin-bottom: 28px;
    }

    .choice-card {
        background: var(--kb-bg);
        border: 2px solid var(--kb-border);
        border-radius: var(--kb-radius);
        padding: 18px 12px;
        cursor: pointer;
        transition: var(--kb-trans);
        text-align: center;
        position: relative;
        overflow: hidden;
        user-select: none;
    }

        .choice-card:hover {
            border-color: var(--kb-blue-lt);
            background: var(--kb-blue-bg);
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(30,64,175,0.12);
        }

        .choice-card.active {
            border-color: var(--kb-blue);
            background: var(--kb-blue-bg);
            box-shadow: 0 0 0 3px rgba(30,64,175,0.15);
            transform: translateY(-2px);
        }

        .choice-card[data-diff="easy"].active {
            border-color: var(--kb-green-lt);
            background: var(--kb-green-bg);
            box-shadow: 0 0 0 3px rgba(16,185,129,0.15);
        }

        .choice-card[data-diff="normal"].active {
            border-color: var(--kb-blue-lt);
            background: var(--kb-blue-bg);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
        }

        .choice-card[data-diff="hard"].active {
            border-color: var(--kb-gold);
            background: var(--kb-gold-bg);
            box-shadow: 0 0 0 3px rgba(217,119,6,0.18);
        }

        .choice-card[data-diff="insanity"].active {
            border-color: var(--kb-red-lt);
            background: var(--kb-red-bg);
            box-shadow: 0 0 0 3px rgba(239,68,68,0.15);
        }

        .choice-card.locked {
            opacity: 0.45;
            cursor: not-allowed;
            pointer-events: none;
        }

        .choice-card .c-icon {
            font-size: 2rem;
            margin-bottom: 8px;
            display: block;
        }

        .choice-card .c-label {
            font-weight: 800;
            font-size: 0.92rem;
            color: var(--kb-charcoal);
            display: block;
        }

        .choice-card .c-sub {
            font-size: 0.7rem;
            color: var(--kb-muted);
            margin-top: 4px;
            display: block;
        }

        .choice-card .c-count {
            font-size: 0.65rem;
            color: var(--kb-faint);
            margin-top: 4px;
            display: block;
        }

        .choice-card .lock-badge {
            position: absolute;
            top: 8px;
            right: 8px;
            font-size: 0.85rem;
        }

    /* ── Start Button ── */
    .start-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 16px 36px;
        border-radius: 14px;
        font-weight: 900;
        font-size: 1rem;
        letter-spacing: 0.06em;
        border: none;
        cursor: pointer;
        transition: var(--kb-trans);
        background: linear-gradient(135deg, var(--kb-blue), var(--kb-blue-lt));
        color: #fff;
        box-shadow: 0 6px 20px rgba(30,64,175,0.25);
        position: relative;
        overflow: hidden;
    }

        .start-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(30,64,175,0.35);
            filter: brightness(1.05);
        }

        .start-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

    /* ── Game Arena ── */
    #game-arena {
        display: none;
        animation: kbFadeUp 0.4s ease both;
    }

    /* HUD */
    .game-hud {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .hud-stat {
        background: var(--kb-surface);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-sm);
        padding: 10px 18px;
        text-align: center;
        min-width: 100px;
    }

        .hud-stat .hud-label {
            font-size: 0.6rem;
            font-weight: 900;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--kb-faint);
            margin-bottom: 4px;
        }

        .hud-stat .hud-value {
            font-size: 1.5rem;
            font-weight: 900;
            color: var(--kb-black);
            line-height: 1;
        }

            .hud-stat .hud-value.score-val {
                color: var(--kb-gold);
            }

            .hud-stat .hud-value.combo-val {
                color: var(--kb-red-lt);
            }

            .hud-stat .hud-value.round-val {
                color: var(--kb-blue);
            }

    /* Timer Bar */
    .timer-bar-track {
        width: 100%;
        height: 8px;
        background: var(--kb-surface2);
        border-radius: 4px;
        margin-bottom: 24px;
        overflow: hidden;
    }

    .timer-bar-fill {
        height: 100%;
        border-radius: 4px;
        transition: width 0.3s linear, background 0.3s ease;
        background: linear-gradient(90deg, var(--kb-green-lt), var(--kb-blue-lt));
    }

        .timer-bar-fill.warning {
            background: linear-gradient(90deg, var(--kb-gold-lt), var(--kb-gold));
        }

        .timer-bar-fill.danger {
            background: linear-gradient(90deg, var(--kb-red-lt), var(--kb-red));
            animation: kbTimerPulse 0.5s ease infinite;
        }

    /* Question Card */
    .question-card {
        background: var(--kb-surface);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-lg);
        padding: 40px 28px;
        text-align: center;
        margin-bottom: 24px;
        box-shadow: var(--kb-shadow);
        animation: kbScaleIn 0.3s ease both;
    }

    .question-label {
        font-size: 0.65rem;
        font-weight: 900;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--kb-faint);
        margin-bottom: 12px;
    }

    .question-kana {
        font-size: clamp(3rem, 8vw, 5rem);
        font-weight: 900;
        color: var(--kb-black);
        line-height: 1.1;
        margin-bottom: 8px;
        word-break: break-all;
    }

    .question-meaning {
        font-size: 0.85rem;
        color: var(--kb-muted);
        margin-top: 8px;
    }

    .question-category {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 100px;
        font-size: 0.62rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--kb-faint);
        background: var(--kb-surface2);
        margin-top: 12px;
    }

    /* Answer Options */
    .options-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
        margin-bottom: 24px;
    }

    .option-btn {
        background: var(--kb-bg);
        border: 2px solid var(--kb-border);
        border-radius: var(--kb-radius);
        padding: 20px 16px;
        font-size: 1.15rem;
        font-weight: 800;
        color: var(--kb-charcoal);
        cursor: pointer;
        transition: var(--kb-trans);
        text-align: center;
        font-family: 'Nunito', sans-serif;
        position: relative;
        overflow: hidden;
    }

        .option-btn:hover:not(:disabled) {
            border-color: var(--kb-blue-lt);
            background: var(--kb-blue-bg);
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(30,64,175,0.12);
        }

        .option-btn:disabled {
            cursor: not-allowed;
            opacity: 0.7;
        }

        .option-btn.correct {
            border-color: var(--kb-green-lt);
            background: var(--kb-green-bg);
            color: var(--kb-green);
            animation: kbPopCorrect 0.4s ease;
        }

        .option-btn.incorrect {
            border-color: var(--kb-red-lt);
            background: var(--kb-red-bg);
            color: var(--kb-red);
            animation: kbShake 0.4s ease;
        }

        .option-btn.reveal-correct {
            border-color: var(--kb-green-lt);
            background: var(--kb-green-bg);
            color: var(--kb-green);
        }

    /* Feedback Toast */
    .feedback-toast {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) scale(0);
        font-size: 2rem;
        font-weight: 900;
        padding: 20px 40px;
        border-radius: var(--kb-radius-lg);
        z-index: 9999;
        pointer-events: none;
        transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
        font-family: 'Nunito', sans-serif;
    }

        .feedback-toast.show {
            transform: translate(-50%, -50%) scale(1);
        }

        .feedback-toast.correct-toast {
            background: var(--kb-green-bg);
            color: var(--kb-green);
            border: 2px solid var(--kb-green-bd);
        }

        .feedback-toast.incorrect-toast {
            background: var(--kb-red-bg);
            color: var(--kb-red);
            border: 2px solid var(--kb-red-bd);
        }

        .feedback-toast.combo-toast {
            background: var(--kb-gold-bg);
            color: var(--kb-gold);
            border: 2px solid var(--kb-gold-bd);
        }

    /* XP Float */
    .xp-float {
        position: fixed;
        font-weight: 900;
        font-size: 1.2rem;
        color: var(--kb-gold);
        pointer-events: none;
        z-index: 9998;
        animation: kbXPFloat 1s ease forwards;
    }

    /* Countdown Overlay */
    #countdown-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255,255,255,0.95);
        z-index: 10000;
        justify-content: center;
        align-items: center;
    }

    .countdown-number {
        font-size: 8rem;
        font-weight: 900;
        color: var(--kb-black);
        animation: kbCountdownPop 0.8s ease;
    }

    .countdown-go {
        font-size: 5rem;
        font-weight: 900;
        color: var(--kb-gold);
        animation: kbCountdownPop 0.8s ease;
    }

    /* ── Results Screen ── */
    #results-screen {
        display: none;
        animation: kbSlideUp 0.5s ease both;
    }

    .results-card {
        background: var(--kb-surface);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-lg);
        padding: 40px 32px;
        text-align: center;
        box-shadow: var(--kb-shadow-lg);
    }

    .results-icon {
        font-size: 4rem;
        margin-bottom: 16px;
        animation: kbVictoryBounce 0.6s ease both;
    }

    .results-title {
        font-size: 2rem;
        font-weight: 900;
        color: var(--kb-black);
        margin-bottom: 8px;
    }

    .results-subtitle {
        font-size: 1rem;
        color: var(--kb-muted);
        margin-bottom: 28px;
    }

    .results-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 16px;
        margin-bottom: 32px;
    }

    .result-stat {
        background: var(--kb-bg);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-sm);
        padding: 16px 12px;
    }

        .result-stat .rs-label {
            font-size: 0.6rem;
            font-weight: 900;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--kb-faint);
            margin-bottom: 6px;
        }

        .result-stat .rs-value {
            font-size: 1.8rem;
            font-weight: 900;
            line-height: 1;
        }

            .result-stat .rs-value.gold {
                color: var(--kb-gold);
            }

            .result-stat .rs-value.blue {
                color: var(--kb-blue);
            }

            .result-stat .rs-value.green {
                color: var(--kb-green-lt);
            }

            .result-stat .rs-value.red {
                color: var(--kb-red-lt);
            }

    .results-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .result-btn {
        padding: 14px 28px;
        border-radius: 12px;
        font-weight: 900;
        font-size: 0.88rem;
        letter-spacing: 0.04em;
        border: none;
        cursor: pointer;
        transition: var(--kb-trans);
        text-decoration: none;
        font-family: 'Nunito', sans-serif;
    }

        .result-btn.primary {
            background: linear-gradient(135deg, var(--kb-blue), var(--kb-blue-lt));
            color: #fff;
            box-shadow: 0 6px 20px rgba(30,64,175,0.25);
        }

            .result-btn.primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 30px rgba(30,64,175,0.35);
            }

        .result-btn.secondary {
            background: var(--kb-surface2);
            color: var(--kb-dark);
            border: 1.5px solid var(--kb-border);
        }

            .result-btn.secondary:hover {
                background: var(--kb-border);
                transform: translateY(-2px);
            }

    /* ── Loading State ── */
    .loading-spinner {
        display: inline-block;
        width: 24px;
        height: 24px;
        border: 3px solid var(--kb-border);
        border-top-color: var(--kb-blue-lt);
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    /* ── Error Message ── */
    .error-banner {
        background: var(--kb-red-bg);
        border: 1.5px solid var(--kb-red-bd);
        border-radius: var(--kb-radius-sm);
        padding: 16px 20px;
        color: var(--kb-red);
        font-weight: 700;
        font-size: 0.9rem;
        margin-bottom: 20px;
        display: none;
    }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        .kb-wrapper {
            padding: 20px 12px;
        }

        #setup-panel {
            padding: 24px 18px;
        }

        .choice-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }

        .options-grid {
