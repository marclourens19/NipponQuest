@*
    ╔══════════════════════════════════════════════════════════════════╗
    ║  KanaBlitz_View.cshtml  —  Solo Game Arena                     ║
    ║  Controller : KanaBlitzController → Play()                     ║
    ║  Route      : /KanaBlitz/Play                                   ║
    ║  API        : GET /KanaBlitz/GetWords?difficulty=&alphabet=     ║
    ║  API        : GET /KanaBlitz/GetArenaPayload?alphabet=&diff=    ║
    ║  API        : GET /KanaBlitz/GetUnlocks                         ║
    ║  Purpose    : Full solo KanaBlitz game with difficulty select   ║
    ║  Aesthetic  : White background · Black / Gold / White / Blue    ║
    ╚══════════════════════════════════════════════════════════════════╝
*@
@{
    ViewData["Title"] = "KanaBlitz — Solo Training";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ══════════════════════════════════════════════════════════════
               NIPPONQUEST — KanaBlitz Solo Arena
               Palette : White bg · Black text · Gold accents · Blue action
            ══════════════════════════════════════════════════════════════ */
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');

    :root {
        --kb-bg: #ffffff;
        --kb-surface: #f8fafc;
        --kb-surface2: #f1f5f9;
        --kb-border: #e2e8f0;
        --kb-border2: #cbd5e1;
        --kb-black: #0f172a;
        --kb-charcoal: #1e293b;
        --kb-dark: #334155;
        --kb-muted: #64748b;
        --kb-faint: #94a3b8;
        --kb-gold: #d97706;
        --kb-gold-lt: #f59e0b;
        --kb-gold-bg: #fef3c7;
        --kb-gold-bd: #fcd34d;
        --kb-blue: #1e40af;
        --kb-blue-lt: #3b82f6;
        --kb-blue-bg: #eff6ff;
        --kb-blue-bd: #93c5fd;
        --kb-green: #065f46;
        --kb-green-lt: #10b981;
        --kb-green-bg: #ecfdf5;
        --kb-red: #991b1b;
        --kb-red-lt: #ef4444;
        --kb-red-bg: #fff1f2;
        --kb-red-bd: #fca5a5;
        --kb-radius: 14px;
        --kb-radius-sm: 10px;
        --kb-radius-lg: 20px;
        --kb-shadow: 0 4px 16px rgba(15,23,42,0.08);
        --kb-shadow-lg: 0 8px 32px rgba(15,23,42,0.12);
        --kb-trans: all 0.22s cubic-bezier(0.4,0,0.2,1);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    .kb-page {
        background: var(--kb-bg);
        min-height: 100vh;
        color: var(--kb-black);
        font-family: 'Nunito', 'Segoe UI', sans-serif;
        padding-bottom: 80px;
    }

        .kb-page::before {
            content: '';
            display: block;
            height: 4px;
            background: linear-gradient(90deg, #0f172a 0%, #d97706 50%, #1e40af 100%);
        }

    .kb-wrapper {
        max-width: 1060px;
        margin: 0 auto;
        padding: 32px 16px;
    }

    /* ── Header Bar ── */
    .arena-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 24px;
        padding-bottom: 18px;
        border-bottom: 1.5px solid var(--kb-border);
    }

    .arena-title-wrap h2 {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--kb-black);
        margin-bottom: 4px;
    }

    .arena-title-wrap .arena-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 4px;
    }

    .arena-tag {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 100px;
        font-size: 0.67rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

        .arena-tag.black {
            background: var(--kb-black);
            color: #fff;
        }

        .arena-tag.gold {
            background: var(--kb-gold-bg);
            color: var(--kb-gold);
            border: 1px solid var(--kb-gold-bd);
        }

        .arena-tag.blue {
            background: var(--kb-blue-bg);
            color: var(--kb-blue);
            border: 1px solid var(--kb-blue-bd);
        }

        .arena-tag.green {
            background: var(--kb-green-bg);
            color: var(--kb-green);
            border: 1px solid #6ee7b7;
        }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--kb-muted);
        text-decoration: none;
        transition: var(--kb-trans);
        padding: 8px 16px;
        border-radius: var(--kb-radius-sm);
        border: 1.5px solid var(--kb-border);
        background: var(--kb-surface);
    }

        .back-link:hover {
            color: var(--kb-blue);
            border-color: var(--kb-blue-bd);
            background: var(--kb-blue-bg);
            transform: translateY(-1px);
        }

    /* ── Setup Panel ── */
    #setup-panel {
        background: var(--kb-surface);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-lg);
        padding: 32px 28px;
        margin-bottom: 24px;
        box-shadow: var(--kb-shadow);
    }

    .section-label {
        font-size: 0.67rem;
        font-weight: 900;
        letter-spacing: 0.2em;
        color: var(--kb-blue);
        text-transform: uppercase;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .section-label::after {
            content: '';
            flex: 1;
            height: 1.5px;
            background: linear-gradient(90deg, var(--kb-border2), transparent);
        }

    /* ── Choice Cards ── */
    .choice-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 12px;
        margin-bottom: 28px;
    }

    .choice-card {
        background: var(--kb-bg);
        border: 2px solid var(--kb-border);
        border-radius: var(--kb-radius);
        padding: 18px 12px;
        cursor: pointer;
        transition: var(--kb-trans);
        text-align: center;
        position: relative;
        overflow: hidden;
        user-select: none;
    }

        .choice-card:hover {
            border-color: var(--kb-blue-lt);
            background: var(--kb-blue-bg);
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(30,64,175,0.12);
        }

        .choice-card.active {
            border-color: var(--kb-blue);
            background: var(--kb-blue-bg);
            box-shadow: 0 0 0 3px rgba(30,64,175,0.15);
            transform: translateY(-2px);
        }

        .choice-card[data-diff="easy"].active {
            border-color: var(--kb-green-lt);
            background: var(--kb-green-bg);
            box-shadow: 0 0 0 3px rgba(16,185,129,0.15);
        }

        .choice-card[data-diff="normal"].active {
            border-color: var(--kb-blue-lt);
            background: var(--kb-blue-bg);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
        }

        .choice-card[data-diff="hard"].active {
            border-color: var(--kb-gold);
            background: var(--kb-gold-bg);
            box-shadow: 0 0 0 3px rgba(217,119,6,0.18);
        }

        .choice-card[data-diff="insanity"].active {
            border-color: var(--kb-red-lt);
            background: var(--kb-red-bg);
            box-shadow: 0 0 0 3px rgba(239,68,68,0.15);
        }

        .choice-card.locked {
            opacity: 0.45;
            cursor: not-allowed;
            pointer-events: none;
        }

        .choice-card .c-icon {
            font-size: 2rem;
            margin-bottom: 8px;
            display: block;
        }

        .choice-card .c-label {
            font-weight: 800;
            font-size: 0.92rem;
            color: var(--kb-charcoal);
            display: block;
        }

        .choice-card .c-sub {
            font-size: 0.7rem;
            color: var(--kb-muted);
            margin-top: 4px;
            display: block;
        }

        .choice-card .c-tag {
            font-size: 0.66rem;
            color: var(--kb-blue);
            margin-top: 3px;
            display: block;
            font-weight: 700;
        }

        .choice-card .c-count {
            font-size: 0.63rem;
            color: var(--kb-faint);
            margin-top: 2px;
            display: block;
        }

    .diff-pip {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-bottom: 6px;
    }

    .pip-easy {
        background: var(--kb-green-lt);
    }

    .pip-normal {
        background: var(--kb-blue-lt);
    }

    .pip-hard {
        background: var(--kb-gold);
    }

    .pip-insanity {
        background: var(--kb-red-lt);
    }

    /* ── Word Count Warning ── */
    #word-warning {
        display: none;
        background: var(--kb-red-bg);
        border: 1.5px solid var(--kb-red-bd);
        border-radius: var(--kb-radius-sm);
        padding: 14px 18px;
        margin-bottom: 20px;
        font-size: 0.85rem;
        color: var(--kb-red);
        font-weight: 700;
    }

    /* ── Start Button ── */
    .start-btn {
        display: block;
        width: 100%;
        padding: 16px;
        border: none;
        border-radius: var(--kb-radius);
        background: linear-gradient(135deg, var(--kb-blue), var(--kb-blue-lt));
        color: #fff;
        font-family: 'Nunito', sans-serif;
        font-size: 1rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        cursor: pointer;
        transition: var(--kb-trans);
        text-transform: uppercase;
        position: relative;
        overflow: hidden;
    }

        .start-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(30,64,175,0.3);
        }

        .start-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

    /* ── Game Arena ── */
    #game-arena {
        display: none;
    }

    /* ── HUD ── */
    .game-hud {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-bottom: 24px;
    }

    .hud-item {
        background: var(--kb-surface);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-sm);
        padding: 14px 12px;
        text-align: center;
    }

        .hud-item .hud-label {
            font-size: 0.62rem;
            font-weight: 900;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--kb-faint);
            margin-bottom: 4px;
        }

        .hud-item .hud-val {
            font-size: 1.6rem;
            font-weight: 900;
            color: var(--kb-black);
            line-height: 1;
        }

        .hud-item.timer .hud-val {
            color: var(--kb-gold);
        }

        .hud-item.combo .hud-val {
            color: var(--kb-blue-lt);
        }

        .hud-item.streak .hud-val {
            color: var(--kb-green-lt);
        }

    /* ── Timer Bar ── */
    .timer-bar-track {
        width: 100%;
        height: 6px;
        background: var(--kb-surface2);
        border-radius: 3px;
        margin-bottom: 24px;
        overflow: hidden;
    }

    .timer-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--kb-gold-lt), var(--kb-gold));
        border-radius: 3px;
        transition: width 0.3s ease;
        width: 100%;
    }

        .timer-bar-fill.low {
            background: linear-gradient(90deg, var(--kb-red-lt), var(--kb-red));
        }

    /* ── Question Card ── */
    .question-card {
        background: var(--kb-surface);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-lg);
        padding: 36px 28px;
        text-align: center;
        margin-bottom: 20px;
        box-shadow: var(--kb-shadow);
        position: relative;
        overflow: hidden;
    }

        .question-card .q-category {
            font-size: 0.65rem;
            font-weight: 900;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--kb-blue);
            margin-bottom: 12px;
        }

        .question-card .q-kana {
            font-size: clamp(2rem, 6vw, 3.5rem);
            font-weight: 900;
            color: var(--kb-black);
            margin-bottom: 8px;
            line-height: 1.2;
        }

        .question-card .q-romaji {
            font-size: 1rem;
            color: var(--kb-muted);
            margin-bottom: 4px;
        }

        .question-card .q-meaning {
            font-size: 0.85rem;
            color: var(--kb-faint);
            margin-bottom: 16px;
        }

        .question-card .q-prompt {
            font-size: 0.72rem;
            font-weight: 800;
            color: var(--kb-gold);
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .question-card .q-missing-highlight {
            display: inline-block;
            background: var(--kb-gold-bg);
            border: 1.5px dashed var(--kb-gold-bd);
            border-radius: 8px;
            padding: 4px 16px;
            font-size: 1.5rem;
            font-weight: 900;
            color: var(--kb-gold);
            margin: 8px 0;
            min-width: 60px;
        }

    /* ── Answer Options ── */
    .answers-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
        margin-bottom: 20px;
    }

    .answer-btn {
        background: var(--kb-bg);
        border: 2px solid var(--kb-border);
        border-radius: var(--kb-radius);
        padding: 20px 16px;
        font-family: 'Nunito', sans-serif;
        font-size: 1.4rem;
        font-weight: 900;
        color: var(--kb-charcoal);
        cursor: pointer;
        transition: var(--kb-trans);
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .answer-btn:hover {
            border-color: var(--kb-blue-lt);
            background: var(--kb-blue-bg);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(30,64,175,0.1);
        }

        .answer-btn.correct {
            border-color: var(--kb-green-lt);
            background: var(--kb-green-bg);
            color: var(--kb-green);
            animation: popIn 0.3s ease;
        }

        .answer-btn.incorrect {
            border-color: var(--kb-red-lt);
            background: var(--kb-red-bg);
            color: var(--kb-red);
            animation: shakeX 0.4s ease;
        }

        .answer-btn:disabled {
            cursor: default;
            pointer-events: none;
        }

        .answer-btn .ans-label {
            position: absolute;
            top: 6px;
            left: 10px;
            font-size: 0.58rem;
            font-weight: 900;
            color: var(--kb-faint);
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

    /* ── Progress Bar ── */
    .progress-track {
        width: 100%;
        height: 4px;
        background: var(--kb-surface2);
        border-radius: 2px;
        margin-bottom: 8px;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--kb-blue), var(--kb-blue-lt));
        border-radius: 2px;
        transition: width 0.4s ease;
    }

    .progress-text {
        font-size: 0.68rem;
        color: var(--kb-faint);
        font-weight: 700;
        text-align: right;
    }

    /* ── Countdown Overlay ── */
    #countdown-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15,23,42,0.85);
        z-index: 9999;
        justify-content: center;
        align-items: center;
    }

        #countdown-overlay .cd-number {
            font-size: 8rem;
            font-weight: 900;
            color: var(--kb-gold-lt);
            animation: countdownPop 0.8s ease;
            text-shadow: 0 0 40px rgba(245,158,11,0.4);
        }

    /* ── Results Screen ── */
    #results-screen {
        display: none;
        background: var(--kb-surface);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-lg);
        padding: 40px 32px;
        text-align: center;
        box-shadow: var(--kb-shadow-lg);
    }

        #results-screen .result-icon {
            font-size: 4rem;
            margin-bottom: 16px;
            display: block;
        }

        #results-screen h2 {
            font-size: 2rem;
            font-weight: 900;
            color: var(--kb-black);
            margin-bottom: 8px;
        }

        #results-screen .result-sub {
            font-size: 0.9rem;
            color: var(--kb-muted);
            margin-bottom: 28px;
        }

    .results-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 32px;
    }

    .result-stat {
        background: var(--kb-bg);
        border: 1.5px solid var(--kb-border);
        border-radius: var(--kb-radius-sm);
        padding: 18px 12px;
    }

        .result-stat .rs-label {
            font-size: 0.62rem;
            font-weight: 900;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--kb-faint);
            margin-bottom: 6px;
        }

        .result-stat .rs-val {
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--kb-black);
        }

            .result-stat .rs-val.gold {
                color: var(--kb-gold);
            }

            .result-stat .rs-val.green {
                color: var(--kb-green-lt);
            }

            .result-stat .rs-val.blue {
                color: var(--kb-blue-lt);
            }

    .results-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

        .results-actions button, .results-actions a {
            padding: 12px 28px;
            border-radius: var(--kb-radius-sm);
            font-family: 'Nunito', sans-serif;
            font-weight: 900;
            font-size: 0.85rem;
            letter-spacing: 0.06em;
            cursor: pointer;
            transition: var(--kb-trans);
            text-decoration: none;
            border: none;
        }

    .btn-play-again {
        background: linear-gradient(135deg, var(--kb-blue), var(--kb-blue-lt));
        color: #fff;
    }

        .btn-play-again:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(30,64,175,0.3);
            color: #fff;
        }

    .btn-change-setup {
        background: var(--kb-surface2);
        color: var(--kb-dark);
        border: 1.5px solid var(--kb-border) !important;
    }

        .btn-change-setup:hover {
            background: var(--kb-border);
            transform: translateY(-2px);
        }

    .btn-back-hub {
        background: var(--kb-gold-bg);
        color: var(--kb-gold);
        border: 1.5px solid var(--kb-gold-bd) !important;
    }

        .btn-back-hub:hover {
            transform: translateY(-2px);
            color: var(--kb-gold);
        }

    /* ── Feedback Toast ── */
    .feedback-toast {
        position: fixed;
        top: 20%;
        left: 50%;
        transform: translateX(-50%) scale(0);
        font-size: 1.2rem;
        font-weight: 900;
        padding: 12px 28px;
        border-radius: var(--kb-radius);
        z-index: 10000;
        pointer-events: none;
        transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
    }

        .feedback-toast.show {
            transform: translateX(-50%) scale(1);
        }

        .feedback-toast.toast-correct {
            background: var(--kb-green-bg);
            color: var(--kb-green);
            border: 1.5px solid #6ee7b7;
        }

        .feedback-toast.toast-incorrect {
            background: var(--kb-red-bg);
            color: var(--kb-red);
            border: 1.5px solid var(--kb-red-bd);
        }

        .feedback-toast.toast-combo {
            background: var(--kb-gold-bg);
            color: var(--kb-gold);
            border: 1.5px solid var(--kb-gold-bd);
        }

    /* ── Animations ── */
    @@keyframes countdownPop {
        0% {
            transform: scale(0.3);
            opacity: 0;
        }

        50% {
            transform: scale(1.2);
            opacity: 1;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes popIn {
        0% {
            transform: scale(0.9);
        }

        50% {
            transform: scale(1.05);
        }

        100% {
            transform: scale(1);
        }
    }

    @@keyframes shakeX {
        0%, 100% {
            transform: translateX(0);
        }

        10% {
            transform: translateX(-6px);
        }

        20% {
            transform: translateX(6px);
        }

        30% {
            transform: translateX(-4px);
        }

        40% {
            transform: translateX(4px);
        }

        50% {
            transform: translateX(-2px);
        }

        60% {
            transform: translateX(2px);
        }
    }

    @@keyframes fadeInUp {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes floatSoft {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-4px);
        }
    }

    @@keyframes glowPulse {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(217,119,6,0.2);
        }

        50% {
            box-shadow: 0 0 20px 4px rgba(217,119,6,0.1);
        }
    }

    @@keyframes slideInRight {
        0% {
            opacity: 0;
            transform: translateX(30px);
        }

        100% {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .anim-fade-up {
        animation: fadeInUp 0.5s cubic-bezier(0.16,1,0.3,1) both;
    }

    .anim-slide-right {
        animation: slideInRight 0.4s ease both;
    }

    /* ── Loading Spinner ── */
    .loading-spinner {
        display: inline-block;
        width: 24px;
        height: 24px;
        border: 3px solid var(--kb-border);
        border-top-color: var(--kb-blue);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        .game-hud {
            grid-template-columns: repeat(2, 1fr);
        }

        .answers-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .results-grid {
            grid-template-columns: 1fr;
        }

        .arena-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .question-card {
            padding: 24px 16px;
        }

            .question-card .q-kana {
                font-size: 2rem;
            }

        .answer-btn {
            font-size: 1.1rem;
            padding: 16px 12px;
        }
    }

    @@media (max-width: 480px) {
        .choice-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        #setup-panel {
            padding: 20px 14px;
        }

        .game-hud {
            gap: 8px;
        }

        .hud-item {
            padding: 10px 8px;
        }

            .hud-item .hud-val {
                font-size: 1.3rem;
            }
    }
</style>

<div class="kb-page">
    <div class="kb-wrapper">
        <!-- Header -->
        <div class="arena-header anim-fade-up">
            <div class="arena-title-wrap">
                <h2>🗡️ KanaBlitz <span style="color:var(--kb-gold)">Solo</span></h2>
                <div class="arena-meta">
                    <span class="arena-tag gold">Solo Training</span>
                    <span class="arena-tag blue" id="header-diff-tag">Normal</span>
                    <span class="arena-tag black" id="header-alpha-tag">Hiragana</span>
                </div>
            </div>
            <a href="/KanaBlitz/Index" class="back-link">← Back to Modes</a>
        </div>

        <!-- Setup Panel -->
        <div id="setup-panel" class="anim-fade-up" style="animation-delay:0.1s">
            <div class="section-label">Difficulty</div>
            <div class="choice-grid" id="diff-grid">
                <div class="choice-card" data-diff="easy" onclick="selectDifficulty('easy')">
                    <span class="diff-pip pip-easy"></span>
                    <span class="c-icon">🌱</span>
                    <span class="c-label">Easy</span>
                    <span class="c-sub">Single Characters</span>
                    <span class="c-count" id="count-easy">—</span>
                </div>
                <div class="choice-card active" data-diff="normal" onclick="selectDifficulty('normal')">
                    <span class="diff-pip pip-normal"></span>
                    <span class="c-icon">⚔️</span>
                    <span class="c-label">Normal</span>
                    <span class="c-sub">Common Words</span>
                    <span class="c-count" id="count-normal">—</span>
                </div>
                <div class="choice-card" data-diff="hard" onclick="selectDifficulty('hard')">
                    <span class="diff-pip pip-hard"></span>
                    <span class="c-icon">🔥</span>
                    <span class="c-label">Hard</span>
                    <span class="c-sub">Yōon & Compounds</span>
                    <span class="c-tag" id="lock-hard">🔒 Locked</span>
                    <span class="c-count" id="count-hard">—</span>
                </div>
                <div class="choice-card" data-diff="insanity" onclick="selectDifficulty('insanity')">
                    <span class="diff-pip pip-insanity"></span>
                    <span class="c-icon">💀</span>
                    <span class="c-label">Insanity</span>
                    <span class="c-sub">Kanji Mastery</span>
                    <span class="c-tag" id="lock-insanity">🔒 Locked</span>
                    <span class="c-count" id="count-insanity">—</span>
                </div>
            </div>

            <div class="section-label">Alphabet</div>
            <div class="choice-grid" id="alpha-grid">
                <div class="choice-card active" data-alpha="hiragana" onclick="selectAlphabet('hiragana')">
                    <span class="c-icon">あ</span>
                    <span class="c-label">Hiragana</span>
                    <span class="c-sub">平仮名</span>
                </div>
                <div class="choice-card" data-alpha="katakana" onclick="selectAlphabet('katakana')">
                    <span class="c-icon">ア</span>
                    <span class="c-label">Katakana</span>
                    <span class="c-sub">片仮名</span>
                </div>
                <div class="choice-card" data-alpha="dakuten" onclick="selectAlphabet('dakuten')">
                    <span class="c-icon">が</span>
                    <span class="c-label">Dakuten</span>
                    <span class="c-sub">濁点</span>
                </div>
                <div class="choice-card" data-alpha="mixed" onclick="selectAlphabet('mixed')">
                    <span class="c-icon">混</span>
                    <span class="c-label">Mixed</span>
                    <span class="c-sub">総合</span>
                </div>
            </div>

            <div id="word-warning"></div>

            <button class="start-btn" id="start-btn" onclick="startGame()" disabled>
                <span id="start-btn-text">Loading word counts…</span>
            </button>
        </div>

        <!-- Countdown Overlay -->
        <div id="countdown-overlay">
            <div class="cd-number" id="cd-number">3</div>
        </div>

        <!-- Game Arena -->
        <div id="game-arena">
            <div class="game-hud">
                <div class="hud-item timer">
                    <div class="hud-label">Time</div>
                    <div class="hud-val" id="hud-time">60</div>
                </div>
                <div class="hud-item">
                    <div class="hud-label">Score</div>
                    <div class="hud-val" id="hud-score">0</div>
                </div>
                <div class="hud-item combo">
                    <div class="hud-label">Combo</div>
                    <div class="hud-val" id="hud-combo">0×</div>
                </div>
                <div class="hud-item streak">
                    <div class="hud-label">Correct</div>
                    <div class="hud-val" id="hud-correct">0</div>
                </div>
            </div>

            <div class="timer-bar-track">
                <div class="timer-bar-fill" id="timer-bar"></div>
            </div>

            <div class="progress-track">
                <div class="progress-fill" id="progress-bar" style="width:0%"></div>
            </div>
            <div class="progress-text" id="progress-text">0 / 0</div>

            <div class="question-card anim-slide-right" id="question-card">
                <div class="q-category" id="q-category">—</div>
                <div class="q-kana" id="q-kana">—</div>
                <div class="q-missing-highlight" id="q-missing">?</div>
                <div class="q-romaji" id="q-romaji">—</div>
                <div class="q-meaning" id="q-meaning">—</div>
                <div class="q-prompt">Select the missing kana</div>
            </div>

            <div class="answers-grid" id="answers-grid"></div>
        </div>

        <!-- Results Screen -->
        <div id="results-screen">
            <span class="result-icon" id="result-icon">🏆</span>
            <h2 id="result-title">Training Complete!</h2>
            <div class="result-sub" id="result-sub">Great effort on your solo run.</div>

            <div class="results-grid">
                <div class="result-stat">
                    <div class="rs-label">Final Score</div>
                    <div class="rs-val gold" id="rs-score">0</div>
                </div>
                <div class="result-stat">
                    <div class="rs-label">Accuracy</div>
                    <div class="rs-val green" id="rs-accuracy">0%</div>
                </div>
                <div class="result-stat">
                    <div class="rs-label">Best Combo</div>
                    <div class="rs-val blue" id="rs-combo">0×</div>
                </div>
                <div class="result-stat">
                    <div class="rs-label">Questions</div>
                    <div class="rs-val" id="rs-total">0</div>
                </div>
                <div class="result-stat">
                    <div class="rs-label">Correct</div>
                    <div class="rs-val green" id="rs-correct">0</div>
                </div>
                <div class="result-stat">
                    <div class="rs-label">XP Earned</div>
                    <div class="rs-val gold" id="rs-xp">0</div>
                </div>
            </div>

            <div class="results-actions">
                <button class="btn-play-again" onclick="playAgain()">Play Again</button>
                <button class="btn-change-setup" onclick="changeSetup()">Change Setup</button>
                <a href="/KanaBlitz/Index" class="btn-back-hub">Mode Selection</a>
            </div>
        </div>

        <!-- Feedback Toast -->
        <div class="feedback-toast" id="feedback-toast"></div>
    </div>
</div>

<script>
    // ═══════════════════════════════════════════════════════════
    //  KanaBlitz Solo Game Engine
    // ═══════════════════════════════════════════════════════════

    // ── Audio Architecture (placeholder hooks for future sounds) ──
    const AudioHooks = {
        correct: () => { /* placeholder: play correct answer sound */ },
        incorrect: () => { /* placeholder: play incorrect answer sound */ },
        victory: () => { /* placeholder: play victory fanfare */ },
        countdown: () => { /* placeholder: play countdown tick */ },
        click: () => { /* placeholder: play button click */ },
        combo: () => { /* placeholder: play combo streak sound */ }
    };

    // ── State ──
    let selectedDifficulty = 'normal';
    let selectedAlphabet = 'hiragana';
    let gameWords = [];
    let currentIndex = 0;
    let score = 0;
    let combo = 0;
    let maxCombo = 0;
    let correctCount = 0;
    let totalAnswered = 0;
    let timeLeft = 60;
    let maxTime = 60;
    let timerInterval = null;
    let isPlaying = false;
    let wordCounts = {};
    let unlockData = null;

    // ── Constants ──
    const TIME_PER_DIFFICULTY = { easy: 75, normal: 60, hard: 50, insanity: 40 };
    const BONUS_TIME = { easy: 4, normal: 3, hard: 2, insanity: 1 };
    const MIN_WORDS = 4; // Minimum words required to start a game (reduced from high thresholds)

    // ── Initialize ──
    document.addEventListener('DOMContentLoaded', async () => {
        await loadWordCounts();
        await loadUnlocks();
        updateStartButton();
    });

    // ── Load Word Counts from API ──
    async function loadWordCounts() {
        try {
            const diffs = ['easy', 'normal', 'hard', 'insanity'];
            const alphas = ['hiragana', 'katakana', 'dakuten', 'mixed'];
            wordCounts = {};

            for (const diff of diffs) {
                for (const alpha of alphas) {
                    try {
                        const res = await fetch(`/KanaBlitz/GetWords?difficulty=${diff}&alphabet=${alpha}`);
                        if (res.ok) {
                            const data = await res.json();
                            const key = `${diff}:${alpha}`;
                            wordCounts[key] = Array.isArray(data) ? data.length : 0;
                        }
                    } catch (e) {
                        // Silently handle - word count will show as 0
                    }
                }
            }

            // Update displayed counts for selected alphabet
            updateWordCountDisplay();
        } catch (e) {
            console.error('Failed to load word counts:', e);
            updateWordCountDisplay();
        }
    }

    function updateWordCountDisplay() {
        ['easy', 'normal', 'hard', 'insanity'].forEach(diff => {
            const key = `${diff}:${selectedAlphabet}`;
            const count = wordCounts[key] || 0;
            const el = document.getElementById(`count-${diff}`);
            if (el) el.textContent = count > 0 ? `${count} words` : 'No words';
        });
    }

    // ── Load Unlocks ──
    async function loadUnlocks() {
        try {
            const res = await fetch('/KanaBlitz/GetUnlocks');
            if (res.ok) {
                unlockData = await res.json();
                applyUnlocks();
            }
        } catch (e) {
            // If not logged in, default unlocks apply
            applyDefaultUnlocks();
        }
    }

    function applyUnlocks() {
        if (!unlockData) { applyDefaultUnlocks(); return; }

        // Hard difficulty
        const hardCard = document.querySelector('[data-diff="hard"]');
        if (unlockData.hard && unlockData.hard.unlocked) {
            hardCard.classList.remove('locked');
            const lockTag = document.getElementById('lock-hard');
            if (lockTag) lockTag.style.display = 'none';
        } else {
            hardCard.classList.add('locked');
        }

        // Insanity difficulty
        const insCard = document.querySelector('[data-diff="insanity"]');
        if (unlockData.insanity && unlockData.insanity.unlocked) {
            insCard.classList.remove('locked');
            const lockTag = document.getElementById('lock-insanity');
            if (lockTag) lockTag.style.display = 'none';
        } else {
            insCard.classList.add('locked');
        }
    }

    function applyDefaultUnlocks() {
        // Easy and Normal always unlocked
        document.querySelector('[data-diff="hard"]').classList.add('locked');
        document.querySelector('[data-diff="insanity"]').classList.add('locked');
    }

    // ── Selection Handlers ──
    function selectDifficulty(diff) {
        const card = document.querySelector(`[data-diff="${diff}"]`);
        if (card.classList.contains('locked')) return;

        AudioHooks.click();
        selectedDifficulty = diff;
        document.querySelectorAll('#diff-grid .choice-card').forEach(c => c.classList.remove('active'));
        card.classList.add('active');

        // Update header tag
        const tagEl = document.getElementById('header-diff-tag');
        tagEl.textContent = diff.charAt(0).toUpperCase() + diff.slice(1);

        updateWordCountDisplay();
        updateStartButton();
    }

    function selectAlphabet(alpha) {
        AudioHooks.click();
        selectedAlphabet = alpha;
        document.querySelectorAll('#alpha-grid .choice-card').forEach(c => c.classList.remove('active'));
        document.querySelector(`[data-alpha="${alpha}"]`).classList.add('active');

        const tagEl = document.getElementById('header-alpha-tag');
        tagEl.textContent = alpha.charAt(0).toUpperCase() + alpha.slice(1);

        updateWordCountDisplay();
        updateStartButton();
    }

    function updateStartButton() {
        const btn = document.getElementById('start-btn');
        const btnText = document.getElementById('start-btn-text');
        const key = `${selectedDifficulty}:${selectedAlphabet}`;
        const count = wordCounts[key] || 0;

        if (count < MIN_WORDS) {
            btn.disabled = true;
            btnText.textContent = `Not enough words (${count}/${MIN_WORDS} needed)`;

            const warning = document.getElementById('word-warning');
            warning.style.display = 'block';
            warning.innerHTML = `⚠️ Only <strong>${count}</strong> words available for <strong>${selectedDifficulty} ${selectedAlphabet}</strong>. Try a different combination. Minimum ${MIN_WORDS} required.`;
        } else {
            btn.disabled = false;
            btnText.textContent = `Start Training — ${count} Words Available`;
            document.getElementById('word-warning').style.display = 'none';
        }
    }

    // ── Game Flow ──
    async function startGame() {
        const btn = document.getElementById('start-btn');
        btn.disabled = true;
        document.getElementById('start-btn-text').textContent = 'Loading words…';

        try {
            const res = await fetch(`/KanaBlitz/GetWords?difficulty=${selectedDifficulty}&alphabet=${selectedAlphabet}`);
            if (!res.ok) throw new Error('Failed to fetch words');
            const data = await res.json();

            if (!Array.isArray(data) || data.length < MIN_WORDS) {
                throw new Error(`Not enough words (${data ? data.length : 0})`);
            }

            gameWords = shuffleArray([...data]);
            currentIndex = 0;
            score = 0;
            combo = 0;
            maxCombo = 0;
            correctCount = 0;
            totalAnswered = 0;
            maxTime = TIME_PER_DIFFICULTY[selectedDifficulty] || 60;
            timeLeft = maxTime;

            // Show countdown
            showCountdown(() => {
                document.getElementById('setup-panel').style.display = 'none';
                document.getElementById('game-arena').style.display = 'block';
                isPlaying = true;
                updateHUD();
                showQuestion();
                startTimer();
            });
        } catch (e) {
            console.error('Start game error:', e);
            const warning = document.getElementById('word-warning');
            warning.style.display = 'block';
            warning.innerHTML = `❌ Failed to load words: ${e.message}. Please try again or select a different combination.`;
            btn.disabled = false;
            document.getElementById('start-btn-text').textContent = 'Try Again';
        }
    }

    function showCountdown(callback) {
        const overlay = document.getElementById('countdown-overlay');
        const numEl = document.getElementById('cd-number');
        overlay.style.display = 'flex';

        let count = 3;
        numEl.textContent = count;

        const interval = setInterval(() => {
            AudioHooks.countdown();
            count--;
            if (count > 0) {
                numEl.textContent = count;
                numEl.style.animation = 'none';
                numEl.offsetHeight; // Trigger reflow
                numEl.style.animation = 'countdownPop 0.8s ease';
            } else if (count === 0) {
                numEl.textContent = 'GO!';
                numEl.style.color = '#10b981';
                numEl.style.animation = 'none';
                numEl.offsetHeight;
                numEl.style.animation = 'countdownPop 0.8s ease';
            } else {
                clearInterval(interval);
                overlay.style.display = 'none';
                numEl.style.color = '';
                callback();
            }
        }, 800);
    }

    function startTimer() {
        clearInterval(timerInterval);
        timerInterval = setInterval(() => {
            timeLeft--;
            updateTimerDisplay();

            if (timeLeft <= 0) {
                clearInterval(timerInterval);
                endGame();
            }
        }, 1000);
    }

    function updateTimerDisplay() {
        document.getElementById('hud-time').textContent = timeLeft;
        const pct = (timeLeft / maxTime) * 100;
        const bar = document.getElementById('timer-bar');
        bar.style.width = pct + '%';
        bar.className = 'timer-bar-fill' + (pct < 25 ? ' low' : '');
    }

    function updateHUD() {
        document.getElementById('hud-score').textContent = score;
        document.getElementById('hud-combo').textContent = combo + '×';
        document.getElementById('hud-correct').textContent = correctCount;
        updateTimerDisplay();
    }

    // ── Question Display ──
    function showQuestion() {
        if (currentIndex >= gameWords.length) {
            // Reshuffle and continue
            gameWords = shuffleArray([...gameWords]);
            currentIndex = 0;
        }

        const word = gameWords[currentIndex];
        const card = document.getElementById('question-card');

        // Animate card entrance
        card.classList.remove('anim-slide-right');
        card.offsetHeight;
        card.classList.add('anim-slide-right');

        // Display question data
        document.getElementById('q-category').textContent = word.categoryTag || word.alphabet || '—';

        // Handle kanji display (strip furigana annotations for the kana display)
        let displayKana = word.wordKana || '';
        const parenMatch = displayKana.match(/^(.+?)\s*\((.+?)\)$/);
        if (parenMatch) {
            document.getElementById('q-kana').textContent = parenMatch[1];
            // Show furigana hint
            document.getElementById('q-romaji').textContent = parenMatch[2] + ' · ' + (word.wordRomaji || '');
        } else {
            document.getElementById('q-kana').textContent = displayKana;
            document.getElementById('q-romaji').textContent = word.wordRomaji || '';
        }

        document.getElementById('q-meaning').textContent = word.meaningEnglish || '';
        document.getElementById('q-missing').textContent = word.missingKana || '?';

        // Generate answer options
        generateAnswers(word);
        updateProgress();
    }

    function generateAnswers(word) {
        const correctAnswer = word.missingKana || '';
        const grid = document.getElementById('answers-grid');
        grid.innerHTML = '';

        // Collect distractors from other words
        let distractors = gameWords
            .filter(w => w.missingKana && w.missingKana !== correctAnswer)
            .map(w => w.missingKana);

        // Remove duplicates and shuffle
        distractors = [...new Set(distractors)];
        distractors = shuffleArray(distractors).slice(0, 3);

        // If not enough distractors, add generic kana
        const fallbackKana = ['あ','い','う','え','お','か','き','く','け','こ','さ','し','す','せ','そ',
            'た','ち','つ','て','と','な','に','ぬ','ね','の','は','ひ','ふ','へ','ほ',
            'ま','み','む','め','も','や','ゆ','よ','ら','り','る','れ','ろ','わ','を','ん'];

        while (distractors.length < 3) {
            const random = fallbackKana[Math.floor(Math.random() * fallbackKana.length)];
            if (random !== correctAnswer && !distractors.includes(random)) {
                distractors.push(random);
            }
        }

        const options = shuffleArray([correctAnswer, ...distractors.slice(0, 3)]);
        const labels = ['A', 'B', 'C', 'D'];

        options.forEach((opt, i) => {
            const btn = document.createElement('button');
            btn.className = 'answer-btn';
            btn.innerHTML = `<span class="ans-label">${labels[i]}</span>${opt}`;
            btn.onclick = () => handleAnswer(btn, opt, correctAnswer);
            grid.appendChild(btn);
        });
    }

    function handleAnswer(btn, selected, correct) {
        if (!isPlaying) return;

        // Disable all answer buttons
        document.querySelectorAll('.answer-btn').forEach(b => b.disabled = true);
        totalAnswered++;

        if (selected === correct) {
            // Correct
            btn.classList.add('correct');
            correctCount++;
            combo++;
            if (combo > maxCombo) maxCombo = combo;

            const points = 10 * Math.max(1, combo);
            score += points;

            // Bonus time
            timeLeft += BONUS_TIME[selectedDifficulty] || 2;
            if (timeLeft > maxTime + 20) timeLeft = maxTime + 20;

            AudioHooks.correct();
            showFeedback('✓ Correct!', 'correct');

            if (combo >= 3) {
                AudioHooks.combo();
                showFeedback(`🔥 ${combo}× Combo! +${points}`, 'combo');
            }
        } else {
            // Incorrect
            btn.classList.add('incorrect');
            // Highlight correct answer
            document.querySelectorAll('.answer-btn').forEach(b => {
                if (b.textContent.includes(correct)) b.classList.add('correct');
            });
            combo = 0;
            timeLeft = Math.max(0, timeLeft - 2);

            AudioHooks.incorrect();
            showFeedback('✗ Incorrect', 'incorrect');
        }

        updateHUD();
        currentIndex++;

        // Next question after delay
        setTimeout(() => {
            if (isPlaying && timeLeft > 0) {
                showQuestion();
            }
        }, 600);
    }

    function showFeedback(text, type) {
        const toast = document.getElementById('feedback-toast');
        toast.textContent = text;
        toast.className = 'feedback-toast toast-' + type + ' show';

        setTimeout(() => {
            toast.classList.remove('show');
        }, 1200);
    }

    function updateProgress() {
        const total = Math.max(gameWords.length, totalAnswered + 1);
        const pct = Math.min(100, ((currentIndex) / total) * 100);
        document.getElementById('progress-bar').style.width = pct + '%';
        document.getElementById('progress-text').textContent = `${totalAnswered} answered · ${currentIndex} shown`;
    }

    // ── End Game ──
    function endGame() {
        isPlaying = false;
        clearInterval(timerInterval);

        AudioHooks.victory();

        const accuracy = totalAnswered > 0 ? Math.round((correctCount / totalAnswered) * 100) : 0;
        const xpEarned = Math.floor(score * 0.5) + (correctCount * 5);

        // Determine result icon and message
        let icon, title, sub;
        if (accuracy >= 90) { icon = '🏆'; title = 'Outstanding!'; sub = 'Near-perfect performance, master!'; }
        else if (accuracy >= 70) { icon = '⭐'; title = 'Great Run!'; sub = 'Strong accuracy, keep it up!'; }
        else if (accuracy >= 50) { icon = '🎯'; title = 'Good Effort!'; sub = 'Room to grow — practice makes perfect.'; }
        else { icon = '📝'; title = 'Keep Practicing!'; sub = 'Every attempt makes you stronger.'; }

        document.getElementById('result-icon').textContent = icon;
        document.getElementById('result-title').textContent = title;
        document.getElementById('result-sub').textContent = sub;
        document.getElementById('rs-score').textContent = score;
        document.getElementById('rs-accuracy').textContent = accuracy + '%';
        document.getElementById('rs-combo').textContent = maxCombo + '×';
        document.getElementById('rs-total').textContent = totalAnswered;
        document.getElementById('rs-correct').textContent = correctCount;
        document.getElementById('rs-xp').textContent = '+' + xpEarned;

        document.getElementById('game-arena').style.display = 'none';
        document.getElementById('results-screen').style.display = 'block';

        // Submit score to server if logged in (fire and forget)
        try {
            fetch('/KanaBlitz/SubmitScore', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    score: score,
                    difficulty: selectedDifficulty,
                    alphabet: selectedAlphabet,
                    correct: correctCount,
                    total: totalAnswered,
                    maxCombo: maxCombo,
                    xpEarned: xpEarned
                })
            }).catch(() => { });
        } catch (e) { }
    }

    function playAgain() {
        document.getElementById('results-screen').style.display = 'none';
        startGame();
    }

    function changeSetup() {
        document.getElementById('results-screen').style.display = 'none';
        document.getElementById('setup-panel').style.display = 'block';
        updateStartButton();
    }

    // ── Utility ──
    function shuffleArray(arr) {
        for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
    }

    // ── Keyboard Support ──
    document.addEventListener('keydown', (e) => {
        if (!isPlaying) return;
        const keyMap = { 'a': 0, 'b': 1, 'c': 2, 'd': 3, '1': 0, '2': 1, '3': 2, '4': 3 };
        const index = keyMap[e.key.toLowerCase()];
        if (index !== undefined) {
            const btns = document.querySelectorAll('.answer-btn:not(:disabled)');
            if (btns[index]) btns[index].click();
        }
    });
</script>
