<script>
    /* ══════════════════════════════════════════════════════════════
       SoundFX Engine — Web Audio API
    ══════════════════════════════════════════════════════════════ */
    const SoundFX = {
        ctx: null,
        init() { try { this.ctx = new (window.AudioContext || window.webkitAudioContext)(); } catch(e) {} },
        _ensure() {
            if (!this.ctx) this.init();
            if (!this.ctx) return false;
            if (this.ctx.state === 'suspended') this.ctx.resume();
            return true;
        },
        play(type) {
            if (!this._ensure()) return;
            const now = this.ctx.currentTime;
            switch (type) {
                case 'correct': {
                    const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                    o.connect(g); g.connect(this.ctx.destination);
                    o.type = 'sine';
                    o.frequency.setValueAtTime(523, now);
                    o.frequency.linearRampToValueAtTime(784, now + 0.1);
                    g.gain.setValueAtTime(0.15, now);
                    g.gain.linearRampToValueAtTime(0, now + 0.2);
                    o.start(now); o.stop(now + 0.2);
                    break;
                }
                case 'incorrect': {
                    const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                    o.connect(g); g.connect(this.ctx.destination);
                    o.type = 'sawtooth';
                    o.frequency.setValueAtTime(300, now);
                    o.frequency.linearRampToValueAtTime(150, now + 0.2);
                    g.gain.setValueAtTime(0.1, now);
                    g.gain.linearRampToValueAtTime(0, now + 0.3);
                    o.start(now); o.stop(now + 0.3);
                    break;
                }
                case 'combo': {
                    [600, 800, 1000, 1200].forEach((f, i) => {
                        const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                        o.connect(g); g.connect(this.ctx.destination);
                        o.type = 'sine';
                        o.frequency.setValueAtTime(f, now + i * 0.06);
                        g.gain.setValueAtTime(0.1, now + i * 0.06);
                        g.gain.linearRampToValueAtTime(0, now + i * 0.06 + 0.1);
                        o.start(now + i * 0.06); o.stop(now + i * 0.06 + 0.1);
                    });
                    break;
                }
                case 'victory': {
                    [523, 659, 784, 1047].forEach((f, i) => {
                        const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                        o.connect(g); g.connect(this.ctx.destination);
                        o.type = 'sine';
                        o.frequency.setValueAtTime(f, now + i * 0.15);
                        g.gain.setValueAtTime(0.12, now + i * 0.15);
                        g.gain.linearRampToValueAtTime(0, now + i * 0.15 + 0.25);
                        o.start(now + i * 0.15); o.stop(now + i * 0.15 + 0.25);
                    });
                    break;
                }
                case 'defeat': {
                    const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                    o.connect(g); g.connect(this.ctx.destination);
                    o.type = 'sine';
                    o.frequency.setValueAtTime(400, now);
                    o.frequency.linearRampToValueAtTime(100, now + 0.6);
                    g.gain.setValueAtTime(0.12, now);
                    g.gain.linearRampToValueAtTime(0, now + 0.7);
                    o.start(now); o.stop(now + 0.7);
                    break;
                }
                case 'countdown': {
                    const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                    o.connect(g); g.connect(this.ctx.destination);
                    o.type = 'sine';
                    o.frequency.setValueAtTime(440, now);
                    g.gain.setValueAtTime(0.1, now);
                    g.gain.linearRampToValueAtTime(0, now + 0.12);
                    o.start(now); o.stop(now + 0.12);
                    break;
                }
                case 'click': {
                    const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                    o.connect(g); g.connect(this.ctx.destination);
                    o.type = 'sine';
                    o.frequency.setValueAtTime(800, now);
                    g.gain.setValueAtTime(0.06, now);
                    g.gain.linearRampToValueAtTime(0, now + 0.04);
                    o.start(now); o.stop(now + 0.04);
                    break;
                }
                case 'damage': {
                    const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                    o.connect(g); g.connect(this.ctx.destination);
                    o.type = 'sawtooth';
                    o.frequency.setValueAtTime(200, now);
                    o.frequency.linearRampToValueAtTime(80, now + 0.15);
                    g.gain.setValueAtTime(0.1, now);
                    g.gain.linearRampToValueAtTime(0, now + 0.2);
                    o.start(now); o.stop(now + 0.2);
                    break;
                }
                case 'tick': {
                    const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                    o.connect(g); g.connect(this.ctx.destination);
                    o.type = 'sine';
                    o.frequency.setValueAtTime(1000, now);
                    g.gain.setValueAtTime(0.04, now);
                    g.gain.linearRampToValueAtTime(0, now + 0.03);
                    o.start(now); o.stop(now + 0.03);
                    break;
                }
            }
        }
    };

    /* ══════════════════════════════════════════════════════════════
       AI Configuration per Difficulty
    ══════════════════════════════════════════════════════════════ */
    const AI_CONFIG = {
        easy:     { hp: 80,  minDelay: 3000, maxDelay: 5500, accuracy: 0.50, damage: 8  },
        normal:   { hp: 100, minDelay: 2000, maxDelay: 4000, accuracy: 0.70, damage: 10 },
        hard:     { hp: 150, minDelay: 1200, maxDelay: 2500, accuracy: 0.85, damage: 12 },
        insanity: { hp: 200, minDelay: 600,  maxDelay: 1500, accuracy: 0.95, damage: 15 }
    };

    const PLAYER_MAX_HP = 100;
    const BASE_DAMAGE = 10;
    const QUICK_DRAW_TIME = 2; // seconds for bonus damage
    const MAX_ROUNDS = 15;
    const TIME_PER_ROUND = { easy: 18, normal: 14, hard: 10, insanity: 7 };

    /* ══════════════════════════════════════════════════════════════
       Battle State
    ══════════════════════════════════════════════════════════════ */
    const B = {
        difficulty: '@(difficulty)',
        alphabet: '@(script)',
        playerName: '@(playerName)',
        words: [],
        currentWord: null,
        round: 0,
        playerHP: PLAYER_MAX_HP,
        playerMaxHP: PLAYER_MAX_HP,
        aiHP: 100,
        aiMaxHP: 100,
        playerCombo: 0,
        maxCombo: 0,
        playerScore: 0,
        playerCorrect: 0,
        playerIncorrect: 0,
        aiCorrect: 0,
        aiTotal: 0,
        aiStreak: 0,
        timePerRound: 14,
        timeLeft: 0,
        timerInterval: null,
        aiTimeout: null,
        answered: false,
        running: false,
        shieldActive: false
    };

    /* ── Init ── */
    document.addEventListener('DOMContentLoaded', () => {
        // Set initial selections from model
        const diffCards = document.querySelectorAll('#diff-grid .choice-card');
        diffCards.forEach(c => {
            c.classList.toggle('active', c.dataset.diff === B.difficulty);
        });
        const alphaCards = document.querySelectorAll('#alpha-grid .choice-card');
        alphaCards.forEach(c => {
            c.classList.toggle('active', c.dataset.alpha === B.alphabet);
        });
    });

    /* ── Selection ── */
    function selectDifficulty(diff) {
        SoundFX.play('click');
        document.querySelectorAll('#diff-grid .choice-card').forEach(c => c.classList.remove('active'));
        document.querySelector(`#diff-grid .choice-card[data-diff="${diff}"]`).classList.add('active');
        B.difficulty = diff;
    }

    function selectAlphabet(alpha) {
        SoundFX.play('click');
        document.querySelectorAll('#alpha-grid .choice-card').forEach(c => c.classList.remove('active'));
        document.querySelector(`#alpha-grid .choice-card[data-alpha="${alpha}"]`).classList.add('active');
        B.alphabet = alpha;
    }

    /* ── Show Error ── */
    function showError(msg) {
        const el = document.getElementById('error-banner');
        el.textContent = msg;
        el.style.display = 'block';
        setTimeout(() => { el.style.display = 'none'; }, 5000);
    }

    /* ── Start Battle ── */
    async function startBattle() {
        SoundFX.play('click');
        const btn = document.getElementById('start-btn');
        btn.disabled = true;
        btn.innerHTML = '<span class="loading-spinner"></span> Loading...';

        try {
            const resp = await fetch(`/KanaBlitz/GetWords?difficulty=${B.difficulty}&alphabet=${B.alphabet}`);
            if (!resp.ok) throw new Error('Failed to fetch words from database.');
            const data = await resp.json();

            if (!Array.isArray(data) || data.length < 4) {
                throw new Error(`Not enough words for ${B.difficulty}/${B.alphabet} (${data?.length || 0} found). Try a different combination.`);
            }

            B.words = shuffleArray([...data]);
            B.round = 0;
            B.playerHP = PLAYER_MAX_HP;
            B.playerMaxHP = PLAYER_MAX_HP;
            const aiConf = AI_CONFIG[B.difficulty] || AI_CONFIG.normal;
            B.aiHP = aiConf.hp;
            B.aiMaxHP = aiConf.hp;
            B.playerCombo = 0;
            B.maxCombo = 0;
            B.playerScore = 0;
            B.playerCorrect = 0;
            B.playerIncorrect = 0;
            B.aiCorrect = 0;
            B.aiTotal = 0;
            B.aiStreak = 0;
            B.timePerRound = TIME_PER_ROUND[B.difficulty] || 14;
            B.running = true;
            B.shieldActive = false;

            btn.disabled = false;
            btn.innerHTML = '🗡️ Start Battle';

            document.getElementById('setup-panel').style.display = 'none';
            document.getElementById('results-screen').style.display = 'none';
            document.getElementById('battle-arena').style.display = 'block';

            updateScoreboard();

            await showCountdown();
            nextRound();

        } catch (err) {
            btn.disabled = false;
            btn.innerHTML = '🗡️ Start Battle';
            showError(err.message);
        }
    }

    /* ── Countdown ── */
    function showCountdown() {
        return new Promise(resolve => {
            const overlay = document.getElementById('countdown-overlay');
            const display = document.getElementById('countdown-display');
            overlay.style.display = 'flex';

            let count = 3;
            display.className = 'countdown-number';
            display.textContent = count;
            SoundFX.play('countdown');

            const iv = setInterval(() => {
                count--;
                if (count > 0) {
                    display.textContent = count;
                    display.style.animation = 'none';
                    void display.offsetHeight;
                    display.style.animation = '';
                    SoundFX.play('countdown');
                } else if (count === 0) {
                    display.className = 'countdown-go';
                    display.textContent = 'FIGHT!';
                    display.style.animation = 'none';
                    void display.offsetHeight;
                    display.style.animation = '';
                    SoundFX.play('combo');
                } else {
                    clearInterval(iv);
                    overlay.style.display = 'none';
                    resolve();
                }
            }, 800);
        });
    }

    /* ── Next Round ── */
    function nextRound() {
        if (B.playerHP <= 0 || B.aiHP <= 0 || B.round >= MAX_ROUNDS || !B.running) {
            endBattle();
            return;
        }

        B.answered = false;

        // Pick a word (cycle through the shuffled pool)
        const wordIndex = B.round % B.words.length;
        B.currentWord = B.words[wordIndex];
        B.round++;

        // Update timer config
        const bar = document.getElementById('timer-bar');
        bar.style.width = '100%';
        bar.className = 'timer-bar-fill';

        // Display question
        const qCard = document.getElementById('question-card');
        qCard.classList.remove('animate-in');
        void qCard.offsetHeight;
        qCard.classList.add('animate-in');

        document.getElementById('q-kana').textContent = B.currentWord.wordKana || B.currentWord.WordKana || '—';
        document.getElementById('q-category').textContent = B.currentWord.categoryTag || B.currentWord.CategoryTag || 'Kana';

        // Build options
        buildOptions();

        // Start timer
        startTimer();

        // Start AI thinking
        startAI();

        updateScoreboard();
    }

    /* ── Build Options (no hints!) ── */
    function buildOptions() {
        const correctRomaji = B.currentWord.wordRomaji || B.currentWord.WordRomaji || '';
        const pool = B.words.filter(w => {
            const r = w.wordRomaji || w.WordRomaji || '';
            return r && r !== correctRomaji;
        });

        const wrongAnswers = shuffleArray([...pool]).slice(0, 3).map(w => w.wordRomaji || w.WordRomaji || '');
        const allAnswers = shuffleArray([correctRomaji, ...wrongAnswers]);

        const grid = document.getElementById('options-grid');
        grid.innerHTML = '';

        allAnswers.forEach((ans, i) => {
            const btn = document.createElement('button');
            btn.className = 'option-btn';
            btn.textContent = ans || '—';
            btn.dataset.answer = ans;
            btn.style.animation = `baFadeUp 0.3s ease ${i * 0.05}s both`;
            btn.addEventListener('click', () => handlePlayerAnswer(ans, correctRomaji, btn));
            grid.appendChild(btn);
        });
    }

    /* ── Start Timer ── */
    function startTimer() {
        B.timeLeft = B.timePerRound;
        const startTime = Date.now();
        const duration = B.timePerRound * 1000;

        B.timerInterval = setInterval(() => {
            const elapsed = Date.now() - startTime;
            const pct = Math.max(0, 1 - elapsed / duration) * 100;
            B.timeLeft = Math.max(0, B.timePerRound - elapsed / 1000);

            const bar = document.getElementById('timer-bar');
            bar.style.width = pct + '%';

            if (pct < 20) {
                bar.className = 'timer-bar-fill danger';
                if (Math.floor(B.timeLeft * 2) % 2 === 0) SoundFX.play('tick');
            } else {
                bar.className = 'timer-bar-fill';
            }

            if (pct <= 0) {
                clearInterval(B.timerInterval);
                handleTimeout();
            }
        }, 100);
    }

    /* ── AI System ── */
    function startAI() {
        const aiConf = AI_CONFIG[B.difficulty] || AI_CONFIG.normal;
        const delay = aiConf.minDelay + Math.random() * (aiConf.maxDelay - aiConf.minDelay);

        // Show AI thinking
        document.getElementById('ai-thinking').style.display = 'block';

        B.aiTimeout = setTimeout(() => {
            if (B.answered) return;
            // AI attempts to answer
            B.aiTotal++;
            const correctRomaji = B.currentWord.wordRomaji || B.currentWord.WordRomaji || '';
            const isCorrect = Math.random() < aiConf.accuracy;

            if (isCorrect) {
                B.aiCorrect++;
                B.aiStreak++;
                // AI deals damage to player
                const aiDmg = aiConf.damage;
                const actualDmg = B.shieldActive ? Math.floor(aiDmg * 0.5) : aiDmg;
                B.playerHP = Math.max(0, B.playerHP - actualDmg);
                B.shieldActive = false;

                document.getElementById('ai-thinking').style.display = 'none';
                showDamageFlash();
                showFloatingText(document.getElementById('p1-panel'), '-' + actualDmg + ' HP', 'damage');
                SoundFX.play('damage');

                // If player hasn't answered yet, they can still answer but took damage
                updateScoreboard();

                if (B.playerHP <= 0) {
                    clearInterval(B.timerInterval);
                    B.answered = true;
                    disableAllOptions();
                    setTimeout(() => endBattle(), 1000);
                }
            } else {
                B.aiStreak = 0;
                document.getElementById('ai-thinking').style.display = 'none';
                updateScoreboard();
            }

            document.getElementById('p2-acc').textContent = B.aiTotal > 0 ? Math.round(B.aiCorrect / B.aiTotal * 100) + '%' : '—';
            document.getElementById('p2-streak').textContent = B.aiStreak;

        }, delay);
    }

    /* ── Handle Player Answer ── */
    function handlePlayerAnswer(selected, correct, btnEl) {
        if (B.answered) return;
        B.answered = true;
        clearInterval(B.timerInterval);
        clearTimeout(B.aiTimeout);
        document.getElementById('ai-thinking').style.display = 'none';

        const allBtns = document.querySelectorAll('.option-btn');
        allBtns.forEach(b => b.disabled = true);

        if (selected === correct) {
            btnEl.classList.add('correct');
            B.playerCorrect++;
            B.playerCombo++;
            if (B.playerCombo > B.maxCombo) B.maxCombo = B.playerCombo;

            // Calculate damage to AI
            let damage = BASE_DAMAGE;
            // Quick Draw bonus
            if (B.timeLeft >= B.timePerRound - QUICK_DRAW_TIME) {
                damage = Math.floor(damage * 1.5);
            }
            // Combo bonus
            if (B.playerCombo >= 5) {
                damage = Math.floor(damage * 2.5); // Execution Blow
            } else if (B.playerCombo >= 3) {
                damage = Math.floor(damage * 1.5);
            }

            B.aiHP = Math.max(0, B.aiHP - damage);

            // Shield: 3+ combo activates shield
            B.shieldActive = B.playerCombo >= 3;

            // Score
            const points = damage * 10 + Math.floor(B.timeLeft * 5);
            B.playerScore += points;

            showFloatingText(document.getElementById('p2-panel'), '-' + damage + ' HP', 'damage');
            showFloatingText(btnEl, '+' + points, 'heal');

            if (B.playerCombo >= 5) {
                SoundFX.play('combo');
                showToast('💀 Execution Blow!', 'combo-toast');
            } else if (B.playerCombo >= 3) {
                SoundFX.play('combo');
                showToast('🛡️ Shield Active! ' + B.playerCombo + '× Combo', 'combo-toast');
            } else {
                SoundFX.play('correct');
                showToast('Correct! -' + damage + ' HP', 'correct-toast');
            }

            // Animate AI HP bar
            document.getElementById('p2-panel').style.animation = 'baHPDamage 0.4s ease';
            setTimeout(() => { document.getElementById('p2-panel').style.animation = ''; }, 400);

        } else {
            btnEl.classList.add('incorrect');
            B.playerIncorrect++;
            B.playerCombo = 0;
            B.shieldActive = false;

            // Reveal correct answer
            allBtns.forEach(b => {
                if (b.dataset.answer === correct) b.classList.add('reveal-correct');
            });

            SoundFX.play('incorrect');
            showToast('Incorrect!', 'incorrect-toast');
        }

        updateScoreboard();

        if (B.aiHP <= 0) {
            setTimeout(() => endBattle(), 1200);
        } else {
            setTimeout(() => nextRound(), 1400);
        }
    }

    /* ── Handle Timeout ── */
    function handleTimeout() {
        if (B.answered) return;
        B.answered = true;
        clearTimeout(B.aiTimeout);
        document.getElementById('ai-thinking').style.display = 'none';

        B.playerIncorrect++;
        B.playerCombo = 0;
        B.shieldActive = false;

        const correctRomaji = B.currentWord.wordRomaji || B.currentWord.WordRomaji || '';
        const allBtns = document.querySelectorAll('.option-btn');
        allBtns.forEach(b => {
            b.disabled = true;
            if (b.dataset.answer === correctRomaji) b.classList.add('reveal-correct');
        });

        SoundFX.play('incorrect');
        showToast("Time's Up!", 'incorrect-toast');
        updateScoreboard();

        if (B.playerHP > 0 && B.aiHP > 0) {
            setTimeout(() => nextRound(), 1200);
        } else {
            setTimeout(() => endBattle(), 1200);
        }
    }

    /* ── Update Scoreboard ── */
    function updateScoreboard() {
        document.getElementById('p1-name').textContent = B.playerName;
        document.getElementById('p1-hp').textContent = B.playerHP;
        document.getElementById('p1-combo').textContent = B.playerCombo;
        document.getElementById('p1-score').textContent = B.playerScore;

        const p1Pct = Math.max(0, (B.playerHP / B.playerMaxHP) * 100);
        const p1Bar = document.getElementById('p1-hp-bar');
        p1Bar.style.width = p1Pct + '%';
        p1Bar.className = 'hp-bar-fill' + (p1Pct < 25 ? ' low' : '');

        document.getElementById('p2-hp').textContent = B.aiHP;

        const p2Pct = Math.max(0, (B.aiHP / B.aiMaxHP) * 100);
        const p2Bar = document.getElementById('p2-hp-bar');
        p2Bar.style.width = p2Pct + '%';
        p2Bar.className = 'hp-bar-fill' + (p2Pct < 25 ? ' low' : '');
    }

    /* ── End Battle ── */
    async function endBattle() {
        B.running = false;
        clearInterval(B.timerInterval);
        clearTimeout(B.aiTimeout);

        const playerWon = B.aiHP <= 0;
        const draw = B.playerHP > 0 && B.aiHP > 0 && B.round >= MAX_ROUNDS;
        const playerWonByHP = draw && B.playerHP > B.aiHP;

        const isVictory = playerWon || playerWonByHP;

        if (isVictory) {
            SoundFX.play('victory');
        } else {
            SoundFX.play('defeat');
        }

        // Calculate XP
        const xpEarned = isVictory
            ? Math.floor(B.playerScore * 0.8 + B.playerCorrect * 15 + 50)
            : Math.floor(B.playerScore * 0.3 + B.playerCorrect * 5);

        // Submit score
        try {
            await fetch('/KanaBlitz/SubmitScore', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    score: B.playerScore,
                    difficulty: B.difficulty,
                    alphabet: B.alphabet,
                    correct: B.playerCorrect,
                    total: B.round,
                    maxCombo: B.maxCombo,
                    xpEarned: xpEarned
                })
            });
        } catch (e) { /* silent */ }

        // Show results
        document.getElementById('battle-arena').style.display = 'none';
        document.getElementById('results-screen').style.display = 'block';

        if (isVictory) {
            document.getElementById('results-icon').textContent = '🏆';
            document.getElementById('results-title').textContent = 'Victory!';
            document.getElementById('results-subtitle').textContent = 'You defeated the AI Opponent! Outstanding performance!';
        } else if (draw && !playerWonByHP) {
            document.getElementById('results-icon').textContent = '🤝';
            document.getElementById('results-title').textContent = 'Draw!';
            document.getElementById('results-subtitle').textContent = 'A close match! The battle ended in a draw.';
        } else {
            document.getElementById('results-icon').textContent = '💀';
            document.getElementById('results-title').textContent = 'Defeat!';
            document.getElementById('results-subtitle').textContent = 'The AI won this round. Train harder and try again!';
        }

        document.getElementById('rs-score').textContent = B.playerScore;
        document.getElementById('rs-rounds').textContent = B.playerCorrect + '/' + B.round;
        document.getElementById('rs-combo').textContent = B.maxCombo + '×';
        document.getElementById('rs-xp').textContent = '+' + xpEarned;
        document.getElementById('rs-php').textContent = B.playerHP;
        document.getElementById('rs-ahp').textContent = B.aiHP;
    }

    /* ── Play Again / Back ── */
    async function playAgain() {
        SoundFX.play('click');
        document.getElementById('results-screen').style.display = 'none';
        try {
            const resp = await fetch(`/KanaBlitz/GetWords?difficulty=${B.difficulty}&alphabet=${B.alphabet}`);
            if (!resp.ok) throw new Error('Failed to fetch words.');
            const data = await resp.json();
            if (!Array.isArray(data) || data.length < 4) throw new Error('Not enough words.');

            B.words = shuffleArray([...data]);
            B.round = 0;
            B.playerHP = PLAYER_MAX_HP;
            B.playerMaxHP = PLAYER_MAX_HP;
            const aiConf = AI_CONFIG[B.difficulty] || AI_CONFIG.normal;
            B.aiHP = aiConf.hp;
            B.aiMaxHP = aiConf.hp;
            B.playerCombo = 0; B.maxCombo = 0; B.playerScore = 0;
            B.playerCorrect = 0; B.playerIncorrect = 0;
            B.aiCorrect = 0; B.aiTotal = 0; B.aiStreak = 0;
            B.running = true; B.shieldActive = false;
            B.timePerRound = TIME_PER_ROUND[B.difficulty] || 14;

            document.getElementById('battle-arena').style.display = 'block';
            updateScoreboard();
            await showCountdown();
            nextRound();
        } catch (e) {
            showError(e.message);
            backToSetup();
        }
    }

    function backToSetup() {
        SoundFX.play('click');
        B.running = false;
        clearInterval(B.timerInterval);
        clearTimeout(B.aiTimeout);
        document.getElementById('battle-arena').style.display = 'none';
        document.getElementById('results-screen').style.display = 'none';
        document.getElementById('setup-panel').style.display = 'block';
    }

    /* ── Helpers ── */
    function shuffleArray(arr) {
        for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
    }

    function showToast(msg, cls) {
        const t = document.getElementById('feedback-toast');
        t.textContent = msg;
        t.className = 'feedback-toast ' + cls + ' show';
        setTimeout(() => { t.className = 'feedback-toast'; }, 900);
    }

    function showFloatingText(anchor, text, type) {
        const el = document.createElement('div');
        el.className = 'xp-float' + (type === 'damage' ? ' damage' : ' heal');
        el.textContent = text;
        const rect = anchor.getBoundingClientRect();
        el.style.left = rect.left + rect.width / 2 + 'px';
        el.style.top = rect.top + 'px';
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 1000);
    }

    function showDamageFlash() {
        const flash = document.createElement('div');
        flash.className = 'damage-flash';
        document.body.appendChild(flash);
        setTimeout(() => flash.remove(), 400);
    }

    function disableAllOptions() {
        document.querySelectorAll('.option-btn').forEach(b => b.disabled = true);
    }

    /* Keyboard shortcuts */
    document.addEventListener('keydown', e => {
        if (!B.running || B.answered) return;
        const num = parseInt(e.key);
        if (num >= 1 && num <= 4) {
            const btns = document.querySelectorAll('.option-btn');
            if (btns[num - 1]) btns[num - 1].click();
        }
    });
</script>
