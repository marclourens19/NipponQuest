@*
    ╔══════════════════════════════════════════════════════════════════╗
    ║  KanaBattle_View.cshtml  —  Multiplayer Battle Arena           ║
    ║  Controller : KanaBattleController → Battle()                   ║
    ║  Route      : /KanaBattle/Battle?difficulty=&script=            ║
    ║  API        : GET /KanaBlitz/GetWords?difficulty=&alphabet=     ║
    ║  Model      : KanaBattleModel                                   ║
    ║  Purpose    : Head-to-head multiplayer kana battle arena        ║
    ║  Aesthetic  : White background · Black / Gold / White / Blue    ║
    ╚══════════════════════════════════════════════════════════════════╝
*@
@model NipponQuest.Models.KanaBattleModel
@{
    ViewData["Title"] = "KanaBattle — Arena";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var difficulty = Model?.Difficulty ?? "normal";
    var script = Model?.Script ?? "hiragana";
    var playerName = Model?.PlayerName ?? "Player 1";
    var isMulti = ViewBag.Multiplayer != null && (bool)ViewBag.Multiplayer;
    var player2Name = ViewBag.Player2Name as string ?? "Player 2";
}

<style>
    /* ══════════════════════════════════════════════════════════════
               NIPPONQUEST — KanaBattle Arena
               Palette : White bg · Black text · Gold accents · Blue action
            ══════════════════════════════════════════════════════════════ */
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');

    :root {
        --ba-bg: #ffffff;
        --ba-surface: #f8fafc;
        --ba-surface2: #f1f5f9;
        --ba-border: #e2e8f0;
        --ba-border2: #cbd5e1;
        --ba-black: #0f172a;
        --ba-charcoal: #1e293b;
        --ba-dark: #334155;
        --ba-muted: #64748b;
        --ba-faint: #94a3b8;
        --ba-gold: #d97706;
        --ba-gold-lt: #f59e0b;
        --ba-gold-bg: #fef3c7;
        --ba-gold-bd: #fcd34d;
        --ba-blue: #1e40af;
        --ba-blue-lt: #3b82f6;
        --ba-blue-bg: #eff6ff;
        --ba-blue-bd: #93c5fd;
        --ba-green: #065f46;
        --ba-green-lt: #10b981;
        --ba-green-bg: #ecfdf5;
        --ba-green-bd: #6ee7b7;
        --ba-red: #991b1b;
        --ba-red-lt: #ef4444;
        --ba-red-bg: #fff1f2;
        --ba-red-bd: #fca5a5;
        --ba-p1: #1e40af;
        --ba-p2: #991b1b;
        --ba-radius: 14px;
        --ba-radius-sm: 10px;
        --ba-radius-lg: 20px;
        --ba-shadow: 0 4px 16px rgba(15,23,42,0.08);
        --ba-shadow-lg: 0 8px 32px rgba(15,23,42,0.12);
        --ba-trans: all 0.22s cubic-bezier(0.4,0,0.2,1);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    .ba-page {
        background: var(--ba-bg);
        min-height: 100vh;
        color: var(--ba-black);
        font-family: 'Nunito', 'Segoe UI', sans-serif;
        padding-bottom: 80px;
    }

        .ba-page::before {
            content: '';
            display: block;
            height: 4px;
            background: linear-gradient(90deg, #0f172a 0%, #991b1b 30%, #d97706 60%, #1e40af 100%);
        }

    .ba-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 28px 16px;
    }

    /* ── Arena Header ── */
    .arena-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 24px;
        padding-bottom: 18px;
        border-bottom: 1.5px solid var(--ba-border);
    }

    .arena-title-wrap h2 {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--ba-black);
        margin-bottom: 4px;
    }

    .arena-title-wrap .arena-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 4px;
    }

    .arena-tag {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 100px;
        font-size: 0.67rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

        .arena-tag.black {
            background: var(--ba-black);
            color: #fff;
        }

        .arena-tag.gold {
            background: var(--ba-gold-bg);
            color: var(--ba-gold);
            border: 1px solid var(--ba-gold-bd);
        }

        .arena-tag.blue {
            background: var(--ba-blue-bg);
            color: var(--ba-blue);
            border: 1px solid var(--ba-blue-bd);
        }

        .arena-tag.red {
            background: var(--ba-red-bg);
            color: var(--ba-red);
            border: 1px solid var(--ba-red-bd);
        }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--ba-muted);
        text-decoration: none;
        transition: var(--ba-trans);
        padding: 8px 16px;
        border-radius: var(--ba-radius-sm);
        border: 1.5px solid var(--ba-border);
        background: var(--ba-surface);
    }

        .back-link:hover {
            color: var(--ba-blue);
            border-color: var(--ba-blue-bd);
            background: var(--ba-blue-bg);
            transform: translateY(-1px);
        }

    /* ── VS Scoreboard ── */
    .vs-scoreboard {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 16px;
        align-items: center;
        margin-bottom: 28px;
        padding: 24px;
        background: var(--ba-surface);
        border: 1.5px solid var(--ba-border);
        border-radius: var(--ba-radius-lg);
        box-shadow: var(--ba-shadow);
    }

    .player-panel {
        text-align: center;
        padding: 16px;
        border-radius: var(--ba-radius);
        transition: var(--ba-trans);
    }

        .player-panel.p1 {
            background: var(--ba-blue-bg);
            border: 1.5px solid var(--ba-blue-bd);
        }

        .player-panel.p2 {
            background: var(--ba-red-bg);
            border: 1.5px solid var(--ba-red-bd);
        }

        .player-panel .p-name {
            font-size: 0.72rem;
            font-weight: 900;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .player-panel.p1 .p-name {
            color: var(--ba-blue);
        }

        .player-panel.p2 .p-name {
            color: var(--ba-red);
        }

        .player-panel .p-score {
            font-size: 2.8rem;
            font-weight: 900;
            line-height: 1;
        }

        .player-panel.p1 .p-score {
            color: var(--ba-p1);
        }

        .player-panel.p2 .p-score {
            color: var(--ba-p2);
        }

        .player-panel .p-stats {
            display: flex;
            gap: 12px;
            justify-content: center;
            margin-top: 10px;
        }

        .player-panel .p-stat {
            font-size: 0.68rem;
            font-weight: 700;
            color: var(--ba-muted);
        }

            .player-panel .p-stat span {
                font-weight: 900;
            }

        .player-panel.p1 .p-stat span {
            color: var(--ba-blue);
        }

        .player-panel.p2 .p-stat span {
            color: var(--ba-red);
        }

    .vs-divider {
        text-align: center;
    }

    .vs-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: var(--ba-gold-bg);
        border: 2px solid var(--ba-gold-bd);
        font-size: 1.1rem;
        font-weight: 900;
        color: var(--ba-gold);
    }

    /* ── Timer Bar ── */
    .timer-bar-track {
        width: 100%;
        height: 6px;
        background: var(--ba-surface2);
        border-radius: 3px;
        margin-bottom: 20px;
        overflow: hidden;
    }

    .timer-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--ba-gold-lt), var(--ba-gold));
        border-radius: 3px;
        transition: width 0.3s ease;
        width: 100%;
    }

        .timer-bar-fill.low {
            background: linear-gradient(90deg, var(--ba-red-lt), var(--ba-red));
        }

    .round-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

        .round-info .ri-label {
            font-size: 0.68rem;
            font-weight: 900;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--ba-faint);
        }

        .round-info .ri-val {
            font-size: 0.92rem;
            font-weight: 900;
            color: var(--ba-charcoal);
        }

            .round-info .ri-val.timer-val {
                color: var(--ba-gold);
            }

    /* ── Question Card ── */
    .question-card {
        background: var(--ba-surface);
        border: 1.5px solid var(--ba-border);
        border-radius: var(--ba-radius-lg);
        padding: 32px 24px;
        text-align: center;
        margin-bottom: 20px;
        box-shadow: var(--ba-shadow);
    }

        .question-card .q-category {
            font-size: 0.65rem;
            font-weight: 900;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--ba-blue);
            margin-bottom: 10px;
        }

        .question-card .q-kana {
            font-size: clamp(1.8rem, 5vw, 3rem);
            font-weight: 900;
            color: var(--ba-black);
            margin-bottom: 6px;
            line-height: 1.2;
        }

        .question-card .q-missing-highlight {
            display: inline-block;
            background: var(--ba-gold-bg);
            border: 1.5px dashed var(--ba-gold-bd);
            border-radius: 8px;
            padding: 4px 16px;
            font-size: 1.4rem;
            font-weight: 900;
            color: var(--ba-gold);
            margin: 6px 0;
            min-width: 60px;
        }

        .question-card .q-romaji {
            font-size: 0.95rem;
            color: var(--ba-muted);
            margin-bottom: 4px;
        }

        .question-card .q-meaning {
            font-size: 0.82rem;
            color: var(--ba-faint);
            margin-bottom: 14px;
        }

        .question-card .q-prompt {
            font-size: 0.7rem;
            font-weight: 800;
            color: var(--ba-gold);
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

    /* ── Answer Options ── */
    .answers-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
        margin-bottom: 16px;
    }

    .answer-btn {
        background: var(--ba-bg);
        border: 2px solid var(--ba-border);
        border-radius: var(--ba-radius);
        padding: 18px 14px;
        font-family: 'Nunito', sans-serif;
        font-size: 1.3rem;
        font-weight: 900;
        color: var(--ba-charcoal);
        cursor: pointer;
        transition: var(--ba-trans);
        text-align: center;
        position: relative;
    }

        .answer-btn:hover {
            border-color: var(--ba-blue-lt);
            background: var(--ba-blue-bg);
            transform: translateY(-2px);
        }

        .answer-btn.correct {
            border-color: var(--ba-green-lt);
            background: var(--ba-green-bg);
            color: var(--ba-green);
        }

        .answer-btn.incorrect {
            border-color: var(--ba-red-lt);
            background: var(--ba-red-bg);
            color: var(--ba-red);
        }

        .answer-btn:disabled {
            cursor: default;
            pointer-events: none;
        }

        .answer-btn .ans-label {
            position: absolute;
            top: 5px;
            left: 9px;
            font-size: 0.56rem;
            font-weight: 900;
            color: var(--ba-faint);
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

    /* ── Player Turn Indicator ── */
    .turn-indicator {
        text-align: center;
        margin-bottom: 16px;
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 10px 16px;
        border-radius: var(--ba-radius-sm);
        background: var(--ba-blue-bg);
        color: var(--ba-blue);
        border: 1.5px solid var(--ba-blue-bd);
        transition: var(--ba-trans);
    }

        .turn-indicator.p2-turn {
            background: var(--ba-red-bg);
            color: var(--ba-red);
            border-color: var(--ba-red-bd);
        }

    /* ── Countdown Overlay ── */
    #countdown-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15,23,42,0.88);
        z-index: 9999;
        justify-content: center;
        align-items: center;
    }

        #countdown-overlay .cd-number {
            font-size: 8rem;
            font-weight: 900;
            color: var(--ba-gold-lt);
            text-shadow: 0 0 40px rgba(245,158,11,0.4);
        }

    /* ── Results Screen ── */
    #results-screen {
        display: none;
        background: var(--ba-surface);
        border: 1.5px solid var(--ba-border);
        border-radius: var(--ba-radius-lg);
        padding: 40px 32px;
        text-align: center;
        box-shadow: var(--ba-shadow-lg);
    }

        #results-screen .result-icon {
            font-size: 4rem;
            margin-bottom: 16px;
            display: block;
        }

        #results-screen h2 {
            font-size: 2rem;
            font-weight: 900;
            color: var(--ba-black);
            margin-bottom: 8px;
        }

        #results-screen .result-sub {
            font-size: 0.9rem;
            color: var(--ba-muted);
            margin-bottom: 28px;
        }

    .results-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 32px;
    }

    .result-stat {
        background: var(--ba-bg);
        border: 1.5px solid var(--ba-border);
        border-radius: var(--ba-radius-sm);
        padding: 18px 12px;
    }

        .result-stat .rs-label {
            font-size: 0.62rem;
            font-weight: 900;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--ba-faint);
            margin-bottom: 6px;
        }

        .result-stat .rs-val {
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--ba-black);
        }

            .result-stat .rs-val.gold {
                color: var(--ba-gold);
            }

            .result-stat .rs-val.green {
                color: var(--ba-green-lt);
            }

            .result-stat .rs-val.blue {
                color: var(--ba-blue-lt);
            }

            .result-stat .rs-val.red {
                color: var(--ba-red);
            }

    .results-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

        .results-actions button, .results-actions a {
            padding: 12px 28px;
            border-radius: var(--ba-radius-sm);
            font-family: 'Nunito', sans-serif;
            font-weight: 900;
            font-size: 0.85rem;
            letter-spacing: 0.06em;
            cursor: pointer;
            transition: var(--ba-trans);
            text-decoration: none;
            border: none;
        }

    .btn-rematch {
        background: linear-gradient(135deg, var(--ba-red-lt), var(--ba-gold));
        color: #fff;
    }

        .btn-rematch:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(239,68,68,0.3);
            color: #fff;
        }

    .btn-new-setup {
        background: var(--ba-surface2);
        color: var(--ba-dark);
        border: 1.5px solid var(--ba-border) !important;
    }

        .btn-new-setup:hover {
            transform: translateY(-2px);
        }

    .btn-back-hub {
        background: var(--ba-gold-bg);
        color: var(--ba-gold);
        border: 1.5px solid var(--ba-gold-bd) !important;
    }

        .btn-back-hub:hover {
            transform: translateY(-2px);
            color: var(--ba-gold);
        }

    /* ── Lobby/Setup (for pre-game config) ── */
    #lobby-panel {
        background: var(--ba-surface);
        border: 1.5px solid var(--ba-border);
        border-radius: var(--ba-radius-lg);
        padding: 32px 28px;
        box-shadow: var(--ba-shadow);
    }

    .section-label {
        font-size: 0.67rem;
        font-weight: 900;
        letter-spacing: 0.2em;
        color: var(--ba-blue);
        text-transform: uppercase;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .section-label::after {
            content: '';
            flex: 1;
            height: 1.5px;
            background: linear-gradient(90deg, var(--ba-border2), transparent);
        }

    .choice-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 12px;
        margin-bottom: 28px;
    }

    .choice-card {
        background: var(--ba-bg);
        border: 2px solid var(--ba-border);
        border-radius: var(--ba-radius);
        padding: 18px 12px;
        cursor: pointer;
        transition: var(--ba-trans);
        text-align: center;
        user-select: none;
    }

        .choice-card:hover {
            border-color: var(--ba-blue-lt);
            background: var(--ba-blue-bg);
            transform: translateY(-2px);
        }

        .choice-card.active {
            border-color: var(--ba-blue);
            background: var(--ba-blue-bg);
            box-shadow: 0 0 0 3px rgba(30,64,175,0.15);
        }

        .choice-card .c-icon {
            font-size: 2rem;
            margin-bottom: 8px;
            display: block;
        }

        .choice-card .c-label {
            font-weight: 800;
            font-size: 0.92rem;
            color: var(--ba-charcoal);
            display: block;
        }

        .choice-card .c-sub {
            font-size: 0.7rem;
            color: var(--ba-muted);
            margin-top: 4px;
            display: block;
        }

    .name-inputs {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 24px;
    }

    .name-input-group label {
        display: block;
        font-size: 0.72rem;
        font-weight: 900;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 6px;
    }

    .name-input-group.p1 label {
        color: var(--ba-blue);
    }

    .name-input-group.p2 label {
        color: var(--ba-red);
    }

    .name-input-group input {
        width: 100%;
        padding: 12px 14px;
        border: 2px solid var(--ba-border);
        border-radius: var(--ba-radius-sm);
        font-family: 'Nunito', sans-serif;
        font-size: 0.92rem;
        font-weight: 700;
        color: var(--ba-black);
        background: var(--ba-bg);
        transition: var(--ba-trans);
    }

        .name-input-group input:focus {
            outline: none;
            border-color: var(--ba-blue-lt);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
        }

    .start-btn {
        display: block;
        width: 100%;
        padding: 16px;
        border: none;
        border-radius: var(--ba-radius);
        background: linear-gradient(135deg, var(--ba-red-lt), var(--ba-gold));
        color: #fff;
        font-family: 'Nunito', sans-serif;
        font-size: 1rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        cursor: pointer;
        transition: var(--ba-trans);
        text-transform: uppercase;
    }

        .start-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(239,68,68,0.3);
        }

    #word-warning {
        display: none;
        background: var(--ba-red-bg);
        border: 1.5px solid var(--ba-red-bd);
        border-radius: var(--ba-radius-sm);
        padding: 14px 18px;
        margin-bottom: 20px;
        font-size: 0.85rem;
        color: var(--ba-red);
        font-weight: 700;
    }

    /* ── Feedback Toast ── */
    .feedback-toast {
        position: fixed;
        top: 20%;
        left: 50%;
        transform: translateX(-50%) scale(0);
        font-size: 1.2rem;
        font-weight: 900;
        padding: 12px 28px;
        border-radius: var(--ba-radius);
        z-index: 10000;
        pointer-events: none;
        transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
    }

        .feedback-toast.show {
            transform: translateX(-50%) scale(1);
        }

        .feedback-toast.toast-correct {
            background: var(--ba-green-bg);
            color: var(--ba-green);
            border: 1.5px solid var(--ba-green-bd);
        }

        .feedback-toast.toast-incorrect {
            background: var(--ba-red-bg);
            color: var(--ba-red);
            border: 1.5px solid var(--ba-red-bd);
        }

        .feedback-toast.toast-combo {
            background: var(--ba-gold-bg);
            color: var(--ba-gold);
            border: 1.5px solid var(--ba-gold-bd);
        }

    /* ── Animations ── */
    @@keyframes countdownPop {
        0% {
            transform: scale(0.3);
            opacity: 0;
        }

        50% {
            transform: scale(1.2);
            opacity: 1;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes popIn {
        0% {
            transform: scale(0.9);
        }

        50% {
            transform: scale(1.05);
        }

        100% {
            transform: scale(1);
        }
    }

    @@keyframes shakeX {
        0%, 100% {
            transform: translateX(0);
        }

        10% {
            transform: translateX(-6px);
        }

        30% {
            transform: translateX(6px);
        }

        50% {
            transform: translateX(-3px);
        }

        70% {
            transform: translateX(3px);
        }
    }

    @@keyframes fadeInUp {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes slideInRight {
        0% {
            opacity: 0;
            transform: translateX(30px);
        }

        100% {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .anim-fade-up {
        animation: fadeInUp 0.5s cubic-bezier(0.16,1,0.3,1) both;
    }

    .anim-slide-right {
        animation: slideInRight 0.4s ease both;
    }

    /* ── Loading Spinner ── */
    .loading-spinner {
        display: inline-block;
        width: 24px;
        height: 24px;
        border: 3px solid var(--ba-border);
        border-top-color: var(--ba-blue);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        .vs-scoreboard {
            grid-template-columns: 1fr;
            text-align: center;
        }

        .vs-divider {
            order: -1;
        }

        .answers-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .results-grid {
            grid-template-columns: 1fr;
        }

        .name-inputs {
            grid-template-columns: 1fr;
        }

        .arena-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    @@media (max-width: 480px) {
        .choice-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        #lobby-panel {
            padding: 20px 14px;
        }

        .player-panel .p-score {
            font-size: 2rem;
        }
    }
</style>

<div class="ba-page">
    <div class="ba-wrapper">
        <!-- Header -->
        <div class="arena-header anim-fade-up">
            <div class="arena-title-wrap">
                <h2>⚔️ Kana<span style="color:var(--ba-red)">Battle</span> Arena</h2>
                <div class="arena-meta">
                    <span class="arena-tag red">Multiplayer</span>
                    <span class="arena-tag blue" id="header-diff-tag">@(difficulty.Substring(0, 1).ToUpper() + difficulty.Substring(1))</span>
                    <span class="arena-tag black" id="header-alpha-tag">@(script.Substring(0, 1).ToUpper() + script.Substring(1))</span>
                </div>
            </div>
            <a href="/KanaBattle/Index" class="back-link">← Back to Modes</a>
        </div>

        <!-- Lobby Setup (shown first) -->
        <div id="lobby-panel" class="anim-fade-up" style="animation-delay:0.1s">
            <div class="section-label">Difficulty</div>
            <div class="choice-grid" id="diff-grid">
                <div class="choice-card" data-diff="easy" onclick="selectDifficulty('easy')">
                    <span class="c-icon">🌱</span>
                    <span class="c-label">Easy</span>
                    <span class="c-sub">Single Characters</span>
                </div>
                <div class="choice-card @(difficulty == "normal" ? "active" : "")" data-diff="normal" onclick="selectDifficulty('normal')">
                    <span class="c-icon">⚔️</span>
                    <span class="c-label">Normal</span>
                    <span class="c-sub">Common Words</span>
                </div>
                <div class="choice-card" data-diff="hard" onclick="selectDifficulty('hard')">
                    <span class="c-icon">🔥</span>
                    <span class="c-label">Hard</span>
                    <span class="c-sub">Yōon & Compounds</span>
                </div>
                <div class="choice-card" data-diff="insanity" onclick="selectDifficulty('insanity')">
                    <span class="c-icon">💀</span>
                    <span class="c-label">Insanity</span>
                    <span class="c-sub">Kanji Mastery</span>
                </div>
            </div>

            <div class="section-label">Alphabet</div>
            <div class="choice-grid" id="alpha-grid">
                <div class="choice-card @(script == "hiragana" ? "active" : "")" data-alpha="hiragana" onclick="selectAlphabet('hiragana')">
                    <span class="c-icon">あ</span>
                    <span class="c-label">Hiragana</span>
                </div>
                <div class="choice-card" data-alpha="katakana" onclick="selectAlphabet('katakana')">
                    <span class="c-icon">ア</span>
                    <span class="c-label">Katakana</span>
                </div>
                <div class="choice-card" data-alpha="dakuten" onclick="selectAlphabet('dakuten')">
                    <span class="c-icon">が</span>
                    <span class="c-label">Dakuten</span>
                </div>
                <div class="choice-card" data-alpha="mixed" onclick="selectAlphabet('mixed')">
                    <span class="c-icon">混</span>
                    <span class="c-label">Mixed</span>
                </div>
            </div>

            <div class="section-label">Warriors</div>
            <div class="name-inputs">
                <div class="name-input-group p1">
                    <label>Player 1</label>
                    <input type="text" id="p1-name" value="@playerName" placeholder="Enter name..." maxlength="20" />
                </div>
                <div class="name-input-group p2">
                    <label>Player 2</label>
                    <input type="text" id="p2-name" value="@player2Name" placeholder="Enter name..." maxlength="20" />
                </div>
            </div>

            <div id="word-warning"></div>

            <button class="start-btn" id="start-btn" onclick="startBattle()">
                ⚔️ Start Battle
            </button>
        </div>

        <!-- Countdown Overlay -->
        <div id="countdown-overlay">
            <div class="cd-number" id="cd-number">3</div>
        </div>

        <!-- Battle Arena -->
        <div id="battle-arena" style="display:none;">
            <div class="vs-scoreboard">
                <div class="player-panel p1">
                    <div class="p-name" id="p1-display">@playerName</div>
                    <div class="p-score" id="p1-score">0</div>
                    <div class="p-stats">
                        <div class="p-stat">Correct: <span id="p1-correct">0</span></div>
                        <div class="p-stat">Combo: <span id="p1-combo">0×</span></div>
                    </div>
                </div>
                <div class="vs-divider">
                    <div class="vs-badge">VS</div>
                </div>
                <div class="player-panel p2">
                    <div class="p-name" id="p2-display">@player2Name</div>
                    <div class="p-score" id="p2-score">0</div>
                    <div class="p-stats">
                        <div class="p-stat">Correct: <span id="p2-correct">0</span></div>
                        <div class="p-stat">Combo: <span id="p2-combo">0×</span></div>
                    </div>
                </div>
            </div>

            <div class="timer-bar-track">
                <div class="timer-bar-fill" id="timer-bar"></div>
            </div>

            <div class="round-info">
                <div>
                    <div class="ri-label">Round</div>
                    <div class="ri-val" id="round-num">1</div>
                </div>
                <div>
                    <div class="ri-label">Time</div>
                    <div class="ri-val timer-val" id="hud-time">60</div>
                </div>
                <div>
                    <div class="ri-label">Question</div>
                    <div class="ri-val" id="q-num">1</div>
                </div>
            </div>

            <div class="turn-indicator" id="turn-indicator">
                🗡️ @playerName's Turn
            </div>

            <div class="question-card anim-slide-right" id="question-card">
                <div class="q-category" id="q-category">—</div>
                <div class="q-kana" id="q-kana">—</div>
                <div class="q-missing-highlight" id="q-missing">?</div>
                <div class="q-romaji" id="q-romaji">—</div>
                <div class="q-meaning" id="q-meaning">—</div>
                <div class="q-prompt">Select the missing kana</div>
            </div>

            <div class="answers-grid" id="answers-grid"></div>
        </div>

        <!-- Results Screen -->
        <div id="results-screen">
            <span class="result-icon" id="result-icon">🏆</span>
            <h2 id="result-title">Battle Complete!</h2>
            <div class="result-sub" id="result-sub">The results are in.</div>

            <div class="vs-scoreboard" id="results-vs" style="margin-bottom:28px;">
                <div class="player-panel p1" id="results-p1">
                    <div class="p-name" id="res-p1-name">Player 1</div>
                    <div class="p-score" id="res-p1-score">0</div>
                    <div class="p-stats">
                        <div class="p-stat">Accuracy: <span id="res-p1-acc">0%</span></div>
                    </div>
                </div>
                <div class="vs-divider">
                    <div class="vs-badge" id="res-vs-icon">VS</div>
                </div>
                <div class="player-panel p2" id="results-p2">
                    <div class="p-name" id="res-p2-name">Player 2</div>
                    <div class="p-score" id="res-p2-score">0</div>
                    <div class="p-stats">
                        <div class="p-stat">Accuracy: <span id="res-p2-acc">0%</span></div>
                    </div>
                </div>
            </div>

            <div class="results-actions">
                <button class="btn-rematch" onclick="rematch()">⚔️ Rematch</button>
                <button class="btn-new-setup" onclick="newSetup()">Change Setup</button>
                <a href="/KanaBattle/Index" class="btn-back-hub">Mode Selection</a>
            </div>
        </div>

        <!-- Feedback Toast -->
        <div class="feedback-toast" id="feedback-toast"></div>
    </div>
</div>

<script>
    // ═══════════════════════════════════════════════════════════
    //  KanaBattle Multiplayer Engine
    // ═══════════════════════════════════════════════════════════

    // ── Audio Architecture (placeholder hooks) ──
    const AudioHooks = {
        correct: () => { },
        incorrect: () => { },
        victory: () => { },
        countdown: () => { },
        click: () => { },
        combo: () => { }
    };

    // ── State ──
    let selectedDifficulty = '@(difficulty)';
    let selectedAlphabet = '@(script)';
    let gameWords = [];
    let currentIndex = 0;
    let isPlaying = false;
    let timeLeft = 60;
    let maxTime = 60;
    let timerInterval = null;
    let currentTurn = 1; // 1 = P1, 2 = P2

    const TOTAL_ROUNDS = 10;
    let currentRound = 0;

    let p1 = { name: '@(playerName)', score: 0, correct: 0, total: 0, combo: 0, maxCombo: 0 };
    let p2 = { name: '@(player2Name)', score: 0, correct: 0, total: 0, combo: 0, maxCombo: 0 };

    const TIME_PER_DIFFICULTY = { easy: 90, normal: 75, hard: 60, insanity: 45 };
    const MIN_WORDS = 4;

    // ── Initialize ──
    document.addEventListener('DOMContentLoaded', () => {
        // Set initial active states from model
        const diffCard = document.querySelector(`[data-diff="${selectedDifficulty}"]`);
        if (diffCard) {
            document.querySelectorAll('#diff-grid .choice-card').forEach(c => c.classList.remove('active'));
            diffCard.classList.add('active');
        }
        const alphaCard = document.querySelector(`[data-alpha="${selectedAlphabet}"]`);
        if (alphaCard) {
            document.querySelectorAll('#alpha-grid .choice-card').forEach(c => c.classList.remove('active'));
            alphaCard.classList.add('active');
        }
    });

    // ── Selection Handlers ──
    function selectDifficulty(diff) {
        AudioHooks.click();
        selectedDifficulty = diff;
        document.querySelectorAll('#diff-grid .choice-card').forEach(c => c.classList.remove('active'));
        document.querySelector(`[data-diff="${diff}"]`).classList.add('active');

        document.getElementById('header-diff-tag').textContent = diff.charAt(0).toUpperCase() + diff.slice(1);
    }

    function selectAlphabet(alpha) {
        AudioHooks.click();
        selectedAlphabet = alpha;
        document.querySelectorAll('#alpha-grid .choice-card').forEach(c => c.classList.remove('active'));
        document.querySelector(`[data-alpha="${alpha}"]`).classList.add('active');

        document.getElementById('header-alpha-tag').textContent = alpha.charAt(0).toUpperCase() + alpha.slice(1);
    }

    // ── Start Battle ──
    async function startBattle() {
        const btn = document.getElementById('start-btn');
        btn.disabled = true;
        btn.textContent = 'Loading words…';

        // Read player names
        p1.name = document.getElementById('p1-name').value.trim() || 'Player 1';
        p2.name = document.getElementById('p2-name').value.trim() || 'Player 2';
        p1.score = 0; p1.correct = 0; p1.total = 0; p1.combo = 0; p1.maxCombo = 0;
        p2.score = 0; p2.correct = 0; p2.total = 0; p2.combo = 0; p2.maxCombo = 0;

        // Update display names
        document.getElementById('p1-display').textContent = p1.name;
        document.getElementById('p2-display').textContent = p2.name;

        try {
            const res = await fetch(`/KanaBlitz/GetWords?difficulty=${selectedDifficulty}&alphabet=${selectedAlphabet}`);
            if (!res.ok) throw new Error('Failed to fetch words');
            const data = await res.json();

            if (!Array.isArray(data) || data.length < MIN_WORDS) {
                throw new Error(`Not enough words (${data ? data.length : 0}). Try another combination.`);
            }

            gameWords = shuffleArray([...data]);
            currentIndex = 0;
            currentRound = 0;
            currentTurn = 1;
            maxTime = TIME_PER_DIFFICULTY[selectedDifficulty] || 75;
            timeLeft = maxTime;

            showCountdown(() => {
                document.getElementById('lobby-panel').style.display = 'none';
                document.getElementById('battle-arena').style.display = 'block';
                isPlaying = true;
                updateScoreboard();
                nextRound();
                startTimer();
            });
        } catch (e) {
            console.error('Start battle error:', e);
            const warning = document.getElementById('word-warning');
            warning.style.display = 'block';
            warning.innerHTML = `❌ ${e.message}`;
            btn.disabled = false;
            btn.textContent = '⚔️ Try Again';
        }
    }

    function showCountdown(callback) {
        const overlay = document.getElementById('countdown-overlay');
        const numEl = document.getElementById('cd-number');
        overlay.style.display = 'flex';
        let count = 3;
        numEl.textContent = count;

        const interval = setInterval(() => {
            AudioHooks.countdown();
            count--;
            if (count > 0) {
                numEl.textContent = count;
                numEl.style.animation = 'none';
                numEl.offsetHeight;
                numEl.style.animation = 'countdownPop 0.8s ease';
            } else if (count === 0) {
                numEl.textContent = 'GO!';
                numEl.style.color = '#10b981';
                numEl.style.animation = 'none';
                numEl.offsetHeight;
                numEl.style.animation = 'countdownPop 0.8s ease';
            } else {
                clearInterval(interval);
                overlay.style.display = 'none';
                numEl.style.color = '';
                callback();
            }
        }, 800);
    }

    function startTimer() {
        clearInterval(timerInterval);
        timerInterval = setInterval(() => {
            timeLeft--;
            updateTimerDisplay();
            if (timeLeft <= 0) {
                clearInterval(timerInterval);
                endBattle();
            }
        }, 1000);
    }

    function updateTimerDisplay() {
        document.getElementById('hud-time').textContent = timeLeft;
        const pct = (timeLeft / maxTime) * 100;
        const bar = document.getElementById('timer-bar');
        bar.style.width = pct + '%';
        bar.className = 'timer-bar-fill' + (pct < 25 ? ' low' : '');
    }

    // ── Game Flow (alternating turns) ──
    function nextRound() {
        if (!isPlaying) return;

        currentRound++;
        if (currentRound > TOTAL_ROUNDS * 2) {
            endBattle();
            return;
        }

        // Alternate turns: P1 on odd rounds, P2 on even
        currentTurn = (currentRound % 2 === 1) ? 1 : 2;

        updateTurnIndicator();
        showQuestion();
        updateRoundInfo();
    }

    function updateTurnIndicator() {
        const indicator = document.getElementById('turn-indicator');
        if (currentTurn === 1) {
            indicator.textContent = `🗡️ ${p1.name}'s Turn`;
            indicator.className = 'turn-indicator';
        } else {
            indicator.textContent = `🗡️ ${p2.name}'s Turn`;
            indicator.className = 'turn-indicator p2-turn';
        }
    }

    function updateRoundInfo() {
        document.getElementById('round-num').textContent = Math.ceil(currentRound / 2);
        document.getElementById('q-num').textContent = currentRound;
    }

    function showQuestion() {
        if (currentIndex >= gameWords.length) {
            gameWords = shuffleArray([...gameWords]);
            currentIndex = 0;
        }

        const word = gameWords[currentIndex];
        const card = document.getElementById('question-card');
        card.classList.remove('anim-slide-right');
        card.offsetHeight;
        card.classList.add('anim-slide-right');

        document.getElementById('q-category').textContent = word.categoryTag || word.alphabet || '—';

        let displayKana = word.wordKana || '';
        const parenMatch = displayKana.match(/^(.+?)\s*\((.+?)\)$/);
        if (parenMatch) {
            document.getElementById('q-kana').textContent = parenMatch[1];
            document.getElementById('q-romaji').textContent = parenMatch[2] + ' · ' + (word.wordRomaji || '');
        } else {
            document.getElementById('q-kana').textContent = displayKana;
            document.getElementById('q-romaji').textContent = word.wordRomaji || '';
        }

        document.getElementById('q-meaning').textContent = word.meaningEnglish || '';
        document.getElementById('q-missing').textContent = word.missingKana || '?';

        generateAnswers(word);
    }

    function generateAnswers(word) {
        const correctAnswer = word.missingKana || '';
        const grid = document.getElementById('answers-grid');
        grid.innerHTML = '';

        let distractors = gameWords
            .filter(w => w.missingKana && w.missingKana !== correctAnswer)
            .map(w => w.missingKana);
        distractors = [...new Set(distractors)];
        distractors = shuffleArray(distractors).slice(0, 3);

        const fallbackKana = ['あ','い','う','え','お','か','き','く','け','こ','さ','し','す','せ','そ',
            'た','ち','つ','て','と','な','に','ぬ','ね','の','は','ひ','ふ','へ','ほ',
            'ま','み','む','め','も','や','ゆ','よ','ら','り','る','れ','ろ','わ','を','ん'];

        while (distractors.length < 3) {
            const random = fallbackKana[Math.floor(Math.random() * fallbackKana.length)];
            if (random !== correctAnswer && !distractors.includes(random)) {
                distractors.push(random);
            }
        }

        const options = shuffleArray([correctAnswer, ...distractors.slice(0, 3)]);
        const labels = ['A', 'B', 'C', 'D'];

        options.forEach((opt, i) => {
            const btn = document.createElement('button');
            btn.className = 'answer-btn';
            btn.innerHTML = `<span class="ans-label">${labels[i]}</span>${opt}`;
            btn.onclick = () => handleAnswer(btn, opt, correctAnswer);
            grid.appendChild(btn);
        });
    }

    function handleAnswer(btn, selected, correct) {
        if (!isPlaying) return;
        document.querySelectorAll('.answer-btn').forEach(b => b.disabled = true);

        const activePlayer = currentTurn === 1 ? p1 : p2;
        activePlayer.total++;

        if (selected === correct) {
            btn.classList.add('correct');
            activePlayer.correct++;
            activePlayer.combo++;
            if (activePlayer.combo > activePlayer.maxCombo) activePlayer.maxCombo = activePlayer.combo;
            activePlayer.score += 10 * Math.max(1, activePlayer.combo);

            timeLeft += 2;
            if (timeLeft > maxTime + 20) timeLeft = maxTime + 20;

            AudioHooks.correct();
            showFeedback(`✓ ${activePlayer.name} Correct!`, 'correct');
        } else {
            btn.classList.add('incorrect');
            document.querySelectorAll('.answer-btn').forEach(b => {
                if (b.textContent.includes(correct)) b.classList.add('correct');
            });
            activePlayer.combo = 0;
            timeLeft = Math.max(0, timeLeft - 3);

            AudioHooks.incorrect();
            showFeedback(`✗ ${activePlayer.name} Wrong!`, 'incorrect');
        }

        currentIndex++;
        updateScoreboard();
        updateTimerDisplay();

        setTimeout(() => {
            if (isPlaying && timeLeft > 0) {
                nextRound();
            }
        }, 700);
    }

    function updateScoreboard() {
        document.getElementById('p1-score').textContent = p1.score;
        document.getElementById('p1-correct').textContent = p1.correct;
        document.getElementById('p1-combo').textContent = p1.combo + '×';

        document.getElementById('p2-score').textContent = p2.score;
        document.getElementById('p2-correct').textContent = p2.correct;
        document.getElementById('p2-combo').textContent = p2.combo + '×';
    }

    // ── End Battle ──
    function endBattle() {
        isPlaying = false;
        clearInterval(timerInterval);
        AudioHooks.victory();

        const p1Acc = p1.total > 0 ? Math.round((p1.correct / p1.total) * 100) : 0;
        const p2Acc = p2.total > 0 ? Math.round((p2.correct / p2.total) * 100) : 0;

        document.getElementById('res-p1-name').textContent = p1.name;
        document.getElementById('res-p1-score').textContent = p1.score;
        document.getElementById('res-p1-acc').textContent = p1Acc + '%';

        document.getElementById('res-p2-name').textContent = p2.name;
        document.getElementById('res-p2-score').textContent = p2.score;
        document.getElementById('res-p2-acc').textContent = p2Acc + '%';

        let icon, title, sub;
        if (p1.score > p2.score) {
            icon = '🏆'; title = `${p1.name} Wins!`;
            sub = `Dominant performance with ${p1Acc}% accuracy!`;
            document.getElementById('results-p1').style.boxShadow = '0 0 0 3px rgba(30,64,175,0.3)';
            document.getElementById('res-vs-icon').textContent = '👑';
        } else if (p2.score > p1.score) {
            icon = '🏆'; title = `${p2.name} Wins!`;
            sub = `Impressive victory with ${p2Acc}% accuracy!`;
            document.getElementById('results-p2').style.boxShadow = '0 0 0 3px rgba(153,27,27,0.3)';
            document.getElementById('res-vs-icon').textContent = '👑';
        } else {
            icon = '🤝'; title = 'Draw!';
            sub = 'An evenly matched battle — both warriors proved their worth!';
            document.getElementById('res-vs-icon').textContent = '=';
        }

        document.getElementById('result-icon').textContent = icon;
        document.getElementById('result-title').textContent = title;
        document.getElementById('result-sub').textContent = sub;

        document.getElementById('battle-arena').style.display = 'none';
        document.getElementById('results-screen').style.display = 'block';
    }

    function rematch() {
        document.getElementById('results-screen').style.display = 'none';
        p1.score = 0; p1.correct = 0; p1.total = 0; p1.combo = 0; p1.maxCombo = 0;
        p2.score = 0; p2.correct = 0; p2.total = 0; p2.combo = 0; p2.maxCombo = 0;
        gameWords = shuffleArray([...gameWords]);
        currentIndex = 0;
        currentRound = 0;
        currentTurn = 1;
        timeLeft = maxTime;

        showCountdown(() => {
            document.getElementById('battle-arena').style.display = 'block';
            isPlaying = true;
            updateScoreboard();
            nextRound();
            startTimer();
        });
    }

    function newSetup() {
        document.getElementById('results-screen').style.display = 'none';
        document.getElementById('lobby-panel').style.display = 'block';
        const btn = document.getElementById('start-btn');
        btn.disabled = false;
        btn.textContent = '⚔️ Start Battle';
    }

    // ── Utility ──
    function shuffleArray(arr) {
        for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
    }

    // ── Feedback Toast ──
    function showFeedback(text, type) {
        const toast = document.getElementById('feedback-toast');
        toast.textContent = text;
        toast.className = 'feedback-toast toast-' + type + ' show';
        setTimeout(() => { toast.classList.remove('show'); }, 1200);
    }

    // ── Keyboard Support ──
    document.addEventListener('keydown', (e) => {
        if (!isPlaying) return;
        const keyMap = { 'a': 0, 'b': 1, 'c': 2, 'd': 3, '1': 0, '2': 1, '3': 2, '4': 3 };
        const index = keyMap[e.key.toLowerCase()];
        if (index !== undefined) {
            const btns = document.querySelectorAll('.answer-btn:not(:disabled)');
            if (btns[index]) btns[index].click();
        }
    });
</script>
