@*
    ╔══════════════════════════════════════════════════════════════════╗
    ║  KanaBlitz_Index.cshtml  —  KanaBlitz Solo Game Arena           ║
    ║  Controller : KanaBlitzController → Index()                     ║
    ║  Route      : /KanaBlitz/Index  (or /KanaBlitz)                 ║
    ║  API        : GET /KanaBlitz/GetWords?difficulty=&script=       ║
    ║  Refactored : Full audit, debug, redesign & UX overhaul         ║
    ╚══════════════════════════════════════════════════════════════════╝
*@
@{
    ViewData["Title"] = "KanaBlitz — Solo Training";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ═══════════════════════════════════════════════
           NIPPONQUEST DESIGN TOKENS — KanaBlitz Solo
           Matches site.css palette & Nunito font stack
        ═══════════════════════════════════════════════ */
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');

    :root {
        --nq-bg: #0b0b18;
        --nq-surface: #12122a;
        --nq-surface2: #1a1a38;
        --nq-border: #2a2a55;
        --nq-border2: #3a3a6a;
        --nq-accent: #7c3aed;
        --nq-accent2: #a855f7;
        --nq-pink: #ec4899;
        --nq-gold: #f59e0b;
        --nq-green: #10b981;
        --nq-red: #ef4444;
        --nq-blue: #0ea5e9;
        --nq-text: #e2e8f0;
        --nq-muted: #94a3b8;
        --nq-faint: #64748b;
        --nq-radius: 14px;
        --nq-radius-sm: 10px;
        --nq-transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .kb-page {
        background: var(--nq-bg);
        min-height: 100vh;
        color: var(--nq-text);
        font-family: 'Nunito', 'Segoe UI', sans-serif;
        padding-bottom: 60px;
    }

        /* ── Ambient particles background ── */
        .kb-page::before {
            content: '';
            position: fixed;
            inset: 0;
            background: radial-gradient(ellipse 80% 50% at 20% 20%, rgba(124,58,237,0.07) 0%, transparent 60%), radial-gradient(ellipse 60% 40% at 80% 80%, rgba(168,85,247,0.05) 0%, transparent 60%);
            pointer-events: none;
            z-index: 0;
        }

    .kb-wrapper {
        max-width: 1080px;
        margin: 0 auto;
        padding: 28px 16px;
        position: relative;
        z-index: 1;
    }

    /* ── Page Header ── */
    .kb-hero {
        text-align: center;
        padding: 16px 0 32px;
    }

    .kb-hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(124,58,237,0.15);
        border: 1px solid rgba(124,58,237,0.35);
        border-radius: 100px;
        padding: 6px 18px;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        color: var(--nq-accent2);
        text-transform: uppercase;
        margin-bottom: 16px;
    }

    .kb-hero h1 {
        font-size: clamp(1.9rem, 5vw, 3rem);
        font-weight: 900;
        letter-spacing: 0.04em;
        background: linear-gradient(135deg, #7c3aed 0%, #a855f7 45%, #ec4899 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1.15;
        margin-bottom: 10px;
    }

    .kb-hero p {
        color: var(--nq-muted);
        font-size: 0.95rem;
        max-width: 520px;
        margin-inline: auto;
        line-height: 1.65;
    }

    /* ── Setup Panel ── */
    #setup-panel {
        background: var(--nq-surface);
        border: 1px solid var(--nq-border);
        border-radius: 20px;
        padding: 32px 28px;
        margin-bottom: 24px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.35);
    }

    .section-label {
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 0.18em;
        color: var(--nq-accent2);
        text-transform: uppercase;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .section-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--nq-border);
        }

    /* ── Choice Grids ── */
    .choice-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 12px;
        margin-bottom: 28px;
    }

    .choice-card {
        background: var(--nq-surface2);
        border: 2px solid var(--nq-border);
        border-radius: var(--nq-radius);
        padding: 18px 12px;
        cursor: pointer;
        transition: var(--nq-transition);
        text-align: center;
        position: relative;
        overflow: hidden;
        user-select: none;
    }

        .choice-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(124,58,237,0.0), rgba(168,85,247,0.0));
            transition: var(--nq-transition);
            border-radius: inherit;
        }

        .choice-card:hover {
            border-color: var(--nq-accent2);
            background: #1e1e42;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(124,58,237,0.2);
        }

            .choice-card:hover::before {
                background: linear-gradient(135deg, rgba(124,58,237,0.06), rgba(168,85,247,0.06));
            }

        .choice-card.active {
            border-color: var(--nq-accent);
            background: rgba(45, 27, 110, 0.7);
            box-shadow: 0 0 20px rgba(124,58,237,0.4), inset 0 0 0 1px rgba(168,85,247,0.3);
            transform: translateY(-2px);
        }

            .choice-card.active::before {
                background: linear-gradient(135deg, rgba(124,58,237,0.1), rgba(168,85,247,0.1));
            }

        .choice-card .c-icon {
            font-size: 2rem;
            margin-bottom: 8px;
            display: block;
        }

        .choice-card .c-label {
            font-weight: 800;
            font-size: 0.95rem;
            display: block;
        }

        .choice-card .c-sub {
            font-size: 0.72rem;
            color: var(--nq-muted);
            margin-top: 4px;
            display: block;
        }

        .choice-card .c-tag {
            font-size: 0.68rem;
            color: var(--nq-accent2);
            margin-top: 3px;
            display: block;
        }

        .choice-card .c-count {
            font-size: 0.65rem;
            color: var(--nq-faint);
            margin-top: 2px;
            display: block;
        }

        /* ── Difficulty Colors ── */
        .choice-card[data-diff="easy"].active {
            border-color: var(--nq-green);
            box-shadow: 0 0 20px rgba(16,185,129,0.35);
        }

        .choice-card[data-diff="normal"].active {
            border-color: var(--nq-blue);
            box-shadow: 0 0 20px rgba(14,165,233,0.35);
        }

        .choice-card[data-diff="hard"].active {
            border-color: var(--nq-gold);
            box-shadow: 0 0 20px rgba(245,158,11,0.35);
        }

        .choice-card[data-diff="insanity"].active {
            border-color: var(--nq-red);
            box-shadow: 0 0 20px rgba(239,68,68,0.35);
        }

    .diff-pip {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-bottom: 6px;
    }

    .pip-easy {
        background: var(--nq-green);
    }

    .pip-normal {
        background: var(--nq-blue);
    }

    .pip-hard {
        background: var(--nq-gold);
    }

    .pip-insanity {
        background: var(--nq-red);
    }

    /* ── Start Button ── */
    #btn-start {
        width: 100%;
        padding: 18px;
        border-radius: var(--nq-radius);
        border: none;
        font-size: 1.05rem;
        font-weight: 900;
        cursor: pointer;
        background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%);
        color: #fff;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        transition: var(--nq-transition);
        position: relative;
        overflow: hidden;
        box-shadow: 0 6px 24px rgba(124,58,237,0.4);
    }

        #btn-start::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -60%;
            width: 30%;
            height: 200%;
            background: rgba(255,255,255,0.2);
            transform: rotate(30deg);
        }

        #btn-start:hover {
            opacity: 0.92;
            transform: translateY(-2px);
            box-shadow: 0 10px 32px rgba(124,58,237,0.55);
        }

            #btn-start:hover::after {
                animation: btnSheen 0.7s ease;
            }

        #btn-start:disabled {
            opacity: 0.4;
            cursor: not-allowed;
            transform: none;
        }

    @@keyframes btnSheen {
        from {
            left: -60%;
        }

        to {
            left: 140%;
        }
    }

    /* ── Word Count Warning ── */
    #word-warning {
        display: none;
        background: rgba(239,68,68,0.1);
        border: 1px solid rgba(239,68,68,0.4);
        border-radius: var(--nq-radius-sm);
        padding: 12px 16px;
        font-size: 0.82rem;
        color: #fca5a5;
        margin-bottom: 16px;
        align-items: center;
        gap: 10px;
    }

        #word-warning.visible {
            display: flex;
        }

    /* ══════════════════════════════════════════════════
           ARENA
        ══════════════════════════════════════════════════ */
    #arena {
        display: none;
    }

    /* ── HUD ── */
    .hud {
        display: grid;
        grid-template-columns: auto 1fr auto auto auto;
        align-items: center;
        gap: 14px;
        background: var(--nq-surface);
        border: 1px solid var(--nq-border);
        border-radius: var(--nq-radius);
        padding: 14px 20px;
        margin-bottom: 16px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.3);
    }

    @@media (max-width: 640px) {
        .hud {
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }
    }

    .hud-stat {
        text-align: center;
    }

        .hud-stat .hs-val {
            font-size: 1.4rem;
            font-weight: 900;
            line-height: 1;
        }

        .hud-stat .hs-lbl {
            font-size: 0.62rem;
            color: var(--nq-muted);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-top: 2px;
        }

    #hud-timer .hs-val {
        color: var(--nq-gold);
        font-variant-numeric: tabular-nums;
    }

    #hud-score .hs-val {
        color: var(--nq-green);
    }

    #hud-combo .hs-val {
        color: var(--nq-accent2);
    }

    .hud-progress {
        height: 6px;
        background: var(--nq-surface2);
        border-radius: 3px;
        overflow: hidden;
    }

    .hud-progress-bar {
        height: 100%;
        border-radius: 3px;
        background: linear-gradient(90deg, var(--nq-accent), var(--nq-accent2));
        transition: width 0.4s ease;
    }

    .hud-lives {
        font-size: 1.25rem;
        letter-spacing: 3px;
    }

    /* ── Question Card ── */
    .q-card {
        background: var(--nq-surface);
        border: 1px solid var(--nq-border);
        border-radius: 20px;
        padding: 36px 24px;
        text-align: center;
        margin-bottom: 16px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        position: relative;
        overflow: hidden;
        transition: var(--nq-transition);
    }

        .q-card::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: inherit;
            background: linear-gradient(135deg, rgba(124,58,237,0) 0%, rgba(168,85,247,0) 100%);
            transition: var(--nq-transition);
            pointer-events: none;
        }

        .q-card.flash-correct::after {
            background: linear-gradient(135deg, rgba(16,185,129,0.12), rgba(16,185,129,0.04));
        }

        .q-card.flash-wrong::after {
            background: linear-gradient(135deg, rgba(239,68,68,0.12), rgba(239,68,68,0.04));
        }

    .q-kana {
        font-size: clamp(3.5rem, 10vw, 5.5rem);
        line-height: 1;
        margin-bottom: 10px;
        display: block;
        animation: kanaReveal 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes kanaReveal {
        from {
            opacity: 0;
            transform: scale(0.75) translateY(10px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .q-meaning {
        font-size: 0.85rem;
        color: var(--nq-faint);
        min-height: 1.3em;
        margin-bottom: 4px;
    }

    .q-cat {
        font-size: 0.7rem;
        color: var(--nq-accent2);
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    /* progress dots */
    .q-progress {
        display: flex;
        justify-content: center;
        gap: 5px;
        margin-top: 18px;
        flex-wrap: wrap;
    }

    .q-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--nq-surface2);
        border: 1px solid var(--nq-border);
        transition: var(--nq-transition);
    }

        .q-dot.done-correct {
            background: var(--nq-green);
            border-color: var(--nq-green);
        }

        .q-dot.done-wrong {
            background: var(--nq-red);
            border-color: var(--nq-red);
        }

        .q-dot.current {
            background: var(--nq-accent2);
            border-color: var(--nq-accent2);
            transform: scale(1.3);
        }

    /* ── Options Grid ── */
    .opt-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 16px;
    }

    @@media (max-width: 480px) {
        .opt-grid {
            grid-template-columns: 1fr;
        }
    }

    .opt-btn {
        background: var(--nq-surface2);
        border: 2px solid var(--nq-border);
        border-radius: var(--nq-radius-sm);
        padding: 16px 12px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        color: var(--nq-text);
        font-family: 'Nunito', sans-serif;
        transition: var(--nq-transition);
        position: relative;
        overflow: hidden;
    }

        .opt-btn:hover:not(:disabled) {
            border-color: var(--nq-accent2);
            background: #1e1e42;
            transform: translateY(-1px);
        }

        .opt-btn:disabled {
            cursor: default;
        }

        .opt-btn.correct {
            border-color: var(--nq-green) !important;
            background: rgba(16,185,129,0.12) !important;
            color: #6ee7b7 !important;
            box-shadow: 0 0 16px rgba(16,185,129,0.25);
        }

        .opt-btn.wrong {
            border-color: var(--nq-red) !important;
            background: rgba(239,68,68,0.1) !important;
            color: #fca5a5 !important;
            box-shadow: 0 0 16px rgba(239,68,68,0.2);
        }

    /* ── Feedback Bar ── */
    #feedback-bar {
        text-align: center;
        font-size: 0.95rem;
        font-weight: 800;
        min-height: 26px;
        letter-spacing: 0.04em;
        transition: color 0.2s;
    }

    /* ── Combo Burst ── */
    .combo-burst {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 3.5rem;
        font-weight: 900;
        pointer-events: none;
        z-index: 9999;
        animation: comboBurst 0.75s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        text-shadow: 0 0 40px currentColor;
    }

    @@keyframes comboBurst {
        0% {
            opacity: 1;
            transform: translate(-50%, -50%) scale(0.5);
        }

        60% {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1.1);
        }

        100% {
            opacity: 0;
            transform: translate(-50%, -50%) scale(0.9) translateY(-40px);
        }
    }

    /* ══════════════════════════════════════════════════
           RESULT OVERLAY
        ══════════════════════════════════════════════════ */
    #result-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.78);
        backdrop-filter: blur(6px);
        z-index: 9000;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

        #result-overlay.show {
            display: flex;
        }

    .result-card {
        background: var(--nq-surface);
        border: 1px solid var(--nq-border2);
        border-radius: 24px;
        padding: 44px 36px;
        text-align: center;
        max-width: 500px;
        width: 100%;
        box-shadow: 0 24px 64px rgba(0,0,0,0.6);
        animation: resultSlideUp 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
        position: relative;
        overflow: hidden;
    }

    @@keyframes resultSlideUp {
        from {
            opacity: 0;
            transform: scale(0.85) translateY(30px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .result-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--nq-accent), var(--nq-accent2), var(--nq-pink));
    }

    .result-emoji {
        font-size: 3.5rem;
        display: block;
        margin-bottom: 10px;
    }

    .result-title {
        font-size: 2rem;
        font-weight: 900;
        margin-bottom: 6px;
        background: linear-gradient(135deg, #7c3aed, #a855f7, #ec4899);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .result-subtitle {
        color: var(--nq-muted);
        font-size: 0.85rem;
        margin-bottom: 24px;
    }

    .result-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 24px;
    }

    .rs-cell {
        background: var(--nq-surface2);
        border: 1px solid var(--nq-border);
        border-radius: var(--nq-radius-sm);
        padding: 16px 10px;
    }

        .rs-cell .rs-val {
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--nq-gold);
        }

        .rs-cell .rs-lbl {
            font-size: 0.65rem;
            color: var(--nq-muted);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-top: 3px;
        }

    .result-xp {
        background: rgba(124,58,237,0.12);
        border: 1px solid rgba(124,58,237,0.3);
        border-radius: var(--nq-radius-sm);
        padding: 14px;
        margin-bottom: 24px;
        font-size: 0.9rem;
        color: var(--nq-accent2);
        font-weight: 700;
    }

    .result-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-primary {
        padding: 12px 28px;
        border-radius: var(--nq-radius-sm);
        border: none;
        font-size: 0.92rem;
        font-weight: 800;
        cursor: pointer;
        background: linear-gradient(135deg, #7c3aed, #a855f7);
        color: #fff;
        font-family: 'Nunito', sans-serif;
        letter-spacing: 0.04em;
        transition: var(--nq-transition);
    }

        .btn-primary:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

    .btn-secondary {
        padding: 12px 28px;
        border-radius: var(--nq-radius-sm);
        border: 1px solid var(--nq-border2);
        font-size: 0.92rem;
        font-weight: 800;
        cursor: pointer;
        background: var(--nq-surface2);
        color: var(--nq-text);
        font-family: 'Nunito', sans-serif;
        letter-spacing: 0.04em;
        transition: var(--nq-transition);
    }

        .btn-secondary:hover {
            border-color: var(--nq-accent2);
            transform: translateY(-1px);
        }

    /* ── Loading overlay ── */
    #loading-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(11,11,24,0.88);
        backdrop-filter: blur(4px);
        z-index: 8000;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 20px;
    }

        #loading-overlay.show {
            display: flex;
        }

    .spinner {
        width: 48px;
        height: 48px;
        border: 3px solid var(--nq-border);
        border-top-color: var(--nq-accent2);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .loading-text {
        color: var(--nq-muted);
        font-size: 0.88rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    /* ── Countdown Overlay ── */
    #countdown-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(11,11,24,0.88);
        backdrop-filter: blur(4px);
        z-index: 8500;
        align-items: center;
        justify-content: center;
    }

        #countdown-overlay.show {
            display: flex;
        }

    .countdown-num {
        font-size: 8rem;
        font-weight: 900;
        color: var(--nq-accent2);
        text-shadow: 0 0 60px rgba(168,85,247,0.7);
        animation: countdownPulse 1s ease-out;
        line-height: 1;
    }

    @@keyframes countdownPulse {
        0% {
            transform: scale(1.4);
            opacity: 0.6;
        }

        60% {
            transform: scale(1.0);
            opacity: 1;
        }

        100% {
            transform: scale(0.85);
            opacity: 0;
        }
    }

    /* ── Timer low warning ── */
    #hud-timer.warning .hs-val {
        color: var(--nq-red);
        animation: timerPulse 0.5s ease infinite alternate;
    }

    @@keyframes timerPulse {
        from {
            opacity: 1;
        }

        to {
            opacity: 0.5;
        }
    }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        #setup-panel {
            padding: 20px 16px;
        }

        .choice-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .result-card {
            padding: 28px 20px;
        }

        .result-stats {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 420px) {
        .result-stats {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>

