</div><!-- /ba-page -->
@section Scripts {
    <script>
        /* ══════════════════════════════════════════════════════════════
           KanaBattle Arena Script
           Handles solo and multiplayer game flow
           API : GET /KanaBlitz/GetWords?difficulty=&script=
           Data: JSON { wordKana, wordRomaji, meaningEnglish, missingKana,
                        categoryTag, displayHtml, alphabet, difficultyLevel }
        ══════════════════════════════════════════════════════════════ */
        (function () {
            'use strict';

            /* ── Injected from Razor model ── */
            const DIFFICULTY    = @Html.Raw($"\"{difficulty}\"");
            const SCRIPT        = @Html.Raw($"\"{script}\"");
            const PLAYER_NAME   = @Html.Raw($"\"{System.Text.Json.JsonSerializer.Serialize(playerName).Trim('"')}\"");
            const PLAYER2_NAME  = @Html.Raw($"\"{System.Text.Json.JsonSerializer.Serialize(player2Name).Trim('"')}\"");
            const IS_MULTI      = @Html.Raw(isMulti ? "true" : "false");

            /* ── Config ── */
            const CFG = {
                totalRounds     : 20,
                basePoints      : 100,
                comboThreshold  : 3,
                comboMultiplier : 15,
                diffTimers      : { easy: 30, normal: 25, hard: 20, insanity: 15 },
                minWords        : { easy: 4, normal: 5, hard: 4, insanity: 4 },
                apiEndpoint     : '/KanaBlitz/GetWords'
            };

            /* ── State ── */
            const S = {
                words        : [],
                queue        : [],
                current      : null,
                qIndex       : 0,
                timerSecs    : 25,
                timerInterval: null,
                answered     : false,
                // Solo state
                solo: { score: 0, correct: 0, incorrect: 0, combo: 0, bestCombo: 0 },
                // Multiplayer state
                multi: {
                    p1: { score: 0, correct: 0, combo: 0, bestCombo: 0 },
                    p2: { score: 0, correct: 0, combo: 0, bestCombo: 0 }
                }
            };

            /* ── DOM ── */
            const $ = id => document.getElementById(id);

            /* ── Audio hooks ── */
            const Audio = { play(type) { /* expandable: correct|incorrect|victory|countdown|click */ } };

            /* ── Utilities ── */
            function shuffle(arr) {
                const a = [...arr];
                for (let i = a.length - 1; i > 0; i--) {
                    const j = Math.floor(Math.random() * (i + 1));
                    [a[i], a[j]] = [a[j], a[i]];
                }
                return a;
            }

            function normalise(str) {
                return (str || '').trim().toLowerCase()
                    .replace(/[āáàä]/g,'a').replace(/[ūúùü]/g,'u')
                    .replace(/[ōóòö]/g,'o').replace(/[ēéèë]/g,'e')
                    .replace(/[īíìï]/g,'i').replace(/\s+/g,' ');
            }

            function escHtml(s) {
                return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            }

            function toast(msg, type = 'default') {
                const el = document.createElement('div');
                el.className = `toast ${type}`;
                el.textContent = msg;
                $('toast-container').appendChild(el);
                setTimeout(() => el.remove(), 3200);
            }

            function calcRank(accuracy, score) {
                if (accuracy >= 0.95 && score >= 1800) return 'S+';
                if (accuracy >= 0.90) return 'S';
                if (accuracy >= 0.80) return 'A';
                if (accuracy >= 0.65) return 'B';
                if (accuracy >= 0.50) return 'C';
                return 'D';
            }

            /* ── Bootstrap ── */
            async function boot() {
                showLoading(true);
                try {
                    const url  = `${CFG.apiEndpoint}?difficulty=${encodeURIComponent(DIFFICULTY)}&script=${encodeURIComponent(SCRIPT)}`;
                    const resp = await fetch(url);
                    if (!resp.ok) throw new Error(`HTTP ${resp.status}: ${resp.statusText}`);
                    const data = await resp.json();
                    if (!Array.isArray(data) || data.length === 0) throw new Error('No words returned from database.');
                    if (data.length < CFG.minWords[DIFFICULTY]) {
                        throw new Error(`Only ${data.length} words found for ${DIFFICULTY}/${SCRIPT}. Database may need reseeding.`);
                    }
                    S.words = data;
                    S.queue = shuffle(data).slice(0, CFG.totalRounds);
                    showLoading(false);
                    await runCountdown();
                    startGame();
                } catch (err) {
                    console.error('[KanaBattle] boot error:', err);
                    showError(err.message);
                }
            }

            function showLoading(visible) {
                const ls = $('loading-state');
                if (ls) ls.style.display = visible ? 'block' : 'none';
            }

            function showError(msg) {
                showLoading(false);
                const es = $('error-state');
                const em = $('error-msg');
                if (es) es.style.display = 'block';
                if (em) em.textContent = msg || 'Unknown error.';
            }

            /* ── Countdown ── */
            async function runCountdown() {
                return new Promise(resolve => {
                    const overlay = $('countdown-overlay');
                    const numEl   = $('countdown-num');
                    overlay.classList.add('visible');
                    let n = 3;
                    numEl.textContent = n;
                    Audio.play('countdown');
                    const iv = setInterval(() => {
                        n--;
                        if (n <= 0) {
                            clearInterval(iv);
                            overlay.classList.remove('visible');
                            resolve();
                        } else {
                            numEl.textContent = n;
                            numEl.style.animation = 'none';
                            requestAnimationFrame(() => requestAnimationFrame(() => {
                                numEl.style.animation = 'baCountPop 0.85s cubic-bezier(0.34,1.56,0.64,1)';
                            }));
                            Audio.play('countdown');
                        }
                    }, 900);
                });
            }

            /* ── Game Start ── */
            function startGame() {
                S.qIndex   = 0;
                S.answered = false;

                if (IS_MULTI) {
                    $('arena-multi').style.display = 'block';
                    $('arena-solo').style.display  = 'none';
                    setupMultiInputs();
                } else {
                    $('arena-solo').style.display  = 'block';
                    $('arena-multi').style.display = 'none';
                    setupSoloInputs();
                }

                nextRound();
            }

            /* ── Round Flow ── */
            function nextRound() {
                if (S.qIndex >= S.queue.length) { endGame(); return; }

                S.current   = S.queue[S.qIndex];
                S.answered  = false;
                S.timerSecs = CFG.diffTimers[DIFFICULTY] ?? 25;
                clearInterval(S.timerInterval);

                const w = S.current;

                if (IS_MULTI) renderMultiKana(w);
                else          renderSoloKana(w);

                updateGlobalHUD();
                startTimer();

                if (!IS_MULTI) {
                    const useMC = DIFFICULTY === 'easy';
                    $('mc-area').style.display  = useMC ? 'block' : 'none';
                    $('type-area').style.display= useMC ? 'none'  : 'block';
                    if (useMC) buildMC(w);
                    else {
                        const inp = $('solo-input');
                        if (inp) { inp.value = ''; inp.className = ''; inp.disabled = false; setTimeout(() => inp.focus(), 60); }
                        const sub = $('solo-submit');
                        if (sub) sub.disabled = false;
                    }
                    const fb = $('solo-feedback');
                    if (fb) { fb.textContent = ''; fb.className = 'feedback-solo'; }
                } else {
                    resetMultiInputs();
                }

                animateKanaCard();
            }

            /* ── Kana Rendering ── */
            function renderSoloKana(w) {
                const el = $('kana-char');
                if (el) el.textContent = w.wordKana || '—';

                const mn = $('kana-meaning');
                if (mn) mn.textContent = (DIFFICULTY === 'hard' || DIFFICULTY === 'insanity') ? (w.meaningEnglish || '') : '';

                const fl = $('kana-fill');
                if (fl) {
                    if ((DIFFICULTY === 'normal' || DIFFICULTY === 'hard' || DIFFICULTY === 'insanity') && w.missingKana) {
                        fl.innerHTML = buildFillHtml(w.wordKana, w.missingKana);
                    } else {
                        fl.textContent = '';
                    }
                }

                const tg = $('kana-tags');
                if (tg) tg.innerHTML = buildTagsHtml(w);
            }

            function renderMultiKana(w) {
                const el = $('m-kana-char');
                if (el) el.textContent = w.wordKana || '—';

                const mn = $('m-kana-meaning');
                if (mn) mn.textContent = (DIFFICULTY === 'hard' || DIFFICULTY === 'insanity') ? (w.meaningEnglish || '') : '';

                const fl = $('m-kana-fill');
                if (fl) {
                    if ((DIFFICULTY === 'normal' || DIFFICULTY === 'hard' || DIFFICULTY === 'insanity') && w.missingKana) {
                        fl.innerHTML = buildFillHtml(w.wordKana, w.missingKana);
                    } else {
                        fl.textContent = '';
                    }
                }

                const tg = $('m-kana-tags');
                if (tg) tg.innerHTML = buildTagsHtml(w);
            }

            function buildFillHtml(word, missing) {
                if (!missing || !word.includes(missing)) return escHtml(word);
                const idx  = word.indexOf(missing);
                const pre  = escHtml(word.slice(0, idx));
                const post = escHtml(word.slice(idx + missing.length));
                return `${pre}<span class="fill-blank">${escHtml(missing)}</span>${post}`;
            }

            function buildTagsHtml(w) {
                let h = '';
                if (w.categoryTag)    h += `<span class="kana-tag">${escHtml(w.categoryTag)}</span>`;
                const diffColour = { easy:'', normal:'blue', hard:'gold', insanity:'gold' };
                h += `<span class="kana-tag ${diffColour[DIFFICULTY] || ''}">${DIFFICULTY.charAt(0).toUpperCase()+DIFFICULTY.slice(1)}</span>`;
                return h;
            }

            function animateKanaCard() {
                const card = $('kana-stage') || $('m-kana-stage');
                if (!card) return;
                card.style.animation = 'none';
                requestAnimationFrame(() => requestAnimationFrame(() => {
                    card.style.animation = 'baSlideIn 0.38s cubic-bezier(0.34,1.56,0.64,1)';
                }));
            }

            /* ── Multiple Choice ── */
            function buildMC(current) {
                const grid = $('mc-grid');
                if (!grid) return;
                const distractors = shuffle(S.words.filter(w => w.wordRomaji !== current.wordRomaji)).slice(0, 3);
                const options = shuffle([current, ...distractors]);
                grid.innerHTML = '';
                options.forEach(opt => {
                    const btn = document.createElement('button');
                    btn.className = 'mc-btn';
                    btn.textContent = opt.wordRomaji.toUpperCase();
                    btn.addEventListener('click', () => handleSoloMC(btn, opt, current));
                    grid.appendChild(btn);
                });
            }

            function handleSoloMC(btn, chosen, correct) {
                if (S.answered) return;
                S.answered = true;
                clearInterval(S.timerInterval);
                const ok = normalise(chosen.wordRomaji) === normalise(correct.wordRomaji);
                processSoloAnswer(ok, correct.wordRomaji);
                document.querySelectorAll('.mc-btn').forEach(b => {
                    b.disabled = true;
                    if (normalise(b.textContent) === normalise(correct.wordRomaji).toUpperCase()) b.classList.add('correct');
                    else if (b === btn && !ok) b.classList.add('incorrect');
                });
                setTimeout(() => { S.qIndex++; nextRound(); }, 1100);
            }

            /* ── Solo Input ── */
            function setupSoloInputs() {
                const inp = $('solo-input');
                const sub = $('solo-submit');
                if (inp) {
                    inp.addEventListener('keydown', e => {
                        if (e.key === 'Enter') { e.preventDefault(); submitSolo(); }
                    });
                }
                if (sub) sub.addEventListener('click', submitSolo);
            }

            function submitSolo() {
                if (S.answered) return;
                const inp = $('solo-input');
                if (!inp || !inp.value.trim()) return;
                S.answered = true;
                clearInterval(S.timerInterval);
                const ok = normalise(inp.value) === normalise(S.current.wordRomaji);
                processSoloAnswer(ok, S.current.wordRomaji);
                inp.className = ok ? 'correct' : 'incorrect';
                inp.disabled  = true;
                const sub = $('solo-submit');
                if (sub) sub.disabled = true;
                setTimeout(() => { S.qIndex++; nextRound(); }, 1000);
            }

            function processSoloAnswer(ok, correctAnswer) {
                const st = S.solo;
                const fb = $('solo-feedback');
                if (ok) {
                    st.correct++;
                    st.combo++;
                    if (st.combo > st.bestCombo) st.bestCombo = st.combo;
                    const timeBonus  = Math.floor(S.timerSecs * 2);
                    const comboBonus = st.combo >= CFG.comboThreshold ? st.combo * CFG.comboMultiplier : 0;
                    st.score += CFG.basePoints + timeBonus + comboBonus;
                    if (fb) {
                        fb.textContent = comboBonus > 0
                            ? `✓ Correct! +${CFG.basePoints + timeBonus} (+${comboBonus} combo!)`
                            : `✓ Correct! +${CFG.basePoints + timeBonus}`;
                        fb.className = 'feedback-solo correct';
                    }
                    const stage = $('kana-stage');
                    if (stage) { stage.style.animation = 'none'; requestAnimationFrame(() => requestAnimationFrame(() => { stage.style.animation = 'baCorrectPop 0.3s ease'; })); }
                    Audio.play('correct');
                } else {
                    st.incorrect++;
                    st.combo = 0;
                    if (fb) {
                        fb.textContent = `✗ Wrong — ${correctAnswer.toUpperCase()}`;
                        fb.className = 'feedback-solo incorrect';
                    }
                    const stage = $('kana-stage');
                    if (stage) { stage.style.animation = 'none'; requestAnimationFrame(() => requestAnimationFrame(() => { stage.style.animation = 'baShake 0.4s ease'; })); }
                    Audio.play('incorrect');
                }
                updateGlobalHUD();
            }

            /* ── Multiplayer Input ── */
            function setupMultiInputs() {
                const p1inp = $('p1-input'), p1sub = $('p1-submit');
                const p2inp = $('p2-input'), p2sub = $('p2-submit');

                if (p1inp) {
                    p1inp.addEventListener('keydown', e => {
                        if (e.key === 'Tab') { e.preventDefault(); submitMulti(1); }
                    });
                }
                if (p1sub) p1sub.addEventListener('click', () => submitMulti(1));

                if (p2inp) {
                    p2inp.addEventListener('keydown', e => {
                        if (e.key === 'Enter') { e.preventDefault(); submitMulti(2); }
                    });
                }
                if (p2sub) p2sub.addEventListener('click', () => submitMulti(2));
            }

            function resetMultiInputs() {
                [1,2].forEach(p => {
                    const inp = $(`p${p}-input`);
                    const sub = $(`p${p}-submit`);
                    const fb  = $(`p${p}-feedback`);
                    if (inp) { inp.value = ''; inp.className = ''; inp.disabled = false; }
                    if (sub) sub.disabled = false;
                    if (fb)  { fb.textContent = ''; fb.className = 'player-feedback'; }
                    const panel = $(`p${p}-panel`);
                    if (panel) panel.classList.remove('active-panel');
                });
            }

            function submitMulti(playerNum) {
                const inp = $(`p${playerNum}-input`);
                if (!inp || !inp.value.trim() || inp.disabled) return;

                const answer = inp.value.trim();
                const ok = normalise(answer) === normalise(S.current.wordRomaji);

                // Lock this player's input
                inp.disabled = true;
                inp.className = ok ? 'correct' : 'incorrect';
                const sub = $(`p${playerNum}-submit`);
                if (sub) sub.disabled = true;

                const fb  = $(`p${playerNum}-feedback`);
                const st  = S.multi[`p${playerNum}`];

                if (ok) {
                    st.correct++;
                    st.combo++;
                    if (st.combo > st.bestCombo) st.bestCombo = st.combo;
                    const timeBonus  = Math.floor(S.timerSecs * 2);
                    const comboBonus = st.combo >= CFG.comboThreshold ? st.combo * CFG.comboMultiplier : 0;
                    st.score += CFG.basePoints + timeBonus + comboBonus;
                    if (fb) { fb.textContent = `✓ Correct! +${CFG.basePoints + timeBonus}`; fb.className = 'player-feedback correct'; }
                    Audio.play('correct');
                } else {
                    st.combo = 0;
                    if (fb) { fb.textContent = `✗ Wrong — ${S.current.wordRomaji.toUpperCase()}`; fb.className = 'player-feedback incorrect'; }
                    Audio.play('incorrect');
                }

                updateMultiScoreboards();

                // If both answered, advance; else check if first-correct wins round
                const bothDone = $('p1-input').disabled && $('p2-input').disabled;
                if (ok || bothDone) {
                    if (!S.answered) {
                        S.answered = true;
                        clearInterval(S.timerInterval);
                        // Lock remaining player
                        ['p1-input','p2-input','p1-submit','p2-submit'].forEach(id => {
                            const el = $(id);
                            if (el) el.disabled = true;
                        });
                        // Reveal correct answer to all
                        if (!ok) {
                            // Show correct answer hint
                            ['p1-feedback','p2-feedback'].forEach(id => {
                                const el = $(id);
                                if (el && !el.textContent) el.textContent = `Answer: ${S.current.wordRomaji.toUpperCase()}`;
                            });
                        }
                        setTimeout(() => { S.qIndex++; nextRound(); }, 1200);
                    }
                }
            }

            function updateMultiScoreboards() {
                const p1 = S.multi.p1, p2 = S.multi.p2;
                const setT = (id, val) => { const el = $(id); if (el) el.textContent = val; };
                setT('p1-score', p1.score.toLocaleString());
                setT('p2-score', p2.score.toLocaleString());
                setT('p1-correct-sub', `${p1.correct} correct`);
                setT('p2-correct-sub', `${p2.correct} correct`);
                setT('rb-p1-score', p1.score.toLocaleString());
                setT('rb-p2-score', p2.score.toLocaleString());
                setT('ghud-score',  p1.score.toLocaleString());
                setT('ghud-score2', p2.score.toLocaleString());
            }

            /* ── Timer ── */
            function startTimer() {
                const totalSecs = S.timerSecs;
                const circ      = 150.8;
                updateArc(1, circ);

                S.timerInterval = setInterval(() => {
                    S.timerSecs--;
                    const timeEl = $('ghud-time');
                    if (timeEl) timeEl.textContent = Math.max(0, S.timerSecs);
                    updateArc(S.timerSecs / totalSecs, circ);

                    const arc = $('timer-arc');
                    if (arc) {
                        if (S.timerSecs <= 5)       arc.style.stroke = '#ef4444';
                        else if (S.timerSecs <= 10) arc.style.stroke = '#f59e0b';
                        else                         arc.style.stroke = '#f59e0b';
                    }

                    if (S.timerSecs <= 0) {
                        clearInterval(S.timerInterval);
                        handleTimeout();
                    }
                }, 1000);
            }

            function updateArc(fraction, circ) {
                const arc = $('timer-arc');
                if (!arc) return;
                arc.style.strokeDashoffset = circ * (1 - Math.max(0, fraction));
            }

            function handleTimeout() {
                S.answered = true;
                const correctRomaji = S.current?.wordRomaji || '—';
                if (!IS_MULTI) {
                    S.solo.combo    = 0;
                    S.solo.incorrect++;
                    const fb = $('solo-feedback');
                    if (fb) { fb.textContent = `⏱ Time's up! Answer: ${correctRomaji.toUpperCase()}`; fb.className = 'feedback-solo incorrect'; }
                    ['solo-input','solo-submit'].forEach(id => { const el = $(id); if (el) el.disabled = true; });
                    document.querySelectorAll('.mc-btn').forEach(b => {
                        b.disabled = true;
                        if (normalise(b.textContent) === normalise(correctRomaji).toUpperCase()) b.classList.add('correct');
                    });
                } else {
                    // Both players timed out
                    ['p1-input','p2-input','p1-submit','p2-submit'].forEach(id => { const el = $(id); if (el) el.disabled = true; });
                    ['p1-feedback','p2-feedback'].forEach(id => {
                        const el = $(id);
                        if (el && !el.textContent) { el.textContent = `⏱ Time's up! Answer: ${correctRomaji.toUpperCase()}`; el.className = 'player-feedback incorrect'; }
                    });
                }
                Audio.play('incorrect');
                updateGlobalHUD();
                setTimeout(() => { S.qIndex++; nextRound(); }, 1400);
            }

            /* ── Global HUD ── */
            function updateGlobalHUD() {
                const setT = (id, val) => { const el = $(id); if (el) el.textContent = val; };
                const round = Math.min(S.qIndex + 1, S.queue.length);
                setT('ghud-q', `${round}/${S.queue.length}`);

                const pct = (S.qIndex / S.queue.length) * 100;
                const pf  = $('progress-fill');
                if (pf) pf.style.width = `${Math.min(100, pct)}%`;

                if (!IS_MULTI) {
                    setT('ghud-score', S.solo.score.toLocaleString());
                    setT('ghud-combo', S.solo.combo);
                    setT('ghud-time',  Math.max(0, S.timerSecs));
                } else {
                    updateMultiScoreboards();
                    setT('ghud-combo', Math.max(S.multi.p1.combo, S.multi.p2.combo));
                }
            }

            /* ── End Game ── */
            function endGame() {
                clearInterval(S.timerInterval);
                const pf = $('progress-fill');
                if (pf) pf.style.width = '100%';

                const overlay = $('results-overlay');
                if (!overlay) return;

                if (!IS_MULTI) {
                    // Solo results
                    const total    = S.solo.correct + S.solo.incorrect;
                    const accuracy = total > 0 ? S.solo.correct / total : 0;
                    const rank     = calcRank(accuracy, S.solo.score);
                    const perfect  = accuracy >= 1.0;

                    const setT = (id, val) => { const el = $(id); if (el) el.textContent = val; };
                    setT('results-trophy',  perfect ? '🏆' : (accuracy >= 0.7 ? '⚔️' : '📖'));
                    setT('results-winner',  perfect ? 'Perfect Run!' : (accuracy >= 0.7 ? 'Well Done!' : 'Keep Practising!'));
                    setT('results-sub',     `${DIFFICULTY} · ${SCRIPT} · ${PLAYER_NAME}`);
                    setT('res-score',       S.solo.score.toLocaleString());
                    setT('res-correct',     S.solo.correct);
                    setT('res-total',       total);
                    setT('res-accuracy',    `${Math.round(accuracy * 100)}%`);
                    setT('res-combo',       S.solo.bestCombo);
                    const rankEl = $('res-rank');
                    if (rankEl) { rankEl.textContent = rank; rankEl.style.color = (rank==='S+'||rank==='S') ? '#d97706' : ''; }

                    const ss = $('solo-stats');
                    const ms = $('multi-stats');
                    if (ss) ss.style.display = 'grid';
                    if (ms) ms.style.display = 'none';

                    Audio.play('victory');
                    savePersonalBest(accuracy);

                } else {
                    // Multiplayer results
                    const p1 = S.multi.p1, p2 = S.multi.p2;
                    const winner = p1.score > p2.score ? PLAYER_NAME : (p2.score > p1.score ? PLAYER2_NAME : 'Draw');
                    const setT   = (id, val) => { const el = $(id); if (el) el.textContent = val; };
                    setT('results-trophy',  p1.score === p2.score ? '🤝' : '🏆');
                    setT('results-winner',  p1.score === p2.score ? 'It\'s a Draw!' : `${winner} Wins!`);
                    setT('results-sub',     `${DIFFICULTY} · ${SCRIPT} · ${S.queue.length} rounds`);
                    setT('p1-result-name',  PLAYER_NAME);
                    setT('p1-result-score', p1.score.toLocaleString());
                    setT('p1-result-sub',   `${p1.correct} correct · Combo ×${p1.bestCombo}`);
                    setT('p2-result-name',  PLAYER2_NAME);
                    setT('p2-result-score', p2.score.toLocaleString());
                    setT('p2-result-sub',   `${p2.correct} correct · Combo ×${p2.bestCombo}`);

                    const p1r = $('p1-result'), p2r = $('p2-result');
                    if (p1r) p1r.classList.toggle('winner', p1.score > p2.score);
                    if (p2r) p2r.classList.toggle('winner', p2.score > p1.score);
                    if (p1.score > p2.score && p1r) p1r.style.animation = 'baWinner 1.5s ease infinite';
                    if (p2.score > p1.score && p2r) p2r.style.animation = 'baWinner 1.5s ease infinite';

                    const ss = $('solo-stats');
                    const ms = $('multi-stats');
                    if (ss) ss.style.display = 'none';
                    if (ms) ms.style.display = 'grid';

                    Audio.play('victory');
                }

                overlay.classList.add('visible');
            }

            async function savePersonalBest(accuracy) {
                try {
                    const payload = {
                        difficulty  : DIFFICULTY,
                        alphabet    : SCRIPT,
                        bestCorrect : S.solo.correct,
                        bestPoints  : S.solo.score,
                        bestCombo   : S.solo.bestCombo,
                        bestAccuracy: accuracy
                    };
                    const token = document.querySelector('input[name="__RequestVerificationToken"]');
                    const resp  = await fetch('/KanaBlitz/SavePersonalBest', {
                        method : 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            ...(token ? { 'RequestVerificationToken': token.value } : {})
                        },
                        body: JSON.stringify(payload)
                    });
                    if (resp.ok) {
                        const data = await resp.json();
                        if (data?.isNewBest) toast('🏅 New Personal Best!', 'success');
                    }
                } catch (e) {
                    console.warn('[KanaBattle] savePersonalBest failed:', e);
                }
            }

            /* ── Rematch ── */
            const rematchBtn = $('btn-rematch');
            if (rematchBtn) {
                rematchBtn.addEventListener('click', () => {
                    const overlay = $('results-overlay');
                    if (overlay) overlay.classList.remove('visible');
                    // Reset state
                    S.qIndex   = 0;
                    S.answered = false;
                    S.solo     = { score:0, correct:0, incorrect:0, combo:0, bestCombo:0 };
                    S.multi.p1 = { score:0, correct:0, combo:0, bestCombo:0 };
                    S.multi.p2 = { score:0, correct:0, combo:0, bestCombo:0 };
                    S.queue    = shuffle(S.words).slice(0, CFG.totalRounds);
                    updateGlobalHUD();
                    runCountdown().then(startGame);
                    Audio.play('click');
                });
            }

            /* ── Init ── */
            boot();

        })();
    </script>
}
