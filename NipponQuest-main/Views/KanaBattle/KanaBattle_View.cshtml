@section Scripts {
    <script>
        (function () {
            'use strict';

            /* ═══════════════════════════════════════════════════════════
               NIPPONQUEST · KanaBattle AI Arena
               Full game logic — database-backed words + adaptive AI
            ═══════════════════════════════════════════════════════════ */

            /* ── Pass Razor values to JS ── */
            const INIT_DIFFICULTY = '@difficulty';
            const INIT_SCRIPT     = '@script';
            const INIT_PLAYERNAME = '@playerName';

            /* ── Audio (Web Audio API) ── */
            let audioCtx = null;
            function getAudio() {
                if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                return audioCtx;
            }
            function playTone(freq, dur, type = 'sine', vol = 0.15) {
                try {
                    const ctx = getAudio();
                    const osc = ctx.createOscillator(); const gain = ctx.createGain();
                    osc.connect(gain); gain.connect(ctx.destination);
                    osc.type = type; osc.frequency.setValueAtTime(freq, ctx.currentTime);
                    gain.gain.setValueAtTime(vol, ctx.currentTime);
                    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + dur);
                    osc.start(); osc.stop(ctx.currentTime + dur);
                } catch (e) {}
            }
            const SFX = {
                correct:   () => { playTone(523,0.07,'sine',0.14); setTimeout(()=>playTone(659,0.09,'sine',0.12),55); },
                wrong:     () => { playTone(200,0.15,'sawtooth',0.1); },
                combo:     () => { [523,659,784,1047].forEach((f,i)=>setTimeout(()=>playTone(f,0.08,'sine',0.13),i*55)); },
                hit:       () => { playTone(150,0.12,'square',0.1); playTone(300,0.05,'sine',0.07); },
                victory:   () => { [523,659,784,1047,1319].forEach((f,i)=>setTimeout(()=>playTone(f,0.14,'sine',0.16),i*90)); },
                defeat:    () => { [392,330,262].forEach((f,i)=>setTimeout(()=>playTone(f,0.18,'sawtooth',0.1),i*120)); },
                countdown: () => { playTone(440,0.1,'sine',0.14); },
                go:        () => { playTone(880,0.18,'sine',0.18); },
                click:     () => { playTone(800,0.04,'sine',0.07); }
            };

            /* ── Kana Pools ── */
            const H_POOL = ['あ','い','う','え','お','か','き','く','け','こ','さ','し','す','せ','そ','た','ち','つ','て','と','な','に','ぬ','ね','の','は','ひ','ふ','へ','ほ','ま','み','む','め','も','や','ゆ','よ','ら','り','る','れ','ろ','わ','を','ん','が','ぎ','ぐ','げ','ご','ざ','じ','ず','ぜ','ぞ','だ','で','ど','ば','び','ぶ','べ','ぼ','ぱ','ぴ','ぷ','ぺ','ぽ'];
            const K_POOL = ['ア','イ','ウ','エ','オ','カ','キ','ク','ケ','コ','サ','シ','ス','セ','ソ','タ','チ','ツ','テ','ト','ナ','ニ','ヌ','ネ','ノ','ハ','ヒ','フ','ヘ','ホ','マ','ミ','ム','メ','モ','ヤ','ユ','ヨ','ラ','リ','ル','レ','ロ','ワ','ヲ','ン','ガ','ギ','グ','ゲ','ゴ','ザ','ジ','ズ','ゼ','ゾ','ダ','デ','ド','バ','ビ','ブ','ベ','ボ','パ','ピ','プ','ペ','ポ'];

            /* ── AI Profiles ── */
            const AI_PROFILES = {
                easy: {
                    name: 'Murasaki (Easy)',
                    maxHp: 80,
                    baseReactionMs: 6000,   // 6s average reaction
                    reactionVariance: 3000,
                    missChance: 0.40,       // 40% miss rate
                    baseDamage: 8,
                    comboPenalty: 0,
                    aggressiveness: 0.3,    // how often it tries combos
                    emoji: '🟢',
                    taunts: ['...thinking...', 'Hmm... let me see...', 'Easy for you? Not me!'],
                },
                normal: {
                    name: 'Aoi (Normal)',
                    maxHp: 110,
                    baseReactionMs: 3500,
                    reactionVariance: 1500,
                    missChance: 0.22,
                    baseDamage: 14,
                    comboPenalty: 5,
                    aggressiveness: 0.55,
                    emoji: '🔵',
                    taunts: ['Nice try!', 'I will catch up!', 'Stay focused...', 'Good answer!'],
                },
                hard: {
                    name: 'Ryuu (Hard)',
                    maxHp: 140,
                    baseReactionMs: 2000,
                    reactionVariance: 800,
                    missChance: 0.10,
                    baseDamage: 20,
                    comboPenalty: 8,
                    aggressiveness: 0.75,
                    emoji: '🟡',
                    taunts: ['Too slow!', 'My turn!', 'Combo time!', 'Is that all you have?'],
                },
                insanity: {
                    name: 'Tenshi (Insanity)',
                    maxHp: 180,
                    baseReactionMs: 900,
                    reactionVariance: 400,
                    missChance: 0.03,
                    baseDamage: 28,
                    comboPenalty: 12,
                    aggressiveness: 0.92,
                    emoji: '🔴',
                    taunts: ['已经太晚了。', 'Pathetic.', 'COMBO!', 'You cannot win!', '速い！'],
                }
            };

            /* ── Game State ── */
            const S = {
                words:           [],
                queue:           [],
                currentWord:     null,
                questionIdx:     0,
                totalQ:          20,
                difficulty:      'easy',
                alphabet:        'hiragana',
                playerName:      'Player',
                isHardMode:      false,
                gameActive:      false,
                playerHP:        100,
                aiHP:            100,
                maxPlayerHP:     100,
                maxAiHP:         100,
                playerScore:     0,
                aiScore:         0,
                playerCorrect:   0,
                playerWrong:     0,
                playerCombo:     0,
                playerMaxCombo:  0,
                playerMult:      1.0,
                totalDmgDealt:   0,
                timerInterval:   null,
                aiTimer:         null,
                timeLeft:        0,
                timePerQ:        10,
                aiProfile:       null,
                aiCombo:         0,
                hardBlanks:      [],
                gameOverReason:  ''
            };

            /* ── DOM Refs ── */
            const $ = id => document.getElementById(id);
            const setupPanel  = $('ba-setup');
            const arenaEl     = $('ba-arena');
            const resultEl    = $('ba-result');
            const countdownEl = $('ba-countdown');
            const startBtn    = $('ba-start-btn');
            const romajiInput = $('ba-romaji-input');

            /* ── AI Diff Cards ── */
            document.querySelectorAll('.ai-diff-card').forEach(card => {
                card.addEventListener('click', () => selectAIDiff(card.dataset.diff));
                card.addEventListener('keydown', e => { if (e.key==='Enter'||e.key===' ') { e.preventDefault(); selectAIDiff(card.dataset.diff); } });
            });

            function selectAIDiff(diff) {
                SFX.click();
                document.querySelectorAll('.ai-diff-card').forEach(c => { c.classList.remove('selected'); c.setAttribute('aria-pressed','false'); });
                const card = document.querySelector(`.ai-diff-card[data-diff="${diff}"]`);
                if (card) { card.classList.add('selected'); card.setAttribute('aria-pressed','true'); }
                S.difficulty = diff;
                const tags = { easy:'green', normal:'blue', hard:'gold', insanity:'red' };
                const lbl  = { easy:'Easy AI', normal:'Normal AI', hard:'Hard AI ★', insanity:'Insanity ★★' };
                $('ba-tag-diff').textContent = lbl[diff] || diff;
                $('ba-tag-diff').className   = `arena-tag ${tags[diff] || 'red'}`;
            }

            /* Alphabet select */
            $('ba-sel-alpha').addEventListener('change', function() {
                S.alphabet = this.value;
                $('ba-tag-alpha').textContent = this.options[this.selectedIndex].text.split(' ')[0];
                SFX.click();
            });

            /* ── Start Battle ── */
            startBtn.addEventListener('click', async () => {
                SFX.click();
                startBtn.disabled = true;
                startBtn.innerHTML = '<span>⏳</span> Loading words...';

                S.difficulty  = document.querySelector('.ai-diff-card.selected')?.dataset.diff ?? 'easy';
                S.alphabet    = $('ba-sel-alpha').value;
                S.playerName  = ($('ba-player-name').value || 'Player').trim().slice(0, 20);
                S.isHardMode  = S.difficulty === 'hard' || S.difficulty === 'insanity';

                try {
                    const r = await fetch(`/KanaBlitz/GetWords?difficulty=${encodeURIComponent(S.difficulty)}&alphabet=${encodeURIComponent(S.alphabet)}`);
                    if (!r.ok) throw new Error(`HTTP ${r.status}`);
                    const data = await r.json();
                    if (!Array.isArray(data) || data.length < 5) throw new Error(`Only ${data?.length ?? 0} words available`);

                    S.words = data;
                    startBtn.disabled = false;
                    startBtn.innerHTML = '<span>⚔️</span> Start Battle';
                    startCountdown();

                } catch (err) {
                    console.error('[KanaBattle]', err);
                    alert('❌ Failed to load words: ' + err.message + '\n\nCheck your database is seeded and the alphabet/difficulty combination has words.');
                    startBtn.disabled = false;
                    startBtn.innerHTML = '<span>⚔️</span> Start Battle';
                }
            });

            /* ── Countdown ── */
            function startCountdown() {
                countdownEl.style.cssText = 'display:flex;position:fixed;inset:0;background:rgba(255,255,255,0.92);backdrop-filter:blur(8px);z-index:9000;align-items:center;justify-content:center;flex-direction:column;gap:16px;';
                const counts = [3,2,1,'⚔️ FIGHT!'];
                let i = 0;

                const tick = () => {
                    SFX.countdown();
                    const isFight = counts[i] === '⚔️ FIGHT!';
                    countdownEl.innerHTML = `
                        <div style="font-size:${isFight?'3.5rem':'7.5rem'};font-weight:900;color:var(--ba-black);animation:baCountdownPop 0.7s ease both;line-height:1;">${counts[i]}</div>
                        <div style="font-size:0.95rem;font-weight:800;color:var(--ba-muted);letter-spacing:0.15em;text-transform:uppercase;">${isFight?'Type rōmaji to attack!':'Prepare yourself...'}</div>
                    `;
                    i++;
                    if (i < counts.length) setTimeout(tick, 900);
                    else {
                        SFX.go();
                        setTimeout(() => { countdownEl.style.display='none'; startBattle(); }, 700);
                    }
                };
                tick();
            }

            /* ── Start Battle ── */
            function startBattle() {
                resetBattle();

                S.aiProfile = AI_PROFILES[S.difficulty];
                S.maxPlayerHP = 100;
                S.maxAiHP     = S.aiProfile.maxHp;
                S.playerHP    = S.maxPlayerHP;
                S.aiHP        = S.maxAiHP;
                S.totalQ      = Math.min(S.difficulty === 'insanity' ? 15 : 20, S.words.length);

                S.queue = shuffle(S.words).slice(0, S.totalQ);

                setupPanel.style.display = 'none';
                arenaEl.style.display    = 'block';
                resultEl.style.display   = 'none';

                /* Set names */
                $('p1-name-display').textContent = S.playerName;
                $('p2-name-display').textContent = S.aiProfile.name;

                updateHPBars();
                S.gameActive = true;
                nextQuestion();
            }

            /* ── Reset ── */
            function resetBattle() {
                clearInterval(S.timerInterval);
                clearTimeout(S.aiTimer);
                S.questionIdx    = 0;
                S.playerScore    = 0;
                S.aiScore        = 0;
                S.playerCorrect  = 0;
                S.playerWrong    = 0;
                S.playerCombo    = 0;
                S.playerMaxCombo = 0;
                S.playerMult     = 1.0;
                S.aiCombo        = 0;
                S.totalDmgDealt  = 0;
                S.gameActive     = false;
                S.gameOverReason = '';
                updateScoreDisplay();
                updateComboDisplay();
            }

            /* ── Next question ── */
            function nextQuestion() {
                clearInterval(S.timerInterval);
                clearTimeout(S.aiTimer);
                $('ba-feedback').textContent = '';
                $('ba-feedback').className   = 'ba-feedback';
                $('ba-kana-card').classList.remove('correct','wrong');
                romajiInput.classList.remove('correct-state','wrong-state');

                if (!S.gameActive || S.questionIdx >= S.totalQ) {
                    if (S.gameActive) endBattle('rounds');
                    return;
                }

                const word = S.queue[S.questionIdx];
                S.currentWord = word;
                $('ba-round-badge').textContent = `Round ${S.questionIdx+1} of ${S.totalQ}`;

                /* Kana display */
                $('ba-kana-display').textContent = word.wordKana;
                $('ba-kana-meaning').textContent = word.meaningEnglish || '';
                $('ba-kana-cat').textContent     = word.categoryTag || '';

                /* Furigana */
                if ((S.difficulty === 'insanity' || S.difficulty === 'hard') && word.wordKana.includes('(')) {
                    const m = word.wordKana.match(/\(([^)]+)\)/);
                    if (m) { $('ba-kana-furigana').textContent = m[1]; $('ba-kana-furigana').style.display='block'; }
                } else { $('ba-kana-furigana').style.display='none'; }

                /* Re-animate kana card */
                const card = $('ba-kana-card');
                card.style.animation = 'none';
                requestAnimationFrame(() => { card.style.animation = ''; card.style.animation = 'baWordDrop 0.4s cubic-bezier(0.34,1.56,0.64,1) both'; });

                if (S.isHardMode) buildHardMode(word);
                else              buildNormalMode();

                startTimer();
                scheduleAIMove();
            }

            /* ── Normal mode ── */
            function buildNormalMode() {
                $('ba-normal-input').style.display = 'block';
                $('ba-kana-selector').style.display = 'none';
                romajiInput.value = '';
                romajiInput.disabled = false;
                setTimeout(() => romajiInput.focus(), 50);
            }

            /* ── Hard mode ── */
            function buildHardMode(word) {
                $('ba-normal-input').style.display = 'none';
                $('ba-kana-selector').style.display = 'block';
                $('ba-submit-kana-btn').disabled = true;

                const kana = extractKana(word.wordKana);
                if (!kana.length) { buildNormalMode(); return; }

                const numBlanks = S.difficulty === 'insanity' ? Math.min(3, Math.max(1, Math.floor(kana.length * 0.5))) : Math.min(2, Math.max(1, Math.floor(kana.length * 0.4)));
                const allIdx    = Array.from({length:kana.length},(_,i)=>i);
                const blankIdx  = shuffle(allIdx).slice(0,numBlanks).sort((a,b)=>a-b);

                S.hardBlanks = blankIdx.map(i => ({ idx:i, char:kana[i], filled:false, userAnswer:null }));

                renderPartial(kana, blankIdx);
                buildOptions(word, kana, blankIdx);
            }

            function extractKana(wordKana) {
                const furi = wordKana.match(/\(([^)]+)\)/);
                const src  = furi ? furi[1] : wordKana;
                return [...src].filter(c => { const cp=c.codePointAt(0); return (cp>=0x3040&&cp<=0x30FF)||(cp>=0xFF65&&cp<=0xFF9F); });
            }

            function renderPartial(kana, blankIdx) {
                const container = $('ba-kana-partial');
                container.innerHTML = '';
                kana.forEach((char,i) => {
                    if (blankIdx.includes(i)) {
                        const b = document.createElement('span');
                        b.className='ba-kana-blank'; b.dataset.blankIdx=String(blankIdx.indexOf(i)); b.textContent='＿';
                        container.appendChild(b);
                    } else {
                        const s = document.createElement('span');
                        s.className='ba-kana-char'; s.textContent=char; s.lang='ja';
                        container.appendChild(s);
                    }
                });
            }

            function buildOptions(word, kana, blankIdx) {
                const grid       = $('ba-option-grid');
                grid.innerHTML   = '';
                const correct    = blankIdx.map(i => kana[i]);
                const pool       = S.alphabet === 'katakana' ? K_POOL : H_POOL;
                const distractors= shuffle(pool.filter(c=>!correct.includes(c))).slice(0, 8-correct.length);
                shuffle([...correct,...distractors]).forEach(char => {
                    const btn = document.createElement('button');
                    btn.className='ba-option-btn'; btn.textContent=char; btn.lang='ja'; btn.dataset.char=char; btn.type='button';
                    btn.addEventListener('click', () => onOptionClick(char, btn));
                    grid.appendChild(btn);
                });
            }

            function onOptionClick(char, btn) {
                if (!S.gameActive) return;
                const next = S.hardBlanks.find(b=>!b.filled);
                if (!next) return;
                SFX.click();
                next.filled = true; next.userAnswer = char;
                const blankEl = $('ba-kana-partial').querySelector(`[data-blank-idx="${S.hardBlanks.indexOf(next)}"]`);
                if (blankEl) { blankEl.textContent=char; blankEl.classList.add('filled'); }
                btn.classList.add('used'); btn.disabled=true;
                if (S.hardBlanks.every(b=>b.filled)) $('ba-submit-kana-btn').disabled=false;
            }

            $('ba-submit-kana-btn').addEventListener('click', () => {
                const ok = S.hardBlanks.every(b=>b.userAnswer===b.char);
                clearInterval(S.timerInterval); clearTimeout(S.aiTimer);
                if (ok) playerCorrect(); else playerWrong();
            });

            /* ── Input ── */
            romajiInput.addEventListener('keydown', e => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    if (!S.gameActive) return;
                    const val = romajiInput.value.trim().toLowerCase();
                    if (!val) return;
                    clearInterval(S.timerInterval); clearTimeout(S.aiTimer);
                    if (val === (S.currentWord?.wordRomaji??'').toLowerCase()) playerCorrect();
                    else playerWrong();
                }
            });

            /* ── Player correct ── */
            function playerCorrect() {
                SFX.correct();
                S.playerCorrect++;
                S.playerCombo++;
                S.playerMaxCombo = Math.max(S.playerMaxCombo, S.playerCombo);
                S.playerMult     = Math.min(3.0, 1 + (S.playerCombo-1)*0.25);

                const base  = S.isHardMode ? 120 : 80;
                const speed = Math.round(S.timeLeft * 4);
                const earned= Math.round((base + speed) * S.playerMult);
                S.playerScore  += earned;
                S.totalDmgDealt+= earned;

                /* Deal damage to AI */
                const dmg = calcPlayerDamage();
                dealDamageToAI(dmg);

                $('ba-kana-card').classList.add('correct');
                romajiInput.classList.add('correct-state');
                showFeedback('⚔️ Hit! +' + dmg + ' dmg', 'correct');
                floatDmg(dmg, true);
                if (S.playerCombo >= 3) SFX.combo();
                updateScoreDisplay();
                updateComboDisplay();

                if (S.aiHP <= 0) { S.gameActive=false; endBattle('playerWin'); return; }

                setTimeout(() => {
                    $('ba-kana-card').classList.remove('correct');
                    romajiInput.classList.remove('correct-state');
                    S.questionIdx++;
                    nextQuestion();
                }, 550);
            }

            /* ── Player wrong ── */
            function playerWrong() {
                SFX.wrong();
                S.playerWrong++;
                S.playerCombo = 0;
                S.playerMult  = 1.0;

                /* AI gets to deal damage on player error */
                const aiDmg = Math.round(S.aiProfile.baseDamage * 0.6);
                dealDamageToPlayer(aiDmg);
                showAILog(`🤖 ${S.aiProfile.name}: "Your mistake! +${aiDmg} dmg!"`);

                $('ba-kana-card').classList.add('wrong');
                romajiInput.classList.add('wrong-state');
                showFeedback(`❌ Wrong — Correct: ${S.currentWord.wordRomaji}`, 'wrong');
                floatDmg(aiDmg, false);
                SFX.hit();
                updateScoreDisplay();
                updateComboDisplay();

                if (S.playerHP <= 0) { S.gameActive=false; endBattle('aiWin'); return; }

                setTimeout(() => {
                    $('ba-kana-card').classList.remove('wrong');
                    romajiInput.classList.remove('wrong-state');
                    S.questionIdx++;
                    nextQuestion();
                }, 900);
            }

            /* ── Timer ── */
            function startTimer() {
                const timePerQ = { easy:12, normal:9, hard:13, insanity:10 }[S.difficulty] ?? 10;
                S.timeLeft     = timePerQ;
                const bar      = $('ba-timer-bar');
                bar.style.width    = '100%';
                bar.className      = 'timer-bar';
                const totalMs      = timePerQ * 1000;
                const startTs      = Date.now();

                S.timerInterval = setInterval(() => {
                    const elapsed = Date.now() - startTs;
                    const pct     = Math.max(0, 1 - elapsed / totalMs);
                    S.timeLeft    = Math.max(0, timePerQ - elapsed / 1000);
                    bar.style.width = (pct*100).toFixed(1)+'%';
                    bar.className   = pct < 0.25 ? 'timer-bar danger' : pct < 0.5 ? 'timer-bar warn' : 'timer-bar';

                    if (elapsed >= totalMs) {
                        clearInterval(S.timerInterval);
                        onTimeout();
                    }
                }, 80);
            }

            function onTimeout() {
                if (!S.gameActive) return;
                clearTimeout(S.aiTimer);
                S.playerWrong++;
                S.playerCombo = 0;
                S.playerMult  = 1.0;
                const aiDmg = Math.round(S.aiProfile.baseDamage * 0.5);
                dealDamageToPlayer(aiDmg);
                showFeedback(`⏰ Too slow! Answer: ${S.currentWord?.wordRomaji??''}`, 'wrong');
                SFX.wrong();
                showAILog(`🤖 ${S.aiProfile.name}: "Too slow!"`);
                updateScoreDisplay();
                updateComboDisplay();
                if (S.playerHP <= 0) { S.gameActive=false; endBattle('aiWin'); return; }
                setTimeout(() => { S.questionIdx++; nextQuestion(); }, 900);
            }

            /* ── AI Move (scheduled independently) ── */
            function scheduleAIMove() {
                clearTimeout(S.aiTimer);
                if (!S.gameActive) return;

                const profile  = S.aiProfile;
                const variance = (Math.random() * 2 - 1) * profile.reactionVariance;
                const delay    = Math.max(500, profile.baseReactionMs + variance);

                S.aiTimer = setTimeout(() => {
                    if (!S.gameActive) return;
                    aiTakesAction();
                }, delay);
            }

            function aiTakesAction() {
                const profile = S.aiProfile;
                const misses  = Math.random() < profile.missChance;

                if (!misses) {
                    /* AI scores on this word */
                    S.aiCombo++;
                    S.aiScore += profile.baseDamage + (S.aiCombo > 3 ? profile.comboPenalty : 0);
                    const dmg = calcAIDamage();
                    dealDamageToPlayer(dmg);

                    const taunt = profile.taunts[Math.floor(Math.random() * profile.taunts.length)];
                    showAILog(`🤖 ${profile.name} answered correctly! ${taunt} (-${dmg}hp)`);
                    $('ba-tag-diff').title = taunt;

                    SFX.hit();
                    floatDmg(dmg, false);
                    updateScoreDisplay();

                    if (S.playerHP <= 0 && S.gameActive) {
                        S.gameActive = false;
                        clearInterval(S.timerInterval);
                        endBattle('aiWin');
                    }
                } else {
                    /* AI misses */
                    S.aiCombo = 0;
                    showAILog(`🤖 ${profile.name} struggled with this one!`);
                }
            }

            /* ── Damage calc ── */
            function calcPlayerDamage() {
                const base     = { easy:18, normal:22, hard:26, insanity:30 }[S.difficulty] ?? 20;
                const comboBns = S.playerCombo >= 3 ? Math.floor(S.playerCombo * 4) : 0;
                const speedBns = Math.round(S.timeLeft * 2);
                return Math.max(8, Math.round((base + comboBns + speedBns) * S.playerMult));
            }

            function calcAIDamage() {
                const base   = S.aiProfile.baseDamage;
                const combob = S.aiCombo > 2 ? Math.floor(S.aiCombo * 3) : 0;
                return Math.max(5, base + combob);
            }

            /* ── HP manipulation ── */
            function dealDamageToAI(dmg) {
                S.aiHP = Math.max(0, S.aiHP - dmg);
                updateHPBars();
                $('p2-panel').classList.add('under-fire');
                setTimeout(() => $('p2-panel').classList.remove('under-fire'), 600);
            }

            function dealDamageToPlayer(dmg) {
                S.playerHP = Math.max(0, S.playerHP - dmg);
                updateHPBars();
                $('p1-panel').classList.add('under-fire');
                setTimeout(() => $('p1-panel').classList.remove('under-fire'), 600);
            }

            function updateHPBars() {
                const p1pct = (S.playerHP / S.maxPlayerHP) * 100;
                const p2pct = (S.aiHP / S.maxAiHP) * 100;

                const p1bar = $('p1-hp-bar');
                const p2bar = $('p2-hp-bar');

                p1bar.style.width = p1pct.toFixed(1) + '%';
                p2bar.style.width = p2pct.toFixed(1) + '%';

                p1bar.className = 'hp-bar p1-bar' + (p1pct < 25 ? ' low' : '');
                p2bar.className = 'hp-bar p2-bar' + (p2pct < 25 ? ' low' : '');

                $('p1-hp-val').textContent = S.playerHP;
                $('p2-hp-val').textContent = S.aiHP;

                $('p1-hp-bar-wrap').setAttribute('aria-valuenow', Math.round(p1pct));
                $('p2-hp-bar-wrap').setAttribute('aria-valuenow', Math.round(p2pct));

                $('p1-score').textContent = S.playerScore;
                $('p2-score').textContent = S.aiScore;
            }

            /* ── Score display ── */
            function updateScoreDisplay() {
                $('ba-score').textContent   = S.playerScore.toLocaleString();
                $('ba-correct').textContent = S.playerCorrect;
                $('ba-wrong').textContent   = S.playerWrong;
                const total = S.playerCorrect + S.playerWrong;
                $('ba-acc').textContent = total > 0 ? Math.round((S.playerCorrect/total)*100)+'%' : '—';
                updateHPBars();
            }

            function updateComboDisplay() {
                $('ba-combo-badge').textContent = `🔥 ${S.playerCombo} Combo`;
                $('ba-mult-badge').textContent  = `×${S.playerMult.toFixed(1)}`;
                $('ba-combo-badge').className   = S.playerCombo >= 3 ? 'combo-badge active' : 'combo-badge inactive';
                $('p1-combo').textContent       = S.playerCombo;
            }

            function showFeedback(text, type) {
                const el = $('ba-feedback');
                el.textContent = text;
                el.className   = `ba-feedback ${type}`;
            }

            function showAILog(msg) {
                $('ai-log-msg').textContent = msg;
                $('ai-log-msg').style.animation = 'none';
                requestAnimationFrame(() => { $('ai-log-msg').style.animation = 'baFadeUp 0.3s ease'; });
            }

            function floatDmg(val, isPlayer) {
                const el = document.createElement('div');
                el.className = `dmg-float ${isPlayer ? 'p1' : 'ai'}`;
                el.textContent = `${isPlayer ? '-':''}${val}hp`;
                el.style.cssText = `left:${isPlayer?60:25}%;top:${25+Math.random()*15}%;`;
                document.body.appendChild(el);
                setTimeout(() => el.remove(), 1000);
            }

            /* ── End Battle ── */
            function endBattle(reason) {
                clearInterval(S.timerInterval);
                clearTimeout(S.aiTimer);
                S.gameActive = false;

                const playerWon = reason === 'playerWin' || (reason === 'rounds' && S.playerHP > S.aiHP);
                const total     = S.playerCorrect + S.playerWrong;
                const acc       = total > 0 ? Math.round((S.playerCorrect/total)*100) : 0;
                const xp        = Math.round(S.playerScore * 0.6 + S.playerCorrect * 8 + (playerWon ? 100 : 20));

                if (playerWon) { SFX.victory(); } else { SFX.defeat(); }

                let emoji = '⚔️', title = 'Battle Over!', sub = '';
                if (playerWon) {
                    if (S.difficulty === 'insanity') { emoji='🌟'; title='LEGENDARY VICTORY!'; sub=`You defeated ${S.aiProfile.name} on Insanity! Incredible!`; }
                    else if (S.difficulty === 'hard')  { emoji='🏆'; title='VICTORY!'; sub=`${S.playerName} defeated ${S.aiProfile.name} on Hard!`; }
                    else { emoji='🎉'; title='You Win!'; sub=`${S.playerName} defeated ${S.aiProfile.name}!`; }
                } else {
                    emoji='💀'; title='Defeated!'; sub=`${S.aiProfile.name} was too powerful. Train harder!`;
                }

                $('ba-result-emoji').textContent = emoji;
                $('ba-result-title').textContent = title;
                $('ba-result-sub').textContent   = sub;
                $('ba-xp-pill').textContent      = `⭐ +${xp} XP`;
                $('br-score').textContent   = S.playerScore.toLocaleString();
                $('br-correct').textContent = S.playerCorrect;
                $('br-acc').textContent     = acc + '%';
                $('br-combo').textContent   = S.playerMaxCombo;
                $('br-dmg').textContent     = S.totalDmgDealt;
                $('br-xp').textContent      = xp;

                resultEl.style.cssText = 'display:flex;position:fixed;inset:0;background:rgba(255,255,255,0.94);backdrop-filter:blur(10px);z-index:8000;align-items:center;justify-content:center;padding:20px;';

                submitBattleScore(xp, acc, total);
            }

            async function submitBattleScore(xp, acc, total) {
                try {
                    await fetch('/KanaBlitz/SubmitScore', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
                        body: JSON.stringify({
                            score: S.playerScore, difficulty: S.difficulty, alphabet: S.alphabet,
                            correct: S.playerCorrect, total: total, maxCombo: S.playerMaxCombo, xpEarned: xp
                        })
                    });
                } catch (e) {}
            }

            function getToken() {
                const el = document.querySelector('input[name="__RequestVerificationToken"]');
                return el ? el.value : '';
            }

            /* ── Util ── */
            function shuffle(arr) {
                const a = [...arr];
                for (let i=a.length-1;i>0;i--) { const j=Math.floor(Math.random()*(i+1)); [a[i],a[j]]=[a[j],a[i]]; }
                return a;
            }

            /* ── Result buttons ── */
            $('ba-rematch-btn').addEventListener('click', () => {
                SFX.click();
                resultEl.style.display = 'none';
                startCountdown();
            });

            $('ba-change-btn').addEventListener('click', () => {
                SFX.click();
                resultEl.style.display = 'none';
                arenaEl.style.display  = 'none';
                setupPanel.style.display = 'block';
            });

            /* ── Pre-populate from Razor ── */
            (function init() {
                selectAIDiff(INIT_DIFFICULTY);
                const alphaSelect = $('ba-sel-alpha');
                if (alphaSelect) {
                    for (let opt of alphaSelect.options) { if (opt.value === INIT_SCRIPT) { opt.selected=true; break; } }
                    S.alphabet = INIT_SCRIPT;
                    $('ba-tag-alpha').textContent = alphaSelect.options[alphaSelect.selectedIndex].text.split(' ')[0];
                }
                if (INIT_PLAYERNAME) { $('ba-player-name').value = INIT_PLAYERNAME; }
            })();

        })();
    </script>
}
