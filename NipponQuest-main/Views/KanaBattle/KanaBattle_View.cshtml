@*
    ╔══════════════════════════════════════════════════════════════╗
    ║  KanaBattle_View.cshtml  —  Battle Arena (vs AI)            ║
    ║  Controller : KanaBattleController → Battle(diff, script)   ║
    ║  Route      : /KanaBattle/Battle?difficulty=&script=        ║
    ║  Model      : KanaBattleModel  { Difficulty, Script }       ║
    ║  Words      : KanaBlitzController → GetWords(diff, alpha)   ║
    ╚══════════════════════════════════════════════════════════════╝
*@
@model NipponQuest.Models.KanaBattleModel
@{
    ViewData["Title"] = "KanaBattle Arena";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Read model values — these match DbInitializer difficulty & alphabet labels exactly.
    // KanaBattleController.Battle() passes Model.Difficulty and Model.Script from query string.
    var diff = Model?.Difficulty ?? "normal";   // "easy" | "normal" | "hard" | "insanity"
    var script = Model?.Script ?? "hiragana"; // "hiragana" | "katakana" | "dakuten" | "mixed"
}

<style>
    /* ── palette ── */
    :root {
        --bg: #0d0d1a;
        --panel: #12122a;
        --border: #2a2a55;
        --accent: #7c3aed;
        --accent2: #a855f7;
        --gold: #f59e0b;
        --green: #10b981;
        --red: #ef4444;
        --text: #e2e8f0;
        --muted: #94a3b8;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Segoe UI', sans-serif;
        overflow-x: hidden;
    }

    /* ── arena wrapper ── */
    .arena-wrap {
        max-width: 900px;
        margin: 0 auto;
        padding: 16px 12px;
    }

    /* ── breadcrumb / back ── */
    .back-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
    }

        .back-bar a {
            color: var(--muted);
            font-size: .82rem;
            text-decoration: none;
        }

            .back-bar a:hover {
                color: var(--text);
            }

        .back-bar .crumb {
            color: var(--accent2);
            font-weight: 700;
            font-size: .82rem;
        }

    /* ── mode badge ── */
    .mode-badge {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 6px 16px;
        font-size: .78rem;
        display: inline-flex;
        gap: 8px;
        align-items: center;
        margin-bottom: 16px;
    }

        .mode-badge .d {
            color: var(--gold);
            font-weight: 700;
        }

        .mode-badge .s {
            color: var(--accent2);
            font-weight: 700;
        }

    /* ── HP bars ── */
    .hp-row {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 12px;
        align-items: center;
        margin-bottom: 12px;
    }

    .hp-block {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 12px 16px;
    }

        .hp-block.player {
            border-color: #2563eb;
        }

        .hp-block.enemy {
            border-color: #dc2626;
            text-align: right;
        }

    .hp-name {
        font-size: .78rem;
        color: var(--muted);
        margin-bottom: 4px;
    }

    .hp-val {
        font-size: 1rem;
        font-weight: 700;
    }

    .hp-bar-outer {
        height: 8px;
        border-radius: 4px;
        background: #1a1a35;
        margin-top: 6px;
        overflow: hidden;
    }

    .hp-bar-inner {
        height: 100%;
        border-radius: 4px;
        transition: width .4s ease;
    }

    .hp-block.player .hp-bar-inner {
        background: linear-gradient(90deg,#2563eb,#60a5fa);
    }

    .hp-block.enemy .hp-bar-inner {
        background: linear-gradient(90deg,#dc2626,#f87171);
    }

    .timer-block {
        text-align: center;
    }

    .timer-num {
        font-size: 2rem;
        font-weight: 900;
        color: var(--gold);
        font-variant-numeric: tabular-nums;
    }

    .timer-diff {
        font-size: .7rem;
        color: var(--muted);
    }

    /* ── combat stage ── */
    .combat-stage {
        position: relative;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 16px;
        height: 320px;
        overflow: hidden;
        margin-bottom: 12px;
    }

    /* falling kana cards */
    .kana-card {
        position: absolute;
        background: #1a1a35;
        border: 2px solid var(--border);
        border-radius: 10px;
        padding: 10px 14px;
        text-align: center;
        min-width: 64px;
        cursor: default;
        transition: border-color .2s;
    }

        .kana-card.skill {
            border-color: var(--gold);
            box-shadow: 0 0 12px rgba(245,158,11,.4);
        }

        .kana-card.target {
            border-color: var(--accent2);
            box-shadow: 0 0 12px rgba(168,85,247,.5);
        }

        .kana-card .k-char {
            font-size: 1.8rem;
            line-height: 1;
        }

        .kana-card .k-hint {
            font-size: .65rem;
            color: var(--muted);
        }

    /* player / enemy sprites */
    .sprite-row {
        position: absolute;
        bottom: 12px;
        left: 0;
        right: 0;
        display: flex;
        justify-content: space-between;
        padding: 0 24px;
        pointer-events: none;
    }

    .sprite {
        text-align: center;
    }

        .sprite .sp-icon {
            font-size: 2.8rem;
        }

        .sprite .sp-name {
            font-size: .7rem;
            color: var(--muted);
            margin-top: 2px;
        }

    /* damage float */
    .dmg-float {
        position: absolute;
        font-size: 1.2rem;
        font-weight: 900;
        pointer-events: none;
        animation: floatUp .9s ease forwards;
    }

        .dmg-float.player-dmg {
            color: #60a5fa;
        }

        .dmg-float.enemy-dmg {
            color: #f87171;
        }

    @@keyframes floatUp {
        0% {
            opacity: 1;
            transform: translateY(0)
        }

        100% {
            opacity: 0;
            transform: translateY(-60px)
        }
    }

    /* combo/streak flash */
    .streak-flash {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%,-50%);
        font-size: 2.5rem;
        font-weight: 900;
        pointer-events: none;
        animation: flashOut .7s ease forwards;
    }

    @@keyframes flashOut {
        0% {
            opacity: 1;
            transform: translate(-50%,-50%) scale(1.2)
        }

        100% {
            opacity: 0;
            transform: translate(-50%,-50%) scale(0.7)
        }
    }

    /* ── input row ── */
    .input-row {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 16px;
        margin-bottom: 12px;
    }

    .target-label {
        font-size: .72rem;
        color: var(--muted);
        margin-bottom: 8px;
    }

    .target-kana {
        font-size: 2.2rem;
        font-weight: 700;
        color: var(--accent2);
    }

    .target-hint {
        font-size: .78rem;
        color: var(--muted);
        margin-top: 2px;
        min-height: 1.2em;
    }

    .target-cat {
        font-size: .7rem;
        color: #64748b;
    }

    .input-line {
        display: flex;
        gap: 10px;
        margin-top: 12px;
    }

    #romaji-input {
        flex: 1;
        background: #1a1a35;
        border: 2px solid var(--border);
        border-radius: 10px;
        padding: 12px 16px;
        color: var(--text);
        font-size: 1.1rem;
        outline: none;
        transition: border-color .2s;
    }

        #romaji-input:focus {
            border-color: var(--accent2);
        }

        #romaji-input.correct {
            border-color: var(--green);
        }

        #romaji-input.wrong {
            border-color: var(--red);
        }

    #btn-attack {
        background: linear-gradient(135deg,#7c3aed,#a855f7);
        border: none;
        border-radius: 10px;
        padding: 12px 22px;
        color: #fff;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity .2s;
    }

        #btn-attack:hover {
            opacity: .88;
        }

    /* ── stats bar ── */
    .stats-bar {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        font-size: .8rem;
        color: var(--muted);
        margin-bottom: 16px;
    }

        .stats-bar span {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 5px 12px;
        }

        .stats-bar .hi {
            color: var(--gold);
            font-weight: 700;
        }

    /* ── active skills ── */
    .skills-row {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 16px;
    }

    .skill-badge {
        background: #1a1a35;
        border: 1px solid var(--gold);
        border-radius: 8px;
        padding: 5px 12px;
        font-size: .78rem;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    /* ── result overlay ── */
    #result-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.8);
        z-index: 999;
        align-items: center;
        justify-content: center;
    }

        #result-overlay.show {
            display: flex;
        }

    .result-card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 40px 32px;
        text-align: center;
        max-width: 520px;
        width: 92%;
    }

    .result-title {
        font-size: 2.2rem;
        font-weight: 900;
        margin-bottom: 8px;
    }

    .result-sub {
        color: var(--muted);
        font-size: .9rem;
        margin-bottom: 20px;
    }

    .result-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
        margin-bottom: 24px;
    }

    .result-stat {
        background: #1a1a35;
        border-radius: 10px;
        padding: 14px;
    }

        .result-stat .val {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--gold);
        }

        .result-stat .lbl {
            font-size: .7rem;
            color: var(--muted);
            margin-top: 3px;
        }

    .result-btns {
        display: flex;
        gap: 10px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-r {
        padding: 12px 22px;
        border-radius: 10px;
        border: none;
        font-size: .9rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity .2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
    }

        .btn-r.primary {
            background: linear-gradient(135deg,#ef4444,#f59e0b);
            color: #fff;
        }

        .btn-r.secondary {
            background: #1a1a35;
            color: var(--text);
            border: 1px solid var(--border);
        }

        .btn-r:hover {
            opacity: .85;
        }

    @@media (max-width: 500px) {
        .hp-row {
            grid-template-columns: 1fr;
        }

        .result-grid {
            grid-template-columns: 1fr 1fr;
        }

        .combat-stage {
            height: 240px;
        }
    }
</style>

<!-- Inject C# model values as JS constants so the game JS can use them -->
<script>
    // ── Passed from KanaBattleController.Battle() ──
    // These match DbInitializer difficulty & alphabet values exactly.
    const BATTLE_DIFFICULTY = "@diff";   // "easy" | "normal" | "hard" | "insanity"
    const BATTLE_SCRIPT     = "@script"; // "hiragana" | "katakana" | "dakuten" | "mixed"
</script>

<div class="arena-wrap">

    <!-- Back / breadcrumb -->
    <div class="back-bar">
        <a href="/KanaBattle/MainView">← Back to Lobby</a>
        <span style="color:var(--border)">|</span>
        <a href="/KanaBlitz/Index">🎯 Solo Mode</a>
        <span class="crumb">⚔️ Battle Arena</span>
    </div>

    <!-- Mode badge -->
    <div>
        <span class="mode-badge">
            ⚔️ KanaBattle &nbsp;·&nbsp;
            <span class="d" id="badge-diff">@diff</span>
            &nbsp;·&nbsp;
            <span class="s" id="badge-script">@script</span>
        </span>
    </div>

    <!-- HP Bars + Timer -->
    <div class="hp-row">
        <div class="hp-block player">
            <div class="hp-name">🧙 You</div>
            <div class="hp-val"><span id="hp-player">1000</span> / <span id="hp-player-max">1000</span></div>
            <div class="hp-bar-outer"><div class="hp-bar-inner" id="hp-bar-player" style="width:100%"></div></div>
        </div>
        <div class="timer-block">
            <div class="timer-num" id="timer">3:00</div>
            <div class="timer-diff" id="timer-diff">@diff · @script</div>
        </div>
        <div class="hp-block enemy">
            <div class="hp-name">👹 Opponent</div>
            <div class="hp-val"><span id="hp-enemy">1000</span> / <span id="hp-enemy-max">1000</span></div>
            <div class="hp-bar-outer"><div class="hp-bar-inner" id="hp-bar-enemy" style="width:100%"></div></div>
        </div>
    </div>

    <!-- Combat Stage -->
    <div class="combat-stage" id="combat-stage">
        <!-- Kana cards are spawned by JS here -->
        <div class="sprite-row">
            <div class="sprite">
                <div class="sp-icon">🧙</div>
                <div class="sp-name">You</div>
            </div>
            <div class="sprite" style="text-align:right">
                <div class="sp-icon">👹</div>
                <div class="sp-name">Enemy</div>
            </div>
        </div>
    </div>

    <!-- Active skills display -->
    <div class="skills-row" id="skills-row">
        <!-- Active skills shown here dynamically -->
    </div>

    <!-- Input Row -->
    <div class="input-row">
        <div class="target-label">Current Target:</div>
        <div class="target-kana" id="target-kana">—</div>
        <div class="target-hint" id="target-hint">&nbsp;</div>
        <div class="target-cat" id="target-cat">&nbsp;</div>
        <div class="input-line">
            <input type="text" id="romaji-input" placeholder='Type romaji and press Enter…'
                   autocomplete="off" autocorrect="off" spellcheck="false" />
            <button id="btn-attack" onclick="submitAnswer()">⚔️ Attack</button>
        </div>
    </div>

    <!-- Stats bar -->
    <div class="stats-bar">
        <span>✅ <span class="hi" id="stat-correct">0</span> correct</span>
        <span>💀 <span class="hi" id="stat-wrong">0</span> wrong</span>
        <span>🔥 Combo <span class="hi" id="stat-combo">0</span>x</span>
        <span>⚔️ Dmg dealt <span class="hi" id="stat-dmg">0</span></span>
        <span>🛡️ Dmg taken <span class="hi" id="stat-taken">0</span></span>
    </div>

</div><!-- /arena-wrap -->
<!-- Result Overlay -->
<div id="result-overlay">
    <div class="result-card">
        <div class="result-title" id="res-title">⚔️ Battle Over!</div>
        <div class="result-sub" id="res-sub">Well fought!</div>
        <div class="result-grid">
            <div class="result-stat"><div class="val" id="res-correct">0</div><div class="lbl">Correct</div></div>
            <div class="result-stat"><div class="val" id="res-dmg">0</div><div class="lbl">Dmg Dealt</div></div>
            <div class="result-stat"><div class="val" id="res-combo">0</div><div class="lbl">Max Combo</div></div>
            <div class="result-stat"><div class="val" id="res-acc">0%</div><div class="lbl">Accuracy</div></div>
            <div class="result-stat"><div class="val" id="res-elo">+0</div><div class="lbl">ELO Change</div></div>
            <div class="result-stat"><div class="val" id="res-time">0s</div><div class="lbl">Time Left</div></div>
        </div>
        <div class="result-btns">
            <button class="btn-r primary" onclick="replayBattle()">⚔️ Rematch</button>
            <a class="btn-r secondary" href="/KanaBattle/MainView">🔙 Lobby</a>
            <a class="btn-r secondary" href="/KanaBlitz/Index">🎯 Solo</a>
        </div>
    </div>
</div>

<script>
    // ══════════════════════════════════════════════════════════════
    //  KanaBattle Arena
    //  Words fetched from: GET /KanaBlitz/GetWords?difficulty=&alphabet=
    //  BATTLE_DIFFICULTY & BATTLE_SCRIPT injected by Razor from Model
    // ══════════════════════════════════════════════════════════════

    // ── config from controller model (injected above) ──
    const diff_cfg = (BATTLE_DIFFICULTY || 'normal').toLowerCase();
    const script_cfg = (BATTLE_SCRIPT || 'hiragana').toLowerCase();

    // ── difficulty configs ──
    // duration, AI attack interval (ms), base AI damage, HP, ELO
    const DIFF_CFG = {
        easy:     { duration: 180, aiInterval: 4000, aiDmg: 40,  hp: 1000, eloWin: 12, eloLoss: 8,  fallSpeed: 0.25, label: '🌿 Easy'     },
        normal:   { duration: 135, aiInterval: 2700, aiDmg: 65,  hp: 1000, eloWin: 20, eloLoss: 15, fallSpeed: 0.45, label: '⚡ Normal'   },
        hard:     { duration: 105, aiInterval: 1700, aiDmg: 90,  hp: 1000, eloWin: 32, eloLoss: 24, fallSpeed: 0.70, label: '🔥 Hard'     },
        insanity: { duration:  90, aiInterval:  900, aiDmg: 130, hp: 1000, eloWin: 50, eloLoss: 38, fallSpeed: 1.10, label: '💀 Insanity' },
    };
    const cfg = DIFF_CFG[diff_cfg] ?? DIFF_CFG.normal;

    // ── game state ──
    let wordPool   = [];
    let fallingCards = [];   // { id, word, el, y, x, isSkill, active }
    let cardIdSeq  = 0;
    let playerHP   = cfg.hp;
    let enemyHP    = cfg.hp;
    let streak     = 0;
    let maxStreak  = 0;
    let correctCnt = 0;
    let wrongCnt   = 0;
    let dmgDealt   = 0;
    let dmgTaken   = 0;
    let timerSecs  = cfg.duration;
    let timerHandle   = null;
    let aiHandle      = null;
    let animHandle    = null;
    let spawnHandle   = null;
    let gameActive    = false;
    let activeSkills  = {};  // { shield, speed, crit }

    const STAGE = document.getElementById('combat-stage');
    const STAGE_H = () => STAGE.offsetHeight;
    const STAGE_W = () => STAGE.offsetWidth;

    // ══════════════════════════════════════════════════════════════
    //  INIT — fetch words from KanaBlitzController.GetWords
    // ══════════════════════════════════════════════════════════════
    async function initBattle() {
        try {
            // Fetch from KanaBlitzController  →  /KanaBlitz/GetWords
            // difficulty and alphabet values match DbInitializer exactly
            const url = `/KanaBlitz/GetWords?difficulty=${encodeURIComponent(diff_cfg)}&alphabet=${encodeURIComponent(script_cfg)}`;
            const res = await fetch(url);
            if (!res.ok) throw new Error('HTTP ' + res.status);
            wordPool = await res.json();
        } catch (e) {
            console.error('GetWords fetch failed:', e);
            wordPool = [];
        }

        if (wordPool.length < 4) {
            alert('Not enough words for this difficulty/script combination. Redirecting to lobby…');
            window.location.href = '/KanaBattle/MainView';
            return;
        }

        wordPool = shuffle(wordPool);
        startBattle();
    }

    // ══════════════════════════════════════════════════════════════
    //  BATTLE START
    // ══════════════════════════════════════════════════════════════
    function startBattle() {
        gameActive = true;
        playerHP   = cfg.hp;
        enemyHP    = cfg.hp;
        streak     = 0; maxStreak = 0;
        correctCnt = 0; wrongCnt  = 0;
        dmgDealt   = 0; dmgTaken  = 0;
        activeSkills = {};
        timerSecs  = cfg.duration;
        fallingCards = [];
        STAGE.querySelectorAll('.kana-card').forEach(e => e.remove());

        updateHPBars();
        updateTimerDisplay();
        updateStats();

        // Badge capitalisation
        document.getElementById('badge-diff').textContent   = capitalize(diff_cfg);
        document.getElementById('badge-script').textContent = capitalize(script_cfg);

        startTimer();
        startAI();
        startSpawner();
        startAnimation();

        document.getElementById('romaji-input').focus();
    }

    // ══════════════════════════════════════════════════════════════
    //  TIMER
    // ══════════════════════════════════════════════════════════════
    function startTimer() {
        clearInterval(timerHandle);
        timerHandle = setInterval(() => {
            if (!gameActive) { clearInterval(timerHandle); return; }
            timerSecs--;
            updateTimerDisplay();
            if (timerSecs <= 0) endBattle('timeout');
        }, 1000);
    }
    function updateTimerDisplay() {
        const m = Math.floor(timerSecs / 60);
        const s = timerSecs % 60;
        document.getElementById('timer').textContent =
            String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
        document.getElementById('timer').style.color =
            timerSecs <= 10 ? '#ef4444' : '#f59e0b';
    }

    // ══════════════════════════════════════════════════════════════
    //  AI ATTACKER
    // ══════════════════════════════════════════════════════════════
    function startAI() {
        clearInterval(aiHandle);
        aiHandle = setInterval(() => {
            if (!gameActive) { clearInterval(aiHandle); return; }
            // Insanity can double-strike
            const attacks = (diff_cfg === 'insanity' && Math.random() < 0.25) ? 2 : 1;
            for (let a = 0; a < attacks; a++) {
                if (activeSkills.shield) {
                    delete activeSkills.shield;
                    updateSkillsUI();
                    showDamageFloat(STAGE_W() * 0.15, STAGE_H() * 0.5, '🛡️ BLOCKED!', false);
                } else {
                    const dmg = Math.round(cfg.aiDmg * (0.85 + Math.random() * 0.3));
                    applyDamage('player', dmg);
                }
            }
            // Hard / Insanity AI sword buff
            if ((diff_cfg === 'hard' || diff_cfg === 'insanity') && Math.random() < 0.15) {
                showDamageFloat(STAGE_W() * 0.5, STAGE_H() * 0.3, '🗡️ AI BUFF!', false);
            }
        }, cfg.aiInterval);
    }

    // ══════════════════════════════════════════════════════════════
    //  KANA CARD SPAWNER
    // ══════════════════════════════════════════════════════════════
    function spawnCard() {
        if (!gameActive || wordPool.length === 0) return;

        const word = wordPool[Math.floor(Math.random() * wordPool.length)];
        const isSkill = Math.random() < 0.12; // 12% chance of skill card
        const el   = document.createElement('div');
        el.className = 'kana-card' + (isSkill ? ' skill' : '');

        el.innerHTML = `<div class="k-char">${escapeHtml(word.wordKana ?? '?')}</div>
                        <div class="k-hint">${isSkill ? '✨ SKILL' : ''}</div>`;

        const maxX = Math.max(20, STAGE_W() - 80);
        const x    = 20 + Math.random() * maxX;
        el.style.left = x + 'px';
        el.style.top  = '-80px';
        STAGE.appendChild(el);

        const card = { id: cardIdSeq++, word, el, y: -80, x, isSkill, active: true };
        fallingCards.push(card);

        // Mark the lowest active card as target
        refreshTarget();
    }

    function startSpawner() {
        // Spawn interval based on difficulty (every N seconds)
        const interval = { easy: 2200, normal: 1500, hard: 900, insanity: 550 }[diff_cfg] ?? 1500;
        clearInterval(spawnHandle);
        spawnCard(); // spawn one immediately
        spawnHandle = setInterval(spawnCard, interval);
    }

    // ══════════════════════════════════════════════════════════════
    //  ANIMATION LOOP — move cards down
    // ══════════════════════════════════════════════════════════════
    function startAnimation() {
        cancelAnimationFrame(animHandle);
        let last = null;
        function loop(ts) {
            if (!gameActive) return;
            if (last === null) last = ts;
            const dt = Math.min((ts - last) / 16.67, 3); // cap delta
            last = ts;

            const stageH = STAGE_H();
            let dirty = false;

            for (let i = fallingCards.length - 1; i >= 0; i--) {
                const c = fallingCards[i];
                if (!c.active) { fallingCards.splice(i, 1); continue; }

                c.y += cfg.fallSpeed * dt;
                c.el.style.top = c.y + 'px';

                // Reached bottom — chip damage
                if (c.y > stageH) {
                    chipDamage(c);
                    removeCard(c);
                    dirty = true;
                }
            }
            if (dirty) refreshTarget();
            animHandle = requestAnimationFrame(loop);
        }
        animHandle = requestAnimationFrame(loop);
    }

    function chipDamage(card) {
        const dmg = Math.round(cfg.aiDmg * 0.3);
        applyDamage('player', dmg);
        showDamageFloat(card.x, STAGE_H() - 40, `-${dmg} ❗`, false);
    }

    function removeCard(card) {
        card.active = false;
        card.el.remove();
    }

    // ── target = lowest (highest y-value) active card ──
    function refreshTarget() {
        let lowest = null;
        for (const c of fallingCards) {
            if (!c.active) continue;
            if (!lowest || c.y > lowest.y) lowest = c;
        }

        document.querySelectorAll('.kana-card.target').forEach(e => e.classList.remove('target'));
        if (lowest) {
            lowest.el.classList.add('target');
            document.getElementById('target-kana').textContent  = lowest.word.wordKana ?? '?';
            document.getElementById('target-hint').textContent  = lowest.word.meaningEnglish
                ? '(' + lowest.word.meaningEnglish + ')'
                : '\u00a0';
            document.getElementById('target-cat').textContent   = lowest.word.categoryTag
                ? '📂 ' + lowest.word.categoryTag
                : '\u00a0';
        } else {
            document.getElementById('target-kana').textContent = '—';
            document.getElementById('target-hint').textContent = '\u00a0';
            document.getElementById('target-cat').textContent  = '\u00a0';
        }
    }

    // ══════════════════════════════════════════════════════════════
    //  ANSWER INPUT
    // ══════════════════════════════════════════════════════════════
    document.getElementById('romaji-input').addEventListener('keydown', (e) => {
        if (e.key === 'Enter') { e.preventDefault(); submitAnswer(); }
    });

    function submitAnswer() {
        if (!gameActive) return;
        const input = document.getElementById('romaji-input');
        const typed = input.value.trim().toUpperCase();
        if (!typed) return;

        // Find target card
        let target = null;
        let lowestY = -Infinity;
        for (const c of fallingCards) {
            if (c.active && c.y > lowestY) { lowestY = c.y; target = c; }
        }

        if (!target) { input.value = ''; return; }

        // correct answer = wordRomaji from KanaWord (DbInitializer)
        const correct = (target.word.wordRomaji ?? '').toUpperCase();
        const isCorrect = typed === correct;

        input.value = '';

        if (isCorrect) {
            // Build damage
            streak++;
            maxStreak = Math.max(maxStreak, streak);
            correctCnt++;

            let dmg = 80 + Math.floor(Math.random() * 40);
            // combo multiplier (5% per streak level, cap at 25)
            const comboMult = 1 + Math.min(streak, 25) * 0.05;
            // speed bonus: the lower c.y, the faster the answer
            const speedBonus = Math.max(0, 1 - target.y / STAGE_H());
            dmg = Math.round(dmg * comboMult * (1 + speedBonus * 0.5));

            // active skills
            if (activeSkills.speed) { dmg = Math.round(dmg * 1.5); activeSkills.speed--; if (activeSkills.speed <= 0) delete activeSkills.speed; updateSkillsUI(); }
            if (activeSkills.crit)  { dmg = Math.round(dmg * 3);   delete activeSkills.crit; updateSkillsUI(); }

            applyDamage('enemy', dmg);
            dmgDealt += dmg;
            showDamageFloat(STAGE_W() * 0.65, STAGE_H() * 0.4, `-${dmg}`, true);

            // Streak flash
            if (streak >= 4) {
                const em = streak >= 12 ? '💥' : streak >= 7 ? '🔥' : '⚡';
                showStreakFlash(em + ' ' + streak + 'x');
            }

            // Skill activation
            if (target.isSkill) activateSkill();

            flashInput('correct');
            removeCard(target);
        } else {
            // Wrong answer — self damage + streak reset
            streak = 0;
            wrongCnt++;
            const selfDmg = 20;
            applyDamage('player', selfDmg);
            dmgTaken += selfDmg;
            showDamageFloat(STAGE_W() * 0.15, STAGE_H() * 0.4, `-${selfDmg} ❌`, false);
            flashInput('wrong');
        }

        updateStats();
        refreshTarget();
    }

    // ══════════════════════════════════════════════════════════════
    //  DAMAGE + HP
    // ══════════════════════════════════════════════════════════════
    function applyDamage(target, amount) {
        if (target === 'player') {
            playerHP = Math.max(0, playerHP - amount);
            dmgTaken += amount;
            if (playerHP === 0) { endBattle('enemy_win'); return; }
        } else {
            enemyHP = Math.max(0, enemyHP - amount);
            if (enemyHP === 0) { endBattle('player_win'); return; }
        }
        updateHPBars();
        updateStats();
    }

    function updateHPBars() {
        const pPct = (playerHP / cfg.hp) * 100;
        const ePct = (enemyHP  / cfg.hp) * 100;
        document.getElementById('hp-player').textContent       = playerHP;
        document.getElementById('hp-enemy').textContent        = enemyHP;
        document.getElementById('hp-bar-player').style.width   = pPct + '%';
        document.getElementById('hp-bar-enemy').style.width    = ePct + '%';
        document.getElementById('hp-bar-player').style.background =
            pPct < 25 ? '#ef4444' : pPct < 50 ? '#f59e0b' : 'linear-gradient(90deg,#2563eb,#60a5fa)';
    }

    // ══════════════════════════════════════════════════════════════
    //  SKILLS
    // ══════════════════════════════════════════════════════════════
    const SKILLS = ['shield','speed','heal','crit'];
    function activateSkill() {
        const sk = SKILLS[Math.floor(Math.random() * SKILLS.length)];
        if (sk === 'heal') {
            playerHP = Math.min(cfg.hp, playerHP + 100);
            updateHPBars();
            showDamageFloat(STAGE_W() * 0.15, STAGE_H() * 0.35, '❤️ +100 HP', false);
        } else if (sk === 'shield') {
            activeSkills.shield = true;
        } else if (sk === 'speed') {
            activeSkills.speed = (activeSkills.speed ?? 0) + 3;
        } else if (sk === 'crit') {
            activeSkills.crit = true;
        }
        updateSkillsUI();
    }

    function updateSkillsUI() {
        const row = document.getElementById('skills-row');
        row.innerHTML = '';
        if (activeSkills.shield) row.innerHTML += `<div class="skill-badge">🛡️ Shield Active</div>`;
        if (activeSkills.speed)  row.innerHTML += `<div class="skill-badge">⚡ Speed ×${activeSkills.speed}</div>`;
        if (activeSkills.crit)   row.innerHTML += `<div class="skill-badge">🗡️ Crit Ready</div>`;
    }

    // ══════════════════════════════════════════════════════════════
    //  STATS UPDATE
    // ══════════════════════════════════════════════════════════════
    function updateStats() {
        document.getElementById('stat-correct').textContent = correctCnt;
        document.getElementById('stat-wrong').textContent   = wrongCnt;
        document.getElementById('stat-combo').textContent   = streak;
        document.getElementById('stat-dmg').textContent     = dmgDealt;
        document.getElementById('stat-taken').textContent   = dmgTaken;
    }

    // ══════════════════════════════════════════════════════════════
    //  VISUAL EFFECTS
    // ══════════════════════════════════════════════════════════════
    function showDamageFloat(x, y, text, isEnemy) {
        const el = document.createElement('div');
        el.className = 'dmg-float ' + (isEnemy ? 'enemy-dmg' : 'player-dmg');
        el.textContent = text;
        el.style.left = x + 'px';
        el.style.top  = y + 'px';
        STAGE.appendChild(el);
        setTimeout(() => el.remove(), 950);
    }

    function showStreakFlash(text) {
        const el = document.createElement('div');
        el.className = 'streak-flash';
        el.textContent = text;
        STAGE.appendChild(el);
        setTimeout(() => el.remove(), 750);
    }

    function flashInput(type) {
        const inp = document.getElementById('romaji-input');
        inp.classList.add(type);
        setTimeout(() => inp.classList.remove(type), 400);
    }

    // ══════════════════════════════════════════════════════════════
    //  END BATTLE
    // ══════════════════════════════════════════════════════════════
    function endBattle(reason) {
        if (!gameActive) return;
        gameActive = false;
        clearInterval(timerHandle);
        clearInterval(aiHandle);
        clearInterval(spawnHandle);
        cancelAnimationFrame(animHandle);

        const playerWon = reason === 'player_win' || (reason === 'timeout' && playerHP > enemyHP);
        const eloChange = playerWon
            ? '+' + cfg.eloWin
            : '-' + cfg.eloLoss;

        const total = correctCnt + wrongCnt;
        const acc   = total > 0 ? Math.round((correctCnt / total) * 100) : 0;

        document.getElementById('res-title').textContent =
            playerWon ? '🏆 Victory!' : '💀 Defeat!';
        document.getElementById('res-sub').textContent =
            playerWon
                ? `You KO'd the opponent! ELO ${eloChange}`
                : `The opponent won. ELO ${eloChange}`;
        document.getElementById('res-correct').textContent = correctCnt;
        document.getElementById('res-dmg').textContent     = dmgDealt;
        document.getElementById('res-combo').textContent   = maxStreak + 'x';
        document.getElementById('res-acc').textContent     = acc + '%';
        document.getElementById('res-elo').textContent     = eloChange;
        document.getElementById('res-time').textContent    = timerSecs + 's';

        document.getElementById('result-overlay').classList.add('show');

        // Submit result to KanaBlitzController.SubmitBattleResult (if endpoint exists)
        submitResult(playerWon, eloChange);
    }

    async function submitResult(won, eloChange) {
        try {
            await fetch('/KanaBlitz/SubmitBattleResult', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json',
                           'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '' },
                body: JSON.stringify({
                    won,
                    difficulty:  diff_cfg,
                    script:      script_cfg,
                    correct:     correctCnt,
                    wrong:       wrongCnt,
                    dmgDealt,
                    maxStreak,
                    eloChange
                })
            });
        } catch { /* silently ignore if endpoint not yet implemented */ }
    }

    // ══════════════════════════════════════════════════════════════
    //  REPLAY
    // ══════════════════════════════════════════════════════════════
    function replayBattle() {
        document.getElementById('result-overlay').classList.remove('show');
        // Clear stage
        STAGE.querySelectorAll('.kana-card').forEach(e => e.remove());
        wordPool = shuffle(wordPool);
        startBattle();
    }

    // ══════════════════════════════════════════════════════════════
    //  HELPERS
    // ══════════════════════════════════════════════════════════════
    function shuffle(arr) {
        const a = [...arr];
        for (let i = a.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [a[i], a[j]] = [a[j], a[i]];
        }
        return a;
    }
    function capitalize(str) {
        return str ? str.charAt(0).toUpperCase() + str.slice(1) : str;
    }
    function escapeHtml(str) {
        return String(str)
            .replace(/&/g,'&amp;').replace(/</g,'&lt;')
            .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ══════════════════════════════════════════════════════════════
    //  BOOT
    // ══════════════════════════════════════════════════════════════
    initBattle();
</script>
