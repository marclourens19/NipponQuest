@section Scripts {
    <script>
        /*
         * ═══════════════════════════════════════════════════════════════
         *  KanaBlitz Solo — Full Game Engine
         *  Fixed: word loading, difficulty validation, state management,
         *         race conditions, combo system, feedback, animations.
         * ═══════════════════════════════════════════════════════════════
         */

        'use strict';

        // ── Config ──────────────────────────────────────────────────────
        const CFG = {
            MIN_WORDS:        5,
            QUESTIONS_PER_GAME: 20,
            TIME_LIMITS:      { easy: 60, normal: 75, hard: 90, insanity: 120 },
            BASE_SCORES:      { easy: 10, normal: 15, hard: 25, insanity: 40 },
            COMBO_THRESHOLDS: [3, 5, 8, 12],
            COMBO_LABELS:     ['🔥 Combo!', '⚡ Hot Streak!', '💥 On Fire!', '🌟 LEGENDARY!'],
            XP_MULTIPLIERS:   { easy: 1, normal: 1.5, hard: 2.5, insanity: 4 },
            OPTIONS_COUNT:    4,
            ANSWER_LOCK_MS:   900,   // ms to show correct/wrong before next question
            WARN_THRESHOLD:   10,    // seconds left before timer warning
        };

        // ── State ────────────────────────────────────────────────────────
        let state = {
            words:        [],
            wordPool:     [],
            questions:    [],
            currentIdx:   0,
            score:        0,
            correct:      0,
            wrong:        0,
            lives:        3,
            combo:        0,
            maxCombo:     0,
            timeLeft:     60,
            totalTime:    60,
            timer:        null,
            locked:       false,
            running:      false,
            dotHistory:   [],
            script:       'hiragana',
            difficulty:   'easy',
        };

        // Selection state
        let sel = { script: 'hiragana', diff: 'easy' };

        // Word counts cache (keyed by "diff|script")
        let wordCountCache = {};

        // ── Audio hooks (expandable) ─────────────────────────────────────
        const Audio = {
            play(name) {
                // Placeholder — wire up AudioContext or HTMLAudioElement here
                // e.g.: new window.AudioContext(); play pre-loaded buffer
                // Sounds: 'correct', 'wrong', 'combo', 'countdown', 'victory', 'defeat'
            }
        };

        // ── DOM refs ─────────────────────────────────────────────────────
        const $ = id => document.getElementById(id);
        const DOM = {
            setupPanel:     $('setup-panel'),
            arena:          $('arena'),
            btnStart:       $('btn-start'),
            wordWarning:    $('word-warning'),
            warningText:    $('warning-text'),
            timerDisplay:   $('timer-display'),
            hudTimer:       $('hud-timer'),
            scoreDisplay:   $('score-display'),
            comboDisplay:   $('combo-display'),
            livesDisplay:   $('lives-display'),
            progressBar:    $('progress-bar'),
            qCard:          $('q-card'),
            qKana:          $('q-kana'),
            qMeaning:       $('q-meaning'),
            qCat:           $('q-cat'),
            qProgress:      $('q-progress'),
            optGrid:        $('opt-grid'),
            feedbackBar:    $('feedback-bar'),
            countdownOverlay: $('countdown-overlay'),
            countdownNum:   $('countdown-num'),
            loadingOverlay: $('loading-overlay'),
            resultOverlay:  $('result-overlay'),
            resultEmoji:    $('result-emoji'),
            resultTitle:    $('result-title'),
            resultSubtitle: $('result-subtitle'),
            resScore:       $('res-score'),
            resCorrect:     $('res-correct'),
            resAccuracy:    $('res-accuracy'),
            resultXp:       $('result-xp'),
        };

        // ── Selection handlers ───────────────────────────────────────────
        function selectScript(val, el) {
            sel.script = val;
            document.querySelectorAll('#grid-script .choice-card').forEach(c => c.classList.remove('active'));
            el.classList.add('active');
            validateSelection();
            updateWordCounts();
            Audio.play('click');
        }

        function selectDiff(val, el) {
            sel.diff = val;
            document.querySelectorAll('#grid-diff .choice-card').forEach(c => c.classList.remove('active'));
            el.classList.add('active');
            validateSelection();
            Audio.play('click');
        }

        // ── Word count fetching ──────────────────────────────────────────
        async function fetchWordCount(diff, script) {
            const cacheKey = `${diff}|${script}`;
            if (wordCountCache[cacheKey] !== undefined) return wordCountCache[cacheKey];
            try {
                const resp = await fetch(`/KanaBlitz/GetWords?difficulty=${diff}&script=${script}`);
                if (!resp.ok) return 0;
                const data = await resp.json();
                const count = Array.isArray(data) ? data.length : 0;
                wordCountCache[cacheKey] = count;
                return count;
            } catch { return 0; }
        }

        async function updateWordCounts() {
            const diffs = ['easy', 'normal', 'hard', 'insanity'];
            for (const d of diffs) {
                const cnt = await fetchWordCount(d, sel.script);
                const el = $(`cnt-${d}`);
                if (el) {
                    el.textContent = cnt > 0 ? `${cnt} words available` : 'No words available';
                    // Disable card visually if no words
                    const card = el.closest('.choice-card');
                    if (card) {
                        if (cnt < CFG.MIN_WORDS) {
                            card.style.opacity = '0.45';
                            card.style.cursor = 'not-allowed';
                        } else {
                            card.style.opacity = '';
                            card.style.cursor = '';
                        }
                    }
                }
            }
        }

        async function validateSelection() {
            const count = await fetchWordCount(sel.diff, sel.script);
            const ok = count >= CFG.MIN_WORDS;
            DOM.wordWarning.classList.toggle('visible', !ok);
            if (!ok) {
                DOM.warningText.textContent = `Only ${count} word(s) found for "${sel.diff}" + "${sel.script}". Minimum ${CFG.MIN_WORDS} needed. Please choose another combination.`;
            }
            DOM.btnStart.disabled = !ok;
            return ok;
        }

        // ── Word fetch for game ──────────────────────────────────────────
        async function loadWords(diff, script) {
            // For "mixed" or broad fetches, merge all scripts
            const scripts = script === 'mixed'
                ? ['hiragana', 'katakana', 'dakuten', 'mixed']
                : [script];

            let allWords = [];
            for (const s of scripts) {
                try {
                    const resp = await fetch(`/KanaBlitz/GetWords?difficulty=${diff}&script=${s}`);
                    if (resp.ok) {
                        const data = await resp.json();
                        if (Array.isArray(data)) allWords = allWords.concat(data);
                    }
                } catch (e) {
                    console.warn(`Failed to load words for ${diff}/${s}:`, e);
                }
            }

            // Deduplicate by WordKana
            const seen = new Set();
            return allWords.filter(w => {
                const key = (w.wordKana || w.WordKana || '');
                if (seen.has(key)) return false;
                seen.add(key);
                return true;
            });
        }

        // ── Game start ───────────────────────────────────────────────────
        async function startGame() {
            const ok = await validateSelection();
            if (!ok) return;

            DOM.loadingOverlay.classList.add('show');
            DOM.btnStart.disabled = true;

            try {
                const words = await loadWords(sel.diff, sel.script);

                if (!words || words.length < CFG.MIN_WORDS) {
                    showWarning(`Not enough words loaded (got ${words ? words.length : 0}). Please try again.`);
                    DOM.loadingOverlay.classList.remove('show');
                    DOM.btnStart.disabled = false;
                    return;
                }

                // Shuffle words and pick question set
                const shuffled = shuffle([...words]);
                const pool = shuffled.slice(0, Math.max(shuffled.length, CFG.QUESTIONS_PER_GAME + 4));

                // Build questions list
                const qs = buildQuestions(pool, words, CFG.QUESTIONS_PER_GAME);

                // Init state
                state = {
                    words,
                    wordPool:   pool,
                    questions:  qs,
                    currentIdx: 0,
                    score:      0,
                    correct:    0,
                    wrong:      0,
                    lives:      3,
                    combo:      0,
                    maxCombo:   0,
                    timeLeft:   CFG.TIME_LIMITS[sel.diff] || 60,
                    totalTime:  CFG.TIME_LIMITS[sel.diff] || 60,
                    timer:      null,
                    locked:     false,
                    running:    false,
                    dotHistory: [],
                    script:     sel.script,
                    difficulty: sel.diff,
                };

                DOM.loadingOverlay.classList.remove('show');
                DOM.setupPanel.style.display = 'none';
                DOM.arena.style.display = 'block';

                // Render progress dots
                renderProgressDots();
                updateHUD();

                // Countdown
                await doCountdown();

                // Begin
                state.running = true;
                loadQuestion();
                startTimer();

            } catch (err) {
                console.error('startGame error:', err);
                DOM.loadingOverlay.classList.remove('show');
                DOM.btnStart.disabled = false;
                showWarning('An error occurred loading the game. Please try again.');
            }
        }

        // ── Build questions (each Q has word + wrong options) ────────────
        function buildQuestions(pool, allWords, count) {
            const selected = [];
            const used = new Set();

            for (const w of pool) {
                if (selected.length >= count) break;
                const key = getWordKana(w);
                if (used.has(key)) continue;
                used.add(key);

                // Build distractors from allWords (exclude current)
                const distractors = allWords
                    .filter(x => getWordRomaji(x) !== getWordRomaji(w))
                    .sort(() => Math.random() - 0.5)
                    .slice(0, CFG.OPTIONS_COUNT - 1)
                    .map(x => getWordRomaji(x));

                // Insert correct at random index
                const options = [...distractors];
                const insertAt = Math.floor(Math.random() * CFG.OPTIONS_COUNT);
                options.splice(insertAt, 0, getWordRomaji(w));

                selected.push({ word: w, options, correct: getWordRomaji(w) });
            }
            return selected;
        }

        // ── Safe property accessors (handles PascalCase & camelCase) ─────
        function getWordKana(w)    { return w.wordKana    || w.WordKana    || '?'; }
        function getWordRomaji(w)  { return w.wordRomaji  || w.WordRomaji  || '?'; }
        function getWordMeaning(w) { return w.meaningEnglish || w.MeaningEnglish || ''; }
        function getWordCat(w)     { return w.categoryTag || w.CategoryTag  || ''; }

        // ── Countdown ────────────────────────────────────────────────────
        function doCountdown() {
            return new Promise(resolve => {
                DOM.countdownOverlay.classList.add('show');
                let n = 3;
                DOM.countdownNum.textContent = n;

                const tick = setInterval(() => {
                    n--;
                    if (n <= 0) {
                        clearInterval(tick);
                        DOM.countdownOverlay.classList.remove('show');
                        resolve();
                    } else {
                        // Re-trigger animation
                        DOM.countdownNum.textContent = n;
                        DOM.countdownNum.style.animation = 'none';
                        requestAnimationFrame(() => {
                            DOM.countdownNum.style.animation = '';
                        });
                    }
                    Audio.play('countdown');
                }, 1000);
            });
        }

        // ── Timer ─────────────────────────────────────────────────────────
        function startTimer() {
            clearInterval(state.timer);
            state.timer = setInterval(() => {
                if (!state.running) return;
                state.timeLeft--;

                // Warning mode
                DOM.hudTimer.classList.toggle('warning', state.timeLeft <= CFG.WARN_THRESHOLD);

                updateHUD();
                if (state.timeLeft <= 0) endGame('timeout');
            }, 1000);
        }

        // ── Load Question ────────────────────────────────────────────────
        function loadQuestion() {
            if (!state.running) return;

            const q = state.questions[state.currentIdx];
            if (!q || state.currentIdx >= state.questions.length) {
                endGame('complete');
                return;
            }

            state.locked = false;

            // Update dot
            if (state.dotHistory[state.currentIdx] !== undefined) {
                // already answered — skip to next
            }

            // Render kana — re-trigger animation
            DOM.qKana.style.animation = 'none';
            requestAnimationFrame(() => { DOM.qKana.style.animation = ''; });
            DOM.qKana.textContent        = getWordKana(q.word);
            DOM.qMeaning.textContent     = getWordMeaning(q.word) ? `(${getWordMeaning(q.word)})` : '';
            DOM.qCat.textContent         = getWordCat(q.word);
            DOM.feedbackBar.textContent  = '';
            DOM.feedbackBar.style.color  = '';

            // Render options
            DOM.optGrid.innerHTML = '';
            q.options.forEach(opt => {
                const btn = document.createElement('button');
                btn.className = 'opt-btn';
                btn.textContent = opt;
                btn.addEventListener('click', () => handleAnswer(opt, q.correct, btn));
                DOM.optGrid.appendChild(btn);
            });

            updateProgressDots();
            updateHUD();
        }

        // ── Handle Answer ─────────────────────────────────────────────────
        function handleAnswer(chosen, correct, btn) {
            if (state.locked || !state.running) return;
            state.locked = true;

            const isCorrect = chosen.toLowerCase().trim() === correct.toLowerCase().trim();

            // Disable all options
            DOM.optGrid.querySelectorAll('.opt-btn').forEach(b => { b.disabled = true; });

            if (isCorrect) {
                btn.classList.add('correct');
                state.combo++;
                state.maxCombo = Math.max(state.maxCombo, state.combo);
                const baseScore = CFG.BASE_SCORES[state.difficulty] || 15;
                const comboMult = 1 + (state.combo - 1) * 0.25;
                const points    = Math.round(baseScore * comboMult);
                state.score  += points;
                state.correct++;

                DOM.feedbackBar.textContent = `✓ Correct! +${points}`;
                DOM.feedbackBar.style.color = 'var(--nq-green)';
                DOM.qCard.classList.add('flash-correct');

                Audio.play('correct');

                // Combo feedback
                const comboIdx = CFG.COMBO_THRESHOLDS.findLastIndex(t => state.combo >= t);
                if (comboIdx >= 0 && state.combo === CFG.COMBO_THRESHOLDS[comboIdx]) {
                    showComboBurst(CFG.COMBO_LABELS[comboIdx]);
                    Audio.play('combo');
                }

                state.dotHistory[state.currentIdx] = 'correct';
            } else {
                btn.classList.add('wrong');
                // Highlight correct
                DOM.optGrid.querySelectorAll('.opt-btn').forEach(b => {
                    if (b.textContent.toLowerCase().trim() === correct.toLowerCase().trim()) {
                        b.classList.add('correct');
                    }
                });
                state.combo = 0;
                state.wrong++;
                state.lives = Math.max(0, state.lives - 1);

                DOM.feedbackBar.textContent = `✗ Correct: ${correct}`;
                DOM.feedbackBar.style.color = 'var(--nq-red)';
                DOM.qCard.classList.add('flash-wrong');

                Audio.play('wrong');
                state.dotHistory[state.currentIdx] = 'wrong';

                if (state.lives <= 0) {
                    updateHUD();
                    setTimeout(() => endGame('lives'), CFG.ANSWER_LOCK_MS);
                    return;
                }
            }

            updateProgressDots();
            updateHUD();

            setTimeout(() => {
                DOM.qCard.classList.remove('flash-correct', 'flash-wrong');
                state.currentIdx++;
                if (state.currentIdx >= state.questions.length) {
                    endGame('complete');
                } else {
                    loadQuestion();
                }
            }, CFG.ANSWER_LOCK_MS);
        }

        // ── HUD update ───────────────────────────────────────────────────
        function updateHUD() {
            DOM.timerDisplay.textContent = state.timeLeft;
            DOM.scoreDisplay.textContent = state.score;
            DOM.comboDisplay.textContent = `×${state.combo + 1}`;

            // Lives as hearts
            const hearts = '❤️'.repeat(state.lives) + '🖤'.repeat(Math.max(0, 3 - state.lives));
            DOM.livesDisplay.textContent = hearts;

            // Progress bar
            const pct = (state.timeLeft / state.totalTime) * 100;
            DOM.progressBar.style.width = `${Math.max(0, pct)}%`;
            DOM.progressBar.style.background = pct > 40
                ? 'linear-gradient(90deg, var(--nq-accent), var(--nq-accent2))'
                : pct > 20
                    ? 'linear-gradient(90deg, #f59e0b, #fbbf24)'
                    : 'linear-gradient(90deg, #ef4444, #f87171)';
        }

        // ── Progress dots ─────────────────────────────────────────────────
        function renderProgressDots() {
            DOM.qProgress.innerHTML = '';
            for (let i = 0; i < state.questions.length; i++) {
                const dot = document.createElement('div');
                dot.className = 'q-dot';
                dot.id = `dot-${i}`;
                DOM.qProgress.appendChild(dot);
            }
        }

        function updateProgressDots() {
            for (let i = 0; i < state.questions.length; i++) {
                const dot = $(`dot-${i}`);
                if (!dot) continue;
                dot.className = 'q-dot';
                if (i === state.currentIdx) dot.classList.add('current');
                else if (state.dotHistory[i] === 'correct') dot.classList.add('done-correct');
                else if (state.dotHistory[i] === 'wrong')   dot.classList.add('done-wrong');
            }
        }

        // ── Combo burst ───────────────────────────────────────────────────
        function showComboBurst(label) {
            const el = document.createElement('div');
            el.className = 'combo-burst';
            el.textContent = label;
            el.style.color = 'var(--nq-gold)';
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 800);
        }

        // ── End game ──────────────────────────────────────────────────────
        function endGame(reason) {
            if (!state.running) return;
            state.running = false;
            clearInterval(state.timer);
            Audio.play(state.correct > state.wrong ? 'victory' : 'defeat');

            const total    = state.correct + state.wrong;
            const accuracy = total > 0 ? Math.round((state.correct / total) * 100) : 0;
            const xpBase   = CFG.BASE_SCORES[state.difficulty] || 15;
            const xp       = Math.round(state.score * (CFG.XP_MULTIPLIERS[state.difficulty] || 1) * 0.3);

            // Choose emoji & title
            let emoji, title, subtitle;
            if (reason === 'lives') {
                emoji = '💔'; title = 'Out of Lives!';
                subtitle = `You answered ${state.correct} correctly before falling.`;
            } else if (accuracy >= 90) {
                emoji = '🏆'; title = 'Outstanding!';
                subtitle = `${accuracy}% accuracy — you're a kana master!`;
            } else if (accuracy >= 70) {
                emoji = '⚡'; title = 'Great Work!';
                subtitle = `${accuracy}% accuracy — keep it up!`;
            } else if (accuracy >= 50) {
                emoji = '💪'; title = 'Good Effort!';
                subtitle = `${accuracy}% accuracy — practice makes perfect.`;
            } else {
                emoji = '🌱'; title = 'Keep Training!';
                subtitle = `${accuracy}% accuracy — every mistake is progress.`;
            }

            DOM.resultEmoji.textContent    = emoji;
            DOM.resultTitle.textContent    = title;
            DOM.resultSubtitle.textContent = subtitle;
            DOM.resScore.textContent       = state.score;
            DOM.resCorrect.textContent     = `${state.correct}/${total}`;
            DOM.resAccuracy.textContent    = `${accuracy}%`;
            DOM.resultXp.textContent       = `+${xp} XP Earned`;

            setTimeout(() => DOM.resultOverlay.classList.add('show'), 400);
        }

        // ── Restart / back ────────────────────────────────────────────────
        function restartGame() {
            DOM.resultOverlay.classList.remove('show');
            // Re-use same settings
            startGame();
        }

        function backToSetup() {
            DOM.resultOverlay.classList.remove('show');
            DOM.arena.style.display = 'none';
            DOM.setupPanel.style.display = '';
            DOM.btnStart.disabled = false;
            clearInterval(state.timer);
            state.running = false;
        }

        // ── Utility ───────────────────────────────────────────────────────
        function shuffle(arr) {
            for (let i = arr.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [arr[i], arr[j]] = [arr[j], arr[i]];
            }
            return arr;
        }

        function showWarning(msg) {
            DOM.wordWarning.classList.add('visible');
            DOM.warningText.textContent = msg;
        }

        // Array.findLastIndex polyfill for older browsers
        if (!Array.prototype.findLastIndex) {
            Array.prototype.findLastIndex = function(fn) {
                for (let i = this.length - 1; i >= 0; i--) {
                    if (fn(this[i], i, this)) return i;
                }
                return -1;
            };
        }

        // ── Init ──────────────────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', () => {
            updateWordCounts();
            validateSelection();

            // Keyboard: Enter to start
            document.addEventListener('keydown', e => {
                if (e.key === 'Enter' && !DOM.arena.style.display.includes('block') && !DOM.btnStart.disabled) {
                    startGame();
                }
            });
        });
    </script>
}
