@*
    ╔══════════════════════════════════════════════════════════════════╗
    ║  KanaBattle_View.cshtml  —  KanaBattle Game Arena               ║
    ║  Controller : KanaBattleController → Battle()                   ║
    ║  Route      : /KanaBattle/Battle?difficulty=&script=            ║
    ║  API        : GET /KanaBlitz/GetWords?difficulty=&script=       ║
    ║  Model      : KanaBattleModel                                   ║
    ║  Refactored : Full audit, debug, redesign & UX overhaul         ║
    ║  Aesthetic  : White background · Black / Gold / White / Blue    ║
    ╚══════════════════════════════════════════════════════════════════╝
*@
@model NipponQuest.Models.KanaBattleModel
@{
    ViewData["Title"] = "KanaBattle — Arena";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Sanitised values from the model (already normalised in controller)
    var difficulty = Model?.Difficulty ?? "normal";
    var script = Model?.Script ?? "hiragana";
    var playerName = Model?.PlayerName ?? "Player 1";
    var isMulti = ViewBag.Multiplayer != null && (bool)ViewBag.Multiplayer;
    var player2Name = ViewBag.Player2Name as string ?? "Player 2";
}

<style>
    /* ══════════════════════════════════════════════════════════════
           NIPPONQUEST — KanaBattle Arena
           Palette : White bg · Black text · Gold accents · Blue action
           Font    : Nunito (loaded via site.css)
        ══════════════════════════════════════════════════════════════ */
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');

    :root {
        --ba-bg: #ffffff;
        --ba-surface: #f8fafc;
        --ba-surface2: #f1f5f9;
        --ba-border: #e2e8f0;
        --ba-border2: #cbd5e1;
        --ba-black: #0f172a;
        --ba-charcoal: #1e293b;
        --ba-dark: #334155;
        --ba-muted: #64748b;
        --ba-faint: #94a3b8;
        --ba-gold: #d97706;
        --ba-gold-lt: #f59e0b;
        --ba-gold-bg: #fef3c7;
        --ba-gold-bd: #fcd34d;
        --ba-blue: #1e40af;
        --ba-blue-lt: #3b82f6;
        --ba-blue-bg: #eff6ff;
        --ba-blue-bd: #93c5fd;
        --ba-green: #065f46;
        --ba-green-lt: #10b981;
        --ba-green-bg: #ecfdf5;
        --ba-green-bd: #6ee7b7;
        --ba-red: #991b1b;
        --ba-red-lt: #ef4444;
        --ba-red-bg: #fff1f2;
        --ba-red-bd: #fca5a5;
        --ba-p1: #1e40af;
        --ba-p2: #991b1b;
        --ba-radius: 14px;
        --ba-radius-sm: 10px;
        --ba-radius-lg: 20px;
        --ba-shadow: 0 4px 16px rgba(15,23,42,0.08);
        --ba-shadow-lg: 0 8px 32px rgba(15,23,42,0.12);
        --ba-trans: all 0.22s cubic-bezier(0.4,0,0.2,1);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    .ba-page {
        background: var(--ba-bg);
        min-height: 100vh;
        color: var(--ba-black);
        font-family: 'Nunito', 'Segoe UI', sans-serif;
        padding-bottom: 80px;
    }

        /* Accent bar: gold for solo, red+gold for multi */
        .ba-page::before {
            content: '';
            display: block;
            height: 4px;
            background: @(isMulti
                        ? "linear-gradient(90deg,#0f172a 0%,#991b1b 40%,#d97706 70%,#1e40af 100%)"
                        : "linear-gradient(90deg,#0f172a 0%,#d97706 50%,#1e40af 100%)");
        }

    .ba-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 28px 16px;
    }

    /* ── Arena Header ── */
    .arena-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 24px;
        padding-bottom: 18px;
        border-bottom: 1.5px solid var(--ba-border);
    }

    .arena-title-wrap h2 {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--ba-black);
        margin-bottom: 4px;
    }

    .arena-title-wrap .arena-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 4px;
    }

    .arena-tag {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 100px;
        font-size: 0.67rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

        .arena-tag.black {
            background: var(--ba-black);
            color: #ffffff;
        }

        .arena-tag.gold {
            background: var(--ba-gold-bg);
            color: var(--ba-gold);
            border: 1px solid var(--ba-gold-bd);
        }

        .arena-tag.blue {
            background: var(--ba-blue-bg);
            color: var(--ba-blue);
            border: 1px solid var(--ba-blue-bd);
        }

        .arena-tag.red {
            background: var(--ba-red-bg);
            color: var(--ba-red);
            border: 1px solid var(--ba-red-bd);
        }

    .arena-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 18px;
        border-radius: var(--ba-radius);
        border: 2px solid var(--ba-border);
        background: var(--ba-bg);
        color: var(--ba-charcoal);
        font-size: 0.82rem;
        font-weight: 800;
        text-decoration: none;
        transition: var(--ba-trans);
    }

        .arena-back:hover {
            border-color: var(--ba-blue-lt);
            background: var(--ba-blue-bg);
            color: var(--ba-blue);
            text-decoration: none;
            transform: translateY(-1px);
        }

    /* ── Multiplayer Split Layout ── */
    .battle-layout {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 0;
        margin-bottom: 24px;
    }

    .player-panel {
        background: var(--ba-surface);
        border: 1.5px solid var(--ba-border);
        border-radius: var(--ba-radius-lg);
        padding: 24px 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        transition: var(--ba-trans);
    }

        .player-panel.p1-panel {
            border-color: rgba(30,64,175,0.3);
        }

        .player-panel.p2-panel {
            border-color: rgba(153,27,27,0.3);
        }

        .player-panel.active-panel {
            box-shadow: 0 0 0 3px rgba(217,119,6,0.3);
        }

    .player-badge {
        font-size: 0.68rem;
        font-weight: 900;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        padding: 4px 14px;
        border-radius: 100px;
        margin-bottom: 10px;
    }

        .player-badge.p1 {
            background: var(--ba-blue-bg);
            color: var(--ba-blue);
            border: 1px solid var(--ba-blue-bd);
        }

        .player-badge.p2 {
            background: var(--ba-red-bg);
            color: var(--ba-red);
            border: 1px solid var(--ba-red-bd);
        }

    .player-name-display {
        font-size: 1.1rem;
        font-weight: 900;
        color: var(--ba-black);
        margin-bottom: 8px;
    }

    .player-score-display {
        font-size: 2.8rem;
        font-weight: 900;
        line-height: 1;
        margin-bottom: 4px;
    }

    .p1-panel .player-score-display {
        color: var(--ba-blue);
    }

    .p2-panel .player-score-display {
        color: var(--ba-red-lt);
    }

    .player-sub {
        font-size: 0.72rem;
        color: var(--ba-muted);
        font-weight: 600;
    }

    .player-input-area {
        width: 100%;
        margin-top: 14px;
    }

        .player-input-area input {
            width: 100%;
            padding: 12px 14px;
            border-radius: var(--ba-radius-sm);
            border: 2px solid var(--ba-border);
            font-size: 0.95rem;
            font-weight: 700;
            font-family: inherit;
            color: var(--ba-black);
            background: var(--ba-bg);
            outline: none;
            transition: var(--ba-trans);
            text-align: center;
        }

    .p1-panel .player-input-area input:focus {
        border-color: var(--ba-blue-lt);
        box-shadow: 0 0 0 2px rgba(59,130,246,0.12);
    }

    .p2-panel .player-input-area input:focus {
        border-color: var(--ba-red-lt);
        box-shadow: 0 0 0 2px rgba(239,68,68,0.12);
    }

    .player-input-area input.correct {
        border-color: var(--ba-green-lt);
        background: var(--ba-green-bg);
        color: var(--ba-green);
    }

    .player-input-area input.incorrect {
        border-color: var(--ba-red-lt);
        background: var(--ba-red-bg);
        color: var(--ba-red);
    }

    .player-submit-btn {
        width: 100%;
        margin-top: 8px;
        padding: 11px;
        border-radius: var(--ba-radius-sm);
        border: none;
        font-size: 0.85rem;
        font-weight: 900;
        cursor: pointer;
        font-family: inherit;
        letter-spacing: 0.06em;
        transition: var(--ba-trans);
    }

    .p1-panel .player-submit-btn {
        background: linear-gradient(135deg, #0f172a, var(--ba-blue));
        color: #ffffff;
    }

    .p2-panel .player-submit-btn {
        background: linear-gradient(135deg, #0f172a, var(--ba-red-lt));
        color: #ffffff;
    }

    .player-submit-btn:hover {
        filter: brightness(1.1);
        transform: translateY(-1px);
    }

    .player-submit-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }

    .player-shortcut {
        font-size: 0.65rem;
        color: var(--ba-faint);
        margin-top: 6px;
        font-weight: 600;
        letter-spacing: 0.06em;
    }

    .player-feedback {
        min-height: 22px;
        font-size: 0.8rem;
        font-weight: 800;
        margin-top: 8px;
        text-align: center;
        transition: var(--ba-trans);
    }

        .player-feedback.correct {
            color: var(--ba-green-lt);
        }

        .player-feedback.incorrect {
            color: var(--ba-red-lt);
        }

    /* VS divider */
    .vs-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 16px;
    }

    .vs-text {
        font-size: 2rem;
        font-weight: 900;
        color: var(--ba-gold);
        background: var(--ba-gold-bg);
        border: 2px solid var(--ba-gold-bd);
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* ── Solo Layout ── */
    .solo-layout {
        max-width: 680px;
        margin: 0 auto;
    }

    /* ── Central Kana Display ── */
    .kana-stage {
        background: var(--ba-bg);
        border: 2px solid var(--ba-border);
        border-radius: var(--ba-radius-lg);
        padding: 44px 24px 36px;
        text-align: center;
        margin-bottom: 20px;
        box-shadow: var(--ba-shadow-lg);
        position: relative;
        overflow: hidden;
        animation: baSlideIn 0.38s cubic-bezier(0.34,1.56,0.64,1);
    }

        .kana-stage::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--ba-gold), var(--ba-blue-lt), var(--ba-gold));
        }

    .kana-stage-char {
        font-size: clamp(4rem,12vw,7rem);
        font-weight: 900;
        color: var(--ba-black);
        line-height: 1;
        display: block;
        margin-bottom: 12px;
        letter-spacing: -0.02em;
    }

    .kana-stage-meaning {
        font-size: 0.84rem;
        color: var(--ba-muted);
        margin-bottom: 10px;
        font-weight: 600;
    }

    .kana-stage-fill {
        font-size: clamp(1.6rem,5vw,2.6rem);
        font-weight: 900;
        color: var(--ba-charcoal);
        margin: 10px 0 6px;
        letter-spacing: 0.05em;
    }

    .fill-blank {
        display: inline-block;
        min-width: 48px;
        border-bottom: 3px solid var(--ba-gold);
        color: var(--ba-gold);
        padding: 0 4px;
    }

    .kana-tags {
        display: flex;
        justify-content: center;
        gap: 8px;
        margin-top: 10px;
        flex-wrap: wrap;
    }

    .kana-tag {
        background: var(--ba-surface2);
        border: 1px solid var(--ba-border);
        border-radius: 100px;
        padding: 3px 12px;
        font-size: 0.66rem;
        font-weight: 700;
        color: var(--ba-dark);
        letter-spacing: 0.07em;
    }

        .kana-tag.gold {
            background: var(--ba-gold-bg);
            border-color: var(--ba-gold-bd);
            color: var(--ba-gold);
        }

        .kana-tag.blue {
            background: var(--ba-blue-bg);
            border-color: var(--ba-blue-bd);
            color: var(--ba-blue);
        }

    /* ── Global HUD ── */
    .global-hud {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--ba-black);
        color: #ffffff;
        border-radius: var(--ba-radius);
        padding: 12px 20px;
        margin-bottom: 18px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .ghud-tile {
        text-align: center;
    }

        .ghud-tile .gv {
            font-size: 1.2rem;
            font-weight: 900;
            color: var(--ba-gold-lt);
            display: block;
        }

        .ghud-tile .gl {
            font-size: 0.58rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            color: rgba(255,255,255,0.45);
            text-transform: uppercase;
        }

    /* Timer ring */
    .ghud-timer {
        position: relative;
        width: 58px;
        height: 58px;
    }

        .ghud-timer svg {
            width: 100%;
            height: 100%;
            transform: rotate(-90deg);
        }

    .timer-track {
        fill: none;
        stroke: rgba(255,255,255,0.1);
        stroke-width: 5;
    }

    .timer-arc {
        fill: none;
        stroke: var(--ba-gold-lt);
        stroke-width: 5;
        stroke-linecap: round;
        transition: stroke-dashoffset 1s linear, stroke 0.3s;
    }

    .timer-num {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        font-weight: 900;
        color: #ffffff;
    }

    /* ── Progress bar ── */
    .progress-wrap {
        background: var(--ba-surface2);
        border-radius: 100px;
        height: 7px;
        overflow: hidden;
        margin-bottom: 18px;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--ba-gold), var(--ba-blue-lt));
        border-radius: 100px;
        transition: width 0.4s cubic-bezier(0.4,0,0.2,1);
    }

    /* ── MC buttons ── */
    .mc-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 14px;
    }

    .mc-btn {
        padding: 15px 12px;
        border-radius: var(--ba-radius);
        border: 2px solid var(--ba-border);
        background: var(--ba-bg);
        font-size: 0.9rem;
        font-weight: 800;
        color: var(--ba-charcoal);
        cursor: pointer;
        transition: var(--ba-trans);
        font-family: inherit;
        text-align: center;
    }

        .mc-btn:hover {
            border-color: var(--ba-blue-lt);
            background: var(--ba-blue-bg);
            transform: translateY(-1px);
        }

        .mc-btn.correct {
            border-color: var(--ba-green-lt);
            background: var(--ba-green-bg);
            color: var(--ba-green);
        }

        .mc-btn.incorrect {
            border-color: var(--ba-red-lt);
            background: var(--ba-red-bg);
            color: var(--ba-red);
        }

        .mc-btn:disabled {
            cursor: not-allowed;
            opacity: 0.7;
            transform: none;
        }

    /* ── Round Scoreboard (multi) ── */
    .round-board {
        background: var(--ba-surface);
        border: 1.5px solid var(--ba-border);
        border-radius: var(--ba-radius);
        padding: 14px 18px;
        margin-bottom: 16px;
        display: flex;
        justify-content: space-around;
        align-items: center;
        gap: 12px;
    }

    .rb-item {
        text-align: center;
    }

        .rb-item .rb-val {
            font-size: 1.5rem;
            font-weight: 900;
            color: var(--ba-black);
        }

        .rb-item .rb-lbl {
            font-size: 0.62rem;
            color: var(--ba-faint);
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .rb-item.p1-rb .rb-val {
            color: var(--ba-blue);
        }

        .rb-item.p2-rb .rb-val {
            color: var(--ba-red-lt);
        }

    /* ── Results ── */
    #results-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(8px);
        z-index: 200;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

        #results-overlay.visible {
            display: flex;
        }

    .results-card {
        background: var(--ba-bg);
        border: 2px solid var(--ba-border);
        border-radius: 24px;
        padding: 40px 32px;
        text-align: center;
        max-width: 700px;
        width: 100%;
        box-shadow: 0 20px 60px rgba(15,23,42,0.16);
        animation: baScaleIn 0.45s cubic-bezier(0.34,1.56,0.64,1);
        position: relative;
        overflow: hidden;
    }

        .results-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--ba-gold), var(--ba-blue-lt));
        }

    .results-trophy {
        font-size: 4rem;
        margin-bottom: 10px;
    }

    .results-winner {
        font-size: 1.8rem;
        font-weight: 900;
        color: var(--ba-black);
        margin-bottom: 6px;
    }

    .results-sub {
        font-size: 0.9rem;
        color: var(--ba-muted);
        margin-bottom: 28px;
    }

    .results-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(110px,1fr));
        gap: 12px;
        margin-bottom: 24px;
    }

    .results-stat {
        background: var(--ba-surface);
        border: 1.5px solid var(--ba-border);
        border-radius: var(--ba-radius);
        padding: 16px 10px;
    }

        .results-stat .rs-val {
            font-size: 1.9rem;
            font-weight: 900;
            color: var(--ba-black);
            display: block;
        }

        .results-stat .rs-lbl {
            font-size: 0.63rem;
            font-weight: 700;
            color: var(--ba-faint);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            display: block;
            margin-top: 3px;
        }

        .results-stat.gold-s .rs-val {
            color: var(--ba-gold);
        }

        .results-stat.blue-s .rs-val {
            color: var(--ba-blue-lt);
        }

        .results-stat.green-s .rs-val {
            color: var(--ba-green-lt);
        }

        .results-stat.red-s .rs-val {
            color: var(--ba-red-lt);
        }

    /* Multi player comparison */
    .multi-result-row {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 16px;
        align-items: center;
        margin-bottom: 24px;
    }

    .player-result-col {
        background: var(--ba-surface);
        border: 1.5px solid var(--ba-border);
        border-radius: var(--ba-radius);
        padding: 18px 14px;
        text-align: center;
    }

        .player-result-col.winner {
            border-color: var(--ba-gold);
            background: var(--ba-gold-bg);
            box-shadow: 0 0 0 3px rgba(217,119,6,0.12);
        }

        .player-result-col .pr-name {
            font-size: 0.9rem;
            font-weight: 900;
            color: var(--ba-dark);
            margin-bottom: 8px;
        }

        .player-result-col .pr-score {
            font-size: 2.2rem;
            font-weight: 900;
        }

    .p1-col .pr-score {
        color: var(--ba-blue);
    }

    .p2-col .pr-score {
        color: var(--ba-red-lt);
    }

    .player-result-col .pr-sub {
        font-size: 0.72rem;
        color: var(--ba-muted);
        font-weight: 600;
        margin-top: 4px;
    }

    .vs-col {
        font-size: 1.4rem;
        font-weight: 900;
        color: var(--ba-gold);
    }

    .results-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-primary {
        padding: 14px 28px;
        border-radius: var(--ba-radius);
        border: none;
        background: linear-gradient(135deg, #0f172a, #1e40af);
        color: #ffffff;
        font-size: 0.9rem;
        font-weight: 900;
        cursor: pointer;
        transition: var(--ba-trans);
        font-family: inherit;
        letter-spacing: 0.06em;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(30,64,175,0.3);
            color: #ffffff;
            text-decoration: none;
        }

    .btn-secondary {
        padding: 14px 28px;
        border-radius: var(--ba-radius);
        border: 2px solid var(--ba-border);
        background: var(--ba-bg);
        color: var(--ba-charcoal);
        font-size: 0.9rem;
        font-weight: 800;
        cursor: pointer;
        transition: var(--ba-trans);
        font-family: inherit;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .btn-secondary:hover {
            border-color: var(--ba-blue-lt);
            background: var(--ba-blue-bg);
            transform: translateY(-1px);
            color: var(--ba-blue);
            text-decoration: none;
        }

    /* ── Countdown overlay ── */
    #countdown-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(255,255,255,0.93);
        backdrop-filter: blur(6px);
        z-index: 300;
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }

        #countdown-overlay.visible {
            display: flex;
        }

    .countdown-num {
        font-size: clamp(6rem,20vw,12rem);
        font-weight: 900;
        color: var(--ba-black);
        line-height: 1;
        animation: baCountPop 0.85s cubic-bezier(0.34,1.56,0.64,1);
    }

    .countdown-label {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--ba-muted);
        margin-top: 16px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    /* ── Toast ── */
    #toast-container {
        position: fixed;
        bottom: 24px;
        right: 24px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        z-index: 500;
        pointer-events: none;
    }

    .toast {
        background: var(--ba-black);
        color: #ffffff;
        padding: 12px 20px;
        border-radius: var(--ba-radius-sm);
        font-size: 0.82rem;
        font-weight: 700;
        box-shadow: 0 6px 20px rgba(0,0,0,0.2);
        animation: baSlideInRight 0.3s cubic-bezier(0.34,1.56,0.64,1), baFadeOut 0.4s ease 2.5s forwards;
        border-left: 4px solid var(--ba-gold);
    }

        .toast.success {
            border-left-color: var(--ba-green-lt);
        }

        .toast.error {
            border-left-color: var(--ba-red-lt);
        }

        .toast.info {
            border-left-color: var(--ba-blue-lt);
        }

    /* ── @@keyframes ── */
    @@keyframes baSlideIn {
        from {
            opacity: 0;
            transform: translateY(20px) scale(0.97);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @@keyframes baFadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes baPop {
        0% {
            transform: scale(0.8);
            opacity: 0;
        }

        60% {
            transform: scale(1.08);
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes baCountPop {
        0% {
            transform: scale(0.4);
            opacity: 0;
        }

        60% {
            transform: scale(1.08);
            opacity: 1;
        }

        100% {
            transform: scale(1);
        }
    }

    @@keyframes baShake {
        0%, 100% {
            transform: translateX(0);
        }

        20% {
            transform: translateX(-6px);
        }

        40% {
            transform: translateX(6px);
        }

        60% {
            transform: translateX(-4px);
        }

        80% {
            transform: translateX(4px);
        }
    }

    @@keyframes baCorrectPop {
        0% {
            transform: scale(1);
        }

        40% {
            transform: scale(1.04);
        }

        100% {
            transform: scale(1);
        }
    }

    @@keyframes baScaleIn {
        from {
            transform: scale(0.88);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes baSlideInRight {
        from {
            opacity: 0;
            transform: translateX(30px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes baFadeOut {
        to {
            opacity: 0;
            transform: translateX(20px);
        }
    }

    @@keyframes baWinner {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(217,119,6,0.4);
        }

        50% {
            box-shadow: 0 0 0 12px rgba(217,119,6,0);
        }
    }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        .battle-layout {
            grid-template-columns: 1fr;
            gap: 14px;
        }

        .vs-divider {
            padding: 8px 0;
        }

        .vs-text {
            width: 50px;
            height: 50px;
            font-size: 1.5rem;
        }

        .mc-grid {
            grid-template-columns: 1fr;
        }

        .multi-result-row {
            grid-template-columns: 1fr;
        }

        .vs-col {
            display: none;
        }

        .results-actions {
            flex-direction: column;
            align-items: center;
        }

        .results-card {
            padding: 28px 18px;
        }

        .global-hud {
            justify-content: center;
        }
    }
</style>

