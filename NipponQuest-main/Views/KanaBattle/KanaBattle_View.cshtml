@*
    ╔══════════════════════════════════════════════════════════════════╗
    ║  KanaBattle_View.cshtml  —  AI Battle Arena                    ║
    ║  Controller : KanaBattleController → Battle() / MainView()     ║
    ║  Route      : /KanaBattle/Battle?difficulty=&script=           ║
    ║  API        : GET /KanaBlitz/GetWords?difficulty=&alphabet=     ║
    ║  API        : POST /KanaBlitz/SubmitScore                      ║
    ║  Model      : KanaBattleModel                                   ║
    ║  Purpose    : Head-to-head AI battle kana arena                 ║
    ║  Aesthetic  : White background · Black / Gold / White / Blue    ║
    ╚══════════════════════════════════════════════════════════════════╝
*@
@model NipponQuest.Models.KanaBattleModel
@{
    ViewData["Title"] = "KanaBattle — Arena";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var difficulty = Model?.Difficulty ?? "normal";
    var script = Model?.Script ?? "hiragana";
    var playerName = Model?.PlayerName ?? "Player 1";
    var isMulti = ViewBag.Multiplayer != null && (bool)ViewBag.Multiplayer;
    var player2Name = ViewBag.Player2Name as string ?? "AI Opponent";
}

<style>
    /* ══════════════════════════════════════════════════════════════
           NIPPONQUEST — KanaBattle AI Arena
           Palette : White bg · Black text · Gold accents · Blue action
        ══════════════════════════════════════════════════════════════ */
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');

    :root {
        --ba-bg: #ffffff;
        --ba-surface: #f8fafc;
        --ba-surface2: #f1f5f9;
        --ba-border: #e2e8f0;
        --ba-border2: #cbd5e1;
        --ba-black: #0f172a;
        --ba-charcoal: #1e293b;
        --ba-dark: #334155;
        --ba-muted: #64748b;
        --ba-faint: #94a3b8;
        --ba-gold: #d97706;
        --ba-gold-lt: #f59e0b;
        --ba-gold-bg: #fef3c7;
        --ba-gold-bd: #fcd34d;
        --ba-blue: #1e40af;
        --ba-blue-lt: #3b82f6;
        --ba-blue-bg: #eff6ff;
        --ba-blue-bd: #93c5fd;
        --ba-green: #065f46;
        --ba-green-lt: #10b981;
        --ba-green-bg: #ecfdf5;
        --ba-green-bd: #6ee7b7;
        --ba-red: #991b1b;
        --ba-red-lt: #ef4444;
        --ba-red-bg: #fff1f2;
        --ba-red-bd: #fca5a5;
        --ba-p1: #1e40af;
        --ba-p2: #991b1b;
        --ba-radius: 14px;
        --ba-radius-sm: 10px;
        --ba-radius-lg: 20px;
        --ba-shadow: 0 4px 16px rgba(15,23,42,0.08);
        --ba-shadow-lg: 0 8px 32px rgba(15,23,42,0.12);
        --ba-trans: all 0.22s cubic-bezier(0.4,0,0.2,1);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    .ba-page {
        background: var(--ba-bg);
        min-height: 100vh;
        color: var(--ba-black);
        font-family: 'Nunito', 'Segoe UI', sans-serif;
        padding-bottom: 80px;
    }

        .ba-page::before {
            content: '';
            display: block;
            height: 4px;
            background: linear-gradient(90deg, #0f172a 0%, #991b1b 30%, #d97706 60%, #1e40af 100%);
        }

    .ba-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 28px 16px;
    }

    /* ── Keyframes ── */
    @@keyframes baFadeUp {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes baScaleIn {
        0% {
            transform: scale(0.9);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes baShake {
        0%, 100% {
            transform: translateX(0);
        }

        10%, 50%, 90% {
            transform: translateX(-5px);
        }

        30%, 70% {
            transform: translateX(5px);
        }
    }

    @@keyframes baPopCorrect {
        0% {
            transform: scale(1);
        }

        40% {
            transform: scale(1.06);
        }

        100% {
            transform: scale(1);
        }
    }

    @@keyframes baComboFlash {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.25);
        }

        100% {
            transform: scale(1);
        }
    }

    @@keyframes baCountdownPop {
        0% {
            transform: scale(0.3);
            opacity: 0;
        }

        50% {
            transform: scale(1.2);
            opacity: 1;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes baSlideUp {
        0% {
            opacity: 0;
            transform: translateY(30px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes baVictoryBounce {
        0% {
            transform: scale(0);
            opacity: 0;
        }

        50% {
            transform: scale(1.15);
        }

        70% {
            transform: scale(0.95);
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes baHPDamage {
        0% {
            transform: scale(1);
        }

        30% {
            transform: scale(1.05);
            filter: brightness(1.2);
        }

        100% {
            transform: scale(1);
            filter: brightness(1);
        }
    }

    @@keyframes baPulseRed {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(239,68,68,0);
        }

        50% {
            box-shadow: 0 0 15px 5px rgba(239,68,68,0.3);
        }
    }

    @@keyframes baXPFloat {
        0% {
            opacity: 1;
            transform: translateY(0);
        }

        100% {
            opacity: 0;
            transform: translateY(-40px);
        }
    }

    @@keyframes baAIThink {
        0%, 100% {
            opacity: 0.3;
        }

        50% {
            opacity: 1;
        }
    }

    @@keyframes baSpin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    @@keyframes baTimerPulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.5;
        }
    }

    @@keyframes baDamageFlash {
        0% {
            background: rgba(239,68,68,0.1);
        }

        100% {
            background: transparent;
        }
    }

    /* ── Header ── */
    .arena-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 24px;
        padding-bottom: 18px;
        border-bottom: 1.5px solid var(--ba-border);
    }

    .arena-title-wrap h2 {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--ba-black);
        margin-bottom: 4px;
    }

    .arena-title-wrap .arena-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 4px;
    }

    .arena-tag {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 100px;
        font-size: 0.67rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

        .arena-tag.black {
            background: var(--ba-black);
            color: #fff;
        }

        .arena-tag.gold {
            background: var(--ba-gold-bg);
            color: var(--ba-gold);
            border: 1px solid var(--ba-gold-bd);
        }

        .arena-tag.blue {
            background: var(--ba-blue-bg);
            color: var(--ba-blue);
            border: 1px solid var(--ba-blue-bd);
        }

        .arena-tag.red {
            background: var(--ba-red-bg);
            color: var(--ba-red);
            border: 1px solid var(--ba-red-bd);
        }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--ba-muted);
        text-decoration: none;
        transition: var(--ba-trans);
        padding: 8px 16px;
        border-radius: var(--ba-radius-sm);
        border: 1.5px solid var(--ba-border);
        background: var(--ba-surface);
    }

        .back-link:hover {
            color: var(--ba-blue);
            border-color: var(--ba-blue-bd);
            background: var(--ba-blue-bg);
            transform: translateY(-1px);
        }

    /* ── VS Scoreboard ── */
    .vs-scoreboard {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 16px;
        align-items: center;
        margin-bottom: 28px;
        padding: 24px;
        background: var(--ba-surface);
        border: 1.5px solid var(--ba-border);
        border-radius: var(--ba-radius-lg);
        box-shadow: var(--ba-shadow);
    }

    .player-panel {
        text-align: center;
        padding: 16px;
        border-radius: var(--ba-radius);
        transition: var(--ba-trans);
        position: relative;
    }

        .player-panel.p1 {
            background: var(--ba-blue-bg);
            border: 1.5px solid var(--ba-blue-bd);
        }

        .player-panel.p2 {
            background: var(--ba-red-bg);
            border: 1.5px solid var(--ba-red-bd);
        }

        .player-panel .p-name {
            font-size: 0.72rem;
            font-weight: 900;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .player-panel.p1 .p-name {
            color: var(--ba-blue);
        }

        .player-panel.p2 .p-name {
            color: var(--ba-red);
        }

        .player-panel .p-hp-text {
            font-size: 2.2rem;
            font-weight: 900;
            line-height: 1;
        }

        .player-panel.p1 .p-hp-text {
            color: var(--ba-p1);
        }

        .player-panel.p2 .p-hp-text {
            color: var(--ba-p2);
        }

    /* Health Bar */
    .hp-bar-track {
        width: 100%;
        height: 10px;
        background: var(--ba-surface2);
        border-radius: 5px;
        margin-top: 10px;
        overflow: hidden;
    }

    .hp-bar-fill {
        height: 100%;
        border-radius: 5px;
        transition: width 0.5s ease;
    }

    .p1 .hp-bar-fill {
        background: linear-gradient(90deg, var(--ba-blue-lt), var(--ba-blue));
    }

    .p2 .hp-bar-fill {
        background: linear-gradient(90deg, var(--ba-red-lt), var(--ba-red));
    }

    .hp-bar-fill.low {
        animation: baPulseRed 1s infinite;
    }

    .player-panel .p-stats {
        display: flex;
        gap: 12px;
        justify-content: center;
        margin-top: 10px;
    }

    .player-panel .p-stat {
        font-size: 0.68rem;
        font-weight: 700;
        color: var(--ba-muted);
    }

        .player-panel .p-stat span {
            font-weight: 900;
        }

    .player-panel.p1 .p-stat span {
        color: var(--ba-blue);
    }

    .player-panel.p2 .p-stat span {
        color: var(--ba-red);
    }

    .vs-divider {
        text-align: center;
    }

    .vs-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: var(--ba-gold-bg);
        border: 2px solid var(--ba-gold-bd);
        font-size: 1.1rem;
        font-weight: 900;
        color: var(--ba-gold);
    }

    /* ── Timer Bar ── */
    .timer-bar-track {
        width: 100%;
        height: 6px;
        background: var(--ba-surface2);
        border-radius: 3px;
        margin-bottom: 20px;
        overflow: hidden;
    }

    .timer-bar-fill {
        height: 100%;
        border-radius: 3px;
        transition: width 0.3s linear, background 0.3s ease;
        background: linear-gradient(90deg, var(--ba-gold-lt), var(--ba-gold));
    }

        .timer-bar-fill.danger {
            background: linear-gradient(90deg, var(--ba-red-lt), var(--ba-red));
            animation: baTimerPulse 0.5s ease infinite;
        }

    /* ── AI Thinking Indicator ── */
    .ai-thinking {
        display: none;
        text-align: center;
        margin-bottom: 16px;
        padding: 10px;
        background: var(--ba-red-bg);
        border: 1px solid var(--ba-red-bd);
        border-radius: var(--ba-radius-sm);
    }

        .ai-thinking .ai-dots {
            display: inline-flex;
            gap: 6px;
        }

        .ai-thinking .ai-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--ba-red);
            animation: baAIThink 1s ease infinite;
        }

            .ai-thinking .ai-dot:nth-child(2) {
                animation-delay: 0.2s;
            }

            .ai-thinking .ai-dot:nth-child(3) {
                animation-delay: 0.4s;
            }

    /* ── Question Card ── */
    .question-card {
        background: var(--ba-surface);
        border: 1.5px solid var(--ba-border);
        border-radius: var(--ba-radius-lg);
        padding: 36px 28px;
        text-align: center;
        margin-bottom: 24px;
        box-shadow: var(--ba-shadow);
    }

        .question-card.animate-in {
            animation: baScaleIn 0.3s ease both;
        }

    .question-label {
        font-size: 0.65rem;
        font-weight: 900;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ba-faint);
        margin-bottom: 10px;
    }

    .question-kana {
        font-size: clamp(2.8rem, 7vw, 4.5rem);
        font-weight: 900;
        color: var(--ba-black);
        line-height: 1.1;
        margin-bottom: 8px;
        word-break: break-all;
    }

    .question-meaning {
        font-size: 0.85rem;
        color: var(--ba-muted);
    }

    .question-category {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 100px;
        font-size: 0.62rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ba-faint);
        background: var(--ba-surface2);
        margin-top: 10px;
    }

    /* ── Options ── */
    .options-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
        margin-bottom: 24px;
    }

    .option-btn {
        background: var(--ba-bg);
        border: 2px solid var(--ba-border);
        border-radius: var(--ba-radius);
        padding: 18px 16px;
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--ba-charcoal);
        cursor: pointer;
        transition: var(--ba-trans);
        text-align: center;
        font-family: 'Nunito', sans-serif;
    }

        .option-btn:hover:not(:disabled) {
            border-color: var(--ba-blue-lt);
            background: var(--ba-blue-bg);
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(30,64,175,0.12);
        }

        .option-btn:disabled {
            cursor: not-allowed;
            opacity: 0.7;
        }

        .option-btn.correct {
            border-color: var(--ba-green-lt);
            background: var(--ba-green-bg);
            color: var(--ba-green);
            animation: baPopCorrect 0.4s ease;
        }

        .option-btn.incorrect {
            border-color: var(--ba-red-lt);
            background: var(--ba-red-bg);
            color: var(--ba-red);
            animation: baShake 0.4s ease;
        }

        .option-btn.reveal-correct {
            border-color: var(--ba-green-lt);
            background: var(--ba-green-bg);
            color: var(--ba-green);
        }

    /* ── Setup Panel (pre-battle) ── */
    #setup-panel {
        background: var(--ba-surface);
        border: 1.5px solid var(--ba-border);
        border-radius: var(--ba-radius-lg);
        padding: 32px 28px;
        margin-bottom: 24px;
        box-shadow: var(--ba-shadow);
        animation: baFadeUp 0.4s ease both;
    }

    .section-label {
        font-size: 0.67rem;
        font-weight: 900;
        letter-spacing: 0.2em;
        color: var(--ba-blue);
        text-transform: uppercase;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .section-label::after {
            content: '';
            flex: 1;
            height: 1.5px;
            background: linear-gradient(90deg, var(--ba-border2), transparent);
        }

    .choice-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 12px;
        margin-bottom: 28px;
    }

    .choice-card {
        background: var(--ba-bg);
        border: 2px solid var(--ba-border);
        border-radius: var(--ba-radius);
        padding: 18px 12px;
        cursor: pointer;
        transition: var(--ba-trans);
        text-align: center;
        user-select: none;
    }

        .choice-card:hover {
            border-color: var(--ba-blue-lt);
            background: var(--ba-blue-bg);
            transform: translateY(-2px);
        }

        .choice-card.active {
            border-color: var(--ba-blue);
            background: var(--ba-blue-bg);
            box-shadow: 0 0 0 3px rgba(30,64,175,0.15);
            transform: translateY(-2px);
        }

        .choice-card[data-diff="easy"].active {
            border-color: var(--ba-green-lt);
            background: var(--ba-green-bg);
            box-shadow: 0 0 0 3px rgba(16,185,129,0.15);
        }

        .choice-card[data-diff="normal"].active {
            border-color: var(--ba-blue-lt);
            background: var(--ba-blue-bg);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
        }

        .choice-card[data-diff="hard"].active {
            border-color: var(--ba-gold);
            background: var(--ba-gold-bg);
            box-shadow: 0 0 0 3px rgba(217,119,6,0.18);
        }

        .choice-card[data-diff="insanity"].active {
            border-color: var(--ba-red-lt);
            background: var(--ba-red-bg);
            box-shadow: 0 0 0 3px rgba(239,68,68,0.15);
        }

        .choice-card .c-icon {
            font-size: 2rem;
            margin-bottom: 8px;
            display: block;
        }

        .choice-card .c-label {
            font-weight: 800;
            font-size: 0.92rem;
            color: var(--ba-charcoal);
            display: block;
        }

        .choice-card .c-sub {
            font-size: 0.7rem;
            color: var(--ba-muted);
            margin-top: 4px;
            display: block;
        }

        .choice-card .c-hp {
            font-size: 0.65rem;
            color: var(--ba-faint);
            margin-top: 4px;
            display: block;
        }

    .start-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 16px 36px;
        border-radius: 14px;
        font-weight: 900;
        font-size: 1rem;
        letter-spacing: 0.06em;
        border: none;
        cursor: pointer;
        transition: var(--ba-trans);
        background: linear-gradient(135deg, #991b1b, var(--ba-gold));
        color: #fff;
        box-shadow: 0 6px 20px rgba(153,27,27,0.25);
        position: relative;
        overflow: hidden;
        font-family: 'Nunito', sans-serif;
    }

        .start-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(153,27,27,0.35);
            filter: brightness(1.05);
        }

        .start-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    /* ── Feedback Toast ── */
    .feedback-toast {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) scale(0);
        font-size: 2rem;
        font-weight: 900;
        padding: 20px 40px;
        border-radius: var(--ba-radius-lg);
        z-index: 9999;
        pointer-events: none;
        transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
        font-family: 'Nunito', sans-serif;
    }

        .feedback-toast.show {
            transform: translate(-50%, -50%) scale(1);
        }

        .feedback-toast.correct-toast {
            background: var(--ba-green-bg);
            color: var(--ba-green);
            border: 2px solid var(--ba-green-bd);
        }

        .feedback-toast.incorrect-toast {
            background: var(--ba-red-bg);
            color: var(--ba-red);
            border: 2px solid var(--ba-red-bd);
        }

        .feedback-toast.combo-toast {
            background: var(--ba-gold-bg);
            color: var(--ba-gold);
            border: 2px solid var(--ba-gold-bd);
        }

        .feedback-toast.damage-toast {
            background: var(--ba-red-bg);
            color: var(--ba-red);
            border: 2px solid var(--ba-red-bd);
        }

    .xp-float {
        position: fixed;
        font-weight: 900;
        font-size: 1.1rem;
        pointer-events: none;
        z-index: 9998;
        animation: baXPFloat 1s ease forwards;
    }

        .xp-float.damage {
            color: var(--ba-red-lt);
        }

        .xp-float.heal {
            color: var(--ba-green-lt);
        }

    /* ── Countdown ── */
    #countdown-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255,255,255,0.95);
        z-index: 10000;
        justify-content: center;
        align-items: center;
    }

    .countdown-number {
        font-size: 8rem;
        font-weight: 900;
        color: var(--ba-black);
        animation: baCountdownPop 0.8s ease;
    }

    .countdown-go {
        font-size: 5rem;
        font-weight: 900;
        color: var(--ba-gold);
        animation: baCountdownPop 0.8s ease;
    }

    /* ── Results ── */
    #results-screen {
        display: none;
        animation: baSlideUp 0.5s ease both;
    }

    .results-card {
        background: var(--ba-surface);
        border: 1.5px solid var(--ba-border);
        border-radius: var(--ba-radius-lg);
        padding: 40px 32px;
        text-align: center;
        box-shadow: var(--ba-shadow-lg);
    }

    .results-icon {
        font-size: 4rem;
        margin-bottom: 16px;
        animation: baVictoryBounce 0.6s ease both;
    }

    .results-title {
        font-size: 2rem;
        font-weight: 900;
