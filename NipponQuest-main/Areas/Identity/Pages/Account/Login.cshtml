@page
@model LoginModel

@{
    ViewData["Title"] = "Welcome Back";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">

<style>
    body { font-family: 'Nunito', sans-serif !important; background: #f8fafc; }

    .auth-wrapper {
        min-height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 1rem;
        background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(14,165,233,0.07) 0%, transparent 70%), #f8fafc;
    }

    .auth-card {
        background: #ffffff;
        border: 2px solid #e2e8f0;
        border-radius: 28px;
        padding: 3.5rem 3rem;
        width: 100%;
        max-width: 520px;
        box-shadow: 0 12px 40px rgba(15, 23, 42, 0.06);
    }

    /* Inputs */
    .auth-input {
        font-family: 'Nunito', sans-serif !important;
        font-weight: 700;
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 14px !important;
        padding: 0.85rem 1rem;
        transition: border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
        color: #0f172a;
    }
    .auth-input::placeholder { color: #94a3b8; font-weight: 600; }
    .auth-input:focus {
        background: #ffffff;
        border-color: #0ea5e9;
        box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.1);
        outline: none;
        color: #0f172a;
    }
    .auth-input.is-invalid { border-color: #ef4444 !important; }
    .icon-pad-left  { padding-left: 2.8rem !important; }
    .icon-pad-right { padding-right: 2.8rem !important; }
    .auth-input-wrapper .bi { z-index: 4; font-size: 1.1rem; }

    /* Labels */
    .auth-label {
        font-family: 'Nunito', sans-serif !important;
        font-size: 0.65rem;
        font-weight: 900;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #64748b;
        margin-bottom: 0.4rem;
        display: block;
    }

    /* Google button */
    .btn-google {
        font-family: 'Nunito', sans-serif !important;
        background: #ffffff;
        color: #0f172a;
        border: 2px solid #e2e8f0 !important;
        border-radius: 14px !important;
        font-weight: 900;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
        padding: 0.85rem 1.5rem;
        transition: all 0.2s ease;
        box-shadow: 0 2px 8px rgba(15, 23, 42, 0.04);
    }
    .btn-google:hover {
        border-color: #cbd5e1 !important;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.08);
        transform: translateY(-1px);
    }
    .btn-google svg { width: 20px; height: 20px; margin-right: 10px; }

    /* Divider */
    .auth-divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 1.5rem 0;
    }
    .auth-divider hr { flex-grow: 1; margin: 0; border-color: #e2e8f0; opacity: 1; }
    .auth-divider span {
        font-size: 0.6rem;
        font-weight: 900;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #94a3b8;
        white-space: nowrap;
    }

    /* Submit button */
    .btn-login {
        font-family: 'Nunito', sans-serif !important;
        font-weight: 900;
        font-size: 0.85rem;
        letter-spacing: 1.5px;
        border-radius: 14px !important;
        border: none !important;
        padding: 0.9rem 1.5rem;
        background: linear-gradient(135deg, #0ea5e9, #2563eb);
        color: #ffffff;
        box-shadow: 0 4px 20px rgba(14, 165, 233, 0.3);
        transition: all 0.25s ease;
    }
    .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(14, 165, 233, 0.4);
        color: #ffffff;
    }

    /* Switch */
    .form-switch .form-check-input {
        width: 2.4em;
        height: 1.2em;
        margin-left: -2.5em;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='-4 -4 8 8'%3e%3ccircle r='3' fill='rgba(0, 0, 0, 0.25)'/%3e%3c/svg%3e");
        background-color: #e2e8f0;
        border-color: #e2e8f0;
        cursor: pointer;
    }
    .form-switch .form-check-input:checked {
        background-color: #0ea5e9;
        border-color: #0ea5e9;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='-4 -4 8 8'%3e%3ccircle r='3' fill='%23fff'/%3e%3c/svg%3e");
    }

    /* Validation */
    .text-danger { font-size: 0.72rem; font-weight: 700; }

    /* Links */
    .auth-link {
        color: #0ea5e9;
        font-weight: 800;
        text-decoration: none;
        transition: color 0.2s;
    }
    .auth-link:hover { color: #2563eb; text-decoration: underline; }

    .auth-footer-link {
        color: #0ea5e9;
        font-weight: 900;
        text-decoration: none;
        border-bottom: 1px solid rgba(14, 165, 233, 0.3);
        transition: border-color 0.2s;
    }
    .auth-footer-link:hover { border-color: #0ea5e9; color: #0ea5e9; }

    @@media (max-width: 576px) {
        .auth-card { padding: 2.5rem 1.5rem; border-radius: 20px; }
    }
</style>

<div class="auth-wrapper">
    <div class="auth-card">

        <!-- Header -->
        <div class="text-center mb-5">
            <div class="mb-3 d-inline-flex align-items-center justify-content-center rounded-circle shadow-sm"
                 style="width: 72px; height: 72px; background: #e0f2fe; border: 1px solid #bae6fd;">
                <i class="bi bi-door-open-fill" style="font-size: 2.25rem; color: #0ea5e9;"></i>
            </div>
            <h1 class="fw-black mb-1" style="letter-spacing: -1.5px; font-size: 2.5rem; color: #0f172a;">Welcome Back</h1>
            <p class="fw-bold mb-0" style="color: #94a3b8; font-size: 0.85rem;">Continue your quest to the top.</p>
        </div>

        <!-- Google OAuth -->
        <div class="mb-3">
            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                @foreach (var provider in Model.ExternalLogins!)
                {
                    @if (provider.Name == "Google")
                    {
                        <button type="submit" name="provider" value="@provider.Name" class="btn btn-google w-100 d-flex align-items-center justify-content-center">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48">
                                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                            </svg>
                            Continue with Google
                        </button>
                    }
                }
            </form>
        </div>

        <!-- Divider -->
        <div class="auth-divider">
            <hr /><span>or use credentials</span><hr />
        </div>

        <!-- Login Form -->
        <form id="account" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

            <!-- Email -->
            <div class="mb-4">
                <label asp-for="Input.Email" class="auth-label">Email Address</label>
                <div class="position-relative auth-input-wrapper">
                    <i class="bi bi-envelope-fill position-absolute top-50 start-0 translate-middle-y ms-3 text-muted opacity-50"></i>
                    <input asp-for="Input.Email"
                           class="form-control auth-input icon-pad-left"
                           autocomplete="username"
                           aria-required="true"
                           placeholder="name@example.com" />
                </div>
                <span asp-validation-for="Input.Email" class="text-danger mt-1 d-block"></span>
            </div>

            <!-- Password -->
            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <label asp-for="Input.Password" class="auth-label mb-0">Password</label>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="auth-link small">Forgot?</a>
                </div>
                <div class="position-relative auth-input-wrapper">
                    <i class="bi bi-shield-lock-fill position-absolute top-50 start-0 translate-middle-y ms-3 text-muted opacity-50"></i>
                    <input asp-for="Input.Password"
                           type="password"
                           class="form-control auth-input icon-pad-left icon-pad-right"
                           autocomplete="current-password"
                           aria-required="true"
                           placeholder="••••••••"
                           id="pwdLogin" />
                    <button type="button"
                            class="btn position-absolute top-50 end-0 translate-middle-y border-0 text-muted opacity-50 px-3"
                            onclick="togglePwd('pwdLogin')" tabindex="-1">
                        <i class="bi bi-eye-fill"></i>
                    </button>
                </div>
                <span asp-validation-for="Input.Password" class="text-danger mt-1 d-block"></span>
            </div>

            <!-- Remember Me -->
            <div class="form-check form-switch mb-4 d-flex align-items-center">
                <input class="form-check-input" type="checkbox" role="switch" asp-for="Input.RememberMe" id="rememberSwitch">
                <label class="form-check-label small fw-bold text-dark ms-2 mt-1 cursor-pointer" for="rememberSwitch">
                    Keep me logged in
                </label>
            </div>

            <!-- Submit -->
            <button id="login-submit"
                    type="submit"
                    class="btn btn-login w-100 d-flex justify-content-center align-items-center gap-2">
                <span>ACCESS ACCOUNT</span>
                <i class="bi bi-arrow-right-short" style="font-size: 1.25rem;"></i>
            </button>
        </form>

        <!-- Footer -->
        <div class="text-center mt-5 pt-4" style="border-top: 2px solid #f1f5f9;">
            <p class="fw-bold mb-0" style="color: #94a3b8; font-size: 0.85rem;">
                New to NipponQuest?
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="auth-footer-link ms-1">Create a profile</a>
            </p>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePwd(id) {
            const input = document.getElementById(id);
            const icon = event.currentTarget.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye-fill', 'bi-eye-slash-fill');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye-slash-fill', 'bi-eye-fill');
            }
        }
    </script>
}
