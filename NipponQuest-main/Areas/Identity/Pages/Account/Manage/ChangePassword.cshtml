@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h3 class="fw-black text-dark mb-4">Change Password</h3>

<partial name="_StatusMessage" for="StatusMessage" />

<form id="change-password-form" method="post">
    <div class="form-floating mb-4">
        <input asp-for="Input.OldPassword" class="form-control form-control-lg custom-input" autocomplete="current-password" aria-required="true" placeholder="Please enter your old password." />
        <label asp-for="Input.OldPassword" class="form-label text-muted fw-bold ps-4">CURRENT PASSWORD</label>
        <span asp-validation-for="Input.OldPassword" class="text-danger small fw-bold mt-1 d-block"></span>
    </div>

    <div class="form-floating mb-4">
        <input asp-for="Input.NewPassword" class="form-control form-control-lg custom-input" autocomplete="new-password" aria-required="true" placeholder="Please enter your new password." />
        <label asp-for="Input.NewPassword" class="form-label text-muted fw-bold ps-4">NEW PASSWORD</label>
        <span asp-validation-for="Input.NewPassword" class="text-danger small fw-bold mt-1 d-block"></span>
    </div>

    <div class="form-floating mb-4">
        <input asp-for="Input.ConfirmPassword" class="form-control form-control-lg custom-input" autocomplete="new-password" aria-required="true" placeholder="Please confirm your new password." />
        <label asp-for="Input.ConfirmPassword" class="form-label text-muted fw-bold ps-4">CONFIRM NEW PASSWORD</label>
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small fw-bold mt-1 d-block"></span>
    </div>

    <button type="submit" class="btn btn-primary-blue rounded-pill px-5 py-3 fw-black shadow-sm text-uppercase tracking-wider hover-lift mt-2">
        Update Password
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <partial name="_ValidationScriptsPartial" />
}
