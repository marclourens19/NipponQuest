@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h3 class="fw-black text-dark mb-4">Explorer Profile</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-xl-9">
        <form id="profile-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold" role="alert"></div>
            
            <div class="mb-4">
                <label asp-for="Username" class="fw-black small text-muted text-uppercase mb-2 ms-1 tracking-wider"></label>
                <div class="position-relative">
                    <input asp-for="Username" class="form-control form-control-lg fw-black rounded-4 bg-light border-light-subtle shadow-sm custom-input pe-5" disabled />
                    <i class="bi bi-lock-fill position-absolute end-0 top-50 translate-middle-y me-4 text-muted opacity-75"></i>
                </div>
            </div>

            <div class="mb-5">
                <label asp-for="Input.PhoneNumber" class="fw-black small text-muted text-uppercase mb-2 ms-1 tracking-wider"></label>
                <input asp-for="Input.PhoneNumber" class="form-control form-control-lg fw-black rounded-4 bg-light border-light-subtle shadow-sm custom-input" placeholder="Add a phone number..." />
                <span asp-validation-for="Input.PhoneNumber" class="text-danger small fw-bold mt-2 d-block"></span>
            </div>

            <button id="update-profile-button" type="submit" class="btn btn-primary-blue rounded-pill fw-black px-5 py-3 shadow-sm text-uppercase tracking-wider hover-lift">
                SAVE CHANGES
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}