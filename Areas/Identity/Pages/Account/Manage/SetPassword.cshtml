@page
@model SetPasswordModel
@{
    ViewData["Title"] = "Set password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h3 class="fw-black text-dark mb-4">Set Password</h3>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="bg-info bg-opacity-10 text-info border border-info rounded-4 p-4 mb-4">
    <p class="fw-bold m-0"><i class="bi bi-info-circle-fill me-2"></i> You do not have a local username/password for this site. Add a local account so you can log in without an external login.</p>
</div>

<form id="set-password-form" method="post">
    <div class="form-floating mb-4">
        <input asp-for="Input.NewPassword" class="form-control form-control-lg custom-input" autocomplete="new-password" placeholder="Please enter your new password." />
        <label asp-for="Input.NewPassword" class="form-label text-muted fw-bold ps-4">NEW PASSWORD</label>
        <span asp-validation-for="Input.NewPassword" class="text-danger small fw-bold mt-1 d-block"></span>
    </div>

    <div class="form-floating mb-4">
        <input asp-for="Input.ConfirmPassword" class="form-control form-control-lg custom-input" autocomplete="new-password" placeholder="Please confirm your new password." />
        <label asp-for="Input.ConfirmPassword" class="form-label text-muted fw-bold ps-4">CONFIRM NEW PASSWORD</label>
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small fw-bold mt-1 d-block"></span>
    </div>

    <button type="submit" class="btn btn-primary-blue rounded-pill px-5 py-3 fw-black shadow-sm text-uppercase tracking-wider hover-lift mt-2">
        Set Password
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}