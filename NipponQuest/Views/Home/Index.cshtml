@using Microsoft.AspNetCore.Identity
@using NipponQuest.Models
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Home Page";
    var currentUser = await UserManager.GetUserAsync(User);
}

<div class="text-center">
    <h1 class="display-4 fw-bold text-primary">Welcome to NipponQuest</h1>
    <p class="lead">Track your journey, master your sets, and level up your brand.</p>
</div>

@* 🛠 SECURE DEVELOPER CONSOLE *@
@* This section only renders if YOU are the one logged in *@
@if (currentUser != null && currentUser.GamerTag == "Yugenclad")
{
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card border-warning bg-dark text-warning shadow-lg">
                    <div class="card-header border-warning d-flex align-items-center">
                        <i class="bi bi-terminal-fill me-2"></i>
                        <span class="fw-bold text-uppercase" style="letter-spacing: 1px;">Developer Admin Tools</span>
                    </div>
                    <div class="card-body text-center">
                        <p class="text-white-50 small">Testing Level Up logic & HUD animations</p>
                        
                        <div class="d-grid gap-2">
                            <a asp-controller="Home" asp-action="AddTestXP" class="btn btn-outline-warning btn-lg">
                                <i class="bi bi-plus-circle-fill"></i> Gain +25 XP
                            </a>
                        </div>
                        
                        <div class="mt-3 small">
                            <span class="badge bg-secondary">Security Active: GamerTag Check</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}


<div class="row text-center mt-4">
    <div class="col-md-4">
        <div class="h1 text-primary"><i class="bi bi-translate"></i></div>
        <h3>Vocabulary</h3>
        <p>Master core words and phrases through spaced repetition tracking.</p>
    </div>
    <div class="col-md-4">
        <div class="h1 text-primary"><i class="bi bi-pen"></i></div>
        <h3>Kanji</h3>
        <p>Track your progress through the Joyo Kanji and JLPT levels.</p>
    </div>
    <div class="col-md-4">
        <div class="h1 text-primary"><i class="bi bi-ear"></i></div>
        <h3>Immersion</h3>
        <p>Log your reading and listening hours to see your fluency grow.</p>
    </div>
</div>
