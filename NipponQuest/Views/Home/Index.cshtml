@using Microsoft.AspNetCore.Identity
@model IReadOnlyList<Octokit.GitHubCommit>
@inject UserManager<NipponQuest.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = "Master Japanese - NipponQuest";
    var currentUser = await UserManager.GetUserAsync(User);

    // Helper function to format numbers into k, M, B strings
    string FormatNumber(long num)
    {
        if (num >= 1000000000)
            return (num / 1000000000D).ToString("0.#") + "B+";
        if (num >= 1000000)
            return (num / 1000000D).ToString("0.#") + "M+";
        if (num >= 1000)
            return (num / 1000D).ToString("0.#") + "k+";

        return num.ToString();
    }

    // Convert ViewBag values safely
    long rawXp = ViewBag.TotalXP != null ? (long)ViewBag.TotalXP : 0;
    int rawStreaks = ViewBag.ActiveStreaks != null ? (int)ViewBag.ActiveStreaks : 0;

    string totalXpDisplay = FormatNumber(rawXp);
    string activeStreaksDisplay = FormatNumber(rawStreaks);
}

<!-- 1. HERO SECTION -->
<div class="hero-section py-5 text-center bg-white" style="margin-top: -16px;">
    <div class="container py-5">
        <span class="badge rounded-pill text-primary border px-3 py-2 fw-bold mb-4 shadow-sm" style="letter-spacing: 0.05em; background: #f0f9ff; border-color: rgba(14, 165, 233, 0.2) !important;">
            THE WORLD'S #1 JAPANESE LEARNING ARENA
        </span>
        <h1 class="fw-black text-dark hero-headline" style="font-size: 5.25rem;">
            Master Japanese.<br><span class="text-primary hero-glow-text">Become Legend.</span>
        </h1>
        <p class="lead text-muted fw-bold mb-5 mt-4 px-md-5 mx-auto hero-supporting" style="max-width: 780px; font-size: 1.3rem;">
            Experience the only platform where <strong>competitive gaming mechanics</strong> accelerate language mastery.
            Build real-world fluency through high-stakes arenas, climb elite leagues, and conquer Nihongo with an unbreakable daily streak.
        </p>
        <div class="d-flex flex-column align-items-center gap-3">
            <div class="d-flex justify-content-center gap-3">
                @if (currentUser != null)
                {
                    <a asp-controller="Leagues" asp-action="Index" class="btn btn-primary btn-lg rounded-pill fw-black px-5 py-3 btn-cta-premium quest-pulse">RESUME YOUR QUEST</a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-lg rounded-pill fw-black px-5 py-3 btn-cta-premium quest-pulse">START YOUR JOURNEY — IT'S 100% FREE</a>
                }
            </div>
            <p class="small text-muted mt-2 fw-bold trust-signal">
                <i class="bi bi-shield-check text-success me-1"></i> INSTANT ACCESS &bull; NO CREDIT CARD &bull; JOIN IN 30 SECONDS
            </p>
        </div>
    </div>
</div>

<!-- 2. GLOBAL STATS BAR (Abbreviated Data) -->
<div class="bg-white border-top border-bottom py-4">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-md-4">
                <div class="stat-number fw-black">@totalXpDisplay</div>
                <div class="text-muted fw-bold small text-uppercase">Total XP Earned</div>
            </div>
            <div class="col-md-4">
                <div class="stat-number fw-black text-primary">850k+</div>
                <div class="text-muted fw-bold small text-uppercase">Kanji Defeated</div>
            </div>
            <div class="col-md-4">
                <div class="stat-number fw-black">@activeStreaksDisplay</div>
                <div class="text-muted fw-bold small text-uppercase">Active Streaks</div>
            </div>
        </div>
    </div>
</div>

<!-- 3. FEATURE CARDS -->
<div class="landing-section bg-soft-blue-gradient">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-black text-dark h1" style="letter-spacing: -0.02em;">Engineered for Fluency</h2>
            <p class="text-muted fw-bold" style="font-size: 1.1rem;">Where gaming immersion meets scientific language acquisition.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="static-card p-4 h-100 border-0">
                    <div class="feature-icon"><i class="bi bi-controller"></i></div>
                    <h4 class="fw-black mb-3">Gamified Curriculum</h4>
                    <p class="text-muted">Conquer Hiragana, Katakana, and Kanji through dynamic challenges that transform learning into a rewarding progression system.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="static-card p-4 h-100 border-0">
                    <div class="feature-icon"><i class="bi bi-trophy-fill"></i></div>
                    <h4 class="fw-black mb-3">Competitive Arenas</h4>
                    <p class="text-muted">Test your skills against players in your skill bracket. Battle for promotion every Sunday at midnight in high-intensity weekly leagues.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="static-card p-4 h-100 border-0">
                    <div class="feature-icon"><i class="bi bi-fire"></i></div>
                    <h4 class="fw-black mb-3">Fluency Engine</h4>
                    <p class="text-muted">Stay consistent with an unbreakable streak system. Earn Gold to customize your legacy and dominate the global rankings.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 4. CENTERED INTERACTIVE TRIAL -->
<div class="landing-section bg-white">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="trial-card p-5 h-100" id="quiz-container">
                    <div id="quiz-game">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h3 class="fw-black m-0">Interactive Trial: <span class="text-primary">Hiragana Blitz</span></h3>
                            <span class="badge bg-soft-blue text-primary fw-black" id="quiz-progress">QUEST 1 / 5</span>
                        </div>
                        
                        <div class="bg-light rounded-4 p-5 mb-4 text-center position-relative" style="min-height: 300px;">
                            <!-- Feedback Overlay -->
                            <div id="feedback-check" class="position-absolute top-50 start-50 translate-middle d-none" style="z-index: 10;">
                                <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem; filter: drop-shadow(0 0 15px rgba(25, 135, 84, 0.4));"></i>
                            </div>

                            <span class="display-1 fw-black d-block mb-2" id="hiragana-display">あ</span>
                            <p class="text-muted fw-bold">What is this character?</p>
                            
                            <div class="d-flex justify-content-center gap-3 mt-4" id="answer-buttons">
                                <!-- Buttons generated by JS -->
                            </div>
                        </div>
                        <p class="text-center text-muted small fw-bold"><i class="bi bi-info-circle me-1"></i> Correct answers prove your mastery to the Arena.</p>
                    </div>

                    <!-- Result Screen -->
                    <div id="quiz-result" class="d-none text-center py-4">
                        <div class="mb-4">
                            <div class="gold-coin mb-3" style="width: 80px; height: 80px; font-size: 2.2rem; border-width: 4px; box-shadow: 0 6px 0 #B45309;"></div>
                            <h2 class="fw-black text-dark">Quest Complete!</h2>
                            <p class="display-4 fw-black text-primary" id="final-score">0 / 5</p>
                        </div>
                        <div class="bg-soft-blue p-4 rounded-4 mb-4 border border-primary border-opacity-10 shadow-sm mx-auto" style="max-width: 550px;">
                            <p class="fw-bold text-dark mb-0 text-center">
                                For completing this quest, a registered account would have earned:
                            </p>
                            <div class="d-flex justify-content-center align-items-center gap-4 mt-3">
                                <span class="fw-black text-xp-yellow" style="font-size: 1.3rem;">
                                    <i class="bi bi-lightning-charge-fill"></i> 10 EXP
                                </span>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="gold-coin" style="width: 24px; height: 24px; font-size: 0.7rem; border-width: 1.5px; box-shadow: 0 2px 0 #B45309;"></div>
                                    <span class="fw-black gold-text-match" style="font-size: 1.3rem;">5 GOLD</span>
                                </div>
                            </div>
                        </div>
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-lg rounded-pill fw-black px-5 btn-cta-premium">CLAIM YOUR REWARDS</a>
                        <button onclick="resetQuiz()" class="btn btn-link d-block mx-auto mt-3 text-muted fw-bold text-decoration-none opacity-50 hover-opacity-100">TRY AGAIN</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 5. TIER TRACK & REWARD HUB -->
<div class="landing-section bg-white pt-0">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-black text-dark display-5 mb-3" style="letter-spacing: -0.03em;">Ascend the <span class="text-primary">Competitive Tiers</span></h2>
            <p class="text-muted fw-bold mx-auto" style="max-width: 650px; font-size: 1.1rem;">Unlock elite status as you progress through 9 tiers of mastery.</p>
        </div>

        <div class="tier-track-wrapper mb-5">
            <div class="tier-track d-flex justify-content-between align-items-center gap-2 py-4 hide-scrollbar">
                <div class="tier-item"><span class="rank-text legend">LEGEND</span></div>
                <div class="tier-connector"></div>
                <div class="tier-item"><span class="rank-text dragon">DRAGON</span></div>
                <div class="tier-connector"></div>
                <div class="tier-item"><span class="rank-text challenger">CHALLENGER</span></div>
                <div class="tier-connector"></div>
                <div class="tier-item"><span class="rank-text master">MASTER</span></div>
                <div class="tier-connector"></div>
                <div class="tier-item"><span class="rank-text diamond">DIAMOND</span></div>
                <div class="tier-connector"></div>
                <div class="tier-item"><span class="rank-text gold">GOLD</span></div>
                <div class="tier-connector"></div>
                <div class="tier-item"><span class="rank-text iron">IRON</span></div>
                <div class="tier-connector"></div>
                <div class="tier-item"><span class="rank-text wood">WOOD</span></div>
                <div class="tier-connector"></div>
                <div class="tier-item"><span class="rank-text sprout">SPROUT</span></div>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="premium-reward-hud p-5 border-0 shadow-lg text-center" style="border-radius: 40px;">
                    <div class="row align-items-center">
                        <div class="col-md-4">
                            <div class="d-flex justify-content-center align-items-center gap-3">
                                <div class="xp-badge-lg">XP</div>
                                <i class="bi bi-plus-lg text-primary fs-3"></i>
                                <div class="gold-coin" style="width: 70px; height: 70px; font-size: 1.8rem; border-width: 4px; box-shadow: 0 6px 0 #B45309;"></div>
                            </div>
                        </div>
                        <div class="col-md-8 text-md-start mt-4 mt-md-0 ps-md-5">
                            <h3 class="fw-black text-dark mb-2">Unlock Premium Rewards</h3>
                            <p class="text-muted fw-bold mb-3">Every Sunday at midnight, turn your accumulated skill into Gold. Unlock profile customizations and exclusive shop items to secure your legacy.</p>
                            <div class="d-inline-flex align-items-center gap-2 bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill fw-black small shadow-sm">
                                <i class="bi bi-lightning-charge-fill text-warning"></i> TOP 20% PROMOTE TO NEXT LEAGUE
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 6. MASTERY ROADMAP (JLPT) -->
<div class="landing-section bg-soft-blue-gradient">
    <div class="container text-center">
        <h2 class="fw-black mb-5">The Roadmap to 100% Mastery</h2>
        <div class="roadmap-container d-flex justify-content-between align-items-center px-md-5">
            <div class="roadmap-line"></div>
            <div class="roadmap-node" title="N5: The Basics">N5</div>
            <div class="roadmap-node node-locked" title="N4: Conversation">N4</div>
            <div class="roadmap-node node-locked" title="N3: Intermediate">N3</div>
            <div class="roadmap-node node-locked" title="N2: Business">N2</div>
            <div class="roadmap-node node-locked" title="N1: Native Legend">N1</div>
        </div>
        <p class="mt-5 text-muted fw-bold">Unlock new JLPT modules as you climb the competitive ranks.</p>
    </div>
</div>

<!-- 7. THE QUEST LOG -->
<div class="quest-timeline">
    @if (Model != null && Model.Any())
    {
        @foreach (var commit in Model)
        {
            <div class="timeline-item d-flex gap-4 mb-4">
                <div class="timeline-dot-wrapper">
                    <div class="timeline-dot" style="background-color: #0d6efd;"></div>
                </div>
                <div class="timeline-content">
                    <h5 class="fw-black mb-1 text-dark">
                        @commit.Commit.Message.Split('\n')[0]
                    </h5>
                    <p class="small text-muted fw-bold mb-0">
                        QUEST COMPLETED • @commit.Commit.Author.Date.ToString("MMM dd, yyyy")
                    </p>
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-muted fw-bold">No recent quests found in the log.</p>
    }
</div>

<!-- 8. FINAL CTA -->
<div class="landing-section bg-white pt-0">
    <div class="container">
        <div class="cta-banner text-center text-white shadow-lg quest-pulse">
            <h2 class="fw-black mb-3" style="letter-spacing: -0.03em;">Ready to start your quest?</h2>
            <p class="lead mb-4 opacity-90 fw-bold">Join learners worldwide mastering Japanese the competitive way.</p>
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-light btn-lg rounded-pill fw-black px-5 py-3 text-primary shadow-sm btn-sheen">
                CLAIM YOUR PLACE IN THE ARENA
            </a>
            <p class="mt-4 small fw-bold" style="opacity: 0.6; letter-spacing: 0.05em;">100% FREE FOREVER</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const quizData = [
            { q: 'あ', a: 'A', options: ['KA', 'A', 'SA'] },
            { q: 'い', a: 'I', options: ['I', 'E', 'O'] },
            { q: 'う', a: 'U', options: ['N', 'U', 'RA'] },
            { q: 'え', a: 'E', options: ['RO', 'RU', 'E'] },
            { q: 'お', a: 'O', options: ['O', 'WA', 'WO'] }
        ];

        let currentQuest = 0;
        let score = 0;

        function initQuiz() {
            const quest = quizData[currentQuest];
            document.getElementById('quiz-progress').innerText = `QUEST ${currentQuest + 1} / 5`;
            document.getElementById('hiragana-display').innerText = quest.q;
        
            const btnContainer = document.getElementById('answer-buttons');
            btnContainer.innerHTML = '';
        
            quest.options.forEach(opt => {
                const btn = document.createElement('button');
                btn.className = 'btn btn-outline-primary fw-black px-4 py-2 trial-answer-btn';
                btn.innerText = opt;
                btn.onclick = () => checkAnswer(opt, btn);
                btnContainer.appendChild(btn);
            });
        }

        function checkAnswer(choice, btn) {
            const correct = quizData[currentQuest].a;
            const allBtns = document.querySelectorAll('.trial-answer-btn');
        
            allBtns.forEach(b => b.disabled = true);

            if (choice === correct) {
                score++;
                btn.classList.remove('btn-outline-primary');
                btn.classList.add('btn-success', 'text-white');
                showFeedback();
            } else {
                btn.classList.remove('btn-outline-primary');
                btn.classList.add('btn-danger', 'text-white');
                setTimeout(nextQuestion, 600);
            }
        }

        function showFeedback() {
            const feedback = document.getElementById('feedback-check');
            feedback.classList.remove('d-none');
            
            setTimeout(() => {
                feedback.style.opacity = '0';
                feedback.style.transition = 'opacity 0.3s ease';
                
                setTimeout(() => {
                    feedback.classList.add('d-none');
                    feedback.style.opacity = '1';
                    nextQuestion();
                }, 300);
            }, 900);
        }

        function nextQuestion() {
            currentQuest++;
            if (currentQuest < quizData.length) {
                initQuiz();
            } else {
                showResults();
            }
        }

        function showResults() {
            document.getElementById('quiz-game').classList.add('d-none');
            document.getElementById('quiz-result').classList.remove('d-none');
            document.getElementById('final-score').innerText = `${score} / 5`;
        }

        function resetQuiz() {
            currentQuest = 0;
            score = 0;
            document.getElementById('quiz-game').classList.remove('d-none');
            document.getElementById('quiz-result').classList.add('d-none');
            initQuiz();
        }

        document.addEventListener('DOMContentLoaded', initQuiz);
    </script>
}