                    <i class="bi bi-hammer fs-3 text-primary"></i>
                </div>
            </div>
            
            <div class="row g-5">
                <!-- Vertical Study Path -->
                <div class="col-md-7">
                    <h6 class="fw-black small text-muted mb-4 text-uppercase" style="letter-spacing: 0.1em;">
                        <i class="bi bi-map me-2"></i>Learning Path
                    </h6>
                    <div id="quest-curriculum" class="study-path-line">
                        <!-- Steps injected here via JS -->
                    </div>
                </div>

                <!-- Mastery Objectives -->
                <div class="col-md-5">
                    <h6 class="fw-black small text-muted mb-4 text-uppercase" style="letter-spacing: 0.1em;">
