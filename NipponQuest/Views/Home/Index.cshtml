@using Microsoft.AspNetCore.Identity
@inject UserManager<NipponQuest.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = "Home Page";
    var currentUser = await UserManager.GetUserAsync(User);
}

<div class="hero-section py-5 text-center">
    <div class="container py-5">
        <h1 class="fw-black text-dark" style="font-size: 4.5rem; letter-spacing: -3px; line-height: 1;">
            Master Japanese.<br><span class="text-primary">Become Legend.</span>
        </h1>
        <p class="lead text-muted fw-bold mb-5 mt-3 px-md-5">
            The competitive way to learn Nihongo. Climb the ranks from Sprout to Legend while building your daily streak and competing with players worldwide.
        </p>
        <div class="d-flex justify-content-center gap-3">
            @if (currentUser != null)
            {
                <a asp-controller="Leagues" asp-action="Index" class="btn btn-cta-main py-3 px-5">Enter the Arena</a>
            }
            else
            {
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-cta-main py-3 px-5">Start Your Quest</a>
            }
        </div>
    </div>
</div>

@if (currentUser != null && currentUser.GamerTag == "Yugenclad")
{
    <div class="container mt-5">
        <div class="game-card bg-dark text-warning border-warning">
            <div class="d-flex align-items-center mb-4 border-bottom border-secondary pb-3">
                <i class="bi bi-terminal-fill me-3 fs-4"></i>
                <span class="fw-black text-uppercase">Dev Command Center</span>
            </div>
            <div class="row g-3">
                <div class="col-md-3"><a asp-action="AddTestXP" class="btn btn-outline-warning btn-sm w-100 fw-bold">+25 XP</a></div>
                <div class="col-md-3"><a asp-action="AddTestGold" class="btn btn-outline-warning btn-sm w-100 fw-bold">+100 Gold</a></div>
                <div class="col-md-6">
                    <form asp-action="SetTestLeague" method="post" class="d-flex gap-2">
                        <select name="rank" class="form-select bg-transparent text-warning border-warning btn-sm" asp-items="Html.GetEnumSelectList<LeagueRank>()"></select>
                        <button type="submit" class="btn btn-warning btn-sm fw-black px-4">CHANGE RANK</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}