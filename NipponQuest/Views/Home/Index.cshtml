<!-- 7. THE QUEST LOG -->
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Centered Header -->
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center gap-2 mb-2">
                    <span class="badge rounded-pill bg-soft-blue text-primary px-3 fw-black">LIVE FEED</span>
                    <div class="spinner-grow spinner-grow-sm text-primary" role="status"></div>
                </div>
                <h2 class="fw-black display-6 mb-2">GitHub <span class="text-primary">Updates</span></h2>
                <p class="text-muted fw-bold small mb-3">Real-time developer logs from the NipponQuest repository.</p>
                <a href="https://github.com/marclourens19/NipponQuest" target="_blank" class="btn btn-outline-dark btn-sm rounded-pill px-4 fw-black">
                    <i class="bi bi-github me-2"></i>VIEW REPO
                </a>
            </div>

            <!-- Condensed Log Container -->
            <div class="quest-log-container p-3 bg-white rounded-4 shadow-sm border">
                @if (Model != null && Model.Any())
                {
                    @foreach (var commit in Model)
                    {
                        var msg = commit.Commit.Message.ToLower();
    
                        // Simplified Tool Icons
                        var icon = "bi-hammer"; // Default tool
    
                        if (msg.Contains("feat") || msg.Contains("add")) { icon = "bi-hammer"; }
                        else if (msg.Contains("fix") || msg.Contains("bug")) { icon = "bi-wrench-adjustable"; }
                        else if (msg.Contains("ui") || msg.Contains("css") || msg.Contains("layout")) { icon = "bi-gear-wide-connected"; }

                        <div class="commit-item d-flex gap-3 pb-3 mb-3 border-bottom last-child-border-0">
                            <div class="icon-box shadow-sm rounded-3 d-flex align-items-center justify-content-center bg-light" style="width: 42px; height: 42px; flex-shrink: 0;">
                                <i class="bi @icon text-primary fs-5"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h6 class="fw-black mb-0 text-dark small" style="line-height: 1.4;">
                                        @commit.Commit.Message.Split('\n')[0]
                                    </h6>
                                    <span class="badge bg-light text-muted border fw-bold ms-2" style="font-size: 0.6rem;">
                                        @commit.Sha.Substring(0, 7).ToUpper()
                                    </span>
                                </div>
                                <p class="small text-muted fw-bold mb-0" style="font-size: 0.7rem;">
                                    <span class="text-primary">QUEST COMPLETED</span> • @commit.Commit.Author.Date.ToString("MMM dd, yyyy")
                                </p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="bi bi-cloud-slash fs-1 text-light"></i>
                        <p class="text-muted fw-bold small">Connecting to HQ...</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- 8. FINAL CTA -->
<div class="landing-section bg-white py-5">
    <div class="container">
        <div class="cta-banner text-center text-white shadow-lg quest-pulse">
            <h2 class="fw-black mb-3" style="letter-spacing: -0.03em;">Ready to start your quest?</h2>
            <p class="lead mb-4 opacity-90 fw-bold">Join learners worldwide mastering Japanese the competitive way.</p>
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-light btn-lg rounded-pill fw-black px-5 py-3 text-primary shadow-sm btn-sheen">
                CLAIM YOUR PLACE IN THE ARENA
            </a>
            <p class="mt-4 small fw-bold" style="opacity: 0.6; letter-spacing: 0.05em;">100% FREE FOREVER</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const quizData = [
            { q: 'あ', a: 'A', options: ['KA', 'A', 'SA'] },
            { q: 'い', a: 'I', options: ['I', 'E', 'O'] },
            { q: 'う', a: 'U', options: ['N', 'U', 'RA'] },
            { q: 'え', a: 'E', options: ['RO', 'RU', 'E'] },
            { q: 'お', a: 'O', options: ['O', 'WA', 'WO'] }
        ];

        let currentQuest = 0;
        let score = 0;

        function initQuiz() {
            const quest = quizData[currentQuest];
            const progress = document.getElementById('quiz-progress');
            if(progress) progress.innerText = `QUEST ${currentQuest + 1} / 5`;
            
            const display = document.getElementById('hiragana-display');
            if(display) display.innerText = quest.q;
        
            const btnContainer = document.getElementById('answer-buttons');
            if(!btnContainer) return;
            btnContainer.innerHTML = '';
        
            quest.options.forEach(opt => {
                const btn = document.createElement('button');
                btn.className = 'btn btn-outline-primary fw-black px-4 py-2 trial-answer-btn';
                btn.innerText = opt;
                btn.onclick = () => checkAnswer(opt, btn);
                btnContainer.appendChild(btn);
            });
        }

        function checkAnswer(choice, btn) {
            const correct = quizData[currentQuest].a;
            const allBtns = document.querySelectorAll('.trial-answer-btn');
        
            allBtns.forEach(b => b.disabled = true);

            if (choice === correct) {
                score++;
                btn.classList.remove('btn-outline-primary');
                btn.classList.add('btn-success', 'text-white');
                showFeedback();
            } else {
                btn.classList.remove('btn-outline-primary');
                btn.classList.add('btn-danger', 'text-white');
                setTimeout(nextQuestion, 600);
            }
        }

        function showFeedback() {
            const feedback = document.getElementById('feedback-check');
            if(!feedback) return;
            feedback.classList.remove('d-none');
            
            setTimeout(() => {
                feedback.style.opacity = '0';
                feedback.style.transition = 'opacity 0.3s ease';
                
                setTimeout(() => {
                    feedback.classList.add('d-none');
                    feedback.style.opacity = '1';
                    nextQuestion();
                }, 300);
            }, 900);
        }

        function nextQuestion() {
            currentQuest++;
            if (currentQuest < quizData.length) {
                initQuiz();
            } else {
                showResults();
            }
        }

        function showResults() {
            const game = document.getElementById('quiz-game');
            const result = document.getElementById('quiz-result');
            const finalScore = document.getElementById('final-score');
            if(game) game.classList.add('d-none');
            if(result) result.classList.remove('d-none');
            if(finalScore) finalScore.innerText = `${score} / 5`;
        }

        function resetQuiz() {
            currentQuest = 0;
            score = 0;
            const game = document.getElementById('quiz-game');
            const result = document.getElementById('quiz-result');
            if(game) game.classList.remove('d-none');
            if(result) result.classList.add('d-none');
            initQuiz();
        }

        function showLevelInfo(level) {
            const card = document.getElementById('quest-requirement-card');
            const title = document.getElementById('quest-title');
            const badgeContainer = document.getElementById('rank-badge-container');
            const curriculum = document.getElementById('quest-curriculum');
            const goals = document.getElementById('quest-goals');

            const requirements = {
                'N5': {
                    color: '#22c55e',
                    rankClass: 'sprout',
                    rankName: 'Beginner Mastery',
                    path: [
                        { step: 'KANA ORIGINS', desc: 'Master Hiragana & Katakana stroke order and phonetics.' },
                        { step: 'GENKI I: PHASE 1', desc: 'Complete Lessons 1-6: Greetings, shopping, and daily time.' },
                        { step: 'GENKI I: PHASE 2', desc: 'Complete Lessons 7-12: Te-form, physical descriptions, and past tense.' },
                        { step: 'PARTICLE SYNC', desc: 'Internalize WA, GA, O, NI, and DE usage in basic sentences.' }
                    ],
                    goals: ['100 Kanji (The Foundation)', '800 Vocabulary Words', 'N5 Mock Exam (90%+ Accuracy)']
                },
                'N4': {
                    color: '#0ea5e9',
                    rankClass: 'diamond',
                    rankName: 'Elementary Mastery',
                    path: [
                        { step: 'GENKI II: CORE', desc: 'Complete Lessons 13-23: Potential, Volitional, and Passive forms.' },
                        { step: 'KEIGO BASICS', desc: 'Understand the hierarchy of polite and humble Japanese.' },
                        { step: 'CONJUNCTION MASTERY', desc: 'Connect complex thoughts using NNODE, TAME, and SHI.' }
                    ],
                    goals: ['300 Kanji (Standard Set)', '1,500 Vocabulary Words', 'Understand 70% of Children\'s Media']
                },
                'N3': {
                    color: '#a855f7',
                    rankClass: 'master',
                    rankName: 'Intermediate Mastery',
                    path: [
                        { step: 'THE TOBIRA BRIDGE', desc: 'Transition from textbook Japanese to natural phrasing.' },
                        { step: 'CASUAL NUANCE', desc: 'Master gender-neutral vs. masculine/feminine casual speech.' },
                        { step: 'TRANSITIVE SYNC', desc: 'Perfect the Transitive vs. Intransitive verb pairings.' }
                    ],
                    goals: ['650 Kanji (Intermediate Set)', '3,750 Vocabulary Words', 'Read basic NHK News Web Easy']
                },
                'N2': {
                    color: '#ef4444',
                    rankClass: 'dragon',
                    rankName: 'Advanced Mastery',
                    path: [
                        { step: 'LITERARY FLOW', desc: 'Understand formal written Japanese used in essays and news.' },
                        { step: 'BUSINESS PROTOCOL', desc: 'Master Sonkeigo and Kenjougo for professional environments.' },
                        { step: 'SOCIAL CONTEXT', desc: 'Detect sarcasm, irony, and cultural subtext in conversation.' }
                    ],
                    goals: ['1,000 Kanji (Advanced Set)', '6,000 Vocabulary Words', 'Work in a Japanese Environment']
                },
                'N1': {
                    color: '#fbbf24',
                    rankClass: 'legend',
                    rankName: 'Legendary Mastery',
                    path: [
                        { step: 'NATIVE IMMERSION', desc: 'Read complex literature and philosophical essays.' },
                        { step: 'CLASSICAL BASICS', desc: 'Understand the roots of modern grammar and archaic kanji.' },
                        { step: 'DIALECT FLUENCY', desc: 'Recognize major regional dialects (Kansai-ben, etc.).' }
                    ],
                    goals: ['2,000+ Kanji (Total Master Set)', '10,000+ Vocabulary Words', '100% Native Fluency']
                }
            };

            const data = requirements[level];
            
            card.style.borderTop = `8px solid ${data.color}`;
            title.innerText = level + " Certification Quest";
            badgeContainer.innerHTML = `<span class="rank-text ${data.rankClass}">${data.rankName}</span>`;
            
            curriculum.innerHTML = data.path.map((p, i) => `
                <div class="path-step mb-4" style="--step-color: ${data.color}">
                    <div class="fw-black text-uppercase mb-1" style="font-size: 0.7rem; color: ${data.color}; letter-spacing: 0.05em;">Step 0${i+1}: ${p.step}</div>
                    <div class="fw-bold text-dark small" style="line-height: 1.4;">${p.desc}</div>
                </div>
            `).join('');

            goals.innerHTML = data.goals.map(g => `
                <div class="p-3 rounded-4 bg-light d-flex align-items-center gap-3 border border-white shadow-sm">
                    <i class="bi bi-check-circle-fill fs-5" style="color: ${data.color}"></i>
                    <span class="fw-black text-dark small">${g}</span>
                </div>
            `).join('');

            card.style.display = 'block';
            card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        document.addEventListener('DOMContentLoaded', initQuiz);
    </script>
}