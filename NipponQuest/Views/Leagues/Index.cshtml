@model NipponQuest.Models.LeagueDashboardViewModel
@{
    ViewData["Title"] = "Leagues";
    var player = Model.CurrentUser;
    int totalUsers = 1240;
}

<div class="container mt-4 mb-5">
    <div class="mb-5 pb-4 border-bottom text-center d-flex flex-column align-items-center">
        <h1 class="fw-black text-dark m-0" style="font-size: 4.5rem; letter-spacing: -3px; line-height: 1;">LEAGUES</h1>
        <span class="brand-japanese-sub" style="font-size: 1.1rem; color: #0ea5e9; margin-top: 0;">リーグ (Rīgu)</span>
    </div>

    <div class="row g-5">
        <div class="col-xl-4 col-lg-5">
            <h3 class="fw-black text-dark text-uppercase mb-4 text-center" style="letter-spacing: -1px;">Path to Legend</h3>
            <div class="d-flex flex-column hide-scrollbar" style="max-height: 80vh; overflow-y: auto;">
                @foreach (var rank in Enum.GetValues(typeof(LeagueRank)).Cast<LeagueRank>().Reverse())
                {
                    var isActive = (rank == player.CurrentLeague);
                    <div class="static-card mb-3 @(isActive ? "border-primary shadow-sm" : "opacity-60")" style="background:#fff; border:2px solid #f1f5f9; border-radius:24px; padding:15px 24px;">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-3">
                                <span class="rank-text @rank.ToString().ToLower()">@rank</span>
                                <div class="small fw-bold text-muted" style="line-height: 1.2;">
                                    @GetRankFullJapanese(rank)<br />
                                    <span style="font-size: 0.65rem; color: #94a3b8; text-transform:uppercase;">@GetRankRomaji(rank)</span>
                                </div>
                            </div>
                            <div class="text-end">
                                <span class="fw-bold text-dark">@GetWeeklyGold(rank)</span>
                                <div class="gold-coin"></div>
                                <div class="weekly-reward-spacing" style="margin-top: 5px;">
                                    <span class="text-muted d-block fw-bold" style="font-size: 7px; letter-spacing: 0.5px;">WEEKLY REWARD</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="col-xl-5 col-lg-7">
            <div class="static-card h-100 d-flex flex-column border-0 shadow-sm arena-border-@player.CurrentLeague.ToString().ToLower()" style="background: #ffffff; border-radius: 24px; padding: 24px;">
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                    <h2 class="text-dark fw-black m-0">@player.CurrentLeague.ToString().ToUpper() ARENA</h2>
                    <div class="badge rounded-pill px-3 py-2 fw-bold text-dark bg-warning border shadow-sm">
                        <i class="bi bi-clock-fill"></i> @(2)d 14h REMAINING
                    </div>
                </div>

                <div class="p-4 rounded-4 text-center mb-4 bg-white border shadow-sm">
                    <div class="text-muted fw-black small text-uppercase mb-1">Your Current Standing</div>
                    <div class="fw-black text-dark" style="font-size: 6rem; line-height: 1;">#@Model.ArenaRank</div>
                    <div class="mt-2 text-success fw-bold">
                        <i class="bi bi-caret-up-fill"></i> 2 Places Climbed
                    </div>
                </div>

                <div class="w-100 mb-4 d-flex flex-column gap-2">
                    @{
                        int totalArena = Model.ArenaRivals.Count;
                        int promoteIdx = (int)Math.Ceiling(totalArena * 0.1);
                        int demoteIdx = totalArena - (int)Math.Ceiling(totalArena * 0.3);
                    }

                    @for (int i = 0; i < totalArena; i++)
                    {
                        var rival = Model.ArenaRivals[i];
                        string zoneClass = i < promoteIdx ? "promote-zone" : (i >= demoteIdx ? "demote-zone" : "safe-zone");

                        <div class="sb-player-row-static p-3 @zoneClass @(rival.IsCurrentUser ? "border-primary bg-light" : "")" style="border-radius:18px; margin-bottom:8px; display:flex; justify-content:space-between; align-items:center; border: 1px solid #f1f5f9;">
                            <div class="d-flex align-items-center gap-3">
                                <span class="fw-black">#@(i + 1)</span>
                                <span class="fw-bold">@rival.User.GamerTag @(rival.IsCurrentUser ? "(YOU)" : "")</span>
                                @if (i < promoteIdx)
                                {
                                    <span class="badge bg-success small">PROMOTION</span>
                                }
                                @if (i >= demoteIdx)
                                {
                                    <span class="badge bg-danger small">DEMOTION</span>
                                }
                            </div>
                            <span class="fw-black">@rival.User.WeeklyXP XP</span>
                        </div>
                    }
                </div>

                <div class="mt-auto">
                    <button class="btn btn-primary btn-lg w-100 rounded-pill fw-black py-3 shadow-lg" style="background: linear-gradient(135deg, #1e3a8a, #0ea5e9); border:none;">
                        <i class="bi bi-lightning-charge-fill" style="color: #fbbf24;"></i> EARN MORE XP!
                    </button>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-12 d-flex flex-column gap-4">
            <div class="static-card text-center py-4 text-white border-0 shadow-sm" style="border-radius:24px; background: linear-gradient(135deg, #1e3a8a, #0ea5e9);">
                <p class="small fw-black text-uppercase opacity-75 mb-1">Overall Global Standing</p>
                <h3 class="fw-black m-0" style="font-family: 'Nunito';">#@Model.ArenaRank / @totalUsers</h3>
            </div>

            <div class="static-card shadow-sm border-light" style="background:#fff; border-radius:24px; padding:24px;">
                <h5 class="fw-bold text-center text-uppercase small text-muted pb-2 border-bottom mb-3">Top 3 Highest Levels</h5>
                @for (int i = 0; i < Model.LevelLeaderboard.Take(3).Count(); i++)
                {
                    var top = Model.LevelLeaderboard.ElementAt(i);
                    <div class="d-flex justify-content-between align-items-center p-2 mb-1 bg-light rounded-3">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fs-4">@(i == 0 ? "👑" : i == 1 ? "🥈" : "🥉")</span>
                            <span class="fw-bold text-dark small">@top.User.GamerTag</span>
                        </div>
                        <span class="level-label-sync small">LV.@top.User.Level</span>
                    </div>
                }
            </div>

            <div class="static-card shadow-sm border-light" style="background:#fff; border-radius:24px; padding:24px;">
                <h5 class="fw-bold text-center text-uppercase small text-muted pb-2 border-bottom mb-3">Top 3 Streak Holders</h5>
                @{
                    var streakHeads = Model.LevelLeaderboard.OrderByDescending(x => x.User.LoginStreak).Take(3).ToList();
                }
                @for (int i = 0; i < streakHeads.Count; i++)
                {
                    var top = streakHeads[i];
                    <div class="d-flex justify-content-between align-items-center p-2 mb-1 bg-light rounded-3">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fs-4">@(i == 0 ? "👑" : i == 1 ? "🥈" : "🥉")</span>
                            <span class="fw-bold text-dark small">@top.User.GamerTag</span>
                        </div>
                        <div class="d-flex align-items-center gap-1">
                            <i class="bi bi-fire streak-flame-active"></i>
                            <span class="fw-black text-danger small" style="color: #f97316 !important;">@top.User.LoginStreak</span>
                        </div>
                    </div>
                }
            </div>

            <div class="static-card text-white shadow-lg border-0 p-4" style="background: linear-gradient(135deg, #1e3a8a, #0ea5e9); border-radius: 24px;">
                <h6 class="fw-black text-uppercase small opacity-75 mb-3">What are Leagues?</h6>
                <p class="fw-black m-0" style="font-size: 1.1rem; line-height: 1.2;">Do lessons. Earn XP. Compete.</p>
                <p class="small mt-2 mb-0 opacity-90">Complete lessons to climb your Arena. Top players promote every week!</p>
            </div>
        </div>
    </div>
</div>

@functions {
    public string GetRankFullJapanese(LeagueRank rank) => rank switch
    {
        LeagueRank.Legend => "伝説 (でんせつ)",
        LeagueRank.Dragon => "龍 (りゅう)",
        LeagueRank.Master => "師匠 (ししょう)",
        LeagueRank.Emerald => "翡翠 (ひすい)",
        LeagueRank.Diamond => "金剛 (こんごう)",
        LeagueRank.Gold => "黄金 (おうごん)",
        LeagueRank.Iron => "鉄 (てつ)",
        LeagueRank.Wood => "木 (き)",
        LeagueRank.Sprout => "芽 (め)",
        _ => "修行者"
    };
    public string GetRankRomaji(LeagueRank rank) => rank switch
    {
        LeagueRank.Legend => "Densetsu",
        LeagueRank.Dragon => "Ryū",
        LeagueRank.Master => "Shishō",
        LeagueRank.Emerald => "Hisui",
        LeagueRank.Diamond => "Kongō",
        LeagueRank.Gold => "Ōgon",
        LeagueRank.Iron => "Tetsu",
        LeagueRank.Wood => "Ki",
        LeagueRank.Sprout => "Me",
        _ => "Senshu"
    };
    public int GetWeeklyGold(LeagueRank rank) => rank switch
    {
        LeagueRank.Legend => 425,
        LeagueRank.Dragon => 300,
        LeagueRank.Sprout => 25,
        _ => ((int)rank) * 25 + 25
    };
}