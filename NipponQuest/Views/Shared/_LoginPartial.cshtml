@using Microsoft.AspNetCore.Identity
@using NipponQuest.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav d-flex flex-row align-items-center gap-3">
    @if (SignInManager.IsSignedIn(User))
    {
        var player = await UserManager.GetUserAsync(User);
        var currentRankClass = player?.LeagueIconClass ?? "sprout";

        <li class="nav-item">
            <div class="hud-bubble">
                <div class="d-flex align-items-center gap-2 pe-3 border-end border-light">
                    <a asp-controller="Leagues" asp-action="Index" class="text-decoration-none">
                        <span class="rank-text @currentRankClass">
                            @(player?.CurrentLeague.ToString() ?? "SPROUT")
                        </span>
                    </a>
                    
                    <div class="hud-text-bold px-1" style="display: flex; align-items: baseline; gap: 2px;">
                        <span>LV.</span>
                        <span style="font-size: 105%;">@(player?.Level ?? 1)</span>
                    </div>
                    
                    <div class="d-flex align-items-center gap-1 ps-1">
                        <span class="hud-text-bold">@(player?.Gold ?? 0)</span>
                        <div class="gold-coin"></div>
                    </div>
                </div>

                <div class="exp-container ms-3" style="width: 140px;">
                    <div class="d-flex justify-content-between px-1 mb-1">
                        <span class="exp-label">EXP</span>
                        <span class="exp-label">@(player?.XPPercentage ?? 0)%</span>
                    </div>
                    <div class="progress" style="height: 10px; background: rgba(0,0,0,0.06); border-radius: 20px;">
                        <div class="progress-bar bg-info" style="width: @(player?.XPPercentage ?? 0)%;"></div>
                    </div>
                </div>
            </div>
        </li>

        <li class="nav-item ms-1">
            <div class="welcome-user-card px-4">
                <span class="hud-text-bold" style="font-size: 0.9rem;">
                    Welcome, <a asp-area="Identity" asp-page="/Account/Manage/Index" class="text-primary text-decoration-none fw-black">@player?.GamerTag</a>
                </span>
            </div>
        </li>

        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="logout-bubble-wrapper border-0">
                    <span class="logout-text">LOGOUT</span>
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="auth-bubble px-4 text-decoration-none fw-black" asp-area="Identity" asp-page="/Account/Login">
                <span class="auth-text-blue">LOGIN</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="auth-bubble px-4 text-decoration-none fw-black" asp-area="Identity" asp-page="/Account/Register">
                <span class="auth-text-dark">REGISTER</span>
            </a>
        </li>
    }
</ul>