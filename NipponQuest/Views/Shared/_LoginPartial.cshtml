@using Microsoft.AspNetCore.Identity
@using NipponQuest.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        var player = await UserManager.GetUserAsync(User);

        <li class="nav-item d-flex align-items-center">
            <span class="badge rounded-pill bg-primary me-1">Lv. @(player?.Level ?? 1)</span>
            <span class="badge rounded-pill bg-warning text-dark me-1">@(player?.Gold ?? 0) G</span>
            <span class="badge rounded-pill bg-info text-dark me-3">@(player?.TotalEXP ?? 0) XP</span>
        
            <a class="nav-link text-dark fw-bold" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                Welcome, @(player?.GamerTag ?? "User")!
            </a>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
    }
</ul>