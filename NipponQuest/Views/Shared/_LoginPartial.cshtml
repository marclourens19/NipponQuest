@using Microsoft.AspNetCore.Identity
@using NipponQuest.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        var player = await UserManager.GetUserAsync(User);

        <li class="nav-item d-flex align-items-center">
            <div class="d-flex align-items-center bg-light-subtle rounded-pill px-3 py-1 border border-secondary-subtle shadow-sm">
                
                <div class="d-flex align-items-center gap-1 pe-3 border-end" style="border-color: rgba(0,0,0,0.1) !important;">
                    <span class="badge rounded-pill bg-primary shadow-sm" style="font-size: 0.7rem; padding: 0.5em 0.8em; line-height: 1;">
                        Lv. @(player?.Level ?? 1)
                    </span>
                    <span class="badge rounded-pill bg-warning text-dark shadow-sm" style="font-size: 0.7rem; padding: 0.5em 0.8em; line-height: 1;">
                        @(player?.Gold ?? 0) G
                    </span>
                </div>

                <div class="d-flex flex-column ms-3" style="width: 130px;">
                    <div class="d-flex justify-content-between px-1" style="font-size: 0.65rem; font-weight: 800; letter-spacing: 0.05em; line-height: 1.2;">
                        <span class="text-info">EXP</span>
                        <span class="text-muted" style="font-weight: 600;">@(player?.CurrentXP ?? 0) / @(player?.RequiredXP ?? 100)</span>
                    </div>
                    <div class="progress shadow-sm" style="height: 10px; background-color: rgba(0,0,0,0.15); border-radius: 10px; margin-top: 1px; border: 1px solid rgba(0,0,0,0.05);">
                        <div class="progress-bar bg-info progress-bar-striped progress-bar-animated"
                             role="progressbar"
                             style="width: @(player?.XPPercentage ?? 0)%; border-radius: 10px; box-shadow: 0 0 8px rgba(13, 202, 240, 0.4);"
                             aria-valuenow="@(player?.CurrentXP ?? 0)"
                             aria-valuemin="0"
                             aria-valuemax="@(player?.RequiredXP ?? 100)">
                        </div>
                    </div>
                </div>
            </div>
        
            <a class="nav-link text-dark fw-bold ms-3" asp-area="Identity" asp-page="/Account/Manage/Index" style="font-size: 0.85rem;">
                Welcome, <span class="text-primary">@(player?.GamerTag ?? "User")</span>!
            </a>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
    }
</ul>