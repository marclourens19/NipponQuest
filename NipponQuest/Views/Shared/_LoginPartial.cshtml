@using Microsoft.AspNetCore.Identity
@using NipponQuest.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        var player = await UserManager.GetUserAsync(User);

        <li class="nav-item d-flex align-items-center">
            <div class="d-flex align-items-center bg-light-subtle rounded-pill px-3 py-1 border border-secondary-subtle shadow-sm">
                
                <div class="d-flex align-items-center gap-2 pe-3 border-end" style="border-color: rgba(0,0,0,0.1) !important;">
                    
                    <span class="rank-text @(player?.LeagueIconClass ?? "sprout")"
                          style="font-size: 0.8rem; min-width: 90px; text-align: center;">
                        @(player?.CurrentLeague.ToString() ?? "SPROUT")
                    </span>

                    <span class="badge rounded-pill bg-primary shadow-sm" style="font-family: 'Nunito', sans-serif; font-size: 0.75rem; padding: 0.5em 0.9em;">
                        Lv. @(player?.Level ?? 1)
                    </span>
                    <span class="badge rounded-pill bg-warning text-dark shadow-sm" style="font-family: 'Nunito', sans-serif; font-size: 0.75rem; padding: 0.5em 0.9em;">
                        @(player?.Gold ?? 0) G
                    </span>
                </div>

                <div class="d-flex flex-column ms-3" style="width: 120px;">
                    <div class="d-flex justify-content-between px-1" style="font-family: 'Nunito', sans-serif; font-size: 0.6rem; font-weight: 900;">
                        <span class="text-info">EXP</span>
                        <span class="text-muted">@(player?.CurrentXP) / @(player?.RequiredXP)</span>
                    </div>
                    <div class="progress shadow-sm" style="height: 8px; background-color: rgba(0,0,0,0.1); border-radius: 10px;">
                        <div class="progress-bar bg-info progress-bar-striped progress-bar-animated"
                             style="width: @(player?.XPPercentage ?? 0)%; border-radius: 10px;">
                        </div>
                    </div>
                </div>
            </div>
        
            <a class="nav-link text-dark fw-bold ms-3" asp-area="Identity" asp-page="/Account/Manage/Index" style="font-size: 0.85rem;">
                Welcome, <span class="text-primary">@(player?.GamerTag ?? "User")</span>!
            </a>
        </li>

        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="nav-link btn btn-link text-dark border-0">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item"><a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Register</a></li>
        <li class="nav-item"><a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a></li>
    }
</ul>