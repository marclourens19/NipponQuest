@model IEnumerable<NipponQuest.Models.DeckViewModel>

<div class="container py-4 mt-4">
    <div class="d-flex justify-content-center mb-5">
        <div class="bg-dark rounded-bottom-4 px-4 py-2 shadow-lg border-1 border-secondary border-top-0" style="background: #1e1e1e !important;">
            <ul class="nav gap-4">
                <li class="nav-item"><a asp-action="Index" class="nav-link text-white fw-black small p-0 active">DECKS</a></li>
                <li class="nav-item"><a href="#" class="nav-link text-white fw-black small p-0 opacity-50">ADD</a></li>
                <li class="nav-item"><a href="#" class="nav-link text-white fw-black small p-0 opacity-50">BROWSE</a></li>
                <li class="nav-item"><a href="#" class="nav-link text-white fw-black small p-0 opacity-50">STATS</a></li>
                <li class="nav-item"><a href="#" class="nav-link text-white fw-black small p-0 opacity-50">SYNC</a></li>
            </ul>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-end mb-4">
        <h1 class="text-white fw-black m-0" style="font-size: 2.5rem;">Your Decks</h1>
        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn btn-cta-premium rounded-pill px-4 fw-black text-white">CREATE NEW</a>
            <button class="btn btn-outline-info rounded-pill px-4 fw-black" onclick="document.getElementById('ankiUpload').click()">IMPORT ANKI</button>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 rounded-4 shadow-lg static-card" style="background: #1a1a1a; border: 1px solid #2d2d2d !important;">
                    <div class="card-body p-4 text-white">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h4 class="fw-black mb-0">@item.Title</h4>
                            <span class="badge bg-primary rounded-pill px-3 fw-black">@item.CardCount</span>
                        </div>
                        <p class="text-muted small fw-bold">@item.Description</p>
                        <div class="d-grid gap-2 mt-4">
                            <a asp-action="Study" asp-route-id="@item.Id" class="btn btn-cta-premium btn-lg rounded-3 fw-black py-3 text-white">OPEN DECK</a>
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-dark border-secondary text-white fw-bold flex-grow-1 rounded-3">EDIT</a>
                                <a asp-action="AddCard" asp-route-deckId="@item.Id" class="btn btn-dark border-secondary text-white fw-bold flex-grow-1 rounded-3">ADD CARD</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete deck?')">
                                    <button class="btn btn-outline-danger rounded-3"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>