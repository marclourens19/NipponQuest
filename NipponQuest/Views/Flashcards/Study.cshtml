@model NipponQuest.Models.Flashcard

<div class="container mt-5">
    <div class="flashcard-container mx-auto" onclick="this.classList.toggle('flipped')">
        <div class="flashcard-inner">
            <div class="card-face card-front bg-dark border-primary shadow-lg d-flex flex-column align-items-center justify-content-center text-white">
                <span class="badge bg-primary mb-3 fw-black">FRONT</span>
                <h1 class="display-1 fw-black">@Model.FrontText</h1>
                <p class="text-muted mt-5 fw-bold">CLICK TO FLIP</p>
            </div>

            <div class="card-face card-back bg-dark border-success shadow-lg d-flex flex-column align-items-center justify-content-center text-white">
                <span class="badge bg-success mb-3 fw-black">ANSWER</span>
                <h1 class="display-3 fw-black">@Model.BackText</h1>
                <div class="mt-auto pb-4 w-100 px-2">
                    <form asp-action="SubmitResult" method="post" class="d-flex justify-content-between gap-2">
                        <input type="hidden" name="cardId" value="@Model.Id" />
                        <button name="result" value="again" class="btn anki-btn anki-btn-again flex-fill">Again</button>
                        <button name="result" value="hard" class="btn anki-btn anki-btn-hard flex-fill">Hard</button>
                        <button name="result" value="good" class="btn anki-btn anki-btn-good flex-fill">Good</button>
                        <button name="result" value="easy" class="btn anki-btn anki-btn-easy flex-fill">Easy</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .flashcard-container { perspective: 1000px; width: 450px; height: 350px; cursor: pointer; }
    .flashcard-inner { position: relative; width: 100%; height: 100%; transition: transform 0.6s; transform-style: preserve-3d; }
    .flashcard-container.flipped .flashcard-inner { transform: rotateY(180deg); }
    .card-face { position: absolute; width: 100%; height: 100%; backface-visibility: hidden; border-radius: 24px; border-width: 2px; }
    .card-back { transform: rotateY(180deg); }
    .anki-btn { border-radius: 50px !important; color: white !important; font-weight: 900 !important; border: none !important; background: #333 !important; transition: all 0.2s ease; font-size: 0.8rem; }
    .anki-btn:hover { transform: translateY(-2px); filter: brightness(1.2); }
    .anki-btn-again:hover { background: #ef4444 !important; }
    .anki-btn-hard:hover { background: #f59e0b !important; }
    .anki-btn-good:hover { background: #3b82f6 !important; }
    .anki-btn-easy:hover { background: #22c55e !important; }
</style>