@model NipponQuest.Models.Deck
<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden bg-dark text-white border-secondary" style="border: 1px solid #333 !important;">
                <div class="bg-primary p-4 text-center text-white">
                    <h3 class="fw-black m-0">Create New Deck</h3>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Create" method="post">
                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-black small">DECK TITLE</label>
                            <input asp-for="Title" class="form-control bg-dark text-white border-secondary auth-input" />
                        </div>
                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-black small">DESCRIPTION</label>
                            <textarea asp-for="Description" class="form-control bg-dark text-white border-secondary auth-input"></textarea>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-cta-premium btn-lg rounded-pill fw-black py-3 text-white">CREATE DECK</button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill fw-bold py-3">CANCEL</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>