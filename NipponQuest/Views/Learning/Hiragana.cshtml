<div class="container py-5">
    <div class="text-center mb-5">
        <span class="badge rounded-pill bg-soft-blue text-primary px-3 py-2 fw-black mb-3 shadow-sm">COURSE 01</span>
        <h1 class="fw-black display-4">Hiragana <span class="text-primary">Mastery</span></h1>
        <p class="lead text-muted fw-bold">Master the complete phonetic system. Click the icons to hear the audio breakdown.</p>
    </div>

    <!-- CHAPTER NAVIGATION -->
    <div class="d-flex justify-content-center mb-5 sticky-top py-3 bg-f8" style="top: 70px; z-index: 100;">
        <div class="bg-white p-2 rounded-pill shadow-sm border d-inline-flex gap-1 overflow-auto hide-scrollbar" style="max-width: 95vw;">
            <a href="#vowels" class="btn btn-primary rounded-pill px-3 fw-black btn-sm">Vowels</a>
            <a href="#k-g-row" class="btn btn-light rounded-pill px-3 fw-bold btn-sm">K & G</a>
            <a href="#s-z-row" class="btn btn-light rounded-pill px-3 fw-bold btn-sm">S & Z</a>
            <a href="#t-d-row" class="btn btn-light rounded-pill px-3 fw-bold btn-sm">T & D</a>
            <a href="#n-row" class="btn btn-light rounded-pill px-3 fw-bold btn-sm">N</a>
            <a href="#h-b-p-row" class="btn btn-light rounded-pill px-3 fw-bold btn-sm">H, B & P</a>
            <a href="#m-row" class="btn btn-light rounded-pill px-3 fw-bold btn-sm">M</a>
            <a href="#y-row" class="btn btn-light rounded-pill px-3 fw-bold btn-sm">Y</a>
            <a href="#r-row" class="btn btn-light rounded-pill px-3 fw-bold btn-sm">R</a>
            <a href="#w-n-row" class="btn btn-light rounded-pill px-3 fw-bold btn-sm">W & N</a>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        @{
            var hiraganaSections = new List<(string Title, string ID, (string Kana, string Romaji, string Note)[] Items)> {
                ("The Vowels", "vowels", new[] {
                    ("あ", "a", "Ah as in Father."), ("い", "i", "Ee as in Feet."),
                    ("う", "u", "Oo as in Boot."), ("え", "e", "Eh as in Met."), ("お", "o", "Oh as in Boat.")
                }),
                ("K & G Rows (Parallel)", "k-g-row", new[] {
                    ("か", "ka", "Kah as in Car."), ("が", "ga", "Gah as in Garden."),
                    ("き", "ki", "Kee as in Key."), ("ぎ", "gi", "Gee as in Geese."),
                    ("く", "ku", "Koo as in Cuckoo."), ("ぐ", "gu", "Goo as in Goose."),
                    ("け", "ke", "Keh as in Kelp."), ("げ", "ge", "Geh as in Get."),
                    ("こ", "ko", "Koh as in Co-op."), ("ご", "go", "Goh as in Golf.")
                }),
                ("S & Z Rows (Parallel)", "s-z-row", new[] {
                    ("さ", "sa", "Sah as in Sauna."), ("ざ", "za", "Zah as in Zara."),
                    ("し", "shi", "Shee as in Sheep."), ("じ", "ji", "Jee as in Jeep."),
                    ("す", "su", "Soo as in Soon."), ("ず", "zu", "Zoo as in Zoo."),
                    ("せ", "se", "Seh as in Set."), ("ぜ", "ze", "Zeh as in Zen."),
                    ("そ", "so", "Soh as in Soft."), ("ぞ", "zo", "Zoh as in Zone.")
                }),
                ("T & D Rows (Parallel)", "t-d-row", new[] {
                    ("た", "ta", "Tah as in Target."), ("だ", "da", "Dah as in Dad."),
                    ("ち", "chi", "Chee as in Cheese."), ("ぢ", "ji", "Jee as in Jeep."),
                    ("つ", "tsu", "Tsu as in Ea-ts-u."), ("づ", "zu", "Zoo as in Zoo."),
                    ("て", "te", "Teh as in Tell."), ("で", "de", "Deh as in Den."),
                    ("と", "to", "Toh as in Toe."), ("ど", "do", "Doh as in Door.")
                }),
                ("N-Row", "n-row", new[] {
                    ("な", "na", "Nah as in Knot."), ("に", "ni", "Nee as in Knee."),
                    ("ぬ", "nu", "Noo as in Newt."), ("ね", "ne", "Neh as in Net."), ("の", "no", "Noh as in Nose.")
                }),
                ("H, B & P Rows (Parallel)", "h-b-p-row", new[] {
                    ("は", "ha", "Hah as in Ha-ha."), ("ば", "ba", "Bah as in Ball."), ("ぱ", "pa", "Pah as in Park."),
                    ("ひ", "hi", "Hee as in Heat."), ("び", "bi", "Bee as in Bee."), ("ぴ", "pi", "Pee as in Peek."),
                    ("ふ", "fu", "Foo as in Fuji."), ("ぶ", "bu", "Boo as in Boot."), ("ぷ", "pu", "Poo as in Pool."),
                    ("へ", "he", "Heh as in Help."), ("べ", "be", "Beh as in Bed."), ("ぺ", "pe", "Peh as in Pen."),
                    ("ほ", "ho", "Hoh as in Home."), ("ぼ", "bo", "Boh as in Boat."), ("ぽ", "po", "Poh as in Poke.")
                }),
                ("M-Row", "m-row", new[] {
                    ("ま", "ma", "Mah as in Mom."), ("み", "mi", "Mee as in Me."),
                    ("む", "mu", "Moo as in Moon."), ("め", "me", "Meh as in Men."), ("も", "mo", "Moh as in More.")
                }),
                ("Y-Row", "y-row", new[] {
                    ("や", "ya", "Yah as in Yard."), ("ゆ", "yu", "Yoo as in You."), ("よ", "yo", "Yoh as in Yoyo.")
                }),
                ("R-Row", "r-row", new[] {
                    ("ら", "ra", "Rah as in Rock."), ("り", "ri", "Ree as in Reed."),
                    ("る", "ru", "Roo as in Root."), ("れ", "re", "Reh as in Red."), ("ろ", "ro", "Roh as in Road.")
                }),
                ("W-Row & N", "w-n-row", new[] {
                    ("わ", "wa", "Wah as in Water."), ("を", "wo", "Oh as in Boat."), ("ん", "n", "Nal 'n' as in End.")
                })
            };
        }

        @foreach (var kanaGroup in hiraganaSections)
        {
            <div class="col-lg-10" id="@kanaGroup.ID">
                <h3 class="fw-black mb-4 text-primary border-bottom pb-2">@kanaGroup.Title</h3>
                <div class="row">
                    @foreach (var item in kanaGroup.Items)
                    {
                        <div class="@(kanaGroup.Items.Length % 3 == 0 ? "col-md-4" : "col-md-6")">
                            <div class="static-card p-0 overflow-hidden mb-4 border-0 shadow-sm">
                                <div class="row g-0">
                                    <div class="col-4 bg-primary d-flex flex-column align-items-center justify-content-center py-3 text-white">
                                        <span class="display-4 fw-black">@item.Kana</span>
                                        <span class="fw-black text-uppercase small">@item.Romaji</span>
                                    </div>
                                    <div class="col-8 p-3 bg-white d-flex flex-column justify-content-center">
                                        <div class="d-flex align-items-center justify-content-between">
                                            <h5 class="fw-black mb-0">@item.Romaji.ToUpper()</h5>
                                            <button class="btn btn-soft-blue btn-sm rounded-circle" onclick="speak('@item.Kana')"><i class="bi bi-volume-up-fill"></i></button>
                                        </div>
                                        <p class="small text-muted fw-bold mb-0 mt-1">@item.Note</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<script>
    function speak(text) {
        const msg = new SpeechSynthesisUtterance();
        msg.text = text;
        msg.lang = 'ja-JP';
        msg.rate = 0.8;
        window.speechSynthesis.speak(msg);
    }
</script>