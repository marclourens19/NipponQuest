@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-container">
    <div class="auth-card shadow-lg">
        <div class="text-center mb-5">
            <h1 class="fw-black text-dark" style="letter-spacing: -2px; font-size: 2.5rem;">Almost There!</h1>
            <p class="text-muted fw-bold">Successfully linked with <strong>@Model.ProviderDisplayName</strong>.</p>
            <p class="small text-muted px-4">To finalize your NipponQuest profile, please choose your unique username below.</p>
        </div>

        <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

            <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <label asp-for="Input.GamerTag" class="form-label small fw-black text-uppercase opacity-75 mb-0" style="letter-spacing: 1px;">Username</label>
                    <span class="badge bg-soft-blue text-primary border fw-bold" style="font-size: 0.65rem;">MAX 12 CHARACTERS</span>
                </div>
                <input asp-for="Input.GamerTag" class="form-control auth-input" placeholder="e.g. ShadowQuest" aria-required="true" maxlength="12" />
                <span asp-validation-for="Input.GamerTag" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Input.Email" class="form-label small fw-black text-uppercase opacity-75" style="letter-spacing: 1px;">Confirmed Email</label>
                <input asp-for="Input.Email" class="form-control auth-input" readonly style="background-color: #f1f5f9 !important; cursor: not-allowed;" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-black w-100 py-3 btn-cta-premium">
                FINALIZE QUEST REGISTRATION
            </button>
        </form>

        <div class="text-center mt-4 pt-3 border-top" style="border-top-color: rgba(0,0,0,0.05) !important;">
            <p class="small text-muted fw-bold mb-0">
                Registering as <span class="text-dark">@Model.Input.Email</span>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}