@{
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container py-5" style="margin-top: 20px;">
    <div class="static-card overflow-hidden border-0 shadow-lg bg-white" style="border-radius: 32px;">
        <div class="row g-0">
            <!-- Sidebar Navigation -->
            <aside class="col-lg-3 bg-light border-end">
                <div class="p-4 text-center border-bottom bg-white">
                    <div class="mx-auto mb-3 d-flex align-items-center justify-content-center bg-soft-blue text-primary rounded-circle shadow-sm" style="width: 80px; height: 80px;">
                        <i class="bi bi-person-bounding-box fs-1"></i>
                    </div>
                    <h5 class="fw-black mb-1">Explorer Profile</h5>
                    <p class="small text-muted fw-bold mb-0">Rank: <span class="text-primary">Sprout</span></p>
                </div>
                
                <div class="p-3">
                    <nav class="nav flex-column account-nav gap-1">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Index" ? "active" : "") d-flex align-items-center gap-3 py-3 px-4 rounded-4" asp-page="./Index">
                            <i class="bi bi-person-circle"></i> Profile
                        </a>
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Email" ? "active" : "") d-flex align-items-center gap-3 py-3 px-4 rounded-4" asp-page="./Email">
                            <i class="bi bi-envelope-heart"></i> Email
                        </a>
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "ChangePassword" ? "active" : "") d-flex align-items-center gap-3 py-3 px-4 rounded-4" asp-page="./ChangePassword">
                            <i class="bi bi-shield-lock"></i> Password
                        </a>
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "TwoFactorAuthentication" ? "active" : "") d-flex align-items-center gap-3 py-3 px-4 rounded-4" asp-page="./TwoFactorAuthentication">
                            <i class="bi bi-patch-check"></i> Security
                        </a>
                        <hr class="my-2 opacity-10">
                        <a class="nav-link text-danger d-flex align-items-center gap-3 py-3 px-4 rounded-4" asp-page="./PersonalData">
                            <i class="bi bi-database-exclamation"></i> Data Privacy
                        </a>
                    </nav>
                </div>
            </aside>

            <!-- Main Content Area (HQ) -->
            <main class="col-lg-9 bg-white p-4 p-md-5">
                <div class="mb-5">
                    <h2 class="fw-black display-6 mb-1">Account <span class="text-primary">HQ</span></h2>
                    <p class="text-muted fw-bold">Manage your legendary identity and security settings.</p>
                </div>
                
                @RenderBody()
            </main>
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}