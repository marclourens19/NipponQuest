@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-xl-8">
        <form id="profile-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
            
            <div class="mb-4">
                <label asp-for="Username" class="fw-black small text-muted text-uppercase mb-2 ms-1" style="letter-spacing: 0.05em;"></label>
                <div class="position-relative">
                    <input asp-for="Username" class="form-control bg-light border-2" style="border-radius: 14px; padding: 12px 18px;" disabled />
                    <i class="bi bi-lock-fill position-absolute end-0 top-50 translate-middle-y me-3 text-muted"></i>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Input.PhoneNumber" class="fw-black small text-muted text-uppercase mb-2 ms-1" style="letter-spacing: 0.05em;"></label>
                <input asp-for="Input.PhoneNumber" class="form-control border-2" style="border-radius: 14px; padding: 12px 18px;" placeholder="Add a phone number..." />
                <span asp-validation-for="Input.PhoneNumber" class="text-danger small fw-bold"></span>
            </div>

            <button id="update-profile-button" type="submit" class="btn btn-cta-premium btn-lg px-5 py-3 rounded-pill fw-black">
                SAVE CHANGES
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}