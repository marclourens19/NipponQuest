@model NipponQuest.Models.Deck

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-11">
            
            <!-- SYSTEM ALERTS (For Economy Errors/Success) -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger shadow-sm rounded-pill fw-bold border-0 d-flex align-items-center mb-4 px-4 py-3 alert-dismissible fade show">
                    <i class="bi bi-exclamation-octagon-fill fs-5 me-2 text-danger"></i>
                    <div>@TempData["Error"]</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success shadow-sm rounded-pill fw-bold border-0 d-flex align-items-center mb-4 px-4 py-3 alert-dismissible fade show">
                    <i class="bi bi-check-circle-fill fs-5 me-2 text-success"></i>
                    <div>@TempData["Message"]</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- 1. TOP HEADER SECTION -->
            <div class="d-flex justify-content-between align-items-end mb-5 flex-wrap gap-3">
                <div>
                    <h1 class="fw-black text-dark m-0 text-uppercase tracking-tight d-flex align-items-center flex-wrap gap-3" style="font-size: 2.8rem; letter-spacing: -1px;">
                        <span>EDIT <span class="text-primary hero-glow-text">DECK</span></span>
                        
                        <!-- HELP BUTTON -->
                        <button class="btn btn-white rounded-circle shadow-sm p-0 d-flex align-items-center justify-content-center text-muted hover-blue transition-all hover-lift" 
                                style="width: 38px; height: 38px; margin-bottom: 8px;" 
                                data-bs-toggle="modal" data-bs-target="#editGuideModal" 
                                title="How to use the Editor">
                            <i class="bi bi-info-lg fs-5 fw-black"></i>
                        </button>
                    </h1>
                    <p class="text-muted fw-bold m-0 mt-1 text-uppercase tracking-wider" style="font-size: 0.85rem;">Update deck details and manage your flashcards</p>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-white rounded-pill px-4 fw-bold shadow-sm text-muted d-flex align-items-center transition-all hover-lift">
                        <i class="bi bi-arrow-left me-2 fs-5"></i> BACK TO MY DECKS
                    </a>
                </div>
            </div>

            <!-- 2. DECK DETAILS FORM CARD (NOW FULL BACKGROUND COLOR) -->
            <div class="static-card border-0 rounded-4 shadow-sm mb-4 p-4 p-md-5 transition-all" style="background-color: @(string.IsNullOrEmpty(Model.ThemeColor) ? "#ffffff" : Model.ThemeColor) !important;" id="MainEditCard">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ApplicationUserId" />
                    
                    <div class="row g-4 align-items-end mb-4">
                        <div class="col-md-6">
                            <label asp-for="Title" class="form-label fw-black text-dark small text-uppercase tracking-wider ms-1">Deck Title</label>
                            <!-- Inputs made slightly translucent so they blend into the new colored background -->
                            <input asp-for="Title" class="form-control form-control-lg auth-input fw-black text-dark border-0 shadow-sm rounded-4 py-3 focus-ring-container" style="background-color: rgba(255,255,255,0.85);" required />
                            <span asp-validation-for="Title" class="text-danger small fw-bold mt-1 d-block ms-1"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Description" class="form-label fw-black text-dark small text-uppercase tracking-wider ms-1">Description</label>
                            <input asp-for="Description" class="form-control form-control-lg auth-input fw-bold text-dark border-0 shadow-sm rounded-4 py-3 focus-ring-container" style="background-color: rgba(255,255,255,0.85);" />
                        </div>

                        <!-- NEW: Gamified Theme Selector -->
                        <div class="col-12 mt-2">
                            <div class="mb-2">
                                <label class="form-label fw-black text-dark small text-uppercase tracking-wider m-0">Equip Deck Theme Color</label>
                            </div>
                            
                            <div class="d-flex flex-wrap align-items-center gap-2 pt-1">
                                <input type="hidden" asp-for="ThemeColor" id="ThemeColorInput" value="@Model.ThemeColor" />
                                
                                <!-- Free Colors (Just White) -->
                                @foreach (var color in (List<string>)ViewBag.FreeColors)
                                {
                                    <div class="color-swatch @(Model.ThemeColor == color ? "selected" : "") transition-all"
                                         style="background-color: @color;"
                                         onclick="selectColor('@color', this, false)" title="Equip @color">
                                    </div>
                                }

                                <div class="vr mx-1 opacity-25" style="height: 34px;"></div>

                                <!-- Premium Colors -->
                                @foreach (var color in (List<string>)ViewBag.PremiumColors)
                                {
                                    bool isOwned = ((List<string>)ViewBag.PurchasedColors).Contains(color);
                                    
                                    <div class="color-swatch @(Model.ThemeColor == color ? "selected" : "") @(isOwned ? "" : "locked") transition-all"
                                         style="background-color: @color;"
                                         onclick="selectColor('@color', this, @(isOwned ? "false" : "true"))" 
                                         title="@(isOwned ? "Equip theme" : "Unlock theme for 50G")">
                                         @if (!isOwned)
                                         {
                                             <i class="bi bi-lock-fill text-white shadow-sm" style="font-size: 0.8rem; text-shadow: 0 1px 2px rgba(0,0,0,0.5);"></i>
                                         }
                                    </div>
                                }

                                <!-- INLINE Buy All Bundle Button -->
                                @if (((List<string>)ViewBag.PremiumColors).Except((List<string>)ViewBag.PurchasedColors).Any())
                                {
                                    <div class="vr mx-1 opacity-25" style="height: 34px;"></div>
                                    <button type="button" class="btn btn-warning rounded-pill fw-black shadow-sm d-flex align-items-center gap-1 transition-all hover-lift px-3" style="font-size: 0.75rem; height: 34px; margin-left: 4px;" data-bs-toggle="modal" data-bs-target="#buyAllColorsModal">
                                        <i class="bi bi-unlock-fill"></i> UNLOCK ALL (500 <div class="gold-coin" style="width: 14px; height: 14px; font-size: 0.5rem; border-width: 1px; vertical-align: middle; display: inline-flex;"></div>)
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Community Publishing Section (WITH GAMIFIED ECONOMY) -->
                    <div class="p-4 rounded-4 border border-dark border-opacity-10 mb-4 transition-all mt-4 shadow-sm" style="background-color: rgba(255,255,255,0.7);">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
                            <div>
                                <h6 class="fw-black text-dark m-0 tracking-wider text-uppercase d-flex align-items-center">
                                    <i class="bi bi-globe-americas text-indigo me-2"></i> Community Hub
                                </h6>
                                <span class="small text-dark fw-bold opacity-75">Sell your master deck to the community and earn Gold.</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                @if (ViewBag.UserLevel < 5)
                                {
                                    <div class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle rounded-pill px-3 py-2 fw-black small">
                                        <i class="bi bi-lock-fill me-1"></i> REACH LVL 5 TO UNLOCK
                                    </div>
                                    <div class="form-check form-switch m-0 fs-5 opacity-50">
                                        <input class="form-check-input shadow-sm border-secondary border-opacity-25" type="checkbox" role="switch" disabled>
                                    </div>
                                }
                                else
                                {
                                    <div class="form-check form-switch m-0 fs-5">
                                        <input class="form-check-input shadow-sm border-secondary border-opacity-25 cursor-pointer" type="checkbox" role="switch" asp-for="IsPublic" id="publishSwitch">
                                        <label class="form-check-label fw-black ms-2 text-dark fs-6 cursor-pointer text-uppercase tracking-wider pt-1" for="publishSwitch">MAKE PUBLIC</label>
                                    </div>
                                }
                            </div>
                        </div>
                        
                        <!-- Price Field (Revealed when Switch is ON) -->
                        <div class="collapse @(Model.IsPublic && ViewBag.UserLevel >= 5 ? "show" : "")" id="priceField">
                            <div class="pt-3 border-top border-dark border-opacity-10 mt-2">
                                <label asp-for="Price" class="form-label fw-black text-dark small text-uppercase tracking-wider ms-1">Market Price (Gold)</label>
                                <div class="input-group shadow-sm" style="border-radius: 1rem;">
                                    <span class="input-group-text bg-white border-0" style="border-top-left-radius: 1rem; border-bottom-left-radius: 1rem;">
                                        <div class="gold-coin" style="width: 24px; height: 24px; font-size: 0.8rem; border-width: 1.5px;"></div>
                                    </span>
                                    <input asp-for="Price" type="number" min="0" max="10000" class="form-control form-control-lg fw-black text-dark bg-white border-0 py-3 focus-ring-container" style="border-top-right-radius: 1rem; border-bottom-right-radius: 1rem;" placeholder="0 for Free" />
                                </div>
                                <span class="text-dark small fw-bold mt-2 d-block ms-1 opacity-75"><i class="bi bi-info-circle-fill text-primary"></i> Tax rates apply: 5% (0-50G), 10% (51-250G), 20% (251G+).</span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-dark rounded-pill fw-black px-5 py-3 shadow-sm text-uppercase tracking-wider btn-cta-premium transition-all hover-lift">
                            <i class="bi bi-save me-2"></i> SAVE DECK INFO
                        </button>
                    </div>
                </form>
            </div>

            <!-- Quick Guide Footer Notice -->
            <div class="bg-light border-0 px-4 py-3 text-center rounded-4 mb-5">
                <p class="text-muted small mb-0 d-inline-flex align-items-center justify-content-center flex-wrap gap-1">
                    <i class="bi bi-info-circle-fill text-primary me-1"></i>
                    <span class="fw-black text-dark me-1 text-uppercase tracking-wider" style="font-size: 0.7rem;">Quick Tip:</span>
                    Edit text directly in the table below. Use <i class="bi bi-save mx-1 text-primary"></i> to save a card, or <i class="bi bi-image mx-1 text-info"></i> / <i class="bi bi-volume-up-fill mx-1 text-indigo"></i> to update media.
                </p>
            </div>

            <!-- 3. CARD MANAGEMENT SECTION -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                <h4 class="fw-black text-dark text-uppercase m-0 tracking-tight">MANAGE CARDS (@Model.Flashcards.Count)</h4>
                <a asp-action="AddCard" asp-route-deckId="@Model.Id" class="btn btn-primary rounded-pill px-4 py-2 fw-black shadow-sm text-uppercase tracking-wider btn-sm btn-cta-premium transition-all hover-lift">
                    <i class="bi bi-plus-lg me-1"></i> ADD NEW CARD
                </a>
            </div>

            <div class="static-card border-0 rounded-4 shadow-sm bg-white overflow-hidden mb-5 p-0" style="border-top: 5px solid #6366f1 !important;">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="bg-light border-bottom border-light-subtle">
                            <tr>
                                <th class="ps-4 py-3 text-muted small fw-black text-uppercase tracking-wider border-0">FRONT (JAPANESE)</th>
                                <th class="py-3 text-muted small fw-black text-uppercase tracking-wider border-0">BACK (MEANING)</th>
                                <th class="py-3 text-muted small fw-black text-center text-uppercase tracking-wider border-0">MEDIA</th>
                                <th class="pe-4 py-3 text-muted small fw-black text-end text-uppercase tracking-wider border-0">ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var card in Model.Flashcards.OrderBy(c => c.Id))
                            {
                                <tr class="card-row border-bottom border-light-subtle transition-all">
                                    <form asp-action="UpdateCard" method="post" enctype="multipart/form-data">
                                        <input type="hidden" name="Id" value="@card.Id" />
                                        <input type="hidden" name="DeckId" value="@card.DeckId" />
                                        
                                        <td class="ps-4 py-3" style="width: 30%;">
                                            <input type="text" name="FrontText" value="@card.FrontText" class="form-control form-control-sm table-input fw-black text-dark fs-6 focus-ring-container" />
                                        </td>
                                        
                                        <td class="py-3" style="width: 35%;">
                                            <input type="text" name="BackText" value="@card.BackText" class="form-control form-control-sm table-input text-muted fw-bold focus-ring-container" />
                                        </td>
                                        
                                        <td class="py-3 text-center" style="width: 15%;">
                                            <div class="d-flex justify-content-center gap-2">
                                                <label class="bubble-btn-sm shadow-sm @(string.IsNullOrEmpty(card.ImageFilePath) ? "" : "border-info") transition-all hover-lift" title="Update Image">
                                                    <i class="bi bi-image @(string.IsNullOrEmpty(card.ImageFilePath) ? "text-secondary opacity-50" : "text-info")"></i>
                                                    <input type="file" name="imageFile" class="d-none" onchange="this.form.submit()" />
                                                </label>
                                                <label class="bubble-btn-sm shadow-sm @(string.IsNullOrEmpty(card.AudioFilePath) ? "" : "border-indigo") transition-all hover-lift" title="Update Audio">
                                                    <i class="bi bi-volume-up-fill @(string.IsNullOrEmpty(card.AudioFilePath) ? "text-secondary opacity-50" : "text-indigo")"></i>
                                                    <input type="file" name="audioFile" class="d-none" onchange="this.form.submit()" />
                                                </label>
                                            </div>
                                        </td>
                                        
                                        <td class="pe-4 py-3 text-end" style="width: 20%;">
                                            <div class="btn-group shadow-sm rounded-pill bg-white border border-light-subtle">
                                                <button type="submit" class="btn btn-white btn-sm px-3 rounded-start-pill border-0 border-end hover-blue transition-all" title="Save Card Changes">
                                                    <i class="bi bi-save text-primary"></i>
                                                </button>
                                                <button type="button" class="btn btn-white btn-sm px-3 rounded-end-pill border-0 text-danger hover-danger transition-all" onclick="confirmDeleteCard(@card.Id)" title="Delete Card">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </form>
                                </tr>
                            }
                            @if (!Model.Flashcards.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5">
                                        <i class="bi bi-inboxes text-muted opacity-25 display-4 mb-3 d-block"></i>
                                        <h5 class="fw-black text-dark text-uppercase">Deck is Empty</h5>
                                        <p class="text-muted fw-bold small">Add your first flashcard to start building this deck.</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            
        </div>
    </div>
</div>

<!-- Hidden Delete Form -->
<form id="deleteCardForm" asp-action="DeleteCard" method="post" style="display:none;">
    <input type="hidden" name="cardId" id="deleteCardId" />
    <input type="hidden" name="deckId" value="@Model.Id" />
</form>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 rounded-5 shadow-lg overflow-hidden text-center p-4 p-md-5 bg-white">
            <div class="modal-body p-0">
                <div class="mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-danger bg-opacity-10" style="width: 80px; height: 80px;">
                        <i class="bi bi-exclamation-octagon text-danger display-5"></i>
                    </div>
                </div>
                <h4 class="fw-black text-dark mb-2 text-uppercase tracking-tight">Delete Card?</h4>
                <p class="text-muted small fw-bold mb-4">This action is permanent and cannot be reversed. Are you sure you want to remove this card?</p>
                <div class="d-grid gap-3">
                    <button type="button" class="btn btn-danger rounded-pill fw-black shadow-sm py-3 text-uppercase tracking-wider transition-all hover-lift" style="border: none;" onclick="executeDelete()">
                        CONFIRM DELETE
                    </button>
                    <button type="button" class="btn btn-light rounded-pill fw-bold text-muted text-uppercase tracking-wider shadow-sm py-2 transition-all hover-lift" data-bs-dismiss="modal">
                        CANCEL
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 4. REVAMPED EDIT GUIDE MODAL -->
<div class="modal fade" id="editGuideModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-5 shadow-lg overflow-hidden">
            <div class="bg-primary p-4 text-center position-relative">
                <div class="position-absolute top-50 start-0 translate-middle-y ps-4 text-white opacity-25">
                    <i class="bi bi-pencil-square display-4"></i>
                </div>
                <h4 class="fw-black text-white m-0 text-uppercase tracking-widest">Quest Log: Editor Guide</h4>
                <button type="button" class="btn-close btn-close-white position-absolute top-50 end-0 translate-middle-y me-4" data-bs-dismiss="modal"></button>
            </div>
            
            <div class="modal-body p-4 p-md-5 bg-white">
                <div class="row g-4">
                    <div class="col-12">
                        <div class="d-flex align-items-start gap-3 p-3 rounded-4 bg-light transition-all hover-lift">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2">
                                <i class="bi bi-card-text fs-4"></i>
                            </div>
                            <div>
                                <h6 class="fw-black text-dark text-uppercase tracking-tight mb-1">1. Selling Decks</h6>
                                <p class="text-muted small fw-bold mb-0">Once you hit Level 5, you can publish decks to the Community Hub and set a Gold price. You will receive a payout whenever a user downloads your deck, minus a small market tax.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start gap-3 p-3 rounded-4 bg-light transition-all hover-lift h-100">
                            <div class="bg-warning bg-opacity-10 text-warning rounded-3 p-2">
                                <i class="bi bi-lightning-charge-fill fs-4"></i>
                            </div>
                            <div>
                                <h6 class="fw-black text-dark text-uppercase tracking-tight mb-1">2. Quick Editing</h6>
                                <p class="text-muted small fw-bold mb-0">Edit your card text directly in the table. Click the <i class="bi bi-save mx-1 text-primary"></i> button on that row to instantly save changes.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start gap-3 p-3 rounded-4 bg-light transition-all hover-lift h-100">
                            <div class="bg-info bg-opacity-10 text-info rounded-3 p-2">
                                <i class="bi bi-collection-play-fill fs-4"></i>
                            </div>
                            <div>
                                <h6 class="fw-black text-dark text-uppercase tracking-tight mb-1">3. Media Attachments</h6>
                                <p class="text-muted small fw-bold mb-0">Click the Image <i class="bi bi-image text-info"></i> or Audio <i class="bi bi-volume-up-fill text-indigo"></i> icons to attach media. Blue/Indigo borders indicate active files.</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="mt-5 text-center">
                    <button type="button" class="btn btn-primary rounded-pill px-5 py-3 fw-black shadow-sm text-uppercase tracking-wider btn-cta-premium w-100" data-bs-dismiss="modal">
                        Understood!
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Single Color Purchase Modal -->
<div class="modal fade" id="buyColorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 rounded-5 shadow-lg overflow-hidden text-center p-4 bg-white">
            <div class="modal-body p-0">
                <div class="mb-3 d-flex justify-content-center">
                    <div id="modalColorPreview" style="width: 60px; height: 60px; border-radius: 50%; border: 3px solid #e2e8f0; box-shadow: 0 4px 10px rgba(0,0,0,0.1);"></div>
                </div>
                <h5 class="fw-black text-dark mb-1 text-uppercase tracking-tight">Unlock Theme?</h5>
                <p class="text-muted small fw-bold mb-4">Permanently unlock this premium color for all your decks.</p>
                
                <form asp-action="PurchaseColor" method="post">
                    <input type="hidden" name="deckId" value="@Model.Id" />
                    <input type="hidden" name="colorHex" id="purchaseColorHex" value="" />
                    
                    <button type="submit" class="btn btn-primary rounded-pill fw-black shadow-sm py-2 px-4 w-100 text-uppercase tracking-wider transition-all hover-lift d-flex justify-content-center align-items-center gap-2 mb-2 btn-cta-premium">
                        UNLOCK FOR 50 <div class="gold-coin" style="width: 18px; height: 18px; font-size: 0.6rem; border-width: 1px;"></div>
                    </button>
                    <button type="button" class="btn btn-light rounded-pill fw-bold text-muted text-uppercase tracking-wider shadow-sm py-2 w-100 transition-all hover-lift" data-bs-dismiss="modal">
                        CANCEL
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Buy All Colors Modal -->
<div class="modal fade" id="buyAllColorsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 rounded-5 shadow-lg overflow-hidden text-center p-4 bg-white">
            <div class="modal-body p-0">
                <div class="mb-3">
                    <i class="bi bi-palette-fill text-warning display-4" style="filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));"></i>
                </div>
                <h5 class="fw-black text-dark mb-1 text-uppercase tracking-tight">Master Painter Bundle</h5>
                <p class="text-muted small fw-bold mb-4">Instantly unlock all remaining premium colors at a major discount.</p>
                
                <form asp-action="PurchaseAllColors" method="post">
                    <input type="hidden" name="deckId" value="@Model.Id" />
                    
                    <button type="submit" class="btn btn-warning rounded-pill fw-black shadow-sm py-2 px-4 w-100 text-uppercase tracking-wider transition-all hover-lift d-flex justify-content-center align-items-center gap-2 mb-2 text-dark">
                        UNLOCK ALL FOR 500 <div class="gold-coin" style="width: 18px; height: 18px; font-size: 0.6rem; border-width: 1px;"></div>
                    </button>
                    <button type="button" class="btn btn-light rounded-pill fw-bold text-muted text-uppercase tracking-wider shadow-sm py-2 w-100 transition-all hover-lift" data-bs-dismiss="modal">
                        CANCEL
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f8fafc; }

    .tracking-tight { letter-spacing: -1px; }
    .tracking-wider { letter-spacing: 1px; }
    .cursor-pointer { cursor: pointer; }
    .hero-glow-text { text-shadow: 0 0 20px rgba(14, 165, 233, 0.2); }
    
    .btn-white { background: #fff; border: 1px solid #e2e8f0; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .btn-white:hover { background: #f8fafc; border-color: #cbd5e1; }
    
    .table-input { 
        border: 1px solid transparent; background: transparent; padding: 0.5rem 0.75rem; 
        border-radius: 8px; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
    }
    .table-input:focus { 
        border-color: #0ea5e9 !important; background: #fff !important; 
        box-shadow: 0 0 0 0.25rem rgba(14, 165, 233, 0.15); outline: none; 
    }
    .card-row:hover .table-input { border-color: #e2e8f0; background: #fff; }

    /* Focus rings for translucent inputs in edit panel */
    .focus-ring-container:focus {
        background-color: #ffffff !important;
        border-color: #0ea5e9 !important;
        box-shadow: 0 0 0 0.25rem rgba(14, 165, 233, 0.25) !important;
        outline: 0;
    }

    .gold-coin {
        background: linear-gradient(135deg, #FFD700 0%, #FFB900 100%);
        border-radius: 50%;
        border: 1.5px solid #B45309;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        color: #451a03 !important; 
    }
    .gold-coin::after { content: "G"; }

    .hover-lift { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .hover-lift:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.1) !important; }
    
    .hover-blue:hover { color: #0ea5e9 !important; border-color: #0ea5e9 !important; }
    .hover-danger:hover { background-color: #ef4444 !important; color: white !important; border-color: #ef4444 !important;}

    .card-row { transition: background-color 0.3s ease; }
    .card-row:hover { background-color: #f8fafc; }

    .bubble-btn-sm { 
        width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center; 
        border-radius: 50%; border: 1.5px solid #e2e8f0; cursor: pointer; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); background: #fff; 
    }
    .border-info { border-color: #0ea5e9 !important; border-width: 2px !important; background-color: #f0f9ff; }
    .border-indigo { border-color: #6366f1 !important; border-width: 2px !important; background-color: #f5f3ff; }

    .color-swatch {
        width: 34px; height: 34px; border-radius: 50%; cursor: pointer;
        display: inline-flex; align-items: center; justify-content: center;
        border: 2px solid rgba(0,0,0,0.1);
    }
    .color-swatch[style*="#ffffff"] { border-color: #e2e8f0; } 
    
    .color-swatch.selected {
        box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.5);
        transform: scale(1.15);
    }
    .color-swatch:not(.locked):hover { transform: scale(1.15); }
    
    .color-swatch.locked {
        opacity: 0.6; cursor: pointer;
        border: 2px dashed rgba(255,255,255,0.5);
    }
    .color-swatch.locked:hover { opacity: 1; transform: scale(1.1); }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const publishSwitch = document.getElementById('publishSwitch');
        if (publishSwitch) {
            publishSwitch.addEventListener('change', function() {
                const priceField = new bootstrap.Collapse(document.getElementById('priceField'), { toggle: false });
                if (this.checked) {
                    priceField.show();
                } else {
                    priceField.hide();
                }
            });
        }
    });

    function selectColor(hex, element, isLocked) {
        if (isLocked) {
            document.getElementById('purchaseColorHex').value = hex;
            document.getElementById('modalColorPreview').style.backgroundColor = hex;
            
            const buyModal = new bootstrap.Modal(document.getElementById('buyColorModal'));
            buyModal.show();
            return;
        }

        document.getElementById('ThemeColorInput').value = hex;
        
        document.querySelectorAll('.color-swatch').forEach(s => {
            s.classList.remove('selected');
        });
        
        element.classList.add('selected');
        
        // Dynamically update the entire card background to test it out visually
        const mainCard = document.getElementById('MainEditCard');
        let bgHex = hex === '#ffffff' ? '#ffffff' : hex; 
        mainCard.style.setProperty('background-color', bgHex, 'important');
    }

    let activeCardId = null;
    function confirmDeleteCard(id) {
        activeCardId = id;
        const deleteModal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));
        deleteModal.show();
    }
    function executeDelete() {
        if (activeCardId) {
            document.getElementById('deleteCardId').value = activeCardId;
            document.getElementById('deleteCardForm').submit();
        }
    }
</script>