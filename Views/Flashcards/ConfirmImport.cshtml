@model List<NipponQuest.Models.Flashcard>

<div class="container py-5 mt-4">
    <!-- 1. TOP HEADER SECTION -->
    <div class="row justify-content-center mb-4">
        <div class="col-lg-11">
            <div class="d-flex justify-content-between align-items-end flex-wrap gap-3">
                <div>
                    <h1 class="fw-black text-dark m-0 text-uppercase tracking-tight d-flex align-items-center flex-wrap gap-3" style="font-size: 2.8rem; letter-spacing: -1px;">
                        <span>REVIEW <span class="text-primary hero-glow-text">IMPORT</span></span>
                        
                        <!-- HELP BUTTON -->
                        <button class="btn btn-white rounded-circle shadow-sm p-0 d-flex align-items-center justify-content-center text-muted hover-blue transition-all hover-lift" 
                                style="width: 38px; height: 38px; margin-bottom: 8px;" 
                                data-bs-toggle="modal" data-bs-target="#importGuideModal" 
                                title="Import Guide">
                            <i class="bi bi-info-lg fs-5 fw-black"></i>
                        </button>
                    </h1>
                    <p class="text-muted fw-bold m-0 mt-1 text-uppercase tracking-wider" style="font-size: 0.85rem;">Review and finalize your Anki deck data</p>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-white rounded-pill px-4 fw-bold shadow-sm text-muted d-flex align-items-center transition-all hover-danger hover-lift">
                        <i class="bi bi-x-lg me-2 fs-5"></i> ABORT IMPORT
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. DATA REVIEW CARD -->
    <div class="row justify-content-center">
        <div class="col-lg-11">
            
            <div class="static-card border-0 rounded-4 shadow-sm bg-white overflow-hidden mb-5 p-0 transition-all" style="border-top: 5px solid #0ea5e9 !important;">
                <form asp-action="FinalizeImport" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="tempFolder" value="@ViewBag.TempFolder" />

                    <!-- Header / Target Deck Name -->
                    <div class="p-4 p-md-5 border-bottom border-light-subtle bg-light d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                        <div class="flex-grow-1" style="max-width: 500px;">
                            <label class="form-label text-dark small fw-black text-uppercase tracking-wider ms-1">Target Deck Title</label>
                            <input type="text" name="deckTitle" value="@ViewBag.DeckName" class="form-control form-control-lg fw-black text-dark bg-white border-0 shadow-sm rounded-4 py-3 focus-ring-container" placeholder="ENTER DECK NAME" required />
                        </div>
                        <div class="text-md-end mt-3 mt-md-0">
                            <span class="badge bg-white text-primary border border-primary-subtle rounded-pill px-4 py-2 fw-black shadow-sm text-uppercase tracking-wider" style="font-size: 0.85rem;">
                                <i class="bi bi-files me-1 text-primary"></i> @Model.Count CARDS DETECTED
                            </span>
                        </div>
                    </div>

                    <!-- Data Table -->
                    <div class="table-responsive bg-white" style="max-height: 60vh; overflow-y: auto;">
                        <table class="table align-middle mb-0">
                            <thead class="sticky-top bg-white shadow-sm" style="z-index: 10;">
                                <tr>
                                    <th class="ps-4 ps-md-5 py-3 text-muted small fw-black text-uppercase tracking-wider border-bottom-0">FRONT (JAPANESE)</th>
                                    <th class="py-3 text-muted small fw-black text-uppercase tracking-wider border-bottom-0">BACK (MEANING)</th>
                                    <th class="pe-4 pe-md-5 py-3 text-muted small fw-black text-end text-uppercase tracking-wider border-bottom-0">MEDIA ASSETS</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.Count; i++)
                                {
                                    <tr class="card-row border-bottom border-light-subtle transition-all">
                                        <td class="ps-4 ps-md-5 py-3" style="width: 35%;">
                                            <span class="fw-black text-dark fs-5 text-japanese">@Model[i].FrontText</span>
                                            <input type="hidden" name="cards[@i].FrontText" value="@Model[i].FrontText" />
                                        </td>
                                        <td class="py-3" style="width: 45%;">
                                            <span class="text-muted fw-bold">@Model[i].BackText</span>
                                            <input type="hidden" name="cards[@i].BackText" value="@Model[i].BackText" />
                                            
                                            <input type="hidden" name="cards[@i].Interval" value="@Model[i].Interval" />
                                            <input type="hidden" name="cards[@i].EaseFactor" value="@Model[i].EaseFactor" />
                                            <input type="hidden" name="cards[@i].NextReview" value="@Model[i].NextReview.ToString("yyyy-MM-ddTHH:mm:ss")" />
                                            <input type="hidden" name="cards[@i].ImageFilePath" value="@Model[i].ImageFilePath" />
                                            <input type="hidden" name="cards[@i].AudioFilePath" value="@Model[i].AudioFilePath" />
                                        </td>
                                        <td class="pe-4 pe-md-5 py-3 text-end" style="width: 20%;">
                                            <div class="d-flex justify-content-end gap-2">
                                                @if (!string.IsNullOrEmpty(Model[i].ImageFilePath))
                                                {
                                                    <div class="media-badge img-badge shadow-sm transition-all hover-scale" title="Image Attached">
                                                        <i class="bi bi-image text-info"></i>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrEmpty(Model[i].AudioFilePath))
                                                {
                                                    <div class="media-badge aud-badge shadow-sm transition-all hover-scale" title="Audio Attached">
                                                        <i class="bi bi-volume-up-fill text-indigo"></i>
                                                    </div>
                                                }
                                                @if (string.IsNullOrEmpty(Model[i].ImageFilePath) && string.IsNullOrEmpty(Model[i].AudioFilePath))
                                                {
                                                    <span class="text-muted small fw-bold opacity-25">NONE</span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Footer Actions -->
                    <div class="p-4 p-md-5 bg-white border-top border-light-subtle d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
                        <div class="d-flex align-items-center gap-2 text-muted small fw-black text-uppercase tracking-wider">
                            <i class="bi bi-info-circle-fill text-primary"></i> Verify all cards before finalizing
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-black px-5 py-3 shadow-sm text-uppercase tracking-wider btn-cta-premium w-100 w-md-auto transition-all hover-lift" @(Model.Any() ? "" : "disabled")>
                            FINALIZE IMPORT <i class="bi bi-check2-circle ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
            
        </div>
    </div>
</div>

<!-- 3. REVAMPED IMPORT GUIDE MODAL (QUEST LOG STYLE) -->
<div class="modal fade" id="importGuideModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-5 shadow-lg overflow-hidden">
            <!-- Header Banner -->
            <div class="bg-primary p-4 text-center position-relative">
                <div class="position-absolute top-50 start-0 translate-middle-y ps-4 text-white opacity-25">
                    <i class="bi bi-cloud-arrow-down-fill display-4"></i>
                </div>
                <h4 class="fw-black text-white m-0 text-uppercase tracking-widest">Quest Log: Import Guide</h4>
                <button type="button" class="btn-close btn-close-white position-absolute top-50 end-0 translate-middle-y me-4" data-bs-dismiss="modal"></button>
            </div>
            
            <div class="modal-body p-4 p-md-5 bg-white">
                <div class="row g-4">
                    <!-- Rule 1 -->
                    <div class="col-12">
                        <div class="d-flex align-items-start gap-3 p-3 rounded-4 bg-light transition-all hover-lift">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2">
                                <i class="bi bi-input-cursor-text fs-4"></i>
                            </div>
                            <div>
                                <h6 class="fw-black text-dark text-uppercase tracking-tight mb-1">Target Deck Title</h6>
                                <p class="text-muted small fw-bold mb-0">Renaming the deck here will define how it appears in your library. Choose a title that fits your study routine.</p>
                            </div>
                        </div>
                    </div>
                    <!-- Rule 2 -->
                    <div class="col-md-6">
                        <div class="d-flex align-items-start gap-3 p-3 rounded-4 bg-light transition-all hover-lift h-100">
                            <div class="bg-info bg-opacity-10 text-info rounded-3 p-2">
                                <i class="bi bi-file-earmark-play-fill fs-4"></i>
                            </div>
                            <div>
                                <h6 class="fw-black text-dark text-uppercase tracking-tight mb-1">Media Verification</h6>
                                <p class="text-muted small fw-bold mb-0">The cyan and indigo badges indicate that your visual and audio assets have been successfully extracted from the package.</p>
                            </div>
                        </div>
                    </div>
                    <!-- Rule 3 -->
                    <div class="col-md-6">
                        <div class="d-flex align-items-start gap-3 p-3 rounded-4 bg-light transition-all hover-lift h-100">
                            <div class="bg-success bg-opacity-10 text-success rounded-3 p-2">
                                <i class="bi bi-database-check fs-4"></i>
                            </div>
                            <div>
                                <h6 class="fw-black text-dark text-uppercase tracking-tight mb-1">Commit Data</h6>
                                <p class="text-muted small fw-bold mb-0">Once finalized, the temporary files are moved to permanent storage and the deck is added to your collection.</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="mt-5 text-center">
                    <button type="button" class="btn btn-primary rounded-pill px-5 py-3 fw-black shadow-sm text-uppercase tracking-wider btn-cta-premium w-100" data-bs-dismiss="modal">
                        Understood!
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f8fafc; }

    /* Specific overrides */
    .tracking-tight { letter-spacing: -1px; }
    .tracking-wider { letter-spacing: 1px; }
    .text-japanese { font-size: 1.4rem; letter-spacing: 1px; }
    
    .hero-glow-text { text-shadow: 0 0 20px rgba(14, 165, 233, 0.2); }

    /* Buttons */
    .btn-white { background: #fff; border: 1px solid #e2e8f0; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .btn-white:hover { background: #f8fafc; border-color: #cbd5e1; }

    /* Media Badges */
    .media-badge {
        width: 34px; height: 34px; border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        background: #ffffff; border: 1.5px solid #f1f5f9;
        transition: all 0.2s ease;
    }
    .img-badge { border-color: rgba(14, 165, 233, 0.3); background-color: #f0f9ff; }
    .aud-badge { border-color: rgba(99, 102, 241, 0.3); background-color: #f5f3ff; }

    /* Hover States */
    .hover-lift { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .hover-lift:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.1) !important; }
    
    .hover-scale:hover { transform: scale(1.15); }
    .hover-danger:hover { color: #ef4444 !important; border-color: #ef4444 !important; background-color: #fff1f2; }
    .hover-blue:hover { color: #0ea5e9 !important; border-color: #0ea5e9 !important; }
    
    .card-row:hover { background-color: #f8fafc; }
    .transition-all { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    
    /* Input Focus */
    .focus-ring-container:focus {
        border-color: #0ea5e9 !important;
        box-shadow: 0 0 0 0.25rem rgba(14, 165, 233, 0.15) !important;
    }

    /* Custom Scrollbar */
    .table-responsive::-webkit-scrollbar { width: 8px; }
    .table-responsive::-webkit-scrollbar-track { background: #f8fafc; }
    .table-responsive::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
</style>