@functions {
    public string GetRankFullJapanese(LeagueRank rank) => rank switch
    {
        LeagueRank.Legend => "伝説 (でんせつ)",
        LeagueRank.Dragon => "龍 (りゅう)",
        LeagueRank.Challenger => "チャレンジャー",
        LeagueRank.Master => "師匠 (ししょう)",
        LeagueRank.Diamond => "金剛 (こんごう)",
        LeagueRank.Gold => "黄金 (おうごん)",
        LeagueRank.Iron => "鉄 (てつ)",
        LeagueRank.Wood => "木 (き)",
        LeagueRank.Sprout => "芽 (め)",
        _ => "修行者"
    };
    public string GetRankRomaji(LeagueRank rank) => rank switch
    {
        LeagueRank.Legend => "Densetsu",
        LeagueRank.Dragon => "Ryū",
        LeagueRank.Challenger => "Charenjā",
        LeagueRank.Master => "Shishō",
        LeagueRank.Diamond => "Kongō",
        LeagueRank.Gold => "Ōgon",
        LeagueRank.Iron => "Tetsu",
        LeagueRank.Wood => "Ki",
        LeagueRank.Sprout => "Me",
        _ => "Senshu"
    };
    public int GetWeeklyGold(LeagueRank rank) => rank switch
    {
        LeagueRank.Sprout     => 150,
        LeagueRank.Wood       => 250,
        LeagueRank.Iron       => 350,
        LeagueRank.Gold       => 450,
        LeagueRank.Diamond    => 550,
        LeagueRank.Master     => 650,
        LeagueRank.Challenger => 850,
        LeagueRank.Dragon     => 1050,
        LeagueRank.Legend     => 1250,
        _ => 150
    };
    public string FormatNumber(long n)
    {
        long abs = System.Math.Abs(n);
        if (abs >= 1_000_000_000_000L) return (n / 1_000_000_000_000.0).ToString("0.#") + "T";
        if (abs >= 1_000_000_000L)     return (n / 1_000_000_000.0).ToString("0.#") + "B";
        if (abs >= 1_000_000L)         return (n / 1_000_000.0).ToString("0.#") + "M";
        if (abs >= 1_000L)             return (n / 1_000.0).ToString("0.#") + "K";
        return n.ToString("N0");
    }
    public string FormatNumber(int n) => FormatNumber((long)n);
}

@section Scripts {
    <script>
        // ── Weekly reset countdown ──
        function updateCountdown() {
            const timerElement = document.getElementById('countdown-timer');
            if (!timerElement) return;
            const targetDate = new Date(timerElement.getAttribute('data-target'));
            const now = new Date();
            const diff = targetDate - now;
            if (diff <= 0) { timerElement.innerHTML = "0s"; return; }
            const d = Math.floor(diff / (1000 * 60 * 60 * 24));
            const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
            const s = Math.floor((diff % (1000 * 60)) / 1000);
            let display = d > 0 ? `${d}d ${h}h` : h > 0 ? `${h}h ${m}m` : m > 0 ? `${m}m ${s}s` : `${s}s`;
            timerElement.innerHTML = display;
        }
        setInterval(updateCountdown, 1000);
        updateCountdown();

        // ── KanaBlitz leaderboard (by difficulty mode, always Mixed alphabet) ──
        let currentSelfId = null;

        async function loadBoard(mode, btn) {
            document.querySelectorAll('.lb-tab-btn').forEach(b => b.classList.remove('active'));
            if (btn) btn.classList.add('active');

            const list  = document.getElementById('lb-list');
            const load  = document.getElementById('lb-loading');
            const empty = document.getElementById('lb-empty');

            list.classList.add('d-none');
            empty.classList.add('d-none');
            load.classList.remove('d-none');
            load.innerHTML = '<div class="spinner-border text-primary" role="status"></div><p class="mt-3 fw-bold text-muted mb-0">Pulling latest scores...</p>';

            const labelMap = { easy: 'Easy', normal: 'Normal', hard: 'Hard', insanity: 'Insanity' };
            document.getElementById('lb-mode-sub').textContent  = `${labelMap[mode]} \u00b7 Mixed`;
            document.getElementById('lb-self-mode').textContent = labelMap[mode];

            try {
                // Endpoint lives on LeaguesController. Difficulty is now the axis;
                // the controller hardcodes alphabet to "mixed" for leaderboard fairness.
                const res = await fetch(`/Leagues/GetBlitzBoard?difficulty=${mode}&top=50`);
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                const data = await res.json();

                const selfCard = document.getElementById('lb-self-card');
                if (data.self) {
                    selfCard.classList.remove('d-none');
                    document.getElementById('lb-self-rank').innerText    = data.self.rank;
                    document.getElementById('lb-self-correct').innerText = data.self.bestCorrect;
                    document.getElementById('lb-self-points').innerText  = (data.self.bestPoints || 0).toLocaleString();
                    document.getElementById('lb-self-acc').innerText     = Math.round((data.self.bestAccuracy || 0) * 100);
                    currentSelfId = data.self.userId;
                } else {
                    selfCard.classList.add('d-none');
                    currentSelfId = null;
                }

                list.innerHTML = '';
                if (!data.rows || data.rows.length === 0) {
                    load.classList.add('d-none');
                    empty.classList.remove('d-none');
                    return;
                }

                data.rows.forEach((r, idx) => {
                    const rank = idx + 1;
                    const isSelf = currentSelfId && r.userId === currentSelfId;

                    const row = document.createElement('div');
                    row.className = 'lg-podium-row' + (rank === 1 ? ' rank-1' : '') + (isSelf ? ' is-self' : '');

                    let medal = '';
                    if (rank === 1) medal = '<div class="lg-podium-medal r1">1</div>';
                    else if (rank === 2) medal = '<div class="lg-podium-medal r2">2</div>';
                    else if (rank === 3) medal = '<div class="lg-podium-medal r3">3</div>';
                    else medal = `<div class="lg-podium-medal" style="background:#f1f5f9;border-color:#e2e8f0;color:#475569;">${rank}</div>`;

                    row.innerHTML = `
                        ${medal}
                        <div class="lg-podium-info">
                            <div class="lg-podium-name">${escapeHtml(r.name)}${isSelf ? ' <span class="you-tag" style="background:#3b82f6;color:#fff;font-size:0.55rem;font-weight:900;letter-spacing:1px;padding:2px 8px;border-radius:50px;margin-left:6px;">YOU</span>' : ''}</div>
                            <div class="lg-podium-sub">${(r.bestPoints || 0).toLocaleString()} pts &middot; ${Math.round((r.bestAccuracy || 0) * 100)}% acc &middot; combo ${r.bestCombo || 0}x</div>
                        </div>
                        <div class="lg-podium-value">${r.bestCorrect} <span style="font-size:0.6rem;color:#94a3b8;font-weight:800;letter-spacing:1px;">CORRECT</span></div>
                    `;

                    list.appendChild(row);
                });

                load.classList.add('d-none');
                list.classList.remove('d-none');
            } catch (e) {
                console.error('[v0] Blitz board load failed:', e);
                load.innerHTML = '<p class="text-danger fw-bold mb-0">Failed to load leaderboard.</p>';
            }
        }

        function escapeHtml(s) {
            return (s || '').replace(/[&<>"']/g, c => ({
                '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
            }[c]));
        }

        document.addEventListener('DOMContentLoaded', () => {
            // Reveal-up animations
            const obs = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) e.target.classList.add('active'); }), { threshold: 0.05 });
            document.querySelectorAll('.lg-reveal').forEach(el => obs.observe(el));

            // Initial blitz board load — Normal as default
            loadBoard('normal', document.querySelector('.lb-tab-btn[data-mode="normal"]'));

            // Smooth-scroll to rankings if the user landed via /Leagues#kanablitz-rankings
            if (window.location.hash === '#kanablitz-rankings') {
                setTimeout(() => {
                    const target = document.getElementById('kanablitz-rankings');
                    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }, 150);
            }
        });
    </script>
}