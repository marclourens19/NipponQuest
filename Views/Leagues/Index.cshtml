@model NipponQuest.Models.LeagueDashboardViewModel
@{
    ViewData["Title"] = "Leagues";
    var player = Model.CurrentUser;
    int totalUsers = Model.TotalUserCount;
}

<div class="container mt-4 mb-5">
    <div class="mb-5 pb-4 border-bottom text-center d-flex flex-column align-items-center">
        <h1 class="fw-black text-dark m-0" style="font-size: 4.5rem; letter-spacing: -3px; line-height: 1;">LEAGUES</h1>
        <span class="brand-japanese-sub" style="font-size: 1.1rem; color: #0ea5e9; margin-top: 0;">
            リーグ (Rīgu)
        </span>
    </div>

    <div class="row g-5">
        <div class="col-xl-4 col-lg-5">
            <h3 class="fw-black text-dark text-uppercase mb-4 text-center" style="letter-spacing: -1px; font-size: 1.25rem;">Path to Legend</h3>
            <div class="d-flex flex-column hide-scrollbar" style="max-height: 80vh; overflow-y: auto; padding: 4px;">
                @foreach (var rank in Enum.GetValues(typeof(LeagueRank)).Cast<LeagueRank>().Reverse())
                {
                    var isActive = (rank == player.CurrentLeague);
                    <div class="static-card mb-3 @(isActive ? "border-primary shadow-sm" : "opacity-60")" style="padding: 16px 24px;">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-3">
                                <span class="rank-text @rank.ToString().ToLower()">@rank</span>
                                <div class="small fw-bold text-muted" style="line-height: 1.1;">
                                    @GetRankFullJapanese(rank)<br />
                                    <span style="font-size: 0.65rem; color: #94a3b8; text-transform:uppercase; letter-spacing: 1px;">@GetRankRomaji(rank)</span>
                                </div>
                            </div>
                            <div class="text-end">
                                <span class="fw-black text-dark" style="font-size: 1.1rem;">@GetWeeklyGold(rank)</span>
                                <div class="gold-coin"></div>
                                <div style="margin-top: 4px;">
                                    <span class="text-muted d-block fw-bold" style="font-size: 0.55rem; letter-spacing: 1px;">WEEKLY REWARD</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="col-xl-5 col-lg-7">
            <div class="static-card arena-card-main h-100 d-flex flex-column border-0 arena-border-@player.CurrentLeague.ToString().ToLower()" style="background: #ffffff; padding: 32px;">
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-4">
                    <h2 class="fw-black m-0 text-rank-@player.CurrentLeague.ToString().ToLower()">@player.CurrentLeague.ToString().ToUpper() ARENA</h2>
                    <div class="badge rounded-pill px-3 py-2 fw-bold text-dark bg-warning border-0 shadow-sm" style="font-size: 0.75rem;">
                        <i class="bi bi-clock-fill me-1"></i>
                        @{
                            DateTime now = DateTime.Now;
                            int daysUntilMonday = ((int)DayOfWeek.Monday - (int)now.DayOfWeek + 7) % 7;
                            if (daysUntilMonday == 0 && now.Hour >= 0) daysUntilMonday = 7;
                            DateTime targetDate = now.Date.AddDays(daysUntilMonday);
                        }
                        <span id="countdown-timer" data-target="@targetDate.ToString("yyyy-MM-ddTHH:mm:ss")">...</span> REMAINING
                    </div>
                </div>

                <div class="p-4 rounded-4 text-center mb-5 bg-white border shadow-sm" style="border: 1px solid #f1f5f9 !important;">
                    <div class="text-muted fw-bold small text-uppercase mb-2" style="letter-spacing: 2px; opacity: 0.5;">Your Current Standing</div>
                    <div class="fw-black text-dark" style="font-size: 6.5rem; line-height: 0.9; letter-spacing: -4px;">#@Model.ArenaRank</div>
                    <div class="mt-3">
                        @{
                            int movement = player.LastWeekArenaRank > 0 ? (player.LastWeekArenaRank - Model.ArenaRank) : 0;
                        }
                        @if (movement > 0)
                        {
                            <div class="text-success fw-bold small text-uppercase"><i class="bi bi-caret-up-fill me-1"></i> @movement PLACES CLIMBED</div>
                        }
                        else if (movement < 0)
                        {

                            <div class="text-danger fw-bold small text-uppercase"><i class="bi bi-caret-down-fill me-1"></i> @Math.Abs(movement) PLACES DROPPED</div>
                        }
                        else
                        {

                            <div class="fw-bold small text-uppercase" style="color: #94a3b8; letter-spacing: 1px; opacity: 0.8;"><i class="bi bi-dash-lg me-1"></i> Position Unchanged</div>
                        }
                    </div>
                </div>

                <div class="w-100 mb-5 d-flex flex-column gap-2">
                    @foreach (var rival in Model.ArenaRivals)
                    {
                        int total = Model.ArenaRivals.Count;
                        int promoteLimit = Math.Max(1, (int)Math.Ceiling(total * 0.2));
                        int demoteLimit = total - (int)Math.Floor(total * 0.2);
                        string zoneClass = (rival.Rank <= promoteLimit) ? "promote-zone" : (rival.Rank > demoteLimit && total > 3 ? "demote-zone" : "safe-zone");

                        <div class="sb-player-row-static p-3 @zoneClass @(rival.IsCurrentUser ? "border-primary bg-light shadow-sm" : "")"
                             style="border-radius:16px; display:flex; justify-content:space-between; align-items:center;">
                            <div class="d-flex align-items-center gap-3">
                                <span class="fw-black text-muted" style="min-width: 30px; font-size: 0.9rem;">#@rival.Rank</span>
                                <span class="fw-bold @(rival.IsCurrentUser ? "text-primary" : "text-dark")">@rival.User.GamerTag @(rival.IsCurrentUser ? "(YOU)" : "")</span>
                                
                                @if (rival.Rank <= promoteLimit)
                                {
                                    <span class="badge bg-success small" style="font-size: 0.6rem;">RANK UP AVAILABLE</span>
                                }
                                @if (zoneClass == "demote-zone")
                                {
                                    <span class="badge bg-danger small" style="font-size: 0.6rem;">EARN XP TO SECURE RANK</span>
                                }
                            </div>
                            <span class="fw-black" style="font-size: 0.9rem;">@rival.User.WeeklyXP <span class="text-muted fw-bold small" style="opacity: 0.6;">XP</span></span>
                        </div>
                    }
                </div>

                <div class="mt-auto">
                    <button class="btn btn-primary btn-lg w-100 rounded-pill fw-black py-3 shadow-lg" style="background: linear-gradient(135deg, #1e3a8a, #0ea5e9); border:none; letter-spacing: 1px; transition: transform 0.2s ease;">
                        <i class="bi bi-lightning-charge-fill me-2" style="color: #fbbf24;"></i> EARN MORE XP!
                    </button>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-12 d-flex flex-column gap-4">
            <div class="static-card text-center py-4 text-white border-0 shadow-sm" style="border-radius:24px; background: linear-gradient(135deg, #1e3a8a, #0ea5e9);">
                <p class="small fw-black text-uppercase opacity-75 mb-1" style="letter-spacing: 1px;">Overall Global Standing</p>
                <h3 class="fw-black m-0" style="font-size: 2rem;">#@Model.GlobalLevelRank <span class="opacity-50" style="font-size: 1rem;">/ @Model.TotalUserCount</span></h3>
            </div>

            <div class="static-card shadow-sm border-light" style="background:#fff; border-radius:24px; padding:24px;">
                <h5 class="fw-bold text-center text-uppercase small text-muted pb-3 border-bottom mb-3" style="letter-spacing: 1px;">Top 3 Highest Levels</h5>
                @foreach (var top in Model.LevelLeaderboard)
                {
                    <div class="d-flex justify-content-between align-items-center p-2 mb-1 bg-light rounded-3">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fs-5">@(top.Rank == 1 ? "👑" : top.Rank == 2 ? "🥈" : "🥉")</span>
                            <span class="fw-bold text-dark small">@top.User.GamerTag</span>
                        </div>
                        <span class="level-label-sync small">LV.@top.User.Level</span>
                    </div>
                }
            </div>

            <div class="static-card shadow-sm border-light" style="background:#fff; border-radius:24px; padding:24px;">
                <h5 class="fw-bold text-center text-uppercase small text-muted pb-3 border-bottom mb-3" style="letter-spacing: 1px;">Top 3 Longest Streaks</h5>
                @foreach (var top in Model.StreakLeaderboard)
                {
                    <div class="d-flex justify-content-between align-items-center p-2 mb-1 bg-light rounded-3">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fs-5">@(top.Rank == 1 ? "👑" : top.Rank == 2 ? "🥈" : "🥉")</span>
                            <span class="fw-bold text-dark small">@top.User.GamerTag</span>
                        </div>
                        <div class="d-flex align-items-center gap-1">
                            <i class="bi bi-fire @(top.User.LoginStreak > 0 ? "streak-flame-active" : "streak-frozen")"></i>
                            <span class="fw-black small">@top.User.LoginStreak</span>
                        </div>
                    </div>
                }
            </div>

            <div class="static-card text-white shadow-lg border-0 p-4" style="background: linear-gradient(135deg, #1e3a8a, #0ea5e9); border-radius: 24px; opacity: 0.95;">
                <h6 class="fw-black text-uppercase small opacity-75 mb-3" style="letter-spacing: 1px;">What are Leagues?</h6>
                <p class="fw-black m-0" style="font-size: 1.15rem; line-height: 1.3;">Do lessons. Earn XP. Compete.</p>
                <p class="small mt-2 mb-0 opacity-80" style="line-height: 1.5;">Climb your weekly Arena. Top players promote to higher ranks every Sunday!</p>
            </div>
        </div>
    </div>
</div>

@functions {
    /* Localization Helpers: Managing DISPLAY NAMES and GOLD rewards logic */
    public string GetRankFullJapanese(LeagueRank rank) => rank switch
    {
        LeagueRank.Legend => "伝説 (でんせつ)",
        LeagueRank.Dragon => "龍 (りゅう)",
        LeagueRank.Challenger => "チャレンジャー",
        LeagueRank.Master => "師匠 (ししょう)",
        LeagueRank.Diamond => "金剛 (こんごう)",
        LeagueRank.Gold => "黄金 (おうごん)",
        LeagueRank.Iron => "鉄 (てつ)",
        LeagueRank.Wood => "木 (き)",
        LeagueRank.Sprout => "芽 (め)",
        _ => "修行者"
    };
    public string GetRankRomaji(LeagueRank rank) => rank switch
    {
        LeagueRank.Legend => "Densetsu",
        LeagueRank.Dragon => "Ryū",
        LeagueRank.Challenger => "Charenjā",
        LeagueRank.Master => "Shishō",
        LeagueRank.Diamond => "Kongō",
        LeagueRank.Gold => "Ōgon",
        LeagueRank.Iron => "Tetsu",
        LeagueRank.Wood => "Ki",
        LeagueRank.Sprout => "Me",
        _ => "Senshu"
    };
    public int GetWeeklyGold(LeagueRank rank) => rank switch
    {
        LeagueRank.Legend => 425,
        LeagueRank.Dragon => 300,
        LeagueRank.Challenger => 225,
        LeagueRank.Master => 175,
        _ => ((int)rank) * 25 + 25
    };
}

@section Scripts {
    <script>
        /* TIMER ENGINE: Countdown logic for Arena reset */
        function updateCountdown() {
            const timerElement = document.getElementById('countdown-timer');
            if (!timerElement) return;
            const targetDate = new Date(timerElement.getAttribute('data-target'));
            const now = new Date();
            const diff = targetDate - now;
            if (diff <= 0) { timerElement.innerHTML = "0s"; return; }
            const d = Math.floor(diff / (1000 * 60 * 60 * 24));
            const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
            const s = Math.floor((diff % (1000 * 60)) / 1000);
            let display = d > 0 ? `${d}d ${h}h` : h > 0 ? `${h}h ${m}m` : m > 0 ? `${m}m ${s}s` : `${s}s`;
            timerElement.innerHTML = display;
        }
        setInterval(updateCountdown, 1000);
        updateCountdown();
    </script>
}