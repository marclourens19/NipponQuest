                                }
                            </div>
                            <span class="xp">@FormatNumber(rival.User.WeeklyXP) <small>XP</small></span>
                        </div>
                    }
                </div>

                <div class="pt-3">
                    <button type="button" class="lg-cta-btn" data-bs-toggle="modal" data-bs-target="#earnXpModal">
                        <i class="bi bi-lightning-charge-fill" style="color: #fbbf24;"></i>
                        Earn More XP
                    </button>
                </div>
            </div>
        </div>

        <!-- SIDEBAR -->
        <div class="col-xl-4 col-lg-5 lg-reveal">
            <div class="d-flex flex-column gap-4 h-100">
                <div class="lg-panel">
                    <div class="d-flex justify-content-between align-items-start mb-3">
