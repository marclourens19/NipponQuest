@section Scripts {
<script>
    // ── SCROLL REVEAL ──
    document.addEventListener('DOMContentLoaded', () => {
        const obs = new IntersectionObserver((entries) => {
            entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('active'); });
        }, { threshold: 0.08, rootMargin: '0px 0px -50px 0px' });
        document.querySelectorAll('.reveal-up').forEach(el => obs.observe(el));
    });

    // ── QUIZ ──
    const quizData = [
        { q: 'あ', a: 'A',  options: ['KA', 'A',  'SA'] },
        { q: 'い', a: 'I',  options: ['I',  'E',  'O']  },
        { q: 'う', a: 'U',  options: ['N',  'U',  'RA'] },
        { q: 'え', a: 'E',  options: ['RO', 'RU', 'E']  },
        { q: 'お', a: 'O',  options: ['O',  'WA', 'WO'] }
    ];
    let currentQuest = 0, score = 0;

    function initQuiz() {
        const quest = quizData[currentQuest];
        document.getElementById('quiz-progress').innerText = `QUEST ${currentQuest + 1} / 5`;
        document.getElementById('hiragana-display').innerText = quest.q;
        const btnContainer = document.getElementById('answer-buttons');
        if (!btnContainer) return;
        btnContainer.innerHTML = '';
        quest.options.forEach(opt => {
            const btn = document.createElement('button');
            btn.className = 'btn btn-outline-primary fw-black trial-answer-btn';
            btn.innerText = opt;
            btn.onclick = () => checkAnswer(opt, btn);
            btnContainer.appendChild(btn);
        });
    }

    function checkAnswer(choice, btn) {
        const correct = quizData[currentQuest].a;
        document.querySelectorAll('.trial-answer-btn').forEach(b => b.disabled = true);
        if (choice === correct) {
            score++;
            btn.classList.replace('btn-outline-primary', 'btn-success');
            btn.classList.add('text-white');
            showFeedback();
        } else {
            btn.classList.replace('btn-outline-primary', 'btn-danger');
            btn.classList.add('text-white');
            setTimeout(nextQuestion, 600);
        }
    }

    function showFeedback() {
        const fb = document.getElementById('feedback-check');
        if (!fb) return;
        fb.classList.remove('d-none');
        setTimeout(() => {
            fb.style.transition = 'opacity 0.3s ease';
            fb.style.opacity = '0';
            setTimeout(() => {
                fb.classList.add('d-none');
                fb.style.opacity = '1';
                nextQuestion();
            }, 300);
        }, 900);
    }

    function nextQuestion() {
        currentQuest++;
        currentQuest < quizData.length ? initQuiz() : showResults();
    }

    function showResults() {
        document.getElementById('quiz-game').classList.add('d-none');
        document.getElementById('quiz-result').classList.remove('d-none');
        document.getElementById('final-score').innerText = `${score} / 5`;
    }

    function resetQuiz() {
        currentQuest = 0; score = 0;
        document.getElementById('quiz-game').classList.remove('d-none');
        document.getElementById('quiz-result').classList.add('d-none');
        initQuiz();
    }

    // ── ROADMAP ──
    function showLevelInfo(level) {
        const requirements = {
            'N5': {
                color: '#22c55e', rankClass: 'sprout', rankName: 'Beginner Mastery',
                path: [
                    { step: 'KANA ORIGINS',     desc: 'Master Hiragana & Katakana stroke order and phonetics.' },
                    { step: 'GENKI I: PHASE 1', desc: 'Complete Lessons 1-6: Greetings, shopping, and daily time.' },
                    { step: 'GENKI I: PHASE 2', desc: 'Complete Lessons 7-12: Te-form, physical descriptions, and past tense.' },
                    { step: 'PARTICLE SYNC',    desc: 'Internalize WA, GA, O, NI, and DE usage in basic sentences.' }
                ],
                goals: ['100 Kanji (The Foundation)', '800 Vocabulary Words', 'N5 Mock Exam (90%+ Accuracy)']
            },
            'N4': {
                color: '#0ea5e9', rankClass: 'diamond', rankName: 'Elementary Mastery',
                path: [
                    { step: 'GENKI II: CORE',       desc: 'Complete Lessons 13-23: Potential, Volitional, and Passive forms.' },
                    { step: 'KEIGO BASICS',          desc: 'Understand the hierarchy of polite and humble Japanese.' },
                    { step: 'CONJUNCTION MASTERY',   desc: 'Connect complex thoughts using NNODE, TAME, and SHI.' }
                ],
                goals: ['300 Kanji (Standard Set)', '1,500 Vocabulary Words', 'Understand 70% of Children\'s Media']
            },
            'N3': {
                color: '#a855f7', rankClass: 'master', rankName: 'Intermediate Mastery',
                path: [
                    { step: 'THE TOBIRA BRIDGE', desc: 'Transition from textbook Japanese to natural phrasing.' },
                    { step: 'CASUAL NUANCE',     desc: 'Master gender-neutral vs. masculine/feminine casual speech.' },
                    { step: 'TRANSITIVE SYNC',   desc: 'Perfect the Transitive vs. Intransitive verb pairings.' }
                ],
                goals: ['650 Kanji (Intermediate Set)', '3,750 Vocabulary Words', 'Read basic NHK News Web Easy']
            },
            'N2': {
                color: '#ef4444', rankClass: 'dragon', rankName: 'Advanced Mastery',
                path: [
                    { step: 'LITERARY FLOW',    desc: 'Understand formal written Japanese used in essays and news.' },
                    { step: 'BUSINESS PROTOCOL',desc: 'Master Sonkeigo and Kenjougo for professional environments.' },
                    { step: 'SOCIAL CONTEXT',   desc: 'Detect sarcasm, irony, and cultural subtext in conversation.' }
                ],
                goals: ['1,000 Kanji (Advanced Set)', '6,000 Vocabulary Words', 'Work in a Japanese Environment']
            },
            'N1': {
                color: '#fbbf24', rankClass: 'legend', rankName: 'Legendary Mastery',
                path: [
                    { step: 'NATIVE IMMERSION',  desc: 'Read complex literature and philosophical essays.' },
                    { step: 'CLASSICAL BASICS',  desc: 'Understand the roots of modern grammar and archaic kanji.' },
                    { step: 'DIALECT FLUENCY',   desc: 'Recognize major regional dialects (Kansai-ben, etc.).' }
                ],
                goals: ['2,000+ Kanji (Total Master Set)', '10,000+ Vocabulary Words', '100% Native Fluency']
            }
        };

        const data = requirements[level];
        const card = document.getElementById('quest-requirement-card');

        card.style.borderTop = `6px solid ${data.color}`;
        document.getElementById('quest-title').innerText = level + ' Certification Quest';
        document.getElementById('rank-badge-container').innerHTML =
            `<span class="rank-text ${data.rankClass}">${data.rankName}</span>`;

        document.getElementById('quest-curriculum').innerHTML = data.path.map((p, i) => `
            <div class="path-step mb-4" style="--step-color: ${data.color}">
                <div class="fw-black text-uppercase mb-1" style="font-size: 0.68rem; color: ${data.color}; letter-spacing: 0.06em;">Step 0${i+1}: ${p.step}</div>
                <div class="fw-bold text-dark small" style="line-height: 1.5;">${p.desc}</div>
            </div>`).join('');

        document.getElementById('quest-goals').innerHTML = data.goals.map(g => `
            <div class="p-3 rounded-4 bg-light d-flex align-items-center gap-3 border border-white shadow-sm">
                <i class="bi bi-check-circle-fill fs-5" style="color: ${data.color}; flex-shrink:0;"></i>
                <span class="fw-black text-dark small">${g}</span>
            </div>`).join('');

        card.style.display = 'block';
        card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    document.addEventListener('DOMContentLoaded', initQuiz);
</script>
}